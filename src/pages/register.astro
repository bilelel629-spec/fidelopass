---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  theme="light"
  title="Essai gratuit 14 jours — Fidelopass"
  description="Créez votre compte Fidelopass gratuitement. 14 jours d'essai sans carte bancaire."
>
  <div class="min-h-screen bg-[#f8fbff] px-4 py-10 sm:py-14 relative overflow-hidden">
    <div class="pointer-events-none absolute -top-32 right-[-10rem] h-[28rem] w-[28rem] rounded-full bg-cyan-200/40 blur-3xl"></div>
    <div class="pointer-events-none absolute bottom-[-8rem] left-[-8rem] h-[24rem] w-[24rem] rounded-full bg-blue-100/80 blur-3xl"></div>
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-10 items-center">

      <!-- Gauche : proposition de valeur -->
      <div class="hidden lg:block">
        <a href="/" class="inline-flex items-center gap-1 mb-10">
          <img src="/logo-premium-cropped.png" alt="Fidelopass" class="h-28 w-auto object-contain" />
        </a>
        <h1 class="font-display text-4xl font-bold text-slate-900 leading-tight">
          Lancez votre programme de fidélité en 5 minutes.
        </h1>
        <p class="text-slate-500 text-base leading-relaxed mt-5 max-w-md">
          14 jours d'essai gratuit. Aucune carte bancaire requise. Vos clients obtiennent leur carte
          directement dans Apple Wallet ou Google Wallet.
        </p>
        <div class="space-y-3 mt-8">
          {[
            'Aucune application à télécharger pour vos clients',
            'Apple Wallet & Google Wallet natifs',
            'Scanner, notifications push et statistiques inclus',
            'Annulation à tout moment, sans engagement',
          ].map((item) => (
            <div class="flex items-center gap-3 text-sm text-slate-600">
              <span class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center text-xs font-bold flex-shrink-0">✓</span>
              {item}
            </div>
          ))}
        </div>
        <div class="mt-10 bg-indigo-50 border border-indigo-100 rounded-2xl p-5 shadow-[0_24px_50px_-32px_rgba(79,70,229,0.35)]">
          <p class="text-indigo-700 font-semibold text-sm">+27% de rétention clients en moyenne</p>
          <p class="text-indigo-500 text-xs mt-1">Constaté chez les commerces utilisant Fidelopass</p>
        </div>
      </div>

      <!-- Droite : formulaire -->
      <div class="bg-white/92 backdrop-blur-xl rounded-[2rem] border border-sky-100 shadow-[0_32px_70px_-34px_rgba(37,99,235,0.28)] p-6 sm:p-8">
        <a href="/" class="lg:hidden inline-flex items-center gap-1 mb-6">
          <img src="/logo-premium-cropped.png" alt="Fidelopass" class="h-20 w-auto object-contain" />
        </a>

        <div class="flex items-center justify-between gap-3 mb-6">
          <div>
            <p class="text-slate-400 text-sm">Essai gratuit · 14 jours · Sans carte bancaire</p>
            <h2 class="font-display text-2xl font-bold text-slate-900 mt-0.5">Créer mon compte</h2>
          </div>
          <div class="flex items-center gap-2">
            <div id="progress-1" class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold text-white" style="background:#4f46e5">1</div>
            <div class="w-8 h-px bg-slate-200"></div>
            <div id="progress-2" class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold text-slate-400 border border-slate-200">2</div>
          </div>
        </div>

        <!-- Étape 1 : choix méthode -->
        <div id="method-step">
          <p class="text-slate-500 text-sm mb-5">Choisissez votre mode d'inscription pour démarrer.</p>
          <div class="grid gap-3 mb-4">
            <button id="choose-apple-btn" type="button" class="w-full rounded-2xl bg-black text-white font-semibold py-3.5 px-4 flex items-center justify-center gap-3 hover:bg-slate-900 transition-colors shadow-sm">
              <svg viewBox="0 0 24 24" class="w-5 h-5 flex-shrink-0" fill="currentColor" aria-hidden="true">
                <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.4c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.56-1.32 3.09-2.53 4zm-3.07-17.4c.04 2.2-1.88 4.02-3.93 3.84-.27-2.04 1.88-4.08 3.93-3.84z"/>
              </svg>
              Continuer avec Apple
            </button>
          </div>
          <div class="grid sm:grid-cols-2 gap-3">
            <button id="choose-email-btn" type="button" class="rounded-2xl border border-slate-200 hover:border-indigo-300 hover:bg-indigo-50/50 transition-all p-5 text-left">
              <p class="text-slate-900 font-semibold text-sm">Par email</p>
              <p class="text-slate-400 text-sm mt-1.5">Recevez un code de vérification et créez votre mot de passe.</p>
            </button>
            <button id="choose-google-btn" type="button" class="rounded-2xl border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-all p-5 text-left">
              <div class="flex items-center gap-2.5 mb-1.5">
                <svg viewBox="0 0 24 24" class="w-5 h-5 flex-shrink-0" fill="none">
                  <path d="M21.56 10.74a9.55 9.55 0 0 0-.15-1.69H12v3.2h5.37a4.6 4.6 0 0 1-2 3.02v2.51h3.23c1.89-1.74 2.96-4.3 2.96-7.04z" fill="#4285F4"/>
                  <path d="M12 22c2.7 0 4.96-.9 6.61-2.43l-3.23-2.51c-.9.6-2.04.96-3.38.96-2.6 0-4.8-1.76-5.59-4.12H3.08v2.6A10 10 0 0 0 12 22z" fill="#34A853"/>
                  <path d="M6.41 13.9A6 6 0 0 1 6.09 12c0-.66.11-1.3.32-1.9V7.5H3.08A10 10 0 0 0 2 12c0 1.61.38 3.13 1.08 4.5l3.33-2.6z" fill="#FBBC05"/>
                  <path d="M12 5.88c1.47 0 2.79.5 3.82 1.5l2.86-2.86A9.96 9.96 0 0 0 12 2 10 10 0 0 0 3.08 7.5l3.33 2.6C7.2 7.64 9.4 5.88 12 5.88z" fill="#EA4335"/>
                </svg>
                <p class="text-slate-900 font-semibold text-sm">Continuer avec Google</p>
              </div>
              <p class="text-slate-400 text-sm">Connexion rapide via votre compte Google.</p>
            </button>
          </div>
          <div id="method-error-msg" class="hidden text-red-600 text-sm bg-red-50 border border-red-200 rounded-xl px-4 py-3 mt-4"></div>
        </div>

        <!-- Étape 2 : formulaire email -->
        <div id="email-step" class="hidden">
          <form id="register-form" class="flex flex-col gap-4">
            <div>
              <label class="label" for="email">Email professionnel</label>
              <input id="email" type="email" class="input" placeholder="vous@commerce.fr" required autocomplete="email" />
            </div>
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="label" for="password">Mot de passe</label>
                <input id="password" type="password" class="input" placeholder="8 caractères minimum" minlength="8" required autocomplete="new-password" />
              </div>
              <div>
                <label class="label" for="confirm">Confirmer</label>
                <input id="confirm" type="password" class="input" placeholder="••••••••" minlength="8" required autocomplete="new-password" />
              </div>
            </div>
            <div id="error-msg" class="hidden text-red-600 text-sm bg-red-50 border border-red-200 rounded-xl px-4 py-3"></div>
            <div class="flex gap-3">
              <button id="email-back-btn" type="button" class="btn-secondary py-3 px-5">Retour</button>
              <button type="submit" id="request-code-btn" class="btn-primary flex-1 py-3">
                Recevoir mon code
              </button>
            </div>
          </form>
        </div>

        <!-- Étape 3 : vérification OTP -->
        <div id="verify-step" class="hidden">
          <div class="rounded-2xl border border-indigo-200 bg-indigo-50 px-4 py-4 mb-5">
            <p class="text-indigo-900 font-medium text-sm">Code envoyé ✓</p>
            <p class="text-indigo-600 text-sm mt-1">Vérifiez votre boîte mail : <span id="verify-email" class="font-semibold"></span></p>
          </div>
          <form id="verify-form" class="flex flex-col gap-4">
            <div>
              <label class="label" for="verification-code">Code de vérification</label>
              <input id="verification-code" type="text" class="input text-center text-lg tracking-[0.3em] font-mono" placeholder="12345678" inputmode="numeric" autocomplete="one-time-code" maxlength="8" required />
            </div>
            <div id="verify-error-msg" class="hidden text-red-600 text-sm bg-red-50 border border-red-200 rounded-xl px-4 py-3"></div>
            <div id="verify-success-msg" class="hidden text-emerald-700 text-sm bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3"></div>
            <button type="submit" id="verify-btn" class="btn-primary w-full py-3">
              Vérifier et activer mon compte
            </button>
          </form>
          <div class="flex gap-3 mt-4">
            <button type="button" id="resend-btn" class="btn-secondary flex-1 py-2.5 text-sm">Renvoyer le code</button>
            <button type="button" id="change-email-btn" class="btn-secondary flex-1 py-2.5 text-sm">Modifier l'email</button>
          </div>
        </div>

        <p class="text-center text-slate-400 text-sm mt-6">
          Déjà un compte ?
          <a href="/login" class="text-indigo-600 hover:text-indigo-500 font-medium ml-1">Se connecter</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { clearSessionCookie, setSessionCookie } from '../lib/session-cookie';

  type PendingRegistration = { email: string; password: string };
  type RegistrationResponse = { message?: string; requires_email_verification?: boolean };

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const API = (import.meta.env.PUBLIC_API_URL || '').trim();
  const PENDING_KEY = 'fidelopass.pending-registration';

  const methodStep = document.getElementById('method-step') as HTMLDivElement;
  const emailStep = document.getElementById('email-step') as HTMLDivElement;
  const verifyStep = document.getElementById('verify-step') as HTMLDivElement;

  const registerForm = document.getElementById('register-form') as HTMLFormElement;
  const verifyForm = document.getElementById('verify-form') as HTMLFormElement;
  const requestCodeBtn = document.getElementById('request-code-btn') as HTMLButtonElement;
  const verifyBtn = document.getElementById('verify-btn') as HTMLButtonElement;
  const chooseEmailBtn = document.getElementById('choose-email-btn') as HTMLButtonElement;
  const chooseGoogleBtn = document.getElementById('choose-google-btn') as HTMLButtonElement;
  const chooseAppleBtn = document.getElementById('choose-apple-btn') as HTMLButtonElement;
  const emailBackBtn = document.getElementById('email-back-btn') as HTMLButtonElement;
  const resendBtn = document.getElementById('resend-btn') as HTMLButtonElement;
  const changeEmailBtn = document.getElementById('change-email-btn') as HTMLButtonElement;

  const methodErrorMsg = document.getElementById('method-error-msg') as HTMLDivElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const verifyErrorMsg = document.getElementById('verify-error-msg') as HTMLDivElement;
  const verifySuccessMsg = document.getElementById('verify-success-msg') as HTMLDivElement;
  const verifyEmailEl = document.getElementById('verify-email') as HTMLSpanElement;
  const codeInput = document.getElementById('verification-code') as HTMLInputElement;
  const progress1 = document.getElementById('progress-1') as HTMLDivElement;
  const progress2 = document.getElementById('progress-2') as HTMLDivElement;
  let statusMessageEl = document.getElementById('auth-progress') as HTMLDivElement | null;
  let redirectInFlight = false;
  const BILLING_CHECK_TIMEOUT_MS = Number(import.meta.env.PUBLIC_BILLING_CHECK_TIMEOUT_MS ?? 2200);

  const apiUrl = (path: string) => `${API}${path}`;
  const setProgress = (step: 1 | 2) => {
    const active = 'background:#4f46e5;color:white;border:none';
    const idle = 'background:transparent;color:#94a3b8;border:1px solid #e2e8f0';
    progress1.style.cssText = step >= 1 ? active : idle;
    progress2.style.cssText = step >= 2 ? active : idle;
  };

  const hideAll = () => [methodErrorMsg, errorMsg, verifyErrorMsg, verifySuccessMsg].forEach((el) => el.classList.add('hidden'));
  const show = (el: HTMLDivElement, msg: string) => { el.textContent = msg; el.classList.remove('hidden'); };
  const normalize = (s: string) => s.trim().toLowerCase();

  function ensureStatusMessageEl() {
    if (statusMessageEl) return statusMessageEl;
    statusMessageEl = document.createElement('div');
    statusMessageEl.id = 'auth-progress';
    statusMessageEl.className = 'hidden text-sky-700 text-sm bg-sky-50 border border-sky-200 rounded-xl px-4 py-3 mt-4';
    methodStep.appendChild(statusMessageEl);
    return statusMessageEl;
  }

  function showProgress(message: string) {
    const el = ensureStatusMessageEl();
    el.textContent = message;
    el.classList.remove('hidden');
  }

  function hideProgress() {
    const el = ensureStatusMessageEl();
    el.classList.add('hidden');
  }

  const getError = (err: unknown, fallback: string, context: 'register' | 'verify' | 'oauth' = 'register') => {
    if (!(err instanceof Error)) return fallback;
    if (/unsupported provider/i.test(err.message)) return 'Inscription Google indisponible. Vérifiez la configuration Supabase.';
    if (/rate limit|too many/i.test(err.message)) return 'Limite d\'envoi atteinte. Réessayez dans quelques minutes.';
    if (/already confirmed|déjà confirmée/i.test(err.message)) return 'Cette adresse est déjà confirmée. Connectez-vous.';
    // "Code invalide ou expiré" ne s'applique qu'à l'étape OTP, pas à la demande de code
    if (context === 'verify' && /expired|invalid/i.test(err.message)) return 'Code invalide ou expiré. Demandez-en un nouveau.';
    return err.message || fallback;
  };

  const savePending = (d: PendingRegistration) => sessionStorage.setItem(PENDING_KEY, JSON.stringify(d));
  const loadPending = (): PendingRegistration | null => {
    try {
      const raw = sessionStorage.getItem(PENDING_KEY);
      if (!raw) return null;
      const p = JSON.parse(raw) as Partial<PendingRegistration>;
      return p.email && p.password ? { email: p.email, password: p.password } : null;
    } catch { return null; }
  };
  const clearPending = () => sessionStorage.removeItem(PENDING_KEY);

  const setStep = (step: 'method' | 'email' | 'verify', email?: string) => {
    hideAll();
    hideProgress();
    methodStep.classList.toggle('hidden', step !== 'method');
    emailStep.classList.toggle('hidden', step !== 'email');
    verifyStep.classList.toggle('hidden', step !== 'verify');
    setProgress(step === 'verify' ? 2 : 1);
    if (step === 'verify' && email) { verifyEmailEl.textContent = email; codeInput.focus(); }
  };

  async function sendCode(email: string, password: string, mode: 'request' | 'resend'): Promise<RegistrationResponse> {
    const { data, error } = mode === 'resend'
      ? await supabase.auth.resend({ type: 'signup', email })
      : await supabase.auth.signUp({ email, password });
    if (error) throw new Error(error.message);
    return { requires_email_verification: mode === 'resend' ? true : !data.session && !data.user?.email_confirmed_at };
  }

  async function requestCode(email: string, password: string, mode: 'request' | 'resend'): Promise<RegistrationResponse> {
    const endpoint = mode === 'request' ? '/api/auth/register/request-code' : '/api/auth/register/resend-code';
    try {
      const res = await fetch(apiUrl(endpoint), {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error ?? 'Impossible d\'envoyer le code.');
      return data;
    } catch (err: unknown) {
      if (err instanceof Error && err.message === 'Failed to fetch') return sendCode(email, password, mode);
      throw err;
    }
  }

  async function getValidSession() {
    const { data: { session } } = await supabase.auth.getSession();
    if (session?.access_token) return session;

    const { data, error } = await supabase.auth.refreshSession();
    if (!error && data.session?.access_token) return data.session;
    return null;
  }

  async function redirectAfterAuth(
    sessionFromFlow: { access_token: string } | null = null,
    options: { redirectToPricingWhenNoAccess?: boolean } = {},
  ) {
    if (redirectInFlight) return;
    redirectInFlight = true;
    try {
      const { redirectToPricingWhenNoAccess = true } = options;
      const activeSession = sessionFromFlow?.access_token ? sessionFromFlow : await getValidSession();
      if (!activeSession?.access_token) {
        clearSessionCookie();
        await supabase.auth.signOut().catch(() => undefined);
        window.location.href = '/login';
        return;
      }

      setSessionCookie(activeSession.access_token);
      showProgress('Vérification de votre abonnement...');

      const controller = new AbortController();
      const timeoutId = window.setTimeout(() => controller.abort(), BILLING_CHECK_TIMEOUT_MS);
      const billingResponse = await fetch(apiUrl('/api/billing/status'), {
        headers: { Authorization: `Bearer ${activeSession.access_token}`, 'Content-Type': 'application/json' },
        signal: controller.signal,
      }).catch(() => null).finally(() => window.clearTimeout(timeoutId));

      if (!billingResponse) {
        setStep('method');
        show(methodErrorMsg, 'Impossible de vérifier votre abonnement pour le moment.');
        hideProgress();
        return;
      }

      const billing = await billingResponse.json().catch(() => ({}));
      if (!billingResponse.ok) {
        if (billingResponse.status === 401) {
          clearSessionCookie();
          await supabase.auth.signOut().catch(() => undefined);
          window.location.href = '/login';
          return;
        }
        setStep('method');
        show(methodErrorMsg, billing?.error ?? 'Erreur lors de la vérification de votre abonnement.');
        hideProgress();
        return;
      }

      if (!billing?.data?.has_access) {
        if (redirectToPricingWhenNoAccess) {
          showProgress('Redirection vers le choix de votre abonnement...');
          window.location.href = '/abonnement/choix';
        }
        return;
      }

      showProgress('Compte prêt, ouverture de votre espace...');
      window.location.href = billing?.data?.onboarding_completed ? '/dashboard' : '/onboarding';
    } finally {
      redirectInFlight = false;
    }
  }

  // Init
  const { data: { session } } = await supabase.auth.getSession();
  if (session) { await redirectAfterAuth(session, { redirectToPricingWhenNoAccess: true }); }

  const oauthErr = new URLSearchParams(window.location.search).get('error_description')
    ?? new URLSearchParams(window.location.hash.replace(/^#/, '')).get('error_description');
  if (oauthErr) { setStep('method'); show(methodErrorMsg, getError(new Error(oauthErr), oauthErr)); }

  supabase.auth.onAuthStateChange((event, s) => {
    if (!s) {
      clearSessionCookie();
      return;
    }
    if (event === 'SIGNED_IN') {
      clearPending();
      setSessionCookie(s.access_token);
      void redirectAfterAuth(s, { redirectToPricingWhenNoAccess: true });
    }
  });

  const pending = loadPending();
  if (pending) setStep('verify', pending.email);
  else setStep('method');

  // Listeners
  chooseEmailBtn.addEventListener('click', () => setStep('email'));

  chooseAppleBtn.addEventListener('click', async () => {
    hideAll();
    hideProgress();
    chooseAppleBtn.disabled = true;
    chooseAppleBtn.textContent = 'Redirection vers Apple...';
    try {
      const { data, error } = await supabase.auth.signInWithOAuth({
        provider: 'apple',
        options: { redirectTo: `${window.location.origin}/auth/confirm` },
      });
      if (error) throw error;
      if (!data.url) throw new Error('URL Apple indisponible.');
      window.location.assign(data.url);
    } catch (err) {
      setStep('method');
      show(methodErrorMsg, getError(err, 'Connexion Apple impossible.'));
      chooseAppleBtn.disabled = false;
      chooseAppleBtn.innerHTML = `<svg viewBox="0 0 24 24" class="w-5 h-5 flex-shrink-0" fill="currentColor" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.4c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.56-1.32 3.09-2.53 4zm-3.07-17.4c.04 2.2-1.88 4.02-3.93 3.84-.27-2.04 1.88-4.08 3.93-3.84z"/></svg> Continuer avec Apple`;
    }
  });

  chooseGoogleBtn.addEventListener('click', async () => {
    hideAll();
    hideProgress();
    chooseGoogleBtn.disabled = true;
    try {
      const { data, error } = await supabase.auth.signInWithOAuth({
        provider: 'google',
        options: { redirectTo: `${window.location.origin}/register`, skipBrowserRedirect: true },
      });
      if (error) throw error;
      if (!data.url) throw new Error('URL Google indisponible.');
      window.location.assign(data.url);
    } catch (err) {
      setStep('method'); show(methodErrorMsg, getError(err, 'Connexion Google impossible.'));
      chooseGoogleBtn.disabled = false;
    }
  });

  emailBackBtn.addEventListener('click', () => setStep('method'));

  registerForm.addEventListener('submit', async (e) => {
    e.preventDefault(); hideAll(); hideProgress();
    const email = normalize((document.getElementById('email') as HTMLInputElement).value);
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirm = (document.getElementById('confirm') as HTMLInputElement).value;
    if (password !== confirm) { show(errorMsg, 'Les mots de passe ne correspondent pas.'); return; }
    requestCodeBtn.disabled = true; requestCodeBtn.textContent = 'Envoi...';
    try {
      const data = await requestCode(email, password, 'request');
      if (data.requires_email_verification === false) {
        const { data: signInData } = await supabase.auth.signInWithPassword({ email, password });
        if (signInData.session?.access_token) {
          setSessionCookie(signInData.session.access_token);
        }
        clearPending(); await redirectAfterAuth(signInData.session ?? null); return;
      }
      savePending({ email, password });
      setStep('verify', email);
      show(verifySuccessMsg, 'Code envoyé. Vérifiez votre boîte mail.');
    } catch (err: unknown) { show(errorMsg, getError(err, 'Une erreur est survenue.', 'register')); }
    finally { requestCodeBtn.disabled = false; requestCodeBtn.textContent = 'Recevoir mon code'; }
  });

  verifyForm.addEventListener('submit', async (e) => {
    e.preventDefault(); hideAll(); hideProgress();
    const pending = loadPending();
    if (!pending) { setStep('method'); show(methodErrorMsg, 'Session expirée. Recommencez.'); return; }
    const token = codeInput.value.replace(/\D+/g, '').trim();
    if (token.length < 6) { show(verifyErrorMsg, 'Entrez le code reçu par email.'); return; }
    verifyBtn.disabled = true; verifyBtn.textContent = 'Vérification...';
    try {
      const { error } = await supabase.auth.verifyOtp({ email: pending.email, token, type: 'email' });
      if (error) throw new Error(error.message);
      clearPending(); show(verifySuccessMsg, 'Email confirmé. Redirection...'); await redirectAfterAuth();
    } catch (err: unknown) { show(verifyErrorMsg, getError(err, 'Une erreur est survenue.', 'verify')); }
    finally { verifyBtn.disabled = false; verifyBtn.textContent = 'Vérifier et activer mon compte'; }
  });

  resendBtn.addEventListener('click', async () => {
    hideAll(); hideProgress(); const pending = loadPending();
    if (!pending) { setStep('method'); return; }
    resendBtn.disabled = true; resendBtn.textContent = 'Renvoi...';
    try {
      await requestCode(pending.email, pending.password, 'resend');
      show(verifySuccessMsg, 'Nouveau code envoyé.');
    } catch (err: unknown) { show(verifyErrorMsg, getError(err, 'Impossible de renvoyer.', 'verify')); }
    finally { resendBtn.disabled = false; resendBtn.textContent = 'Renvoyer le code'; }
  });

  changeEmailBtn.addEventListener('click', async () => {
    clearPending(); codeInput.value = ''; setStep('email');
    clearSessionCookie();
    await supabase.auth.signOut().catch(() => undefined);
  });
</script>
