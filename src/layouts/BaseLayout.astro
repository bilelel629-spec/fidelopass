---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  theme?: 'light' | 'dashboard';
}

const {
  title = 'Fidelopass — Cartes de fidélité dématérialisées',
  description = 'Créez et gérez vos cartes de fidélité Apple Wallet & Google Wallet en quelques minutes.',
  theme = 'light',
} = Astro.props;
---

<!doctype html>
<html lang="fr" class={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body class:list={[
    "min-h-screen antialiased",
    theme === 'dashboard' ? 'bg-navy-900 text-slate-50' : 'bg-white text-slate-900'
  ]}>
    <slot />
  </body>
</html>
