---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Assistance cartes — Admin Fidelopass" activeNav="cartes">
  <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="dashboard-kicker">Support opérationnel</p>
      <h1 class="dashboard-title">Assistance cartes commerçants</h1>
      <p class="dashboard-subtitle">Intervenez directement sur la carte d’un commerce (support, assistance setup 20€, correction urgente).</p>
    </div>
    <a href="/admin/commerces" class="btn-secondary px-4 py-2.5 text-sm">
      Retour à la liste des commerces
    </a>
  </div>

  <div class="grid gap-6 xl:grid-cols-[320px_1fr]">
    <section class="card dashboard-panel p-5">
      <h2 class="font-display text-xl font-bold text-slate-900">Sélection</h2>
      <div class="mt-4 space-y-4">
        <div>
          <label class="label mb-2 block" for="admin-commerce-select">Commerce</label>
          <select id="admin-commerce-select" class="input">
            <option value="">Choisir un commerce</option>
          </select>
        </div>
        <div>
          <label class="label mb-2 block" for="admin-point-select">Point de vente</label>
          <select id="admin-point-select" class="input" disabled>
            <option value="">Choisir un point de vente</option>
          </select>
        </div>
      </div>
      <div id="admin-commerce-meta" class="mt-4 hidden rounded-2xl border border-sky-100 bg-sky-50/70 p-4 text-xs text-slate-600"></div>
      <p id="admin-help-msg" class="mt-4 text-xs text-slate-500">Choisissez un commerce puis un point de vente pour éditer sa carte.</p>
    </section>

    <section class="card dashboard-panel p-6">
      <div class="mb-5 flex flex-wrap items-center justify-between gap-3">
        <div>
          <h2 class="font-display text-2xl font-bold text-slate-900">Personnalisation rapide</h2>
          <p class="mt-1 text-sm text-slate-500">Préparez une proposition admin, puis laissez le commerçant valider. Application immédiate possible en urgence.</p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <button id="admin-save-draft-btn" type="button" class="btn-secondary px-4 py-2.5 text-sm" disabled>Brouillon admin</button>
          <button id="admin-submit-validation-btn" type="button" class="btn-primary px-5 py-2.5 text-sm" disabled>Soumettre au commerçant</button>
          <button id="admin-apply-now-btn" type="button" class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-2.5 text-sm font-semibold text-amber-800 transition hover:bg-amber-100 disabled:cursor-not-allowed disabled:opacity-60" disabled>Appliquer maintenant</button>
        </div>
      </div>
      <div id="admin-proposal-status" class="mb-4 hidden rounded-xl border border-indigo-200 bg-indigo-50/70 px-4 py-3 text-xs text-indigo-700"></div>

      <div id="admin-error" class="hidden mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
      <div id="admin-success" class="hidden mb-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700"></div>

      <div class="grid gap-4 lg:grid-cols-2">
        <div>
          <label class="label mb-2 block" for="admin-card-name">Nom de la carte *</label>
          <input id="admin-card-name" type="text" class="input" placeholder="Carte fidélité commerce" />
        </div>
        <div>
          <label class="label mb-2 block" for="admin-label-client">Label client</label>
          <input id="admin-label-client" type="text" class="input" placeholder="Client" />
        </div>
      </div>

      <div class="mt-4">
        <label class="label mb-2 block" for="admin-description">Description</label>
        <input id="admin-description" type="text" class="input" placeholder="Cumulez et débloquez vos récompenses." />
      </div>

      <div class="mt-5 grid gap-4 lg:grid-cols-2">
        <div class="rounded-2xl border border-sky-100 bg-sky-50/60 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-700/75">Programme</p>
          <div class="mt-3 grid grid-cols-2 gap-2">
            <label class="cursor-pointer rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm">
              <input id="admin-type-tampons" type="radio" name="admin-type" value="tampons" checked class="mr-2" />
              Tampons
            </label>
            <label class="cursor-pointer rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm">
              <input id="admin-type-points" type="radio" name="admin-type" value="points" class="mr-2" />
              Points
            </label>
          </div>
          <div class="mt-3 grid grid-cols-2 gap-2">
            <div>
              <label class="label mb-1 block" for="admin-tampons-total">Tampons</label>
              <input id="admin-tampons-total" type="number" min="1" max="50" value="10" class="input" />
            </div>
            <div>
              <label class="label mb-1 block" for="admin-points-target">Points cible</label>
              <input id="admin-points-target" type="number" min="1" value="100" class="input" />
            </div>
          </div>
          <div class="mt-3">
            <label class="label mb-1 block" for="admin-reward">Récompense</label>
            <input id="admin-reward" type="text" class="input" placeholder="Ex: -10% / 1 café offert" />
          </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Couleurs</p>
          <div class="mt-3 grid grid-cols-3 gap-3">
            <label class="text-xs text-slate-600">Fond
              <input id="admin-color-bg" type="color" class="mt-1 h-10 w-full cursor-pointer rounded-xl border border-slate-200 bg-white p-1" value="#0f172a" />
            </label>
            <label class="text-xs text-slate-600">Texte
              <input id="admin-color-text" type="color" class="mt-1 h-10 w-full cursor-pointer rounded-xl border border-slate-200 bg-white p-1" value="#ffffff" />
            </label>
            <label class="text-xs text-slate-600">Accent
              <input id="admin-color-accent" type="color" class="mt-1 h-10 w-full cursor-pointer rounded-xl border border-slate-200 bg-white p-1" value="#60a5fa" />
            </label>
          </div>
        </div>
      </div>

      <div class="mt-5 grid gap-4 lg:grid-cols-2">
        <div>
          <label class="label mb-2 block" for="admin-logo-url">URL logo</label>
          <input id="admin-logo-url" type="url" class="input" placeholder="https://..." />
        </div>
        <div>
          <label class="label mb-2 block" for="admin-strip-url">URL bannière</label>
          <input id="admin-strip-url" type="url" class="input" placeholder="https://..." />
        </div>
      </div>

      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        <div>
          <label class="label mb-2 block" for="admin-stamp-url">URL logo tampon</label>
          <input id="admin-stamp-url" type="url" class="input" placeholder="https://..." />
        </div>
        <div>
          <label class="label mb-2 block" for="admin-stamp-scale">Taille logo tampon</label>
          <input id="admin-stamp-scale" type="range" min="0.6" max="1.5" step="0.05" value="1" class="w-full accent-sky-600" />
          <p class="mt-1 text-xs text-slate-500">Valeur: <span id="admin-stamp-scale-value">1.00</span></p>
        </div>
      </div>

      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        <div>
          <label class="label mb-2 block" for="admin-welcome-message">Message d’accueil</label>
          <input id="admin-welcome-message" type="text" class="input" maxlength="180" />
        </div>
        <div>
          <label class="label mb-2 block" for="admin-success-message">Message après ajout</label>
          <input id="admin-success-message" type="text" class="input" maxlength="180" />
        </div>
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  type CommerceItem = {
    id: string;
    nom: string;
    plan?: string | null;
    plan_override?: string | null;
    effective_plan?: string | null;
    actif: boolean;
  };

  type PointVenteItem = {
    id: string;
    nom: string;
    principal: boolean;
    actif: boolean;
  };

  type CarteItem = Record<string, unknown> & { id: string; point_vente_id: string };
  type AdminProposal = {
    id: string;
    status: 'draft_admin' | 'pending_merchant' | 'rejected_merchant' | 'applied_merchant';
    payload: Record<string, unknown>;
    updated_at?: string | null;
    submitted_at?: string | null;
    admin_note?: string | null;
    merchant_comment?: string | null;
  };

  let commerces: CommerceItem[] = [];
  let pointsVente: PointVenteItem[] = [];
  let cartes: CarteItem[] = [];
  let currentProposal: AdminProposal | null = null;
  let selectedCommerceId = '';
  let selectedPointId = '';

  const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001';
  const SESSION_PROBE_TIMEOUT_MS = Number(import.meta.env.PUBLIC_AUTH_SESSION_PROBE_TIMEOUT_MS ?? 900);
  const commerceSelect = document.getElementById('admin-commerce-select') as HTMLSelectElement;
  const pointSelect = document.getElementById('admin-point-select') as HTMLSelectElement;
  const saveDraftBtn = document.getElementById('admin-save-draft-btn') as HTMLButtonElement;
  const submitValidationBtn = document.getElementById('admin-submit-validation-btn') as HTMLButtonElement;
  const applyNowBtn = document.getElementById('admin-apply-now-btn') as HTMLButtonElement;
  const proposalStatusBox = document.getElementById('admin-proposal-status') as HTMLDivElement;
  const errorBox = document.getElementById('admin-error') as HTMLDivElement;
  const successBox = document.getElementById('admin-success') as HTMLDivElement;
  const stampScale = document.getElementById('admin-stamp-scale') as HTMLInputElement;
  const stampScaleValue = document.getElementById('admin-stamp-scale-value') as HTMLSpanElement;
  const commerceMeta = document.getElementById('admin-commerce-meta') as HTMLDivElement;

  function setFeedback(type: 'error' | 'success', message: string) {
    if (type === 'error') {
      errorBox.textContent = message;
      errorBox.classList.remove('hidden');
      successBox.classList.add('hidden');
      return;
    }
    successBox.textContent = message;
    successBox.classList.remove('hidden');
    errorBox.classList.add('hidden');
  }

  function clearFeedback() {
    errorBox.classList.add('hidden');
    successBox.classList.add('hidden');
  }

  function setProposalStatus(message: string, visible = true) {
    proposalStatusBox.textContent = message;
    proposalStatusBox.classList.toggle('hidden', !visible);
  }

  function disableActionButtons(disabled: boolean) {
    saveDraftBtn.disabled = disabled;
    submitValidationBtn.disabled = disabled;
    applyNowBtn.disabled = disabled;
  }

  function withTimeout<T>(promise: Promise<T>, timeoutMs: number): Promise<T> {
    return Promise.race([
      promise,
      new Promise<T>((_, reject) => window.setTimeout(() => reject(new Error('timeout')), timeoutMs)),
    ]);
  }

  async function getAccessTokenFast() {
    const { supabase } = await import('../../lib/supabase');
    const sessionResult = await withTimeout(supabase.auth.getSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null);
    const sessionToken = sessionResult?.data?.session?.access_token;
    if (sessionToken) return sessionToken;
    const refreshResult = await withTimeout(supabase.auth.refreshSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null);
    return refreshResult?.data?.session?.access_token ?? '';
  }

  async function authFetch(url: string, opts: RequestInit = {}) {
    const accessToken = await getAccessTokenFast();
    return fetch(url, {
      ...opts,
      headers: {
        ...(opts.headers ?? {}),
        Authorization: `Bearer ${accessToken}`,
        'Content-Type': 'application/json',
      },
    });
  }

  function setInput(id: string, value: string | number | null | undefined) {
    const el = document.getElementById(id) as HTMLInputElement | null;
    if (!el) return;
    el.value = value == null ? '' : String(value);
  }

  function getInput(id: string) {
    return (document.getElementById(id) as HTMLInputElement).value.trim();
  }

  function buildPayload() {
    const selectedType = (document.querySelector('input[name="admin-type"]:checked') as HTMLInputElement)?.value ?? 'tampons';
    const payload: Record<string, unknown> = {
      point_vente_id: selectedPointId,
      nom: getInput('admin-card-name'),
      label_client: getInput('admin-label-client') || 'Client',
      description: getInput('admin-description') || null,
      type: selectedType,
      recompense_description: getInput('admin-reward') || null,
      couleur_fond: getInput('admin-color-bg') || '#0f172a',
      couleur_texte: getInput('admin-color-text') || '#ffffff',
      couleur_accent: getInput('admin-color-accent') || '#60a5fa',
      logo_url: getInput('admin-logo-url') || null,
      strip_url: getInput('admin-strip-url') || null,
      tampon_icon_url: getInput('admin-stamp-url') || null,
      tampon_icon_scale: Number(stampScale.value || '1'),
      welcome_message: getInput('admin-welcome-message') || null,
      success_message: getInput('admin-success-message') || null,
    };

    if (selectedType === 'points') {
      payload.points_recompense = Number(getInput('admin-points-target') || 100);
    } else {
      payload.tampons_total = Number(getInput('admin-tampons-total') || 10);
    }
    return payload;
  }

  function validatePayload(payload: Record<string, unknown>): string | null {
    const cardName = String(payload.nom ?? '').trim();
    if (cardName.length < 2) return 'Le nom de carte est obligatoire (2 caractères minimum).';
    return null;
  }

  function setCurrentCard(card: CarteItem | null) {
    const isPoints = String(card?.type ?? 'tampons') === 'points';
    (document.getElementById('admin-type-points') as HTMLInputElement).checked = isPoints;
    (document.getElementById('admin-type-tampons') as HTMLInputElement).checked = !isPoints;
    setInput('admin-card-name', String(card?.nom ?? ''));
    setInput('admin-label-client', String(card?.label_client ?? 'Client'));
    setInput('admin-description', String(card?.description ?? ''));
    setInput('admin-tampons-total', Number(card?.tampons_total ?? 10));
    setInput('admin-points-target', Number(card?.points_recompense ?? 100));
    setInput('admin-reward', String(card?.recompense_description ?? ''));
    setInput('admin-logo-url', String(card?.logo_url ?? ''));
    setInput('admin-strip-url', String(card?.strip_url ?? ''));
    setInput('admin-stamp-url', String(card?.tampon_icon_url ?? ''));
    setInput('admin-welcome-message', String(card?.welcome_message ?? ''));
    setInput('admin-success-message', String(card?.success_message ?? ''));
    setInput('admin-color-bg', String(card?.couleur_fond ?? '#0f172a'));
    setInput('admin-color-text', String(card?.couleur_texte ?? '#ffffff'));
    setInput('admin-color-accent', String(card?.couleur_accent ?? '#60a5fa'));
    const scale = Number(card?.tampon_icon_scale ?? 1);
    stampScale.value = String(scale);
    stampScaleValue.textContent = Number(scale).toFixed(2);
  }

  function applyProposalPayload(payload: Record<string, unknown>) {
    if (!payload || typeof payload !== 'object') return;
    const type = String(payload.type ?? '');
    if (type === 'points' || type === 'tampons') {
      (document.getElementById('admin-type-points') as HTMLInputElement).checked = type === 'points';
      (document.getElementById('admin-type-tampons') as HTMLInputElement).checked = type === 'tampons';
    }
    if (payload.nom !== undefined) setInput('admin-card-name', String(payload.nom ?? ''));
    if (payload.label_client !== undefined) setInput('admin-label-client', String(payload.label_client ?? 'Client'));
    if (payload.description !== undefined) setInput('admin-description', String(payload.description ?? ''));
    if (payload.tampons_total !== undefined) setInput('admin-tampons-total', Number(payload.tampons_total ?? 10));
    if (payload.points_recompense !== undefined) setInput('admin-points-target', Number(payload.points_recompense ?? 100));
    if (payload.recompense_description !== undefined) setInput('admin-reward', String(payload.recompense_description ?? ''));
    if (payload.logo_url !== undefined) setInput('admin-logo-url', String(payload.logo_url ?? ''));
    if (payload.strip_url !== undefined) setInput('admin-strip-url', String(payload.strip_url ?? ''));
    if (payload.tampon_icon_url !== undefined) setInput('admin-stamp-url', String(payload.tampon_icon_url ?? ''));
    if (payload.welcome_message !== undefined) setInput('admin-welcome-message', String(payload.welcome_message ?? ''));
    if (payload.success_message !== undefined) setInput('admin-success-message', String(payload.success_message ?? ''));
    if (payload.couleur_fond !== undefined) setInput('admin-color-bg', String(payload.couleur_fond ?? '#0f172a'));
    if (payload.couleur_texte !== undefined) setInput('admin-color-text', String(payload.couleur_texte ?? '#ffffff'));
    if (payload.couleur_accent !== undefined) setInput('admin-color-accent', String(payload.couleur_accent ?? '#60a5fa'));
    if (payload.tampon_icon_scale !== undefined) {
      const scale = Number(payload.tampon_icon_scale ?? 1);
      stampScale.value = String(scale);
      stampScaleValue.textContent = Number(scale).toFixed(2);
    }
  }

  async function loadPointProposal(commerceId: string, pointVenteId: string) {
    const response = await authFetch(`${API_BASE}/api/admin/commerces/${commerceId}/card-assistance/proposal?point_vente_id=${encodeURIComponent(pointVenteId)}`);
    if (!response.ok) throw new Error('Impossible de charger la proposition admin.');
    const { data } = await response.json();
    currentProposal = (data ?? null) as AdminProposal | null;
  }

  async function hydrateSelectedPoint() {
    if (!selectedCommerceId || !selectedPointId) {
      setCurrentCard(null);
      currentProposal = null;
      setProposalStatus('', false);
      disableActionButtons(true);
      return;
    }
    const existingCard = cartes.find((card) => card.point_vente_id === selectedPointId) ?? null;
    setCurrentCard(existingCard);
    await loadPointProposal(selectedCommerceId, selectedPointId);
    if (currentProposal?.payload) {
      applyProposalPayload(currentProposal.payload);
      if (currentProposal.status === 'pending_merchant') {
        setProposalStatus('Proposition envoyée au commerçant et en attente de validation.');
      } else {
        setProposalStatus('Brouillon admin chargé. Vous pouvez continuer puis soumettre.');
      }
    } else {
      setProposalStatus('Aucune proposition enregistrée pour ce point de vente.', true);
    }
    disableActionButtons(false);
  }

  async function loadCommerces() {
    const res = await authFetch(`${API_BASE}/api/admin/commerces`);
    if (!res.ok) throw new Error('Impossible de charger les commerces.');
    const { data } = await res.json();
    commerces = (data ?? []) as CommerceItem[];
    commerceSelect.innerHTML = '<option value="">Choisir un commerce</option>' + commerces.map((commerce) => (
      `<option value="${commerce.id}">${commerce.nom}</option>`
    )).join('');
  }

  async function loadCommerceAssistance(commerceId: string) {
    const res = await authFetch(`${API_BASE}/api/admin/commerces/${commerceId}/card-assistance`);
    if (!res.ok) throw new Error('Impossible de charger les cartes du commerce.');
    const { data } = await res.json();
    pointsVente = data?.points_vente ?? [];
    cartes = data?.cartes ?? [];

    const commerce = data?.commerce;
    if (commerce) {
      commerceMeta.classList.remove('hidden');
      commerceMeta.innerHTML = `
        <p><span class="font-semibold text-slate-800">${commerce.nom}</span></p>
        <p class="mt-1">Plan effectif: <span class="font-semibold text-slate-700">${String(commerce.effective_plan ?? commerce.plan ?? 'starter')}</span></p>
      `;
    } else {
      commerceMeta.classList.add('hidden');
    }

    pointSelect.disabled = pointsVente.length === 0;
    pointSelect.innerHTML = '<option value="">Choisir un point de vente</option>' + pointsVente.map((point) => (
      `<option value="${point.id}">${point.nom}${point.principal ? ' · principal' : ''}</option>`
    )).join('');

    if (pointsVente.length > 0) {
      selectedPointId = pointsVente[0].id;
      pointSelect.value = selectedPointId;
      await hydrateSelectedPoint();
    } else {
      selectedPointId = '';
      setCurrentCard(null);
      currentProposal = null;
      disableActionButtons(true);
      setProposalStatus('Aucun point de vente actif pour ce commerce.', true);
    }
  }

  async function runWithButtonState(button: HTMLButtonElement, loadingLabel: string, task: () => Promise<void>) {
    const previousLabel = button.textContent ?? '';
    button.disabled = true;
    button.textContent = loadingLabel;
    try {
      await task();
    } finally {
      button.disabled = false;
      button.textContent = previousLabel;
    }
  }

  async function saveCardProposal(submitForValidation: boolean) {
    if (!selectedCommerceId || !selectedPointId) return;
    const payload = buildPayload();
    const validationError = validatePayload(payload);
    if (validationError) {
      setFeedback('error', validationError);
      return;
    }

    clearFeedback();
    try {
      const response = await authFetch(`${API_BASE}/api/admin/commerces/${selectedCommerceId}/card-assistance/proposal`, {
        method: 'POST',
        body: JSON.stringify({
          ...payload,
          submit_for_validation: submitForValidation,
        }),
      });
      const result = await response.json().catch(() => null);
      if (!response.ok) throw new Error(result?.error ?? 'Impossible de sauvegarder la proposition.');
      await hydrateSelectedPoint();
      setFeedback('success', submitForValidation
        ? 'Proposition envoyée au commerçant pour validation.'
        : 'Brouillon admin enregistré.');
    } catch (error) {
      setFeedback('error', error instanceof Error ? error.message : 'Erreur inattendue.');
    }
  }

  async function applyCardDirectly() {
    if (!selectedCommerceId || !selectedPointId) return;
    const payload = buildPayload();
    const validationError = validatePayload(payload);
    if (validationError) {
      setFeedback('error', validationError);
      return;
    }

    clearFeedback();
    try {
      const response = await authFetch(`${API_BASE}/api/admin/commerces/${selectedCommerceId}/card-assistance`, {
        method: 'PATCH',
        body: JSON.stringify(payload),
      });
      const result = await response.json().catch(() => null);
      if (!response.ok) throw new Error(result?.error ?? 'Impossible d’appliquer la carte.');
      await loadCommerceAssistance(selectedCommerceId);
      if (selectedPointId) pointSelect.value = selectedPointId;
      setFeedback('success', 'Carte appliquée immédiatement sur le commerce.');
    } catch (error) {
      setFeedback('error', error instanceof Error ? error.message : 'Erreur inattendue.');
    }
  }

  commerceSelect.addEventListener('change', async () => {
    selectedCommerceId = commerceSelect.value;
    selectedPointId = '';
    clearFeedback();
    disableActionButtons(true);
    pointSelect.disabled = true;
    pointSelect.innerHTML = '<option value="">Choisir un point de vente</option>';
    setCurrentCard(null);
    setProposalStatus('', false);
    if (!selectedCommerceId) return;
    try {
      await loadCommerceAssistance(selectedCommerceId);
    } catch (error) {
      setFeedback('error', error instanceof Error ? error.message : 'Erreur inattendue.');
    }
  });

  pointSelect.addEventListener('change', async () => {
    selectedPointId = pointSelect.value;
    clearFeedback();
    if (!selectedPointId) {
      setCurrentCard(null);
      currentProposal = null;
      setProposalStatus('', false);
      disableActionButtons(true);
      return;
    }
    try {
      await hydrateSelectedPoint();
    } catch (error) {
      setFeedback('error', error instanceof Error ? error.message : 'Erreur inattendue.');
    }
  });

  stampScale.addEventListener('input', () => {
    stampScaleValue.textContent = Number(stampScale.value || '1').toFixed(2);
  });

  saveDraftBtn.addEventListener('click', () => runWithButtonState(saveDraftBtn, 'Enregistrement...', async () => {
    await saveCardProposal(false);
  }));
  submitValidationBtn.addEventListener('click', () => runWithButtonState(submitValidationBtn, 'Envoi...', async () => {
    await saveCardProposal(true);
  }));
  applyNowBtn.addEventListener('click', () => runWithButtonState(applyNowBtn, 'Application...', async () => {
    await applyCardDirectly();
  }));

  (async () => {
    try {
      await loadCommerces();
      const params = new URLSearchParams(window.location.search);
      const preselectedCommerce = params.get('commerce');
      if (preselectedCommerce && commerces.some((commerce) => commerce.id === preselectedCommerce)) {
        commerceSelect.value = preselectedCommerce;
        selectedCommerceId = preselectedCommerce;
        await loadCommerceAssistance(selectedCommerceId);
      }
    } catch (error) {
      setFeedback('error', error instanceof Error ? error.message : 'Impossible de charger l’espace assistance.');
    }
  })();
</script>
