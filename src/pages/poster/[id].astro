---
import BaseLayout from '../../layouts/BaseLayout.astro';

const { id } = Astro.params;
const apiBase = (
  import.meta.env.PUBLIC_API_URL
  ?? (import.meta.env.PROD ? 'https://api.fidelopass.com' : 'http://localhost:3001')
).replace(/\/$/, '');
---

<BaseLayout title="Affiche A4 — Fidelopass" description="Téléchargez une affiche A4 Fidelopass prête à imprimer avec le QR code de votre carte.">
  <div class="min-h-screen px-4 py-8">
    <div class="max-w-6xl mx-auto">
      <div class="poster-ui flex flex-col lg:flex-row gap-6 items-start justify-between mb-6">
        <div>
          <p class="text-slate-400 text-sm uppercase tracking-[0.28em]">Affiches Fidelopass</p>
          <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mt-3">Préparez une affiche A4 prête à imprimer</h1>
          <p class="text-slate-400 text-sm sm:text-base mt-3 max-w-2xl">
            Choisissez un modèle, imprimez-le en A4 ou téléchargez uniquement le QR code pour vos supports en boutique.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <button id="download-qr" type="button" class="btn-secondary px-5 py-3 text-sm">Télécharger le QR</button>
          <button id="print-poster" type="button" class="btn-primary px-5 py-3 text-sm">Imprimer l’affiche</button>
        </div>
      </div>

      <div class="poster-ui flex flex-wrap gap-3 mb-6">
        <button type="button" class="poster-template-btn btn-secondary text-sm px-4 py-2.5" data-template="essential">Essentiel</button>
        <button type="button" class="poster-template-btn btn-secondary text-sm px-4 py-2.5" data-template="signature">Signature</button>
      </div>

      <div id="poster-loading" class="text-center py-16">
        <div class="w-8 h-8 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-slate-400 text-sm">Préparation de l’affiche...</p>
      </div>

      <div id="poster-error" class="hidden text-center py-12">
        <div class="card p-8 max-w-xl mx-auto">
          <p class="text-red-400 font-semibold">Impossible de charger cette affiche.</p>
          <p class="text-slate-400 text-sm mt-2">Vérifiez que votre carte est bien publiée puis réessayez.</p>
        </div>
      </div>

      <div id="poster-stage" class="hidden">
        <div id="poster-sheet" class="poster-sheet mx-auto bg-white text-slate-900 overflow-hidden shadow-2xl border border-white/10">
          <div id="poster-essential" class="poster-variant hidden h-full">
            <div class="poster-safe-zone h-full flex flex-col">
              <div class="flex items-center justify-between gap-6">
                <div class="flex items-center gap-4">
                  <img id="poster-essential-logo" src="" alt="" class="hidden w-16 h-16 rounded-2xl object-cover" />
                  <div>
                    <p class="text-[10px] uppercase tracking-[0.34em] text-slate-500">Fidelopass</p>
                    <h2 id="poster-essential-commerce" class="font-display text-[2.05rem] leading-tight font-bold mt-2">Votre commerce</h2>
                  </div>
                </div>
                <div id="poster-essential-badge" class="px-4 py-2 rounded-full text-sm font-semibold border border-slate-200 bg-slate-50">Carte fidélité</div>
              </div>

              <div class="mt-7">
                <h3 id="poster-essential-title" class="font-display text-[2.65rem] leading-[1.03] font-bold max-w-[11.5cm]">
                  Scannez et ajoutez votre carte fidélité
                </h3>
                <p id="poster-essential-subtitle" class="text-[1rem] text-slate-600 mt-3.5 max-w-[12.5cm]">
                  Bienvenue, créez votre carte fidélité en 10 secondes.
                </p>
              </div>

              <div class="mt-auto grid grid-cols-[1fr_88mm] gap-6 items-end">
                <div id="poster-essential-program" class="rounded-[1.1rem] p-6 text-white">
                  <p class="text-[11px] uppercase tracking-[0.28em] opacity-85">Programme fidélité</p>
                  <p id="poster-essential-reward" class="font-display text-[1.8rem] leading-tight font-bold mt-2.5">10 achats = 1 récompense</p>
                  <p class="text-sm opacity-90 mt-3">Montrez cette carte à chaque passage pour cumuler vos avantages.</p>
                </div>
                <div class="rounded-[1.1rem] border border-slate-200 bg-slate-50 p-4 text-center">
                  <img id="poster-essential-qr" src="" alt="QR code Fidelopass" class="w-[74mm] h-[74mm] mx-auto rounded-xl" />
                  <p class="text-sm font-semibold mt-2.5">Scannez ici</p>
                  <p class="text-xs text-slate-500 mt-1">Ajout direct dans Apple Wallet & Google Wallet.</p>
                </div>
              </div>
            </div>
          </div>

          <div id="poster-signature" class="poster-variant hidden h-full">
            <div class="h-full relative overflow-hidden">
              <div id="poster-signature-banner" class="absolute inset-x-0 top-0 h-[32%] bg-slate-900"></div>
              <div class="absolute inset-0 bg-gradient-to-br from-black/35 via-transparent to-black/40"></div>

              <div class="poster-safe-zone relative z-10 h-full flex flex-col">
                <div class="flex items-start justify-between gap-5">
                  <div class="max-w-[12.6cm] text-white">
                    <p class="text-[10px] uppercase tracking-[0.34em] text-white/70">Carte fidélité digitale</p>
                    <h2 id="poster-signature-commerce" class="font-display text-[2.25rem] leading-tight font-bold mt-2.5">Votre commerce</h2>
                    <p id="poster-signature-copy" class="text-[1rem] text-white/90 mt-3.5 leading-relaxed">
                      Scannez, ajoutez votre carte et profitez de vos avantages à chaque passage.
                    </p>
                  </div>
                  <img id="poster-signature-logo" src="" alt="" class="hidden w-16 h-16 rounded-2xl object-cover border border-white/25" />
                </div>

                <div class="mt-auto grid grid-cols-[92mm_1fr] gap-6 items-end">
                  <div class="rounded-[1.2rem] bg-white p-4 text-center shadow-xl">
                    <img id="poster-signature-qr" src="" alt="QR code Fidelopass" class="w-[78mm] h-[78mm] mx-auto rounded-xl" />
                    <p class="text-sm font-semibold mt-3">Scannez pour créer votre carte</p>
                    <p class="text-xs text-slate-500 mt-1">Aucune app à télécharger.</p>
                  </div>
                  <div class="rounded-[1.2rem] bg-white/12 backdrop-blur-md border border-white/15 p-5 text-white">
                    <p class="text-[11px] uppercase tracking-[0.24em] text-white/70">Récompense</p>
                    <p id="poster-signature-reward" class="font-display text-[1.9rem] leading-tight font-bold mt-2.5">Récompense fidélité</p>
                    <div class="grid grid-cols-2 gap-3 mt-4">
                      <div class="rounded-xl bg-white/10 p-3">
                        <p class="text-[10px] uppercase tracking-[0.2em] text-white/70">Ajout</p>
                        <p class="text-sm font-semibold mt-1">10 secondes</p>
                      </div>
                      <div class="rounded-xl bg-white/10 p-3">
                        <p class="text-[10px] uppercase tracking-[0.2em] text-white/70">Compatibilité</p>
                        <p class="text-sm font-semibold mt-1">iPhone & Android</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .poster-sheet {
    width: min(100%, 860px);
    aspect-ratio: 210 / 297;
    border-radius: 1.5rem;
  }

  .poster-safe-zone {
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    padding: 1.2cm;
  }

  @page {
    size: A4 portrait;
    margin: 0;
  }

  @media print {
    html, body {
      width: 210mm;
      height: 297mm;
      margin: 0 !important;
      padding: 0 !important;
      background: #fff !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    nav,
    header,
    footer,
    .poster-ui,
    #poster-loading,
    #poster-error {
      display: none !important;
    }

    main,
    .min-h-screen,
    #poster-stage {
      margin: 0 !important;
      padding: 0 !important;
      min-height: auto !important;
      width: 210mm !important;
      height: 297mm !important;
      background: #fff !important;
    }

    #poster-sheet {
      width: 210mm !important;
      height: 297mm !important;
      aspect-ratio: auto !important;
      border: none !important;
      border-radius: 0 !important;
      box-shadow: none !important;
      margin: 0 !important;
      overflow: hidden !important;
      page-break-inside: avoid;
    }

    .poster-safe-zone {
      padding: 12mm !important;
    }
  }
</style>

<script define:vars={{ apiBase, carteId: id }}>
  const API = apiBase;
  const qrBase = 'https://api.qrserver.com/v1/create-qr-code/';
  const params = new URLSearchParams(window.location.search);
  const TEMPLATE_ALIASES = {
    minimal: 'essential',
    premium: 'signature',
    promo: 'signature',
    essential: 'essential',
    signature: 'signature',
  };
  let currentTemplate = normalizeTemplate(params.get('template'));

  function normalizeTemplate(value) {
    const key = String(value || '').trim().toLowerCase();
    return TEMPLATE_ALIASES[key] || 'essential';
  }

  function apiUrl(path) {
    return `${API}${path}`;
  }

  function qrUrl(cardId, size = 720) {
    return `${qrBase}?size=${size}x${size}&data=${encodeURIComponent(`${window.location.origin}/carte/${cardId}`)}&bgcolor=ffffff&color=111827&qzone=1`;
  }

  function rewardSummary(data) {
    const tiers = Array.isArray(data.carte.rewards_config) ? data.carte.rewards_config : [];
    if (tiers.length) {
      return tiers.map((item) => `${item.seuil} ${data.carte.type === 'points' ? 'pts' : 'tampons'} = ${item.recompense}`).join(' • ');
    }
    return data.carte.recompense_description || 'Récompense fidélité';
  }

  function setImage(id, src) {
    const img = document.getElementById(id);
    if (!img || !src) return;
    img.src = src;
    img.classList.remove('hidden');
  }

  function renderTemplate(name) {
    currentTemplate = normalizeTemplate(name);
    document.querySelectorAll('.poster-variant').forEach((node) => node.classList.add('hidden'));
    document.getElementById(`poster-${currentTemplate}`)?.classList.remove('hidden');
    document.querySelectorAll('.poster-template-btn').forEach((button) => {
      const active = button.dataset.template === currentTemplate;
      button.className = active
        ? 'poster-template-btn btn-primary text-sm px-4 py-2.5'
        : 'poster-template-btn btn-secondary text-sm px-4 py-2.5';
    });
    const nextUrl = new URL(window.location.href);
    nextUrl.searchParams.set('template', currentTemplate);
    window.history.replaceState({}, '', nextUrl);
  }

  async function downloadQr() {
    const response = await fetch(qrUrl(carteId, 1200));
    const blob = await response.blob();
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `fidelopass-qr-${carteId}.png`;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

  async function loadPoster() {
    try {
      const response = await fetch(apiUrl(`/api/cartes/${carteId}/public`));
      if (!response.ok) throw new Error();
      const { data } = await response.json();

      const commerceName = data.commerce.nom;
      const message = data.carte.welcome_message || `Bienvenue chez ${commerceName}, créez votre carte fidélité en 10 secondes.`;
      const reward = rewardSummary(data);
      const qr = qrUrl(carteId);
      const logo = data.carte.logo_url ?? data.commerce.logo_url ?? '';
      const typeLabel = data.carte.type === 'points' ? 'Carte à points' : 'Carte à tampons';
      const accent = data.carte.couleur_accent ?? '#6366f1';
      const fond = data.carte.couleur_fond ?? '#0f172a';
      const fond2 = data.carte.couleur_fond_2 ?? accent;

      document.getElementById('poster-essential-commerce').textContent = commerceName;
      document.getElementById('poster-essential-title').textContent = `Scannez pour rejoindre ${commerceName}`;
      document.getElementById('poster-essential-subtitle').textContent = message;
      document.getElementById('poster-essential-reward').textContent = reward;
      document.getElementById('poster-essential-badge').textContent = typeLabel;
      document.getElementById('poster-essential-badge').style.background = `${accent}1f`;
      document.getElementById('poster-essential-badge').style.color = accent;
      document.getElementById('poster-essential-program').style.background = `linear-gradient(135deg, ${fond}, ${fond2})`;

      document.getElementById('poster-signature-commerce').textContent = commerceName;
      document.getElementById('poster-signature-copy').textContent = message;
      document.getElementById('poster-signature-reward').textContent = reward;
      document.getElementById('poster-signature-banner').style.background = data.carte.strip_url
        ? `linear-gradient(rgba(15,23,42,0.3), rgba(15,23,42,0.45)), url("${data.carte.strip_url}") center/cover`
        : `linear-gradient(135deg, ${fond}, ${fond2})`;

      ['poster-essential-qr', 'poster-signature-qr'].forEach((elementId) => {
        document.getElementById(elementId).src = qr;
      });

      setImage('poster-essential-logo', logo);
      setImage('poster-signature-logo', logo);

      document.getElementById('poster-loading').classList.add('hidden');
      document.getElementById('poster-stage').classList.remove('hidden');
      renderTemplate(currentTemplate);
    } catch {
      document.getElementById('poster-loading').classList.add('hidden');
      document.getElementById('poster-error').classList.remove('hidden');
    }
  }

  document.getElementById('print-poster').addEventListener('click', () => window.print());
  document.getElementById('download-qr').addEventListener('click', downloadQr);
  document.querySelectorAll('.poster-template-btn').forEach((button) => {
    button.addEventListener('click', () => renderTemplate(button.dataset.template || 'essential'));
  });

  loadPoster();
</script>
