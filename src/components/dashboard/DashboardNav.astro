---
import { DASHBOARD_NAV_ITEMS } from '../../lib/dashboard-nav';

interface Props {
  activeNav?: string;
}
const { activeNav = '' } = Astro.props;
const navItems = DASHBOARD_NAV_ITEMS;
---

<aside class="hidden lg:flex w-[17.5rem] shrink-0 h-full min-h-0 flex-col border-r border-slate-200/60 bg-white/88 backdrop-blur-2xl shadow-[0_18px_42px_-30px_rgba(15,23,42,0.28)]">
  <div class="px-5 py-5 border-b border-slate-200/65">
    <a href="/dashboard" class="flex flex-col gap-2">
      <img src="/logo-premium.png" alt="Fidelopass" class="h-14 w-48 object-cover object-center" />
      <span class="text-[0.68rem] font-semibold tracking-[0.23em] uppercase text-sky-700/75">Espace commerçant</span>
    </a>
    <div class="mt-4 rounded-2xl border border-slate-200/60 bg-white/90 px-3 py-2.5 shadow-[0_8px_20px_-20px_rgba(37,99,235,0.45)]">
      <p class="text-[0.62rem] font-semibold uppercase tracking-[0.2em] text-slate-500">Plan actif</p>
      <span
        id="dashboard-plan-badge"
        class="mt-1 inline-flex items-center rounded-full border border-slate-200 bg-white px-2.5 py-1 text-[0.67rem] font-semibold tracking-wide text-slate-500"
      >
        Chargement...
      </span>
    </div>
    <div class="mt-3 rounded-2xl border border-slate-200/60 bg-white px-3 py-2.5 shadow-[0_10px_24px_-20px_rgba(15,23,42,0.25)]">
      <p class="text-[0.62rem] font-semibold uppercase tracking-[0.2em] text-slate-500">Point de vente</p>
      <select id="dashboard-point-vente-select" class="mt-1.5 w-full rounded-xl border border-slate-200 bg-white px-2.5 py-2 text-xs font-medium text-slate-700 focus:border-sky-300 focus:outline-none">
        <option>Chargement...</option>
      </select>
      <p id="dashboard-point-vente-usage" class="mt-1.5 text-[0.68rem] text-slate-500"></p>
    </div>
  </div>

  <nav class="flex-1 min-h-0 overflow-y-auto px-3 py-4 flex flex-col gap-1.5">
    {navItems.map(({ href, id, label, paths }) => (
      <a
        href={href}
        class={`group flex items-center gap-3 rounded-2xl px-3.5 py-2.5 text-sm transition-all duration-300
          ${activeNav === id
            ? 'bg-gradient-to-r from-blue-600 via-indigo-500 to-violet-500 text-white shadow-[0_18px_34px_-24px_rgba(37,99,235,0.9)] ring-1 ring-white/35'
            : 'text-slate-600 hover:bg-white hover:text-slate-900 hover:shadow-[0_12px_28px_-24px_rgba(15,23,42,0.4)]'
          }`}
      >
        <span class={`flex h-10 w-10 items-center justify-center rounded-2xl border transition-all
          ${activeNav === id
            ? 'border-white/20 bg-white/15 shadow-inner'
            : 'border-slate-200 bg-slate-50 text-sky-600 group-hover:border-sky-200 group-hover:bg-sky-50'
          }`}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-[1.125rem] w-[1.125rem]">
            {paths.map((path) => <path d={path}></path>)}
          </svg>
        </span>
        <span class={activeNav === id ? 'font-semibold' : 'font-medium'}>{label}</span>
      </a>
    ))}
  </nav>

  <div class="px-4 pb-4 space-y-2 border-t border-slate-200/65 pt-4">
    <a href="/app" class="flex items-center justify-between rounded-2xl border border-sky-200 bg-gradient-to-r from-sky-50 to-blue-50 px-4 py-3 text-sm font-semibold text-sky-800 transition hover:border-sky-300 hover:shadow-[0_16px_30px_-25px_rgba(37,99,235,0.5)]">
      <span>Ouvrir le scanner</span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
        <path d="M7 3H5a2 2 0 0 0-2 2v2"></path>
        <path d="M17 3h2a2 2 0 0 1 2 2v2"></path>
        <path d="M21 17v2a2 2 0 0 1-2 2h-2"></path>
        <path d="M3 17v2a2 2 0 0 0 2 2h2"></path>
        <path d="M8 12h8"></path>
      </svg>
    </a>
    <button id="logout-btn" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-left text-sm font-medium text-slate-600 transition hover:border-red-200 hover:bg-red-50 hover:text-red-600 hover:shadow-[0_14px_26px_-24px_rgba(220,38,38,0.6)]">
      Se déconnecter
    </button>
  </div>
</aside>

<header class="lg:hidden fixed top-0 inset-x-0 z-40 border-b border-slate-200/70 bg-white/94 backdrop-blur-2xl px-4 py-2.5 flex items-center justify-between shadow-[0_12px_28px_-26px_rgba(15,23,42,0.5)]">
  <a href="/dashboard" class="flex items-center gap-3 min-w-0">
    <img src="/logo-premium.png" alt="Fidelopass" class="h-10 w-36 object-cover object-center" />
  </a>
  <div class="flex items-center gap-2">
    <span
      id="dashboard-plan-badge-mobile"
      class="inline-flex items-center rounded-full border border-slate-200 bg-white px-2.5 py-1 text-[0.65rem] font-semibold tracking-wide text-slate-500"
    >
      ...
    </span>
    <a href="/app" class="rounded-full border border-sky-200 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-700 shadow-[0_8px_16px_-14px_rgba(37,99,235,0.45)]">
      Scanner
    </a>
  </div>
</header>

<nav class="lg:hidden fixed bottom-0 inset-x-0 z-40 border-t border-slate-200/70 bg-white/94 backdrop-blur-2xl px-2 pt-2 pb-[calc(env(safe-area-inset-bottom)+0.55rem)] shadow-[0_-12px_26px_-22px_rgba(15,23,42,0.5)]">
  <div class="grid grid-cols-5 gap-1">
    {navItems.filter((item) => item.id !== 'points-vente').slice(0, 5).map(({ href, id, label, paths }) => (
      <a
        href={href}
        class={`min-w-0 flex flex-col items-center justify-center gap-1 rounded-2xl px-2 py-2 text-[0.68rem] transition-all
          ${activeNav === id
            ? 'bg-gradient-to-r from-blue-600 to-indigo-500 text-white font-semibold shadow-[0_10px_18px_-16px_rgba(37,99,235,0.7)]'
            : 'text-slate-500 hover:text-slate-800'
          }`}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 leading-none">
          {paths.map((path) => <path d={path}></path>)}
        </svg>
        <span class="truncate max-w-full">{label}</span>
      </a>
    ))}
  </div>
</nav>

<script>
  import { ACTIVE_POINT_VENTE_STORAGE_KEY, authFetch } from '../../lib/api';
  import { planBadgeClass, planLabel } from '../../lib/dashboard-config';
  import { clearSessionCookie, setSessionCookie } from '../../lib/session-cookie';
  import { withTimeout } from '../../lib/utils/with-timeout';
  import { createClient } from '@supabase/supabase-js';

  const API_URL = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001';
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );
  const SESSION_PROBE_TIMEOUT_MS = Number(import.meta.env.PUBLIC_AUTH_SESSION_PROBE_TIMEOUT_MS ?? 900);
  const API_FETCH_TIMEOUT_MS = Number(import.meta.env.PUBLIC_API_FETCH_TIMEOUT_MS ?? 3500);

  const desktopPlanBadge = document.getElementById('dashboard-plan-badge');
  const mobilePlanBadge = document.getElementById('dashboard-plan-badge-mobile');
  const pointVenteSelect = document.getElementById('dashboard-point-vente-select') as HTMLSelectElement | null;
  const pointVenteUsage = document.getElementById('dashboard-point-vente-usage');

  function emitPointVenteReady(pointVenteId: string | null) {
    window.dispatchEvent(new CustomEvent('fidelopass:point-vente-ready', {
      detail: { pointVenteId: pointVenteId ?? null },
    }));
  }

  function setPlanBadge(planRaw: unknown) {
    const label = planLabel(planRaw);
    const classes = planBadgeClass(planRaw);

    for (const element of [desktopPlanBadge, mobilePlanBadge]) {
      if (!element) continue;
      element.textContent = label;
      element.className = classes;
    }
  }

  function getStoredPointVenteId() {
    try {
      return window.localStorage.getItem(ACTIVE_POINT_VENTE_STORAGE_KEY);
    } catch {
      return null;
    }
  }

  function setStoredPointVenteId(pointVenteId: string | null) {
    try {
      if (pointVenteId) window.localStorage.setItem(ACTIVE_POINT_VENTE_STORAGE_KEY, pointVenteId);
      else window.localStorage.removeItem(ACTIVE_POINT_VENTE_STORAGE_KEY);
    } catch {
      // localStorage best-effort
    }
  }

  async function authFetchWithTimeout(path: string, init?: RequestInit): Promise<Response> {
    return withTimeout(authFetch(path, init), API_FETCH_TIMEOUT_MS);
  }

  async function loadPointVenteSelector() {
    if (!pointVenteSelect) return;

    let res = await authFetchWithTimeout('/api/commerces/points-vente');
    if (res.status === 403) {
      setStoredPointVenteId(null);
      res = await authFetchWithTimeout('/api/commerces/points-vente');
    }
    if (!res.ok) {
      pointVenteSelect.innerHTML = '<option value="">Point indisponible</option>';
      return;
    }

    const payload = await res.json().catch(() => null);
    const points = Array.isArray(payload?.data) ? payload.data : [];
    const usage = payload?.usage;
    const selectedFromApi = payload?.selected_point_vente_id as string | null;
    const storedPointId = getStoredPointVenteId();
    const selectedId = points.some((point: { id: string }) => point.id === storedPointId)
      ? storedPointId
      : selectedFromApi;

    if (points.length === 0) {
      pointVenteSelect.innerHTML = '<option value="">Ajoutez un point de vente</option>';
      if (pointVenteUsage) pointVenteUsage.textContent = '0 point de vente actif';
      setStoredPointVenteId(null);
      emitPointVenteReady(null);
      return;
    }

    pointVenteSelect.innerHTML = points.map((point: { id: string; nom: string }) => (
      `<option value="${point.id}">${point.nom}</option>`
    )).join('');

    if (selectedId && points.some((point: { id: string }) => point.id === selectedId)) {
      pointVenteSelect.value = selectedId;
      setStoredPointVenteId(selectedId);
      emitPointVenteReady(selectedId);
    } else {
      const fallbackPointId = pointVenteSelect.value || points[0]?.id || null;
      setStoredPointVenteId(fallbackPointId);
      emitPointVenteReady(fallbackPointId);
    }

    if (pointVenteUsage && usage) {
      pointVenteUsage.textContent = `${usage.current}/${usage.max} points de vente utilisés`;
    }
  }

  async function loadPlanBadge() {
    try {
      const res = await authFetchWithTimeout('/api/dashboard/plan');
      const payload = await res.json().catch(() => null);
      if (!res.ok) throw new Error(payload?.error ?? 'Plan indisponible');
      setPlanBadge(payload?.data?.plan);
    } catch (error) {
      console.error('[dashboard plan badge]', error);
      setPlanBadge('starter');
    }
  }

  pointVenteSelect?.addEventListener('change', (event) => {
    const nextPointVenteId = (event.target as HTMLSelectElement).value || null;
    setStoredPointVenteId(nextPointVenteId);
    window.location.reload();
  });

  await loadPointVenteSelector();
  await loadPlanBadge();

  const sessionResult = await withTimeout(supabase.auth.getSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null) as {
    data?: { session?: { access_token?: string } | null };
  } | null;
  const session = sessionResult?.data?.session ?? null;
  if (session?.access_token) {
    setSessionCookie(session.access_token);
  }

  function clearBrowserAuthState() {
    clearSessionCookie();
    for (const storage of [window.localStorage, window.sessionStorage]) {
      try {
        Object.keys(storage).forEach((key) => {
          if (
            key.startsWith('sb-')
            || key.includes('supabase')
            || key.startsWith('fidelopass.pending-registration')
            || key === ACTIVE_POINT_VENTE_STORAGE_KEY
          ) {
            storage.removeItem(key);
          }
        });
      } catch {
        // best effort
      }
    }
  }

  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    clearBrowserAuthState();
    await fetch(`${API_URL}/api/auth/logout`, { method: 'POST', credentials: 'include' }).catch(() => undefined);
    await supabase.auth.signOut({ scope: 'global' }).catch(() => undefined);
    clearSessionCookie();
    window.location.replace('/login?logout=1');
  });
</script>
