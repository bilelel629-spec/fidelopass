---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';

const howItWorks = [
  {
    step: '1',
    title: 'Le client scanne votre QR code',
    description: 'Depuis votre affiche en magasin, un lien privé ou votre site, il ouvre sa carte en quelques secondes.',
  },
  {
    step: '2',
    title: 'Il ajoute sa carte à Apple ou Google Wallet',
    description: 'Aucune application à télécharger. La carte reste accessible directement dans le téléphone.',
  },
  {
    step: '3',
    title: 'Vous scannez et fidélisez en boutique',
    description: 'Chaque passage devient une action simple : ajout de tampon, de points, récompense et message client.',
  },
];

const benefits = [
  'Cartes dématérialisées totalement personnalisées',
  'Programmes à tampons ou à points selon votre activité',
  'Expérience plus ludique et plus mémorable pour vos clients',
  'Notifications Wallet et rappels contextuels',
  'Templates prêts à imprimer avec QR code pour le magasin',
  'Signaux pilotables : scans, cartes actives, retours clients',
];

const faqs = [
  {
    question: 'Mes clients doivent-ils installer une application ?',
    answer: 'Non. Ils ajoutent simplement leur carte à Apple Wallet ou Google Wallet depuis leur téléphone.',
  },
  {
    question: 'Combien de temps faut-il pour lancer la première carte ?',
    answer: 'Le parcours est pensé pour une mise en place rapide. Une première version crédible peut être publiée en quelques minutes.',
  },
  {
    question: 'Est-ce adapté à un commerce de proximité ?',
    answer: 'Oui. Fidelopass est pensé pour les commerces qui veulent un QR code en boutique, un scanner mobile simple et une carte moderne sans complexité technique.',
  },
  {
    question: 'Puis-je personnaliser complètement le rendu ?',
    answer: 'Oui. Logo, bannière, couleurs, templates métier, récompenses et structure du programme sont personnalisables.',
  },
];
---

<BaseLayout
  title="Fidelopass — Cartes de fidélité Wallet premium pour commerces"
  description="Fidelopass aide les commerces à lancer une carte de fidélité Apple Wallet et Google Wallet sans application client, avec QR code boutique, scanner et design premium."
>
  <div class="min-h-screen bg-[#f6f8fb] text-slate-900">
    <div class="absolute inset-x-0 top-0 h-[38rem] pointer-events-none bg-[radial-gradient(circle_at_top,rgba(56,189,248,0.18),rgba(246,248,251,0)_52%),linear-gradient(180deg,#ffffff_0%,#f6f8fb_100%)]"></div>

    <div class="relative">
      <PublicNav currentPath="/" />

      <section class="max-w-7xl mx-auto px-4 sm:px-6 pt-8 pb-18 lg:pb-24">
        <div class="grid lg:grid-cols-[1fr_0.95fr] gap-12 items-center">
          <div>
            <div class="inline-flex items-center rounded-full border border-sky-200 bg-white px-4 py-1.5 text-sm font-medium text-sky-700 shadow-sm">
              Fidélité premium sans application client
            </div>
            <h1 class="mt-6 font-display text-5xl sm:text-6xl lg:text-7xl font-bold leading-[0.95] text-slate-950 max-w-4xl">
              Faites revenir vos clients
              <span class="block text-sky-500">avec une carte de fidélité moderne</span>
            </h1>
            <p class="mt-6 max-w-2xl text-lg sm:text-xl leading-relaxed text-slate-600">
              Fidelopass permet aux commerces de lancer une carte Apple Wallet et Google Wallet élégante, simple à scanner en boutique et suffisamment professionnelle pour inspirer confiance dès le premier regard.
            </p>

            <div class="mt-8 flex flex-col sm:flex-row gap-4">
              <a href="/register" class="inline-flex items-center justify-center rounded-xl bg-slate-950 px-8 py-3.5 text-base font-medium text-white shadow-[0_18px_45px_-18px_rgba(15,23,42,0.55)] transition-colors hover:bg-slate-800">
                Essai gratuit 14 jours
              </a>
              <a href="/how-it-works" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-8 py-3.5 text-base font-medium text-slate-700 transition-colors hover:border-slate-300 hover:text-slate-950">
                Comment ça fonctionne
              </a>
            </div>

            <div class="mt-8 flex flex-wrap gap-3 text-sm">
              <span class="rounded-full border border-slate-200 bg-white px-4 py-2 text-slate-600 shadow-sm">Essai gratuit de 14 jours</span>
              <span class="rounded-full border border-slate-200 bg-white px-4 py-2 text-slate-600 shadow-sm">Aucune carte bancaire requise</span>
              <span class="rounded-full border border-slate-200 bg-white px-4 py-2 text-slate-600 shadow-sm">Aucune application pour vos clients</span>
              <span class="rounded-full border border-slate-200 bg-white px-4 py-2 text-slate-600 shadow-sm">Installation en 5 minutes</span>
            </div>
          </div>

          <div class="relative">
            <div class="absolute -inset-6 rounded-[2rem] bg-[radial-gradient(circle,rgba(56,189,248,0.22),rgba(255,255,255,0)_62%)] blur-2xl"></div>
            <div class="relative rounded-[2rem] border border-white bg-white p-5 shadow-[0_30px_80px_-30px_rgba(15,23,42,0.28)]">
              <div class="grid gap-4">
                <div class="rounded-[1.5rem] border border-slate-200 bg-[linear-gradient(145deg,#0f172a,#1d4ed8_55%,#38bdf8)] p-5 text-white">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                      <div class="h-11 w-11 rounded-2xl bg-white/15 backdrop-blur-sm flex items-center justify-center text-lg">☕</div>
                      <div>
                        <p class="text-sm font-semibold">Maison Aure</p>
                        <p class="text-xs text-white/75">Carte de fidélité café</p>
                      </div>
                    </div>
                    <div class="rounded-full bg-white/12 px-3 py-1 text-xs font-medium text-white/90">4 / 8 tampons</div>
                  </div>

                  <div class="mt-5 rounded-[1.25rem] bg-black/15 p-4">
                    <div class="grid grid-cols-4 gap-3">
                      {Array.from({ length: 8 }).map((_, index) => (
                        <div class={`aspect-square rounded-full border-2 flex items-center justify-center text-sm ${index < 4 ? 'border-amber-400 bg-amber-400 text-white' : 'border-white/25 text-white/40'}`}>
                          {index < 4 ? '✓' : '•'}
                        </div>
                      ))}
                    </div>
                  </div>

                  <div class="mt-5 rounded-[1rem] bg-white px-4 py-3 text-center">
                    <div class="h-14 rounded-lg bg-[repeating-linear-gradient(90deg,#111827_0,#111827_3px,transparent_3px,transparent_7px)]"></div>
                    <p class="mt-2 text-xs text-slate-400">QR et identifiant client</p>
                  </div>
                </div>

                <div class="grid sm:grid-cols-2 gap-4">
                  <div class="rounded-[1.5rem] border border-slate-200 bg-[#f8fbff] p-5">
                    <p class="text-xs uppercase tracking-[0.26em] text-slate-400">Vue commerçant</p>
                    <p class="mt-3 text-lg font-semibold text-slate-950">Simple à piloter</p>
                    <div class="mt-4 space-y-3">
                      <div class="rounded-2xl bg-white p-4 shadow-sm">
                        <p class="text-xs text-slate-400">Cartes actives</p>
                        <p class="mt-1 text-2xl font-semibold text-slate-950">248</p>
                      </div>
                      <div class="rounded-2xl bg-white p-4 shadow-sm">
                        <p class="text-xs text-slate-400">Scans cette semaine</p>
                        <p class="mt-1 text-2xl font-semibold text-slate-950">67</p>
                      </div>
                    </div>
                  </div>

                  <div class="rounded-[1.5rem] border border-slate-200 bg-[#f9f8ff] p-5">
                    <p class="text-xs uppercase tracking-[0.26em] text-slate-400">Pourquoi ça rassure</p>
                    <div class="mt-4 space-y-3">
                      <div class="rounded-2xl border border-slate-200 bg-white p-4">
                        <p class="font-medium text-slate-950">Sans application client</p>
                        <p class="mt-2 text-sm leading-relaxed text-slate-600">Le client ajoute sa carte directement dans le Wallet de son téléphone.</p>
                      </div>
                      <div class="rounded-2xl border border-slate-200 bg-white p-4">
                        <p class="font-medium text-slate-950">Prêt pour le comptoir</p>
                        <p class="mt-2 text-sm leading-relaxed text-slate-600">QR boutique, scanner mobile et affiches imprimables dès la mise en ligne.</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 pb-18">
        <div class="rounded-[2rem] border border-slate-200 bg-white px-6 py-8 sm:px-8 shadow-[0_18px_50px_-35px_rgba(15,23,42,0.2)]">
          <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-5 mb-8">
            <div>
              <p class="text-sm font-semibold tracking-[0.22em] text-sky-600 uppercase">Comment ça fonctionne</p>
              <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold text-slate-950">Un parcours simple pour le commerce comme pour le client.</h2>
            </div>
            <p class="max-w-2xl text-base leading-relaxed text-slate-600">
              Le but est de rendre la fidélité aussi naturelle qu’une carte papier, mais avec la lisibilité, la personnalisation et les données d’un vrai produit digital.
            </p>
          </div>

          <div class="grid lg:grid-cols-3 gap-5">
            {howItWorks.map((item) => (
              <article class="rounded-[1.5rem] border border-slate-200 bg-[#fbfcfe] p-6">
                <div class="h-11 w-11 rounded-2xl bg-slate-950 text-white flex items-center justify-center font-semibold">{item.step}</div>
                <h3 class="mt-5 font-display text-2xl font-bold text-slate-950 leading-tight">{item.title}</h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-600">{item.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 pb-18">
        <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-8 items-start">
          <div class="rounded-[2rem] border border-slate-200 bg-white p-7 shadow-[0_18px_50px_-35px_rgba(15,23,42,0.2)]">
            <p class="text-sm font-semibold tracking-[0.22em] text-sky-600 uppercase">Pourquoi Fidelopass</p>
            <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold text-slate-950">Une fidélité plus claire, plus rentable et plus élégante.</h2>
            <p class="mt-4 text-base leading-relaxed text-slate-600">
              Fidelopass ne vend pas seulement une carte. Il vend un parcours de fidélité moderne, prêt à être affiché en magasin et suffisamment simple pour être utilisé tous les jours.
            </p>

            <div class="mt-6 rounded-[1.5rem] bg-[#f8fbff] p-5">
              <p class="text-sm font-medium text-slate-950">Moyenne de +27% de rétention clients</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">
                Le bon message au bon moment, une carte visible dans le téléphone et un passage boutique simplifié augmentent les chances de retour et la mémorisation du programme.
              </p>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            {benefits.map((benefit) => (
              <div class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-[0_18px_50px_-35px_rgba(15,23,42,0.18)]">
                <div class="flex items-start gap-3">
                  <span class="mt-1 h-2.5 w-2.5 rounded-full bg-sky-400"></span>
                  <p class="text-sm leading-relaxed text-slate-700">{benefit}</p>
                </div>
              </div>
            ))}
            <div class="rounded-[1.5rem] border border-slate-200 bg-[linear-gradient(135deg,#0f172a,#1e3a8a)] p-5 text-white shadow-[0_20px_60px_-35px_rgba(15,23,42,0.35)] sm:col-span-2">
              <p class="text-sm uppercase tracking-[0.22em] text-sky-200">En plus</p>
              <p class="mt-3 text-lg font-semibold">Pas d’application nécessaire pour vos clients, mais une expérience beaucoup plus premium qu’une carte papier.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 pb-18">
        <div class="rounded-[2rem] border border-slate-200 bg-white px-6 py-8 sm:px-8 shadow-[0_18px_50px_-35px_rgba(15,23,42,0.2)]">
          <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-5 mb-8">
            <div>
              <p class="text-sm font-semibold tracking-[0.22em] text-sky-600 uppercase">FAQ</p>
              <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold text-slate-950">Les questions qu’un commerce se pose avant de lancer.</h2>
            </div>
          </div>

          <div class="grid lg:grid-cols-2 gap-4">
            {faqs.map((faq) => (
              <article class="rounded-[1.5rem] border border-slate-200 bg-[#fbfcfe] p-6">
                <h3 class="text-lg font-semibold text-slate-950">{faq.question}</h3>
                <p class="mt-3 text-sm leading-relaxed text-slate-600">{faq.answer}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="max-w-7xl mx-auto px-4 sm:px-6 pb-20">
        <div class="rounded-[2rem] border border-slate-200 bg-[linear-gradient(135deg,#ffffff_0%,#eff6ff_55%,#e0f2fe_100%)] px-6 py-10 sm:px-8 shadow-[0_20px_60px_-35px_rgba(15,23,42,0.22)]">
          <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-center">
            <div>
              <p class="text-sm font-semibold tracking-[0.22em] text-sky-600 uppercase">Prêt à faire revenir vos clients ?</p>
              <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold text-slate-950">Essai gratuit de 14 jours. Aucune carte de crédit requise.</h2>
              <p class="mt-4 max-w-2xl text-base sm:text-lg leading-relaxed text-slate-600">
                Aucune application pour vos clients. Installation en 5 minutes. Une première carte, un QR en boutique et un vrai parcours Wallet pour commencer à fidéliser rapidement.
              </p>
            </div>
            <div class="flex flex-col sm:flex-row lg:flex-col gap-3">
              <a href="/register" class="inline-flex items-center justify-center rounded-xl bg-slate-950 px-8 py-3.5 text-base font-medium text-white shadow-[0_18px_45px_-18px_rgba(15,23,42,0.45)] transition-colors hover:bg-slate-800">
                Commencer l’essai gratuit
              </a>
              <a href="/pricing" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-8 py-3.5 text-base font-medium text-slate-700 transition-colors hover:border-slate-300 hover:text-slate-950">
                Voir la tarification
              </a>
            </div>
          </div>
        </div>
      </section>

      <PublicFooter />
    </div>
  </div>
</BaseLayout>
