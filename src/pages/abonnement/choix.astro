---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  theme="light"
  title="Choisir un abonnement — Fidelopass"
  description="Choisissez votre plan Fidelopass pour activer votre espace commerçant."
>
  <section class="min-h-screen bg-[linear-gradient(180deg,#ffffff_0%,#f5f9ff_62%,#ffffff_100%)] px-4 py-10 sm:py-14 relative overflow-hidden">
    <div class="pointer-events-none absolute -top-20 right-[-10rem] h-[28rem] w-[28rem] rounded-full bg-cyan-200/35 blur-3xl"></div>
    <div class="pointer-events-none absolute bottom-[-8rem] left-[-8rem] h-[24rem] w-[24rem] rounded-full bg-blue-100/80 blur-3xl"></div>

    <div class="max-w-5xl mx-auto">
      <a href="/" class="inline-flex items-center mb-6">
        <img src="/logo-premium-cropped.png" alt="Fidelopass" class="h-14 w-auto object-contain" />
      </a>

      <div class="max-w-2xl">
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.26em] text-sky-700/75">Activation abonnement</p>
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-slate-900 leading-tight mt-3">
          Choisissez votre plan pour activer l’accès à l’outil.
        </h1>
        <p class="text-slate-500 text-base mt-4 leading-relaxed">
          Vous pourrez ajouter l’option <strong>Accompagnement Setup (20€)</strong> à l’étape suivante avant Stripe.
        </p>
      </div>

      <div class="inline-flex items-center gap-1 mt-8 rounded-2xl border border-slate-200 bg-white p-1.5 shadow-sm">
        <button id="toggle-monthly" type="button" class="px-5 py-2 rounded-xl text-sm font-medium transition-all text-slate-500">
          Mensuel
        </button>
        <button id="toggle-annual" type="button" class="px-5 py-2 rounded-xl text-sm font-semibold transition-all bg-white text-slate-900 shadow-sm">
          Annuel
          <span class="ml-1.5 rounded-full bg-emerald-100 text-emerald-700 text-xs px-2 py-0.5 font-semibold">-29%</span>
        </button>
      </div>

      <div class="mt-4 rounded-xl border border-slate-200 bg-white/90 px-4 py-3 text-sm text-slate-600">
        <p><strong>Mensuel :</strong> résiliable à tout moment.</p>
        <p class="mt-1"><strong>Annuel :</strong> engagement de 12 mois (paiement mensuel ou en une fois).</p>
      </div>

      <div id="annual-payment-mode" class="mt-4 rounded-2xl border border-indigo-100 bg-indigo-50/70 p-3">
        <p class="text-xs uppercase tracking-[0.16em] text-indigo-700/80 font-semibold px-1 mb-2">Paiement annuel</p>
        <div class="grid sm:grid-cols-2 gap-2">
          <button id="annual-installments-btn" type="button" class="rounded-xl border border-indigo-300 bg-white px-4 py-2.5 text-sm font-semibold text-indigo-700 transition-colors">
            Mensuel sur 12 mois
          </button>
          <button id="annual-once-btn" type="button" class="rounded-xl border border-indigo-200 bg-indigo-50 px-4 py-2.5 text-sm font-medium text-indigo-700 transition-colors">
            En une fois
          </button>
        </div>
      </div>

      <div id="choice-error" class="hidden mt-5 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600"></div>
      <div id="choice-warning" class="hidden mt-3 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700"></div>

      <div class="grid lg:grid-cols-2 gap-6 mt-8">
        <article class="rounded-[2rem] border border-slate-200 bg-white shadow-[0_20px_50px_rgba(15,23,42,0.08)] p-8">
          <p class="text-xs font-bold uppercase tracking-widest text-slate-400">Starter</p>
          <div class="flex items-end gap-1 mt-3">
            <span
              class="font-display font-bold leading-none text-slate-900 text-4xl plan-price"
              data-monthly="35"
              data-annual-monthly="25"
              data-annual-once="300"
            >35€</span>
            <span
              class="text-sm mb-1 text-slate-400 plan-price-suffix"
              data-monthly="/mois"
              data-annual-monthly="/mois"
              data-annual-once="une fois"
            >/mois</span>
          </div>
          <p
            class="text-xs text-slate-400 mt-2 plan-price-label"
            data-monthly="35€/mois sans engagement"
            data-annual-monthly="25€/mois · engagement 12 mois"
            data-annual-once="300€ payés aujourd’hui · 12 mois d’accès"
          >
            35€/mois sans engagement
          </p>
          <ul class="space-y-2.5 mt-6 text-sm text-slate-600">
            <li>• Jusqu’à 500 cartes actives</li>
            <li>• 1 lieu / commerce</li>
            <li>• Notifications push incluses</li>
            <li>• Carte points, tampons et VIP</li>
            <li>• Géolocalisation Wallet</li>
          </ul>
          <button
            type="button"
            class="plan-select-btn mt-7 w-full rounded-xl bg-slate-950 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-900 transition-colors"
            data-plan="starter"
            data-price-monthly="price_1TMlVz60FYcAjVxl8VNyc7o6"
            data-price-annual-subscription="price_1TMlVy60FYcAjVxlsTpI09J1"
            data-price-annual-once="price_1TMlVz60FYcAjVxlSG7wb8dA"
          >
            Continuer avec Starter
          </button>
        </article>

        <article class="rounded-[2rem] border border-indigo-400 bg-[linear-gradient(155deg,#1e1b4b_0%,#312e81_62%,#0284c7_100%)] shadow-[0_30px_80px_rgba(49,46,129,0.24)] p-8 text-white">
          <div class="inline-flex rounded-full bg-amber-400 px-3 py-1 text-[0.7rem] font-bold uppercase tracking-[0.16em] text-amber-900">
            Le plus choisi
          </div>
          <p class="text-xs font-bold uppercase tracking-widest text-indigo-200 mt-4">Pro</p>
          <div class="flex items-end gap-1 mt-3">
            <span
              class="font-display font-bold leading-none text-4xl plan-price"
              data-monthly="65"
              data-annual-monthly="49"
              data-annual-once="588"
            >65€</span>
            <span
              class="text-sm mb-1 text-indigo-200 plan-price-suffix"
              data-monthly="/mois"
              data-annual-monthly="/mois"
              data-annual-once="une fois"
            >/mois</span>
          </div>
          <p
            class="text-xs text-indigo-200 mt-2 plan-price-label"
            data-monthly="65€/mois sans engagement"
            data-annual-monthly="49€/mois · engagement 12 mois"
            data-annual-once="588€ payés aujourd’hui · 12 mois d’accès"
          >
            65€/mois sans engagement
          </p>
          <ul class="space-y-2.5 mt-6 text-sm text-indigo-100">
            <li>• Jusqu’à 2000 cartes actives</li>
            <li>• 3 lieux / commerces</li>
            <li>• Push auto avis Google (+1h)</li>
            <li>• Analytics avancés</li>
            <li>• Support prioritaire</li>
          </ul>
          <button
            type="button"
            class="plan-select-btn mt-7 w-full rounded-xl bg-white px-5 py-3 text-sm font-semibold text-indigo-700 hover:bg-indigo-50 transition-colors"
            data-plan="pro"
            data-price-monthly="price_1TMlVx60FYcAjVxlm2p12mJm"
            data-price-annual-subscription="price_1TMlVw60FYcAjVxlVWNs7aJd"
            data-price-annual-once="price_1TMlVx60FYcAjVxlTlIYvWFd"
          >
            Continuer avec Pro
          </button>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { withTimeout } from '../../lib/utils/with-timeout';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const API = (import.meta.env.PUBLIC_API_URL || 'https://api.fidelopass.com').replace(/\/$/, '');
  const STORAGE_KEY = 'fidelopass.checkout.selection';
  const SESSION_PROBE_TIMEOUT_MS = Number(import.meta.env.PUBLIC_AUTH_SESSION_PROBE_TIMEOUT_MS ?? 900);
  const BILLING_CHECK_TIMEOUT_MS = Number(import.meta.env.PUBLIC_BILLING_CHECK_TIMEOUT_MS ?? 2200);
  const monthlyBtn = document.getElementById('toggle-monthly') as HTMLButtonElement;
  const annualBtn = document.getElementById('toggle-annual') as HTMLButtonElement;
  const annualPaymentMode = document.getElementById('annual-payment-mode') as HTMLDivElement;
  const annualInstallmentsBtn = document.getElementById('annual-installments-btn') as HTMLButtonElement;
  const annualOnceBtn = document.getElementById('annual-once-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('choice-error') as HTMLDivElement;
  const warningEl = document.getElementById('choice-warning') as HTMLDivElement;

  type SessionLike = { access_token: string };
  type PriceSlot =
    | 'starter_mensuel'
    | 'starter_annuel_mensuel'
    | 'starter_annuel_once'
    | 'pro_mensuel'
    | 'pro_annuel_mensuel'
    | 'pro_annuel_once';
  let activeSession: SessionLike | null = null;
  let currentMode: 'monthly' | 'annual' = 'annual';
  let annualPaymentType: 'subscription' | 'payment' = 'subscription';
  let pricingLoaded = false;
  let pricingDegraded = false;

  function toggleWarning(message: string | null) {
    if (!message) {
      warningEl.classList.add('hidden');
      warningEl.textContent = '';
      return;
    }
    warningEl.textContent = message;
    warningEl.classList.remove('hidden');
  }

  function resolveButtonPriceAvailability(button: HTMLButtonElement) {
    if (currentMode === 'monthly') {
      return button.dataset.availabilityMonthly === '1';
    }
    if (annualPaymentType === 'payment') {
      return button.dataset.availabilityAnnualOnce === '1';
    }
    return button.dataset.availabilityAnnualSubscription === '1';
  }

  function refreshPlanButtonsState() {
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.plan-select-btn'));
    const unavailableCount = buttons.reduce((acc, button) => (
      acc + (resolveButtonPriceAvailability(button) ? 0 : 1)
    ), 0);

    buttons.forEach((button) => {
      const baseLabel = button.dataset.plan === 'pro' ? 'Continuer avec Pro' : 'Continuer avec Starter';
      const available = pricingLoaded && resolveButtonPriceAvailability(button);
      button.disabled = !available;
      button.classList.toggle('opacity-50', !available);
      button.classList.toggle('cursor-not-allowed', !available);
      button.textContent = available ? baseLabel : 'Tarif indisponible';
    });

    if (!pricingLoaded) {
      toggleWarning('Chargement des tarifs en cours...');
      return;
    }

    if (unavailableCount > 0 && !pricingDegraded) {
      toggleWarning('Certains tarifs sont temporairement indisponibles. Réessayez dans quelques instants.');
      return;
    }

    if (pricingDegraded) {
      toggleWarning('Mode dégradé: validation Stripe indisponible pour le moment.');
      return;
    }

    toggleWarning(null);
  }

  function setMode(mode: 'monthly' | 'annual') {
    currentMode = mode;
    const isAnnual = mode === 'annual';
    monthlyBtn.className = isAnnual
      ? 'px-5 py-2 rounded-xl text-sm font-medium transition-all text-slate-500'
      : 'px-5 py-2 rounded-xl text-sm font-semibold transition-all bg-white text-slate-900 shadow-sm';
    annualBtn.className = isAnnual
      ? 'px-5 py-2 rounded-xl text-sm font-semibold transition-all bg-white text-slate-900 shadow-sm'
      : 'px-5 py-2 rounded-xl text-sm font-medium transition-all text-slate-500';

    annualPaymentMode.classList.toggle('hidden', !isAnnual);

    const suffixKey = !isAnnual
      ? 'monthly'
      : annualPaymentType === 'payment'
        ? 'annualOnce'
        : 'annualMonthly';

    document.querySelectorAll<HTMLElement>('.plan-price').forEach((el) => {
      const value = suffixKey === 'monthly'
        ? el.dataset.monthly
        : suffixKey === 'annualMonthly'
          ? el.dataset.annualMonthly
          : el.dataset.annualOnce;
      el.textContent = `${value ?? '0'}€`;
    });

    document.querySelectorAll<HTMLElement>('.plan-price-suffix').forEach((el) => {
      const value = suffixKey === 'monthly'
        ? el.dataset.monthly
        : suffixKey === 'annualMonthly'
          ? el.dataset.annualMonthly
          : el.dataset.annualOnce;
      el.textContent = value ?? '';
    });

    document.querySelectorAll<HTMLElement>('.plan-price-label').forEach((el) => {
      const value = suffixKey === 'monthly'
        ? el.dataset.monthly
        : suffixKey === 'annualMonthly'
          ? el.dataset.annualMonthly
          : el.dataset.annualOnce;
      el.textContent = value ?? '';
    });
    refreshPlanButtonsState();
  }

  function setAnnualPaymentType(type: 'subscription' | 'payment') {
    annualPaymentType = type;
    annualInstallmentsBtn.className = type === 'subscription'
      ? 'rounded-xl border border-indigo-300 bg-white px-4 py-2.5 text-sm font-semibold text-indigo-700 transition-colors'
      : 'rounded-xl border border-indigo-200 bg-indigo-50 px-4 py-2.5 text-sm font-medium text-indigo-700 transition-colors';
    annualOnceBtn.className = type === 'payment'
      ? 'rounded-xl border border-indigo-300 bg-white px-4 py-2.5 text-sm font-semibold text-indigo-700 transition-colors'
      : 'rounded-xl border border-indigo-200 bg-indigo-50 px-4 py-2.5 text-sm font-medium text-indigo-700 transition-colors';
    setMode(currentMode);
  }

  function resolvePriceSlot(plan: string): PriceSlot {
    const normalizedPlan = plan === 'pro' ? 'pro' : 'starter';
    if (currentMode === 'monthly') return `${normalizedPlan}_mensuel` as PriceSlot;
    if (annualPaymentType === 'payment') return `${normalizedPlan}_annuel_once` as PriceSlot;
    return `${normalizedPlan}_annuel_mensuel` as PriceSlot;
  }

  async function hydratePricingConfig(accessToken: string) {
    pricingLoaded = false;
    refreshPlanButtonsState();
    try {
      const res = await fetch(`${API}/api/checkout/pricing-config`, {
        headers: {
          Authorization: `Bearer ${accessToken}`,
          'Content-Type': 'application/json',
        },
      });
      if (!res.ok) return;
      const payload = await res.json().catch(() => null);
      pricingDegraded = Boolean(payload?.degraded);
      const starter = payload?.data?.starter;
      const pro = payload?.data?.pro;
      const starterBtn = document.querySelector<HTMLButtonElement>('.plan-select-btn[data-plan="starter"]');
      const proBtn = document.querySelector<HTMLButtonElement>('.plan-select-btn[data-plan="pro"]');
      if (starterBtn && starter) {
        if (starter.monthly?.priceId) starterBtn.dataset.priceMonthly = String(starter.monthly.priceId);
        if (starter.annual_monthly?.priceId) starterBtn.dataset.priceAnnualSubscription = String(starter.annual_monthly.priceId);
        if (starter.annual_once?.priceId) starterBtn.dataset.priceAnnualOnce = String(starter.annual_once.priceId);
        starterBtn.dataset.availabilityMonthly = starter.monthly?.available ? '1' : '0';
        starterBtn.dataset.availabilityAnnualSubscription = starter.annual_monthly?.available ? '1' : '0';
        starterBtn.dataset.availabilityAnnualOnce = starter.annual_once?.available ? '1' : '0';
      }
      if (proBtn && pro) {
        if (pro.monthly?.priceId) proBtn.dataset.priceMonthly = String(pro.monthly.priceId);
        if (pro.annual_monthly?.priceId) proBtn.dataset.priceAnnualSubscription = String(pro.annual_monthly.priceId);
        if (pro.annual_once?.priceId) proBtn.dataset.priceAnnualOnce = String(pro.annual_once.priceId);
        proBtn.dataset.availabilityMonthly = pro.monthly?.available ? '1' : '0';
        proBtn.dataset.availabilityAnnualSubscription = pro.annual_monthly?.available ? '1' : '0';
        proBtn.dataset.availabilityAnnualOnce = pro.annual_once?.available ? '1' : '0';
      }
    } catch {
      pricingDegraded = true;
    } finally {
      pricingLoaded = true;
      refreshPlanButtonsState();
    }
  }

  async function requireSessionAndBilling() {
    const sessionResult = await withTimeout(supabase.auth.getSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null);
    const session = sessionResult?.data?.session ?? null;
    if (!session) {
      window.location.replace('/register');
      return null;
    }

    const billing = await withTimeout(fetch(`${API}/api/billing/status`, {
      headers: {
        Authorization: `Bearer ${session.access_token}`,
        'Content-Type': 'application/json',
      },
    }).then((r) => r.json()).catch(() => ({})), BILLING_CHECK_TIMEOUT_MS).catch(() => ({}));

    if (billing?.data?.has_access) {
      window.location.replace(billing?.data?.onboarding_completed ? '/dashboard' : '/onboarding');
      return null;
    }

    activeSession = session;
    await hydratePricingConfig(session.access_token);
    return session;
  }

  async function choosePlan(btn: HTMLButtonElement) {
    errorEl.classList.add('hidden');
    const session = activeSession;
    if (!session) {
      window.location.replace('/register');
      return;
    }

    const isAnnual = currentMode === 'annual';
    const priceId = !isAnnual
      ? btn.dataset.priceMonthly
      : annualPaymentType === 'payment'
        ? btn.dataset.priceAnnualOnce
        : btn.dataset.priceAnnualSubscription;
    if (!priceId || !resolveButtonPriceAvailability(btn)) {
      errorEl.textContent = "Ce tarif n'est pas disponible pour le moment. Réessayez dans quelques instants.";
      errorEl.classList.remove('hidden');
      return;
    }

    const checkoutMode: 'subscription' | 'payment' = isAnnual && annualPaymentType === 'payment'
      ? 'payment'
      : 'subscription';
    const priceSlot = resolvePriceSlot(btn.dataset.plan ?? 'starter');

    const selection = {
      plan: btn.dataset.plan,
      mode: currentMode,
      annualPaymentType,
      checkoutMode,
      priceSlot,
      priceId,
      selectedAt: Date.now(),
    };
    sessionStorage.setItem(STORAGE_KEY, JSON.stringify(selection));
    window.location.href = '/abonnement/setup';
  }

  monthlyBtn.addEventListener('click', () => setMode('monthly'));
  annualBtn.addEventListener('click', () => setMode('annual'));
  annualInstallmentsBtn.addEventListener('click', () => setAnnualPaymentType('subscription'));
  annualOnceBtn.addEventListener('click', () => setAnnualPaymentType('payment'));

  setAnnualPaymentType('subscription');
  setMode('annual');

  const cancelled = new URLSearchParams(window.location.search).get('cancelled');
  const guard = new URLSearchParams(window.location.search).get('guard');
  const priceUnavailable = new URLSearchParams(window.location.search).get('price_unavailable');
  if (cancelled === '1') {
    errorEl.textContent = 'Paiement annulé. Vous pouvez reprendre votre sélection.';
    errorEl.classList.remove('hidden');
  } else if (guard === '1') {
    errorEl.textContent = 'Votre session nécessite un abonnement actif pour accéder à l’espace commerçant.';
    errorEl.classList.remove('hidden');
  } else if (priceUnavailable === '1') {
    errorEl.textContent = 'Le tarif sélectionné n’est plus disponible. Veuillez choisir un autre mode de facturation.';
    errorEl.classList.remove('hidden');
  }

  document.querySelectorAll<HTMLButtonElement>('.plan-select-btn').forEach((btn) => {
    btn.dataset.availabilityMonthly = btn.dataset.priceMonthly ? '1' : '0';
    btn.dataset.availabilityAnnualSubscription = btn.dataset.priceAnnualSubscription ? '1' : '0';
    btn.dataset.availabilityAnnualOnce = btn.dataset.priceAnnualOnce ? '1' : '0';
    btn.addEventListener('click', () => choosePlan(btn));
  });

  refreshPlanButtonsState();
  void requireSessionAndBilling();
</script>
