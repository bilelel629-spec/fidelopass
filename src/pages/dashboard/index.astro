---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Dashboard — Fidelopass" activeNav="dashboard">
  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.26em] text-sky-700/70">Vue d'ensemble</p>
      <h1 class="font-display text-3xl font-bold text-slate-900 mt-2">Tableau de bord</h1>
      <p class="text-slate-600 text-sm mt-2">Retrouvez vos chiffres clés, vos scans récents et les signaux utiles pour piloter votre fidélité.</p>
    </div>
    <div class="flex gap-2">
      <button id="refresh-btn" type="button" class="rounded-2xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-medium text-slate-600 transition hover:border-slate-300 hover:bg-slate-50 flex items-center gap-1.5">
        <svg id="refresh-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
          <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
          <path d="M21 3v5h-5"></path>
          <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
          <path d="M8 16H3v5"></path>
        </svg>
        <span class="hidden sm:inline">Rafraîchir</span>
      </button>
      <a href="/dashboard/carte" class="hidden sm:inline-flex rounded-2xl border border-sky-200 bg-white px-4 py-2.5 text-sm font-medium text-sky-700 transition hover:border-sky-300 hover:bg-sky-50">Configurer ma carte</a>
      <a href="/app/scan" class="hidden sm:inline-flex rounded-2xl bg-sky-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-sky-700">Ouvrir le scanner</a>
    </div>
  </div>

  <div id="card-shortcuts" class="hidden mb-8 rounded-[1.4rem] border border-sky-100 bg-white/95 p-4 shadow-[0_18px_48px_-36px_rgba(59,130,246,0.35)]">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-[0.64rem] font-semibold uppercase tracking-[0.24em] text-sky-700/70">Accès rapide</p>
        <p class="mt-1 text-sm text-slate-600">Votre carte est active. Accédez directement au QR client et à l’installation scanner.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a id="dashboard-client-qr-btn" href="#" target="_blank" rel="noreferrer" class="rounded-2xl border border-sky-200 bg-white px-4 py-2.5 text-sm font-medium text-sky-700 transition hover:border-sky-300 hover:bg-sky-50">Afficher le QR client</a>
        <a id="dashboard-add-scanner-btn" href="/app/install" class="rounded-2xl bg-sky-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-sky-700">Ajouter un scanner</a>
      </div>
    </div>
  </div>

  <div id="points-vente-cta" class="mb-8 rounded-[1.4rem] border border-sky-100 bg-gradient-to-r from-sky-50/90 to-white p-5 shadow-[0_18px_48px_-36px_rgba(59,130,246,0.3)]">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="text-[0.64rem] font-semibold uppercase tracking-[0.24em] text-sky-700/70">Points de vente</p>
        <h2 class="mt-2 font-display text-xl font-bold text-slate-900">Où créer ou ajouter un point de vente ?</h2>
        <p class="mt-1 text-sm text-slate-600">Tout se fait ici : gérez vos adresses, choisissez le point actif, puis personnalisez la carte correspondante.</p>
        <p id="points-vente-cta-usage" class="mt-2 text-xs font-medium text-sky-700">Chargement du quota...</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/dashboard/points-vente" class="rounded-2xl bg-sky-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-sky-700">
          Gérer mes points de vente
        </a>
        <a href="/dashboard/carte" class="rounded-2xl border border-sky-200 bg-white px-4 py-2.5 text-sm font-medium text-sky-700 transition hover:border-sky-300 hover:bg-sky-50">
          Personnaliser le point actif
        </a>
      </div>
    </div>
  </div>

  <!-- Stats (en premier sur mobile) -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8 order-first">
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Clients totaux</span>
      <span id="stat-clients" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <span class="text-emerald-600 text-xs font-medium">Ce mois-ci</span>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Scans aujourd'hui</span>
      <span id="stat-scans" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <span class="text-slate-500 text-xs">Transactions</span>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Récompenses offertes</span>
      <span id="stat-recompenses" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <span class="text-slate-500 text-xs">Total</span>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Clients notifiables</span>
      <span id="stat-push" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <span class="text-slate-500 text-xs">Wallet ou push</span>
    </div>
  </div>

  <!-- Accordion : Guide de démarrage (en bas sur mobile) -->
  <div id="setup-accordion" class="mb-8 rounded-[1.6rem] border border-sky-100 bg-white/90 shadow-[0_18px_48px_-36px_rgba(59,130,246,0.25)] overflow-hidden">
    <button
      id="setup-accordion-btn"
      type="button"
      class="w-full flex items-center justify-between px-5 py-4 text-left group"
      aria-expanded="false"
    >
      <div class="flex items-center gap-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-xl bg-sky-100 text-sky-600">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0"></path>
          </svg>
        </span>
        <div>
          <p class="text-sm font-semibold text-slate-900">Guide de démarrage</p>
          <p class="text-xs text-slate-500">3 étapes pour mettre votre programme en ligne</p>
        </div>
      </div>
      <svg id="setup-accordion-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-slate-400 transition-transform duration-200">
        <path d="M6 9l6 6 6-6"></path>
      </svg>
    </button>
    <div id="setup-accordion-panel" class="hidden border-t border-sky-100">
      <div class="grid gap-4 md:grid-cols-3 p-5">
        <a href="/dashboard/carte" class="card p-5 transition hover:-translate-y-0.5 hover:shadow-[0_20px_60px_-42px_rgba(59,130,246,0.6)]">
          <p class="text-xs uppercase tracking-[0.24em] text-sky-600/70">Étape 1</p>
          <h2 class="mt-2 text-lg font-semibold text-slate-900">Personnaliser la carte</h2>
          <p class="mt-2 text-sm text-slate-600">Templates, visuels, programme fidélité, messages et géolocalisation dans un parcours guidé.</p>
        </a>
        <a href="/app/install" class="card p-5 transition hover:-translate-y-0.5 hover:shadow-[0_20px_60px_-42px_rgba(59,130,246,0.6)]">
          <p class="text-xs uppercase tracking-[0.24em] text-sky-600/70">Étape 2</p>
          <h2 class="mt-2 text-lg font-semibold text-slate-900">Installer le scanner du personnel</h2>
          <p class="mt-2 text-sm text-slate-600">Scannez le QR d'installation, autorisez la caméra puis utilisez l'espace scan en caisse.</p>
        </a>
        <a href="/dashboard/clients" class="card p-5 transition hover:-translate-y-0.5 hover:shadow-[0_20px_60px_-42px_rgba(59,130,246,0.6)]">
          <p class="text-xs uppercase tracking-[0.24em] text-sky-600/70">Étape 3</p>
          <h2 class="mt-2 text-lg font-semibold text-slate-900">Suivre vos clients</h2>
          <p class="mt-2 text-sm text-slate-600">Consultez vos clients, exportez-les en CSV et pilotez vos messages ou récompenses.</p>
        </a>
      </div>
    </div>
  </div>

  <!-- Graphique + activité récente -->
  <div class="grid gap-6 xl:grid-cols-[1.4fr_0.6fr] mb-6">
    <!-- Graphique scans 7 jours -->
    <div class="card p-6">
      <div class="flex items-center justify-between mb-5">
        <div>
          <h2 class="font-display font-bold text-slate-900">Activité des 7 derniers jours</h2>
          <p class="text-slate-500 text-xs mt-0.5">Scans et récompenses par jour</p>
        </div>
        <div class="flex items-center gap-4 text-xs text-slate-500">
          <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-sky-500"></span>Scans</span>
          <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm bg-emerald-400"></span>Récompenses</span>
        </div>
      </div>
      <div id="chart-container" class="h-44 flex items-end gap-1.5">
        <!-- Barres générées par JS -->
        <p class="text-slate-400 text-sm m-auto">Chargement...</p>
      </div>
    </div>

    <!-- Admin shortcut -->
    <div id="admin-shortcut" class="hidden card p-6 border border-sky-100 bg-sky-50/80">
      <p class="text-xs uppercase tracking-[0.24em] text-sky-600/75">Accès fondateur</p>
      <h2 class="mt-2 font-display text-xl font-bold text-slate-900">Administration plateforme</h2>
      <p class="mt-2 text-sm text-slate-600">Accédez à la vue globale des commerces, aux exports et aux indicateurs de pilotage.</p>
      <a href="/admin" class="btn-secondary mt-4 inline-flex px-4 py-2.5 text-sm">Ouvrir l'admin</a>
    </div>
  </div>

  <!-- Activité récente -->
  <div class="card p-6">
    <h2 class="font-display font-bold text-slate-900 mb-4">Activité récente</h2>
    <div id="recent-transactions" class="flex flex-col gap-3">
      <p class="text-slate-500 text-sm">Chargement...</p>
    </div>
  </div>
</DashboardLayout>

<script>
  import { authFetch } from '../../lib/api';
  import { supabase } from '../../lib/supabase';

  function escapeHtml(value: unknown) {
    return String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;',
    }[char] ?? char));
  }

  // Accordion guide de démarrage
  const accordionBtn = document.getElementById('setup-accordion-btn')!;
  const accordionPanel = document.getElementById('setup-accordion-panel')!;
  const accordionArrow = document.getElementById('setup-accordion-arrow')!;

  accordionBtn.addEventListener('click', () => {
    const isOpen = accordionPanel.classList.contains('hidden');
    accordionPanel.classList.toggle('hidden', !isOpen);
    accordionArrow.style.transform = isOpen ? 'rotate(180deg)' : '';
    accordionBtn.setAttribute('aria-expanded', String(isOpen));
  });

  // Chargement des stats
  async function loadStats() {
    try {
      const res = await authFetch('/api/dashboard/stats');
      if (!res.ok) return;
      const data = await res.json();
      document.getElementById('stat-clients')!.textContent = String(data.totalClients ?? 0);
      document.getElementById('stat-scans')!.textContent = String(data.scansAujourdhui ?? 0);
      document.getElementById('stat-recompenses')!.textContent = String(data.totalRecompenses ?? 0);
      document.getElementById('stat-push')!.textContent = String(data.clientsPushActifs ?? 0);
    } catch {
      // silencieux
    }
  }

  // Graphique barres
  async function loadChart() {
    const container = document.getElementById('chart-container')!;
    try {
      const res = await authFetch('/api/dashboard/weekly-scans');
      if (!res.ok) throw new Error();
      const { data } = await res.json();

      if (!data?.length) {
        container.innerHTML = '<p class="text-slate-400 text-sm m-auto">Aucune activité cette semaine.</p>';
        return;
      }

      const maxVal = Math.max(...data.map((d: { scans: number; recompenses: number }) => d.scans + d.recompenses), 1);
      const CHART_HEIGHT = 160; // px

      container.innerHTML = data.map((d: { date: string; scans: number; recompenses: number }) => {
        const scansH = Math.round((d.scans / maxVal) * CHART_HEIGHT);
        const recH = Math.round((d.recompenses / maxVal) * CHART_HEIGHT);
        const label = new Date(d.date + 'T12:00:00').toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric' });
        return `
          <div class="flex-1 flex flex-col items-center gap-1 min-w-0">
            <div class="w-full flex flex-col-reverse items-center gap-0.5" style="height:${CHART_HEIGHT}px">
              <div class="w-full rounded-t-lg bg-sky-500 transition-all" style="height:${scansH}px" title="${d.scans} scan(s)"></div>
              ${recH > 0 ? `<div class="w-full rounded-t-lg bg-emerald-400 transition-all" style="height:${recH}px" title="${d.recompenses} récompense(s)"></div>` : ''}
            </div>
            <p class="text-[0.62rem] text-slate-500 text-center truncate w-full">${escapeHtml(label)}</p>
          </div>
        `;
      }).join('');
    } catch {
      container.innerHTML = '<p class="text-slate-400 text-sm m-auto">Impossible de charger le graphique.</p>';
    }
  }

  async function loadRecentTransactions() {
    try {
      const res = await authFetch('/api/transactions?limit=5');
      if (!res.ok) return;
      const { data } = await res.json();
      const container = document.getElementById('recent-transactions')!;

      if (!data?.length) {
        container.innerHTML = '<p class="text-slate-500 text-sm">Aucune transaction pour le moment.</p>';
        return;
      }

      container.innerHTML = data.map((t: { type: string; valeur: number; created_at: string }) => `
        <div class="flex items-center justify-between py-3 border-b border-slate-200 last:border-0">
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full ${t.type === 'ajout_tampon' ? 'bg-indigo-400' : t.type === 'ajout_points' ? 'bg-cyan-400' : 'bg-emerald-400'}"></span>
            <span class="text-slate-700 text-sm capitalize">${escapeHtml(t.type.replace('_', ' '))}</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="font-mono text-sm text-slate-900">+${t.valeur}</span>
            <span class="text-slate-500 text-xs">${new Date(t.created_at).toLocaleDateString('fr-FR')}</span>
          </div>
        </div>
      `).join('');
    } catch {
      // silencieux
    }
  }

  async function loadCardShortcuts() {
    try {
      const res = await authFetch('/api/cartes');
      if (!res.ok) return;
      const { data } = await res.json();
      if (!data?.id) return;
      const container = document.getElementById('card-shortcuts') as HTMLDivElement;
      const qrBtn = document.getElementById('dashboard-client-qr-btn') as HTMLAnchorElement;
      qrBtn.href = `/poster/${data.id}?template=premium`;
      container.classList.remove('hidden');
    } catch {
      // silencieux
    }
  }

  async function loadPointsVenteCta() {
    const usage = document.getElementById('points-vente-cta-usage');
    if (!usage) return;

    try {
      const res = await authFetch('/api/commerces/points-vente');
      if (!res.ok) throw new Error();
      const payload = await res.json().catch(() => null);
      const plan = String(payload?.plan ?? 'starter').toLowerCase();
      const stats = payload?.usage;
      const selectedId = payload?.selected_point_vente_id;
      const points = Array.isArray(payload?.data) ? payload.data : [];
      const selected = points.find((point: { id: string; nom?: string }) => point.id === selectedId);

      usage.textContent = `Plan ${plan === 'pro' ? 'Pro' : 'Starter'} : ${stats?.current ?? 0}/${stats?.max ?? 1} point(s) de vente utilisés. Actif: ${selected?.nom ?? '—'}.`;
    } catch {
      usage.textContent = 'Impossible de charger le quota des points de vente.';
    }
  }

  async function loadAdminShortcut() {
    try {
      const { data: { session } } = await supabase.auth.getSession();
      const email = session?.user?.email?.toLowerCase();
      const isAdmin = ['bilelel@live.fr', 'bilel@pulse-agency.fr'].includes(email ?? '');
      document.getElementById('admin-shortcut')!.classList.toggle('hidden', !isAdmin);
    } catch {}
  }

  async function refreshAll() {
    const icon = document.getElementById('refresh-icon')!;
    const btn = document.getElementById('refresh-btn') as HTMLButtonElement;
    btn.disabled = true;
    icon.style.animation = 'spin 0.8s linear infinite';
    await Promise.all([loadStats(), loadChart(), loadRecentTransactions(), loadCardShortcuts(), loadPointsVenteCta()]);
    icon.style.animation = '';
    btn.disabled = false;
  }

  document.getElementById('refresh-btn')!.addEventListener('click', refreshAll);

  // Animation spin
  const style = document.createElement('style');
  style.textContent = '@keyframes spin { to { transform: rotate(360deg); } }';
  document.head.appendChild(style);

  loadStats();
  loadChart();
  loadRecentTransactions();
  loadCardShortcuts();
  loadPointsVenteCta();
  loadAdminShortcut();
</script>
