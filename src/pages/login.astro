---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Connexion — Fidelopass" description="Connectez-vous à votre espace commerçant Fidelopass.">
  <div class="min-h-screen bg-[#f8fbff] px-4 py-10 sm:py-14 relative overflow-hidden">
    <div class="pointer-events-none absolute -top-28 right-[-8rem] h-[26rem] w-[26rem] rounded-full bg-cyan-200/35 blur-3xl"></div>
    <div class="pointer-events-none absolute bottom-[-7rem] left-[-6rem] h-[22rem] w-[22rem] rounded-full bg-blue-100/80 blur-3xl"></div>

    <div class="max-w-6xl mx-auto grid lg:grid-cols-[1.05fr_0.95fr] gap-10 items-center">
      <div class="hidden lg:block">
        <a href="/" class="inline-flex items-center gap-1 mb-10">
          <img src="/logo-premium-cropped.png" alt="Fidelopass" class="h-28 w-auto object-contain" />
        </a>
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-700/70">Espace commerçant</p>
        <h1 class="font-display text-4xl font-bold text-slate-900 leading-tight mt-3">
          Retrouvez votre tableau de bord et pilotez votre fidélité sereinement.
        </h1>
        <p class="text-slate-500 text-base leading-relaxed mt-5 max-w-lg">
          Gérez vos cartes Wallet, votre scanner, vos clients, vos notifications et vos performances depuis un seul espace clair.
        </p>

        <div class="grid sm:grid-cols-2 gap-4 mt-8 max-w-xl">
          {[
            ['Scanner du personnel prêt à l’usage', 'Accès rapide depuis le mobile du commerce.'],
            ['Messages Wallet et push centralisés', 'Gardez le contact sans application client.'],
            ['Design de carte personnalisable', 'Modifiez votre identité visuelle à tout moment.'],
            ['Suivi clients et historique', 'Gardez une vue claire sur les visites et récompenses.'],
          ].map(([title, text]) => (
            <div class="rounded-2xl border border-sky-100 bg-white/80 backdrop-blur-md p-5 shadow-[0_18px_44px_-34px_rgba(37,99,235,0.25)]">
              <p class="font-semibold text-slate-900 text-sm">{title}</p>
              <p class="text-slate-500 text-sm mt-2 leading-relaxed">{text}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="bg-white/92 backdrop-blur-xl rounded-[2rem] border border-sky-100 shadow-[0_32px_70px_-34px_rgba(37,99,235,0.28)] p-6 sm:p-8">
        <a href="/" class="lg:hidden inline-flex items-center gap-1 mb-6">
          <img src="/logo-premium-cropped.png" alt="Fidelopass" class="h-20 w-auto object-contain" />
        </a>

        <div class="mb-7">
          <p class="text-sky-700/70 text-sm">Connexion commerçant</p>
          <h2 class="font-display text-3xl font-bold text-slate-900 mt-1">Bienvenue</h2>
          <p class="text-slate-500 text-sm mt-2">Connectez-vous pour accéder à votre tableau de bord Fidelopass.</p>
        </div>

        <button id="apple-login-btn" type="button" class="w-full rounded-2xl bg-black text-white font-semibold py-3.5 px-4 flex items-center justify-center gap-3 border border-black hover:bg-slate-900 transition-colors mb-3 shadow-sm">
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor" aria-hidden="true">
            <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.4c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.56-1.32 3.09-2.53 4zm-3.07-17.4c.04 2.2-1.88 4.02-3.93 3.84-.27-2.04 1.88-4.08 3.93-3.84z"/>
          </svg>
          Continuer avec Apple
        </button>

        <button id="google-login-btn" type="button" class="w-full rounded-2xl bg-white text-slate-950 font-semibold py-3.5 px-4 flex items-center justify-center gap-3 border border-slate-200 hover:bg-slate-50 transition-colors mb-5 shadow-sm">
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" aria-hidden="true">
            <path d="M21.56 10.74a9.55 9.55 0 0 0-.15-1.69H12v3.2h5.37a4.6 4.6 0 0 1-2 3.02v2.51h3.23c1.89-1.74 2.96-4.3 2.96-7.04z" fill="#4285F4"/>
            <path d="M12 22c2.7 0 4.96-.9 6.61-2.43l-3.23-2.51c-.9.6-2.04.96-3.38.96-2.6 0-4.8-1.76-5.59-4.12H3.08v2.6A10 10 0 0 0 12 22z" fill="#34A853"/>
            <path d="M6.41 13.9A6 6 0 0 1 6.09 12c0-.66.11-1.3.32-1.9V7.5H3.08A10 10 0 0 0 2 12c0 1.61.38 3.13 1.08 4.5l3.33-2.6z" fill="#FBBC05"/>
            <path d="M12 5.88c1.47 0 2.79.5 3.82 1.5l2.86-2.86A9.96 9.96 0 0 0 12 2 10 10 0 0 0 3.08 7.5l3.33 2.6C7.2 7.64 9.4 5.88 12 5.88z" fill="#EA4335"/>
          </svg>
          Continuer avec Google
        </button>

        <div class="flex items-center gap-3 mb-5">
          <div class="h-px flex-1 bg-slate-200"></div>
          <span class="text-xs uppercase tracking-[0.2em] text-slate-400">ou</span>
          <div class="h-px flex-1 bg-slate-200"></div>
        </div>

        <form id="login-form" class="flex flex-col gap-4">
          <div>
            <label class="label" for="email">Email</label>
            <input id="email" type="email" class="input" placeholder="vous@commerce.fr" required autocomplete="email" />
          </div>
          <div>
            <div class="flex items-center justify-between gap-3">
              <label class="label" for="password">Mot de passe</label>
              <button id="forgot-btn" type="button" class="text-xs text-indigo-600 hover:text-indigo-500 transition-colors mb-1">
                Mot de passe oublié ?
              </button>
            </div>
            <input id="password" type="password" class="input" placeholder="••••••••" required autocomplete="current-password" />
          </div>

          <div class="rounded-2xl border border-sky-100 bg-sky-50/90 px-4 py-3 text-sm text-slate-600">
            Les nouveaux comptes doivent d’abord confirmer leur email avec le code reçu lors de l’inscription.
          </div>

          <div id="error-msg" class="hidden text-red-600 text-sm bg-red-50 border border-red-200 rounded-xl px-4 py-3"></div>
          <button type="submit" class="btn-primary w-full py-3.5 mt-2">Se connecter</button>
        </form>

        <p class="text-center text-slate-500 text-sm mt-6">
          Pas encore de compte ?
          <a href="/register" class="text-indigo-600 hover:text-indigo-500 transition-colors ml-1 font-medium">S'inscrire</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const googleLoginBtn = document.getElementById('google-login-btn') as HTMLButtonElement;
  const appleLoginBtn = document.getElementById('apple-login-btn') as HTMLButtonElement;
  const forgotBtn = document.getElementById('forgot-btn') as HTMLButtonElement;

  function apiUrl(path: string) {
    const API = (import.meta.env.PUBLIC_API_URL ?? '').trim();
    return `${API}${path}`;
  }

  async function getValidSession() {
    const { data: { session } } = await supabase.auth.getSession();
    if (session?.access_token) return session;

    const { data, error } = await supabase.auth.refreshSession();
    if (!error && data.session?.access_token) return data.session;
    return null;
  }

  async function redirectAfterAuth(
    sessionFromFlow: { access_token: string } | null = null,
    options: { redirectToPricingWhenNoAccess?: boolean } = {},
  ) {
    const { redirectToPricingWhenNoAccess = true } = options;
    const activeSession = sessionFromFlow?.access_token ? sessionFromFlow : await getValidSession();

    if (!activeSession?.access_token) {
      await supabase.auth.signOut().catch(() => undefined);
      errorMsg.textContent = 'Votre session a expiré. Merci de vous reconnecter.';
      errorMsg.classList.remove('hidden');
      return;
    }

    const billingResponse = await fetch(apiUrl('/api/billing/status'), {
      headers: { Authorization: `Bearer ${activeSession.access_token}`, 'Content-Type': 'application/json' },
    }).catch(() => null);

    if (!billingResponse) {
      errorMsg.textContent = 'Impossible de vérifier votre abonnement pour le moment.';
      errorMsg.classList.remove('hidden');
      return;
    }

    const billing = await billingResponse.json().catch(() => ({}));
    if (!billingResponse.ok) {
      if (billingResponse.status === 401) {
        await supabase.auth.signOut().catch(() => undefined);
        errorMsg.textContent = 'Session invalide ou expirée. Merci de vous reconnecter.';
      } else {
        errorMsg.textContent = billing?.error ?? 'Erreur lors de la vérification de votre abonnement.';
      }
      errorMsg.classList.remove('hidden');
      return;
    }

    if (!billing?.data?.has_access) {
      if (redirectToPricingWhenNoAccess) {
        window.location.href = '/abonnement/choix';
      }
      return;
    }

    window.location.href = billing?.data?.onboarding_completed ? '/dashboard' : '/onboarding';
  }

  const { data: { session } } = await supabase.auth.getSession();
  if (session) {
    await redirectAfterAuth(session, { redirectToPricingWhenNoAccess: false });
  }

  async function startGoogleOAuth() {
    const { data, error } = await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: {
        redirectTo: `${window.location.origin}/login`,
        skipBrowserRedirect: true,
      },
    });

    if (error) throw error;
    if (!data.url) throw new Error('Redirection Google indisponible.');

    const probe = await fetch(data.url, {
      redirect: 'manual',
      credentials: 'include',
    }).catch(() => null);

    if (probe && probe.status >= 400) {
      const payload = await probe.json().catch(() => ({}));
      throw new Error(payload.msg ?? payload.error_description ?? 'Connexion Google indisponible.');
    }

    window.location.assign(data.url);
  }

  appleLoginBtn.addEventListener('click', async () => {
    errorMsg.classList.add('hidden');
    appleLoginBtn.disabled = true;
    appleLoginBtn.textContent = 'Redirection vers Apple...';

    try {
      const { data, error } = await supabase.auth.signInWithOAuth({
        provider: 'apple',
        options: {
          redirectTo: `${window.location.origin}/auth/confirm`,
        },
      });
      if (error) throw error;
      if (!data.url) throw new Error('Redirection Apple indisponible.');
      window.location.assign(data.url);
    } catch (error) {
      const message = error instanceof Error ? error.message.toLowerCase() : '';
      errorMsg.textContent = message.includes('unsupported provider')
        ? 'Connexion Apple indisponible : le provider Apple doit être activé dans Supabase.'
        : (error instanceof Error ? error.message : 'Impossible de démarrer la connexion Apple.');
      errorMsg.classList.remove('hidden');
      appleLoginBtn.disabled = false;
      appleLoginBtn.innerHTML = `<svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor" aria-hidden="true"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.7 9.05 7.4c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.56-1.32 3.09-2.53 4zm-3.07-17.4c.04 2.2-1.88 4.02-3.93 3.84-.27-2.04 1.88-4.08 3.93-3.84z"/></svg> Continuer avec Apple`;
    }
  });

  googleLoginBtn.addEventListener('click', async () => {
    errorMsg.classList.add('hidden');
    googleLoginBtn.disabled = true;
    googleLoginBtn.textContent = 'Redirection vers Google...';

    try {
      await startGoogleOAuth();
    } catch (error) {
      const message = error instanceof Error ? error.message.toLowerCase() : '';
      errorMsg.textContent = message.includes('unsupported provider')
        ? 'Connexion Google indisponible : le provider Google doit être activé dans Supabase.'
        : (error instanceof Error ? error.message : 'Impossible de démarrer la connexion Google.');
      errorMsg.classList.remove('hidden');
      googleLoginBtn.disabled = false;
      googleLoginBtn.innerHTML = `<svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" aria-hidden="true"><path d="M21.56 10.74a9.55 9.55 0 0 0-.15-1.69H12v3.2h5.37a4.6 4.6 0 0 1-2 3.02v2.51h3.23c1.89-1.74 2.96-4.3 2.96-7.04z" fill="#4285F4"/><path d="M12 22c2.7 0 4.96-.9 6.61-2.43l-3.23-2.51c-.9.6-2.04.96-3.38.96-2.6 0-4.8-1.76-5.59-4.12H3.08v2.6A10 10 0 0 0 12 22z" fill="#34A853"/><path d="M6.41 13.9A6 6 0 0 1 6.09 12c0-.66.11-1.3.32-1.9V7.5H3.08A10 10 0 0 0 2 12c0 1.61.38 3.13 1.08 4.5l3.33-2.6z" fill="#FBBC05"/><path d="M12 5.88c1.47 0 2.79.5 3.82 1.5l2.86-2.86A9.96 9.96 0 0 0 12 2 10 10 0 0 0 3.08 7.5l3.33 2.6C7.2 7.64 9.4 5.88 12 5.88z" fill="#EA4335"/></svg> Continuer avec Google`;
    }
  });

  forgotBtn.addEventListener('click', () => {
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    window.location.href = email ? `/reset-password?email=${encodeURIComponent(email)}` : '/reset-password';
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Connexion...';

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    if (error) {
      const message = error.message?.toLowerCase?.() ?? '';
      errorMsg.textContent = message.includes('email not confirmed')
        ? 'Confirmez d’abord votre adresse email avec le code reçu lors de l’inscription.'
        : 'Email ou mot de passe incorrect.';
      errorMsg.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Se connecter';
      return;
    }

    await redirectAfterAuth(data.session ?? null);
  });
</script>
