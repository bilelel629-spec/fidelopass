---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Commerces — Admin Fidelopass" activeNav="commerces">
  <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="dashboard-kicker">Administration</p>
      <h1 class="dashboard-title">Tous les commerces</h1>
      <p class="dashboard-subtitle">Consultez les comptes créés, leur niveau d’équipement, leur base clients et exportez la liste quand vous en avez besoin.</p>
    </div>
    <button id="export-admin-commerces" type="button" class="btn-primary px-4 py-2.5 text-sm">
      Exporter en CSV
    </button>
  </div>

  <div class="mb-6 grid gap-3 md:grid-cols-[1fr_180px_180px]">
    <input id="search" type="search" class="input" placeholder="Rechercher un commerce, un email..." />
    <select id="filter-statut" class="input">
      <option value="">Tous les statuts</option>
      <option value="actif">Actifs</option>
      <option value="inactif">Inactifs</option>
    </select>
    <select id="filter-carte" class="input">
      <option value="">Toutes les cartes</option>
      <option value="configured">Carte configurée</option>
      <option value="missing">Sans carte</option>
    </select>
  </div>

  <p id="admin-commerces-feedback" class="mb-4 hidden rounded-xl border px-4 py-3 text-sm"></p>

  <div class="card dashboard-panel overflow-hidden">
    <div id="commerces-table">
      <p class="p-6 text-sm text-slate-500">Chargement...</p>
    </div>
  </div>
</AdminLayout>

<script>
  import { withTimeout } from '../../lib/utils/with-timeout';

  type AdminCommerce = {
    id: string;
    nom: string;
    adresse: string | null;
    email: string | null;
    telephone: string | null;
    actif: boolean;
    plan?: string | null;
    plan_override?: string | null;
    effective_plan?: string | null;
    created_at: string;
    cartes: unknown[];
    clients: unknown[];
  };

  let allCommerces: AdminCommerce[] = [];
  const SESSION_PROBE_TIMEOUT_MS = Number(import.meta.env.PUBLIC_AUTH_SESSION_PROBE_TIMEOUT_MS ?? 900);
  const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001';

  function normalizePlan(planRaw: unknown) {
    return String(planRaw ?? 'starter').trim().toLowerCase();
  }

  function planLabel(planRaw: unknown) {
    const plan = normalizePlan(planRaw);
    if (plan.includes('sur-mesure') || plan.includes('surmesure') || plan.includes('custom')) return 'Sur mesure';
    if (plan.includes('pro')) return 'Pro';
    return 'Starter';
  }

  function planSelectValue(planRaw: unknown): 'starter' | 'pro' | 'sur-mesure' {
    const plan = normalizePlan(planRaw);
    if (plan.includes('sur-mesure') || plan.includes('surmesure') || plan.includes('custom')) return 'sur-mesure';
    if (plan.includes('pro')) return 'pro';
    return 'starter';
  }

  function getOnboardingState(commerce: AdminCommerce) {
    if (!commerce.cartes.length) return { label: 'Compte créé', badge: 'badge-warning' };
    if (!commerce.clients.length) return { label: 'Carte prête', badge: 'badge-info' };
    return { label: 'Carte partagée', badge: 'badge-success' };
  }

  function setActionFeedback(message: string, tone: 'success' | 'error') {
    const feedback = document.getElementById('admin-commerces-feedback') as HTMLParagraphElement;
    feedback.textContent = message;
    feedback.className = tone === 'success'
      ? 'mb-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700'
      : 'mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700';
  }

  async function getAccessTokenFast() {
    const { supabase } = await import('../../lib/supabase');
    const sessionResult = await withTimeout(supabase.auth.getSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null);
    const sessionToken = sessionResult?.data?.session?.access_token;
    if (sessionToken) return sessionToken;
    const refreshResult = await withTimeout(supabase.auth.refreshSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null);
    return refreshResult?.data?.session?.access_token ?? '';
  }

  async function authFetch(url: string, opts: RequestInit = {}) {
    const accessToken = await getAccessTokenFast();
    return fetch(url, {
      ...opts,
      headers: {
        ...(opts.headers ?? {}),
        Authorization: `Bearer ${accessToken}`,
        'Content-Type': 'application/json',
      },
    });
  }

  function exportCsv(data: AdminCommerce[]) {
    const rows = [
      ['Nom', 'Email', 'Téléphone', 'Adresse', 'Carte configurée', 'Clients', 'Plan effectif', 'Plan source', 'Onboarding', 'Statut', 'Créé le'],
      ...data.map((commerce) => [
        commerce.nom,
        commerce.email ?? '',
        commerce.telephone ?? '',
        commerce.adresse ?? '',
        commerce.cartes.length > 0 ? 'Oui' : 'Non',
        String(commerce.clients.length),
        planLabel(commerce.effective_plan ?? commerce.plan),
        commerce.plan_override ? `Override: ${planLabel(commerce.plan_override)}` : planLabel(commerce.plan),
        getOnboardingState(commerce).label,
        commerce.actif ? 'Actif' : 'Inactif',
        new Date(commerce.created_at).toLocaleDateString('fr-FR'),
      ]),
    ];

    const csv = rows
      .map((row) => row.map((value) => `"${String(value).replaceAll('"', '""')}"`).join(';'))
      .join('\n');

    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = 'fidelopass-commerces-admin.csv';
    link.click();
    URL.revokeObjectURL(url);
  }

  function renderTable(data: AdminCommerce[]) {
    const container = document.getElementById('commerces-table')!;
    if (!data.length) {
      container.innerHTML = '<p class="p-6 text-sm text-slate-500">Aucun commerce trouvé.</p>';
      return;
    }

    container.innerHTML = `
      <div class="overflow-x-auto">
        <table class="w-full min-w-[1100px]">
          <thead class="border-b border-slate-200">
            <tr class="text-left">
              <th class="px-6 py-3 text-xs uppercase tracking-wide text-slate-500">Commerce</th>
              <th class="px-6 py-3 text-xs uppercase tracking-wide text-slate-500">Contact</th>
              <th class="px-6 py-3 text-xs uppercase tracking-wide text-slate-500">Carte</th>
              <th class="px-6 py-3 text-xs uppercase tracking-wide text-slate-500">Clients</th>
              <th class="px-6 py-3 text-xs uppercase tracking-wide text-slate-500">Abonnement</th>
              <th class="px-6 py-3 text-xs uppercase tracking-wide text-slate-500">Onboarding</th>
              <th class="px-6 py-3 text-xs uppercase tracking-wide text-slate-500">Statut</th>
              <th class="px-6 py-3 text-xs uppercase tracking-wide text-slate-500">Inscrit</th>
              <th class="px-6 py-3 text-xs uppercase tracking-wide text-slate-500">Action</th>
            </tr>
          </thead>
          <tbody>
            ${data.map((commerce) => `
              <tr class="border-b border-slate-100 last:border-0 hover:bg-sky-50/70 transition-colors">
                <td class="px-6 py-4">
                  <p class="text-sm font-semibold text-slate-900">${commerce.nom}</p>
                  <p class="mt-1 text-xs text-slate-500">${commerce.adresse ?? 'Adresse non renseignée'}</p>
                </td>
                <td class="px-6 py-4 text-sm text-slate-600">
                  <p>${commerce.email ?? '—'}</p>
                  <p class="text-xs text-slate-400">${commerce.telephone ?? 'Pas de téléphone'}</p>
                </td>
                <td class="px-6 py-4">
                  ${commerce.cartes.length > 0
                    ? '<span class="badge badge-success">Configurée</span>'
                    : '<span class="badge bg-slate-100 text-slate-500 border border-slate-200">À faire</span>'}
                </td>
                <td class="px-6 py-4 font-mono text-sm text-sky-700">${commerce.clients.length}</td>
                <td class="px-6 py-4">
                  <div class="space-y-2">
                    <span class="badge bg-slate-100 text-slate-700 border border-slate-200">${planLabel(commerce.effective_plan ?? commerce.plan)}</span>
                    <div class="flex items-center gap-2">
                      <select
                        data-plan-select="${commerce.id}"
                        class="rounded-xl border border-slate-200 bg-white px-2.5 py-1.5 text-xs font-medium text-slate-700"
                      >
                        <option value="starter" ${planSelectValue(commerce.effective_plan ?? commerce.plan) === 'starter' ? 'selected' : ''}>Starter</option>
                        <option value="pro" ${planSelectValue(commerce.effective_plan ?? commerce.plan) === 'pro' ? 'selected' : ''}>Pro</option>
                        <option value="sur-mesure" ${planSelectValue(commerce.effective_plan ?? commerce.plan) === 'sur-mesure' ? 'selected' : ''}>Sur mesure</option>
                      </select>
                      <button
                        data-plan-apply="${commerce.id}"
                        class="rounded-lg border border-sky-200 bg-sky-50 px-2.5 py-1.5 text-[0.7rem] font-semibold text-sky-700 transition hover:border-sky-300 hover:bg-sky-100"
                        type="button"
                      >
                        Appliquer
                      </button>
                    </div>
                    <p class="text-[0.68rem] text-slate-500">
                      ${commerce.plan_override
                        ? `Override actif (${planLabel(commerce.plan_override)}). Base: ${planLabel(commerce.plan)}`
                        : `Base: ${planLabel(commerce.plan)}`}
                    </p>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <span class="badge ${getOnboardingState(commerce).badge}">${getOnboardingState(commerce).label}</span>
                </td>
                <td class="px-6 py-4">
                  ${commerce.actif
                    ? '<span class="badge badge-success">Actif</span>'
                    : '<span class="badge badge-danger">Inactif</span>'}
                </td>
                <td class="px-6 py-4 text-sm text-slate-600">${new Date(commerce.created_at).toLocaleDateString('fr-FR')}</td>
                <td class="px-6 py-4">
                  <div class="flex flex-col gap-2">
                    <a href="/admin/cartes?commerce=${commerce.id}" class="rounded-xl border border-sky-200 bg-sky-50 px-3 py-2 text-center text-xs font-medium text-sky-700 transition hover:border-sky-300 hover:bg-sky-100">
                      Personnaliser carte
                    </a>
                    <button onclick="toggleCommerce('${commerce.id}', ${!commerce.actif})" class="rounded-xl border border-slate-200 px-3 py-2 text-xs font-medium text-slate-600 transition hover:bg-slate-50">
                      ${commerce.actif ? 'Désactiver' : 'Activer'}
                    </button>
                  </div>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
  }

  async function loadCommerces() {
    const container = document.getElementById('commerces-table')!;
    try {
      const res = await authFetch(`${API_BASE}/api/admin/commerces`);
      if (!res.ok) throw new Error();
      const { data } = await res.json();
      allCommerces = data ?? [];
      applyFilters();
    } catch {
      container.innerHTML = '<p class="p-6 text-sm text-red-500">Erreur lors du chargement.</p>';
    }
  }

  async function toggleCommerce(id: string, actif: boolean) {
    await authFetch(`${API_BASE}/api/admin/commerces/${id}`, {
      method: 'PATCH',
      body: JSON.stringify({ actif }),
    });
    await loadCommerces();
  }

  async function updatePlan(id: string, planOverride: 'starter' | 'pro' | 'sur-mesure') {
    const endpoint = `${API_BASE}/api/admin/commerces/${id}/plan`;
    const response = await authFetch(endpoint, {
      method: 'PATCH',
      body: JSON.stringify({ plan_override: planOverride }),
    });
    if (!response.ok) {
      const payload = await response.json().catch(() => null);
      throw new Error(payload?.error ?? 'Impossible de mettre à jour le plan.');
    }
  }

  function bindPlanActions() {
    document.querySelectorAll<HTMLButtonElement>('[data-plan-apply]').forEach((button) => {
      button.addEventListener('click', async () => {
        const id = button.dataset.planApply;
        if (!id) return;
        const select = document.querySelector<HTMLSelectElement>(`[data-plan-select="${id}"]`);
        if (!select) return;

        const nextPlan = select.value as 'starter' | 'pro' | 'sur-mesure';
        const initialLabel = button.textContent ?? 'Appliquer';
        button.disabled = true;
        button.textContent = '...';
        try {
          await updatePlan(id, nextPlan);
          await loadCommerces();
          setActionFeedback('Plan mis à jour avec succès.', 'success');
        } catch (error) {
          setActionFeedback(error instanceof Error ? error.message : 'Erreur de mise à jour du plan.', 'error');
          button.disabled = false;
          button.textContent = initialLabel;
        }
      });
    });
  }

  function applyFilters() {
    const search = (document.getElementById('search') as HTMLInputElement).value.toLowerCase();
    const statut = (document.getElementById('filter-statut') as HTMLSelectElement).value;
    const carte = (document.getElementById('filter-carte') as HTMLSelectElement).value;

    const filtered = allCommerces.filter((commerce) => {
      const matchesSearch = !search
        || commerce.nom.toLowerCase().includes(search)
        || (commerce.email ?? '').toLowerCase().includes(search)
        || (commerce.telephone ?? '').toLowerCase().includes(search);
      const matchesStatus = !statut
        || (statut === 'actif' && commerce.actif)
        || (statut === 'inactif' && !commerce.actif);
      const matchesCard = !carte
        || (carte === 'configured' && commerce.cartes.length > 0)
        || (carte === 'missing' && commerce.cartes.length === 0);
      return matchesSearch && matchesStatus && matchesCard;
    });

    renderTable(filtered);
    bindPlanActions();
  }

  (window as unknown as Record<string, unknown>).toggleCommerce = toggleCommerce;

  document.getElementById('search')!.addEventListener('input', applyFilters);
  document.getElementById('filter-statut')!.addEventListener('change', applyFilters);
  document.getElementById('filter-carte')!.addEventListener('change', applyFilters);
  document.getElementById('export-admin-commerces')!.addEventListener('click', () => exportCsv(allCommerces));

  loadCommerces();
</script>
