---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Ouverture du QR client — Fidelopass" activeNav="dashboard">
  <div class="mx-auto max-w-2xl">
    <div class="card p-7 sm:p-9">
      <p class="text-[0.64rem] font-semibold uppercase tracking-[0.24em] text-sky-700/70">Affiche client</p>
      <h1 class="mt-2 font-display text-2xl font-bold text-slate-900">Ouverture du QR en cours…</h1>
      <p id="qr-client-status" class="mt-3 text-sm text-slate-600">
        Recherche de votre carte active pour le point de vente sélectionné.
      </p>

      <div id="qr-client-actions" class="mt-6 hidden flex flex-wrap gap-3">
        <button id="qr-client-retry" type="button" class="btn-primary px-5 py-2.5 text-sm">Réessayer</button>
        <a href="/dashboard/carte" class="btn-secondary px-5 py-2.5 text-sm">Configurer ma carte</a>
        <a href="/dashboard" class="btn-secondary px-5 py-2.5 text-sm">Retour au dashboard</a>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { ACTIVE_POINT_VENTE_STORAGE_KEY, authFetch } from '../../lib/api';

  const statusEl = document.getElementById('qr-client-status');
  const actionsEl = document.getElementById('qr-client-actions');
  const retryBtn = document.getElementById('qr-client-retry');

  function setStatus(message: string, showActions = false) {
    if (statusEl) statusEl.textContent = message;
    actionsEl?.classList.toggle('hidden', !showActions);
  }

  function getStoredPointVenteId(): string | null {
    try {
      const value = window.localStorage.getItem(ACTIVE_POINT_VENTE_STORAGE_KEY)?.trim() ?? '';
      return value.length > 0 ? value : null;
    } catch {
      return null;
    }
  }

  function clearStoredPointVenteId() {
    try {
      window.localStorage.removeItem(ACTIVE_POINT_VENTE_STORAGE_KEY);
    } catch {
      // best effort
    }
  }

  async function pointAwareFetch(path: string, init?: RequestInit): Promise<Response> {
    const response = await authFetch(path, init);
    if (response.status !== 403 && response.status !== 404) return response;

    const pointVenteId = getStoredPointVenteId();
    if (!pointVenteId) return response;
    clearStoredPointVenteId();
    return authFetch(path, init);
  }

  async function openClientPoster() {
    setStatus('Recherche de votre carte active…');
    actionsEl?.classList.add('hidden');

    try {
      const res = await pointAwareFetch('/api/cartes/active');
      if (!res.ok) throw new Error('api-error');

      const payload = await res.json().catch(() => ({ data: null }));
      const carteId = payload?.data?.id as string | undefined;

      if (!carteId) {
        setStatus('Aucune carte active trouvée pour ce point de vente. Configurez votre carte puis réessayez.', true);
        return;
      }

      window.location.replace(`/poster/${carteId}?template=signature`);
    } catch {
      setStatus('Impossible d’ouvrir l’affiche pour le moment. Vérifiez votre connexion puis réessayez.', true);
    }
  }

  retryBtn?.addEventListener('click', () => {
    void openClientPoster();
  });

  void openClientPoster();
</script>

