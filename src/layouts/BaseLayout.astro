---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  theme?: 'light' | 'dashboard';
}

const {
  title = 'Fidelopass — Cartes de fidélité dématérialisées',
  description = 'Créez et gérez vos cartes de fidélité Apple Wallet & Google Wallet en quelques minutes.',
  theme = 'light',
} = Astro.props;
---

<!doctype html>
<html lang="fr" class={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8fafc" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const KEY = 'fidelopass-theme';
        try {
          localStorage.removeItem(KEY);
        } catch {
          // ignore
        }
        document.documentElement.dataset.theme = 'light';
        document.documentElement.classList.remove('dark');
      })();
    </script>
  </head>
  <body class:list={[
    "min-h-screen antialiased overflow-x-hidden bg-transparent text-slate-900",
    theme === 'dashboard' ? 'dashboard-theme' : 'light-theme'
  ]}>
    <slot />
  </body>
</html>
