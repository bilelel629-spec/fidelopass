---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Mon compte commerçant — Fidelopass" activeNav="parametres">
  <div class="mb-6">
    <p class="dashboard-kicker">Compte commerçant</p>
    <h1 class="dashboard-title">Mon compte</h1>
    <p class="dashboard-subtitle">Gérez vos informations, votre abonnement et l’organisation de vos points de vente.</p>
  </div>

  <div class="mb-5 dashboard-tabs">
    <div class="grid gap-2 sm:grid-cols-3">
      <button type="button" data-tab="profil" class="account-tab dashboard-tab dashboard-tab-active">Profil</button>
      <button type="button" data-tab="abonnement" class="account-tab dashboard-tab">Abonnement</button>
      <button type="button" data-tab="organisation" class="account-tab dashboard-tab">Organisation</button>
    </div>
  </div>

  <section id="tab-profil" class="account-panel card dashboard-panel p-6">
    <h2 class="mb-5 font-display text-xl font-bold text-slate-900">Profil du commerce</h2>
    <form id="settings-form" class="flex flex-col gap-5">
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label class="label" for="nom">Nom du commerce</label>
          <input id="nom" type="text" class="input" placeholder="Ma Boutique" required />
        </div>
        <div>
          <label class="label" for="telephone">Téléphone</label>
          <input id="telephone" type="tel" class="input" placeholder="06 12 34 56 78" />
        </div>
      </div>
      <div>
        <label class="label" for="email-commerce">Email contact</label>
        <input id="email-commerce" type="email" class="input" placeholder="contact@moncommerce.fr" />
      </div>
      <div class="rounded-2xl border border-sky-100 bg-sky-50 px-4 py-3 text-sm text-slate-700">
        Adresse, géolocalisation et message de proximité se règlent dans
        <a href="/dashboard/carte" class="font-semibold text-sky-700 underline underline-offset-2">Ma carte</a>.
      </div>
      <div id="error-msg" class="hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
      <div id="success-msg" class="hidden rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700"></div>
      <button type="submit" class="btn-primary w-fit px-6 py-2.5">Enregistrer</button>
    </form>
  </section>

  <section id="tab-abonnement" class="account-panel hidden card dashboard-panel p-6">
    <h2 class="mb-5 font-display text-xl font-bold text-slate-900">Abonnement</h2>
    <div class="mb-5 rounded-2xl border border-sky-100 bg-sky-50/70 px-4 py-3 text-sm leading-6 text-slate-700">
      Votre abonnement pilote les limites de points de vente, scanners et automatisations. Pour gérer la carte bancaire ou annuler, utilisez le portail de facturation sécurisé.
    </div>
    <div class="grid gap-4 lg:grid-cols-2">
      <div class="rounded-2xl border border-sky-100 bg-sky-50/80 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-700/75">Plan actuel</p>
        <p class="mt-2 text-xl font-semibold text-slate-900"><span id="plans-current-plan">Chargement…</span></p>
        <p class="mt-1 text-sm text-slate-600">Statut: <span id="plans-current-status" class="font-semibold text-slate-900">Chargement…</span></p>
        <div class="mt-4 flex flex-col gap-2 sm:flex-row">
          <a id="plans-upgrade-btn" href="/abonnement/choix" class="btn-primary px-4 py-2.5 text-sm text-center">Changer de plan</a>
          <button id="plans-cancel-btn" type="button" class="btn-secondary px-4 py-2.5 text-sm">Gérer mon abonnement</button>
        </div>
        <p id="plans-action-feedback" class="hidden mt-3 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-700"></p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-slate-900">Résumé capacité</p>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li>Starter: 1 point de vente, 3 scanners</li>
          <li>Pro: jusqu’à 3 points de vente, 6 scanners par lieu</li>
          <li>Sur mesure: capacité adaptée à votre réseau</li>
        </ul>
        <a href="/pricing" class="btn-secondary mt-4 inline-flex px-4 py-2.5 text-sm">Voir les tarifs détaillés</a>
      </div>
    </div>
  </section>

  <section id="tab-organisation" class="account-panel hidden card dashboard-panel p-6">
    <h2 class="mb-5 font-display text-xl font-bold text-slate-900">Organisation</h2>
    <div class="mb-5 grid gap-3 sm:grid-cols-3">
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Lieu</p>
        <p class="mt-2 text-sm font-semibold text-slate-900">Point actif</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Équipe</p>
        <p class="mt-2 text-sm font-semibold text-slate-900">Scanner caisse</p>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Client</p>
        <p class="mt-2 text-sm font-semibold text-slate-900">QR de partage</p>
      </div>
    </div>
    <div class="grid gap-4 lg:grid-cols-2">
      <div class="rounded-2xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-slate-900">Point de vente actif</p>
        <p id="organisation-adresse" class="mt-2 text-sm text-slate-600">Adresse en cours de chargement…</p>
        <p id="organisation-rayon" class="mt-2 text-xs text-slate-500">Rayon de géolocalisation: —</p>
        <a href="/dashboard/points-vente" class="btn-secondary mt-4 inline-flex px-4 py-2.5 text-sm">Gérer les points de vente</a>
      </div>
      <div class="rounded-2xl border border-slate-200 bg-white p-5">
        <p class="text-sm font-semibold text-slate-900">Scanner équipe</p>
        <p class="mt-2 text-sm text-slate-600">Installez le scanner en caisse et partagez le QR client rapidement.</p>
        <div class="mt-4 flex flex-wrap gap-2">
          <a href="/app/install" class="btn-secondary px-4 py-2.5 text-sm">Installer un scanner</a>
          <a href="/dashboard/carte" class="btn-secondary px-4 py-2.5 text-sm">Afficher le QR client</a>
        </div>
      </div>
    </div>
  </section>

  <section class="mt-6 card dashboard-panel border border-red-100 p-6">
    <h2 class="mb-1 font-display font-bold text-slate-900">Déconnexion</h2>
    <p class="mb-4 text-sm text-slate-600">Vous serez redirigé vers la page de connexion.</p>
    <button id="logout-btn" class="btn-secondary border-red-200 px-5 py-2 text-red-600 hover:bg-red-50 hover:text-red-600">
      Se déconnecter
    </button>
  </section>
</DashboardLayout>

<script>
  import { authFetch } from '../../lib/api';
  import { signOut } from '../../lib/auth';
  import { planLabel } from '../../lib/dashboard-config';

  function setAccountTab(tab: string) {
    document.querySelectorAll<HTMLElement>('.account-tab').forEach((button) => {
      const active = button.dataset.tab === tab;
      button.className = active
        ? 'account-tab dashboard-tab dashboard-tab-active'
        : 'account-tab dashboard-tab';
    });
    document.querySelectorAll<HTMLElement>('.account-panel').forEach((panel) => panel.classList.add('hidden'));
    document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
  }

  document.querySelectorAll<HTMLElement>('.account-tab').forEach((button) => {
    button.addEventListener('click', () => setAccountTab(button.dataset.tab ?? 'profil'));
  });

  const requestedTab = new URLSearchParams(window.location.search).get('tab');
  if (requestedTab) setAccountTab(requestedTab);

  const form = document.getElementById('settings-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const successMsg = document.getElementById('success-msg') as HTMLDivElement;
  const plansCurrentPlan = document.getElementById('plans-current-plan') as HTMLSpanElement;
  const plansCurrentStatus = document.getElementById('plans-current-status') as HTMLSpanElement;
  const plansUpgradeBtn = document.getElementById('plans-upgrade-btn') as HTMLAnchorElement;
  const plansCancelBtn = document.getElementById('plans-cancel-btn') as HTMLButtonElement;
  const plansActionFeedback = document.getElementById('plans-action-feedback') as HTMLParagraphElement;

  function setPlansFeedback(message = '') {
    if (!message) {
      plansActionFeedback.classList.add('hidden');
      plansActionFeedback.textContent = '';
      return;
    }
    plansActionFeedback.textContent = message;
    plansActionFeedback.classList.remove('hidden');
  }

  async function loadSettings() {
    try {
      const res = await authFetch('/api/commerces/me');
      if (!res.ok) return;
      const { data } = await res.json();
      if (!data) return;

      (document.getElementById('nom') as HTMLInputElement).value = data.nom ?? '';
      (document.getElementById('telephone') as HTMLInputElement).value = data.telephone ?? '';
      (document.getElementById('email-commerce') as HTMLInputElement).value = data.email ?? '';
      document.getElementById('organisation-adresse')!.textContent = data.adresse ?? 'Adresse non renseignée';
      document.getElementById('organisation-rayon')!.textContent = `Rayon de géolocalisation: ${(data.rayon_geo ?? 1000).toLocaleString('fr-FR')} m`;
    } catch {
      // best effort
    }
  }

  async function loadPlansControls() {
    try {
      const res = await authFetch('/api/billing/status');
      if (!res.ok) throw new Error();
      const payload = await res.json();
      const data = payload?.data;
      if (!data) throw new Error();

      const rawPlan = data.plan ?? 'starter';
      const readablePlan = planLabel(rawPlan);
      const status = String(data.billing_status ?? 'unpaid');
      const hasSubscription = Boolean(data.stripe_subscription_id);

      plansCurrentPlan.textContent = readablePlan;
      plansCurrentStatus.textContent = status;

      if (readablePlan === 'STARTER') {
        plansUpgradeBtn.textContent = 'Passer au plan Pro';
        plansUpgradeBtn.href = '/abonnement/choix';
      } else if (readablePlan === 'PRO') {
        plansUpgradeBtn.textContent = 'Passer en Sur mesure';
        plansUpgradeBtn.href = '/contact';
      } else {
        plansUpgradeBtn.textContent = 'Contacter l’équipe';
        plansUpgradeBtn.href = '/contact';
      }

      plansCancelBtn.disabled = !hasSubscription;
      plansCancelBtn.classList.toggle('opacity-50', !hasSubscription);
      plansCancelBtn.classList.toggle('cursor-not-allowed', !hasSubscription);
      if (!hasSubscription) {
        setPlansFeedback('Aucun abonnement Stripe actif détecté pour le moment.');
      } else {
        setPlansFeedback('');
      }
    } catch {
      plansCurrentPlan.textContent = 'Indisponible';
      plansCurrentStatus.textContent = 'Indisponible';
      setPlansFeedback('Impossible de charger le statut d’abonnement.');
    }
  }

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    errorMsg.classList.add('hidden');
    successMsg.classList.add('hidden');
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Enregistrement...';

    try {
      const res = await authFetch('/api/commerces/me', {
        method: 'PATCH',
        body: JSON.stringify({
          nom: (document.getElementById('nom') as HTMLInputElement).value,
          telephone: (document.getElementById('telephone') as HTMLInputElement).value || null,
          email: (document.getElementById('email-commerce') as HTMLInputElement).value || null,
        }),
      });
      const payload = await res.json().catch(() => null);
      if (!res.ok) throw new Error(payload?.error ?? 'Erreur');
      successMsg.textContent = 'Profil commerçant enregistré.';
      successMsg.classList.remove('hidden');
      await loadSettings();
    } catch (error: unknown) {
      errorMsg.textContent = error instanceof Error ? error.message : 'Erreur lors de l’enregistrement.';
      errorMsg.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enregistrer';
    }
  });

  plansCancelBtn.addEventListener('click', async () => {
    setPlansFeedback('');
    plansCancelBtn.disabled = true;
    const previousLabel = plansCancelBtn.textContent;
    plansCancelBtn.textContent = 'Ouverture...';
    try {
      const res = await authFetch('/api/checkout/create-portal-session', { method: 'POST' });
      const payload = await res.json().catch(() => null);
      if (!res.ok || !payload?.url) throw new Error(payload?.error ?? 'Impossible d’ouvrir la gestion de l’abonnement.');
      window.location.href = payload.url;
    } catch (error: unknown) {
      setPlansFeedback(error instanceof Error ? error.message : 'Impossible d’ouvrir la gestion de l’abonnement.');
      plansCancelBtn.disabled = false;
      plansCancelBtn.textContent = previousLabel ?? 'Gérer mon abonnement';
    }
  });

  document.getElementById('logout-btn')!.addEventListener('click', async () => {
    await signOut();
    window.location.href = '/login';
  });

  loadSettings();
  loadPlansControls();
</script>
