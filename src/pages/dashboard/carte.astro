  async function loadExistingCarte(){
    try{
      const res=await authFetch('/api/cartes'); if(!res.ok)return;
      const {data}=await res.json(); if(!data)return;
      carteId=data.id;
      setMaxUnlockedStep(TOTAL_STEPS);
      (Array.from({ length: TOTAL_STEPS }, (_, index) => index + 1) as WizardStep[]).forEach((step) => completedSteps.add(step));
      const set=(id:string,val:string)=>{const el=document.getElementById(id) as HTMLInputElement;if(el)el.value=val;};
      set('nom-carte',data.nom??''); set('description',data.description??''); set('tampons-total',String(data.tampons_total??10));
      set('points-par-euro',String(data.points_par_euro??1)); set('points-recompense',String(data.points_recompense??100));
      set('recompense',data.recompense_description??''); set('message-geo',data.message_geo??'');
      set('couleur-fond',data.couleur_fond??'#0f172a'); set('couleur-texte',data.couleur_texte??'#ffffff'); set('couleur-accent',data.couleur_accent??'#6366f1');
      set('push-icon-bg-color', data.push_icon_bg_color ?? data.couleur_accent ?? '#6366f1');
      updatePushIconPreview();
      set('label-client',data.label_client??'Client');
      if(data.couleur_fond_2){set('couleur-fond-2',data.couleur_fond_2);if(!isGradient)gradientToggle.click();}
      if(data.gradient_angle!=null){set('gradient-angle',String(data.gradient_angle));document.getElementById('gradient-angle-val')!.textContent=`${data.gradient_angle}°`;}

      function sr(name:string,val:string){const el=document.querySelector(`input[name="${name}"][value="${val}"]`) as HTMLInputElement;if(el)el.checked=true;}
      function sl(prefix:string,opts:string[],sel:string){opts.forEach(v=>document.getElementById(`${prefix}${v}-label`)!.style.cssText=v===sel?'border-color:#60a5fa;background:rgb(239 246 255);color:#0f172a':'border-color:#dbeafe;background:#ffffff');}

      const pt=data.pattern_type??'none'; sr('pattern_type',pt); sl('pat-',['none','dots','grid','waves','diagonal','confetti'],pt);
      applyStripStyle();
      const layout=data.strip_layout??'background'; sr('strip_layout',layout);
      ['background','top','bottom'].forEach(v=>document.getElementById(`strip-layout-${v}-label`)!.style.cssText=v===layout?'border-color:#60a5fa;background:rgb(239 246 255);color:#0f172a':'border-color:#dbeafe;background:#ffffff;color:#64748b');
      const tp=data.type??'tampons'; sr('type',tp); applyTypeUI(tp);
      savedProgramType = tp === 'points' ? 'points' : 'tampons';
      typeChangePendingRevalidation = false;
      document.getElementById('type-tampons-label')!.style.cssText=tp==='tampons'?'border-color:#60a5fa;background:rgb(239 246 255);color:#0f172a':'border-color:#dbeafe;background:#ffffff';
      document.getElementById('type-points-label')!.style.cssText=tp==='points'?'border-color:#60a5fa;background:rgb(239 246 255);color:#0f172a':'border-color:#dbeafe;background:#ffffff';
      const bt=data.barcode_type??'QR'; sr('barcode_type',bt);
      ['QR','PDF417','AZTEC','NONE'].forEach(v=>document.getElementById(`barcode-${v.toLowerCase()}-label`)!.style.cssText=v===bt?'border-color:#60a5fa;background:rgb(239 246 255);color:#0f172a':'border-color:#dbeafe;background:#ffffff');
      if(data.logo_url){logoUrl=data.logo_url;setLogoPreview(logoUrl);}
      set('welcome-message', data.welcome_message ?? `Bienvenue chez ${data.nom ?? 'nous'}, créez votre carte fidélité en 10 secondes.`);
      set('success-message', data.success_message ?? 'Votre carte est prête, montrez-la à chaque passage.');
      const existingRewards = parseJsonArray<RewardTier>(data.rewards_config);
      renderRewardTiers(existingRewards);
      const multiRewardsFlag = Boolean(data.rewards_multi_enabled) || existingRewards.length > 0;
      setMultiRewardsEnabled(multiRewardsFlag, { silent: true });
      renderVipTiers(parseJsonArray<VipTier>(data.vip_tiers));
      setBrandingEnabled(data.branding_powered_by_enabled !== false, { silent: true });
      if(data.strip_url){
        stripUrl=data.strip_url;
        const focus = parseStripPosition(data.strip_position ?? '50:50');
        setStripFocus(focus.x, focus.y, { silent: true });
        setStripPreview(stripUrl);
