---
import '../styles/global.css';
import DashboardNav from '../components/dashboard/DashboardNav.astro';

interface Props {
  title?: string;
  activeNav?: string;
}

const { title = 'Dashboard — Fidelopass', activeNav = '' } = Astro.props;
const contextualHelp: Record<string, { label: string; title: string; body: string }> = {
  dashboard: {
    label: 'À quoi ça sert ?',
    title: 'Votre cockpit quotidien',
    body: 'Cette page sert à voir quoi faire maintenant: créer la carte, installer le scanner, partager le QR ou suivre les premiers retours clients.',
  },
  carte: {
    label: 'À quoi ça sert ?',
    title: 'Créer et faire évoluer votre carte',
    body: 'Chaque réglage modifie l’expérience Wallet de vos clients: identité, programme, couleurs, messages, géolocalisation et partage.',
  },
  notifications: {
    label: 'À quoi ça sert ?',
    title: 'Faire revenir vos clients',
    body: 'Utilisez cet onglet pour envoyer une offre immédiate ou activer les automatisations Wallet comme avis Google et anniversaire.',
  },
  'points-vente': {
    label: 'À quoi ça sert ?',
    title: 'Gérer vos lieux indépendamment',
    body: 'Chaque point de vente peut avoir sa carte, son adresse, son scanner et ses campagnes, surtout utile pour les commerces multi-sites.',
  },
  clients: {
    label: 'À quoi ça sert ?',
    title: 'Comprendre votre base fidèle',
    body: 'Retrouvez vos clients, leurs points ou tampons, les récompenses disponibles et les profils à relancer.',
  },
  transactions: {
    label: 'À quoi ça sert ?',
    title: 'Suivre ce qui se passe en caisse',
    body: 'L’historique permet de vérifier les scans, les ajouts de points ou tampons et les récompenses distribuées.',
  },
  parametres: {
    label: 'À quoi ça sert ?',
    title: 'Piloter votre compte commerçant',
    body: 'Retrouvez ici vos informations, votre plan, la facturation et les paramètres d’organisation.',
  },
  'assistant-carte': {
    label: 'À quoi ça sert ?',
    title: 'Confier le design à notre équipe',
    body: 'Si vous prenez l’accompagnement, notre équipe prépare une carte cohérente avec votre commerce puis vous la fait valider.',
  },
};
const help = contextualHelp[activeNav];
---

<!doctype html>
<html lang="fr" class="dashboard">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f8fafc" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const KEY = 'fidelopass-theme';
        try {
          localStorage.removeItem(KEY);
        } catch {}
        document.documentElement.dataset.theme = 'light';
        document.documentElement.classList.remove('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen bg-transparent text-slate-900 antialiased">
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -top-36 right-[-9rem] h-[32rem] w-[32rem] rounded-full bg-blue-200/40 blur-3xl"></div>
      <div class="absolute top-[22%] left-[-11rem] h-[28rem] w-[28rem] rounded-full bg-indigo-200/25 blur-3xl"></div>
      <div class="absolute bottom-[-9rem] right-[14%] h-[20rem] w-[20rem] rounded-full bg-cyan-200/25 blur-3xl"></div>
      <div class="absolute inset-x-0 top-0 h-52 bg-gradient-to-b from-white/85 to-transparent"></div>
    </div>
    <div class="flex min-h-screen lg:h-screen overflow-hidden">
      <DashboardNav activeNav={activeNav} />
      <main class="relative z-10 flex-1 min-w-0 overflow-y-auto pb-24 lg:pb-8">
        <div class="p-4 sm:p-6 md:p-8 pt-24 lg:pt-9 max-w-[86rem] mx-auto">
          {help && (
            <aside class="mb-5 rounded-[1.4rem] border border-sky-100 bg-white/82 px-4 py-3 shadow-[0_16px_38px_-34px_rgba(37,99,235,0.38)] backdrop-blur-xl sm:px-5 sm:py-4">
              <p class="text-[0.62rem] font-semibold uppercase tracking-[0.24em] text-sky-700/75">{help.label}</p>
              <div class="mt-1 flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-3">
                <h2 class="font-display text-base font-bold text-slate-900">{help.title}</h2>
                <p class="text-sm leading-6 text-slate-600">{help.body}</p>
              </div>
            </aside>
          )}
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { clearSessionCookie, setSessionCookie } from '../lib/session-cookie';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );
  const API = (import.meta.env.PUBLIC_API_URL ?? 'https://api.fidelopass.com').replace(/\/$/, '');

  type SessionLike = { access_token: string };
  type TourStep = { selector: string; title: string; body: string };

  const TOUR_STEPS: TourStep[] = [
    { selector: 'a[href="/dashboard"]', title: 'Dashboard', body: 'Suivez vos indicateurs clés et les actions prioritaires de la journée.' },
    { selector: 'a[href="/dashboard/carte"]', title: 'Ma carte', body: 'Personnalisez votre carte fidélité: visuel, programme, messages et options.' },
    { selector: 'a[href="/dashboard/notifications"]', title: 'Notifications push', body: 'Envoyez des messages immédiats ou activez vos automatisations clients.' },
    { selector: 'a[href="/dashboard/points-vente"]', title: 'Points de vente', body: 'Ajoutez vos lieux et passez facilement d’un point de vente à l’autre.' },
    { selector: 'a[href="/dashboard/clients"]', title: 'Clients', body: 'Retrouvez les clients inscrits, les récompenses disponibles et les profils à relancer.' },
    { selector: 'a[href="/dashboard/transactions"]', title: 'Historique', body: 'Vérifiez les passages en caisse, les ajouts et les récompenses distribuées.' },
    { selector: 'a[href="/dashboard/assistant-carte"]', title: 'Assistant carte', body: 'Confiez la création de la carte à notre équipe si vous avez pris l’accompagnement.' },
    { selector: 'a[href="/app"]', title: 'Scanner', body: 'Installez et ouvrez le scanner équipe pour valider les passages en caisse.' },
  ];

  function getVisibleTarget(selector: string): HTMLElement | null {
    const nodes = Array.from(document.querySelectorAll<HTMLElement>(selector));
    return nodes.find((node) => node.offsetParent !== null) ?? nodes[0] ?? null;
  }

  async function setTourSeen(accessToken: string, seen: boolean) {
    try {
      await fetch(`${API}/api/dashboard/tour-status`, {
        method: 'PATCH',
        headers: {
          Authorization: `Bearer ${accessToken}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ seen }),
      });
    } catch {
      // best effort
    }
  }

  function startDashboardTour(accessToken: string) {
    const style = document.createElement('style');
    style.textContent = `
      .dashboard-tour-highlight {
        position: relative;
        z-index: 80 !important;
        box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.55), 0 0 0 8px rgba(56, 189, 248, 0.18);
        border-radius: 1rem;
      }
    `;
    document.head.appendChild(style);

    const overlay = document.createElement('div');
    overlay.className = 'fixed inset-0 z-[75] bg-slate-900/45 backdrop-blur-[1px]';

    const card = document.createElement('div');
    card.className = 'fixed z-[85] left-1/2 -translate-x-1/2 bottom-5 w-[min(92vw,460px)] rounded-2xl border border-sky-100 bg-white p-5 shadow-2xl';
    overlay.appendChild(card);
    document.body.appendChild(overlay);

    let index = 0;
    let activeTarget: HTMLElement | null = null;

    const cleanupTarget = () => {
      if (!activeTarget) return;
      activeTarget.classList.remove('dashboard-tour-highlight');
      activeTarget = null;
    };

    const finish = async () => {
      cleanupTarget();
      overlay.remove();
      style.remove();
      await setTourSeen(accessToken, true);
    };

    const render = () => {
      const step = TOUR_STEPS[index];
      cleanupTarget();
      activeTarget = getVisibleTarget(step.selector);
      activeTarget?.classList.add('dashboard-tour-highlight');

      card.innerHTML = `
        <p class="text-[0.65rem] font-semibold uppercase tracking-[0.24em] text-sky-700/75">Guide rapide (${index + 1}/${TOUR_STEPS.length})</p>
        <h3 class="mt-2 text-lg font-display font-bold text-slate-900">${step.title}</h3>
        <p class="mt-2 text-sm text-slate-600">${step.body}</p>
        <div class="mt-4 flex items-center justify-between gap-2">
          <button type="button" id="tour-skip" class="rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 hover:bg-slate-50">
            Passer
          </button>
          <button type="button" id="tour-next" class="rounded-xl bg-sky-600 px-3.5 py-2 text-xs font-semibold text-white hover:bg-sky-700">
            ${index === TOUR_STEPS.length - 1 ? 'Terminer' : 'Suivant'}
          </button>
        </div>
      `;

      const nextBtn = card.querySelector<HTMLButtonElement>('#tour-next');
      const skipBtn = card.querySelector<HTMLButtonElement>('#tour-skip');
      nextBtn?.addEventListener('click', async () => {
        if (index >= TOUR_STEPS.length - 1) {
          await finish();
          return;
        }
        index += 1;
        render();
      });
      skipBtn?.addEventListener('click', finish);
    };

    render();
  }

  async function maybeShowTour(session: SessionLike) {
    try {
      const res = await fetch(`${API}/api/dashboard/tour-status`, {
        headers: {
          Authorization: `Bearer ${session.access_token}`,
          'Content-Type': 'application/json',
        },
      });
      if (!res.ok) return;
      const payload = await res.json().catch(() => null);
      if (payload?.data?.seen) return;
      startDashboardTour(session.access_token);
    } catch {
      // ignore
    }
  }

  async function initDashboardGuard() {
    const SESSION_PROBE_TIMEOUT_MS = Number(import.meta.env.PUBLIC_AUTH_SESSION_PROBE_TIMEOUT_MS ?? 2500);
    const timeoutSymbol = Symbol('session-timeout');
    const withSoftTimeout = <T,>(promise: Promise<T>, timeoutMs: number) => Promise.race([
      promise,
      new Promise<typeof timeoutSymbol>((resolve) => window.setTimeout(() => resolve(timeoutSymbol), timeoutMs)),
    ]);

    async function resolveSession(): Promise<{ state: 'authenticated'; session: SessionLike } | { state: 'missing' } | { state: 'unknown' }> {
      const sessionResult = await withSoftTimeout(supabase.auth.getSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null) as
        | typeof timeoutSymbol
        | { data?: { session?: SessionLike | null } }
        | null;

      if (sessionResult === timeoutSymbol) return { state: 'unknown' };
      const session = sessionResult?.data?.session ?? null;
      if (session?.access_token) return { state: 'authenticated', session };

      const refreshResult = await withSoftTimeout(supabase.auth.refreshSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null) as
        | typeof timeoutSymbol
        | { data?: { session?: SessionLike | null } }
        | null;

      if (refreshResult === timeoutSymbol) return { state: 'unknown' };
      const refreshedSession = refreshResult?.data?.session ?? null;
      if (refreshedSession?.access_token) return { state: 'authenticated', session: refreshedSession };

      return { state: 'missing' };
    }

    const resolved = await resolveSession();

    if (resolved.state === 'authenticated') {
      setSessionCookie(resolved.session.access_token);
      maybeShowTour(resolved.session);
      return;
    }

    if (resolved.state === 'unknown') {
      // Le middleware serveur protège déjà les routes dashboard via le cookie fp_session.
      // Si Supabase JS est simplement lent, ne pas envoyer l'utilisateur sur /login puis le reconnecter aussitôt.
      window.setTimeout(async () => {
        const retry = await resolveSession();
        if (retry.state === 'authenticated') setSessionCookie(retry.session.access_token);
      }, 1200);
      return;
    }

    clearSessionCookie();
    window.location.replace('/login');
  }

  initDashboardGuard();
</script>
