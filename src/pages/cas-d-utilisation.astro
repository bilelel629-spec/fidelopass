---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';

const cardCases = [
  {
    title: 'Carte de points cashback',
    description: 'Permettez à vos clients de gagner des points à chaque achat, puis de les transformer en récompenses, remises ou avantages concrets.',
  },
  {
    title: 'Carte de tampons numérique',
    description: 'Récompensez les visites répétées avec un système de fidélité simple, visible et très facile à comprendre pour le client.',
  },
  {
    title: 'Carte de membre',
    description: 'Gérez un accès, un niveau ou un statut membre pour un club, une salle de sport, un événement ou une activité premium.',
  },
];

const featureCases = [
  'Notifications push et messages Wallet',
  'Récompenses d’anniversaire',
  'Relances clients inactifs',
  'QR code en comptoir ou en vitrine',
  'Scanner mobile pour valider les passages',
  'Segmentation simple selon le programme choisi',
];

const businessCases = [
  'Boulangeries',
  'Snacks',
  'Restaurants',
  'Boucheries',
  'Coiffeurs',
  'Spas',
  'Diététiciens',
  'Esthéticiennes',
  'Instituts',
  'Concept stores',
  'Salles de sport',
  'Bars et coffee shops',
];
---

<BaseLayout
  theme="light"
  title="Cas d'utilisation — Fidelopass"
  description="Découvrez tous les cas d'utilisation de Fidelopass : cartes à points, cartes à tampons, cartes de membre, notifications push, récompenses d’anniversaire et commerces compatibles."
>
  <PublicNav currentPath="/cas-d-utilisation" />

  <section class="relative overflow-hidden bg-[linear-gradient(180deg,#ffffff_0%,#f5f9ff_65%,#ffffff_100%)] pt-14 pb-14">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-20 right-0 h-72 w-72 rounded-full bg-sky-200/35 blur-3xl"></div>
      <div class="absolute top-20 left-0 h-64 w-64 rounded-full bg-indigo-200/25 blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <span class="mb-5 inline-flex items-center rounded-full border border-sky-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-sky-700 shadow-sm">Cas d'utilisation</span>
      <h1 class="font-display text-5xl sm:text-6xl font-bold text-slate-900 leading-tight">
        Une solution pensée pour plusieurs façons de fidéliser
      </h1>
      <p class="text-slate-500 text-lg leading-relaxed mt-6 max-w-3xl mx-auto">
        Fidelopass s’adapte à votre activité, à votre type de récompense et à la manière dont vous voulez faire revenir vos clients.
      </p>
    </div>
  </section>

  <section class="bg-slate-50/70 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="font-display text-4xl font-bold text-slate-900">Programmes principaux</h2>
      </div>
      <div class="grid lg:grid-cols-3 gap-6">
        {cardCases.map((item) => (
          <article class="rounded-[1.75rem] border border-slate-200 bg-white p-7 shadow-[0_18px_45px_rgba(15,23,42,0.08)]">
            <h3 class="font-display text-2xl font-bold text-slate-900">{item.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed mt-4">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 grid lg:grid-cols-2 gap-8">
      <div class="rounded-[2rem] border border-slate-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-8 shadow-[0_20px_50px_rgba(15,23,42,0.06)]">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-700">Fonctionnalités utiles</p>
        <h2 class="font-display text-3xl font-bold text-slate-900 mt-3">Au-delà de la carte elle-même</h2>
        <div class="mt-6 space-y-3">
          {featureCases.map((item) => (
            <div class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-white p-4 text-sm shadow-sm">
              <span class="mt-1 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span>
              <span class="text-slate-600">{item}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-[0_20px_50px_rgba(15,23,42,0.06)]">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-700">Secteurs adaptés</p>
        <h2 class="font-display text-3xl font-bold text-slate-900 mt-3">Commerces et métiers compatibles</h2>
        <div class="mt-6 flex flex-wrap gap-3">
          {businessCases.map((item) => (
            <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-medium text-slate-700">{item}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[linear-gradient(135deg,#0f172a_0%,#312e81_55%,#0284c7_100%)] py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-4xl font-bold text-white">Prêt à trouver le bon format pour votre commerce ?</h2>
      <p class="text-indigo-200 text-lg mt-4">Testez Fidelopass gratuitement pendant 15 jours et choisissez le programme le plus adapté à votre activité.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/register" class="inline-flex items-center justify-center bg-white text-indigo-700 font-bold px-8 py-4 rounded-xl hover:bg-indigo-50 transition-colors text-base shadow-lg">
          Démarrer l'essai gratuit
        </a>
        <a href="/contact" class="inline-flex items-center justify-center bg-white/10 text-white font-medium px-8 py-4 rounded-xl hover:bg-white/20 border border-white/20 transition-colors text-base">
          Parler à l'équipe
        </a>
      </div>
    </div>
  </section>

  <PublicFooter />
</BaseLayout>
