---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Confirmation du compte — Fidelopass">
  <div class="relative min-h-screen overflow-hidden px-4 py-12 flex items-center justify-center bg-[linear-gradient(180deg,#ffffff_0%,#f5f9ff_62%,#ffffff_100%)]">
    <div class="pointer-events-none absolute -top-28 right-[-8rem] h-[26rem] w-[26rem] rounded-full bg-cyan-200/35 blur-3xl"></div>
    <div class="pointer-events-none absolute bottom-[-7rem] left-[-6rem] h-[22rem] w-[22rem] rounded-full bg-blue-100/80 blur-3xl"></div>
    <div class="card w-full max-w-lg border border-slate-200/80 bg-white/95 p-8 shadow-[0_24px_56px_-32px_rgba(37,99,235,0.35)]">
      <div class="text-center">
        <a href="/" class="inline-flex items-center justify-center">
          <img src="/logo-premium-cropped.png" alt="Fidelopass" class="h-16 w-auto object-contain" />
        </a>
        <h1 class="font-display text-3xl font-bold text-slate-900 mt-6">
          Confirmation de votre compte
        </h1>
        <p id="confirm-message" class="text-slate-500 mt-4 leading-relaxed">
          Validation en cours...
        </p>
        <div id="confirm-error" class="hidden mt-6 text-red-700 text-sm bg-red-50 border border-red-200 rounded-xl px-4 py-3"></div>
        <a
          id="confirm-login-link"
          href="/login"
          class="hidden mt-6 inline-flex items-center justify-center btn-primary px-6 py-3"
        >
          Aller à la connexion
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { resolvePostAuthDestination } from '../../lib/post-auth-destination';
  import { clearSessionCookie, setSessionCookie } from '../../lib/session-cookie';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const message = document.getElementById('confirm-message') as HTMLParagraphElement;
  const errorBox = document.getElementById('confirm-error') as HTMLDivElement;
  const loginLink = document.getElementById('confirm-login-link') as HTMLAnchorElement;
  let redirectInFlight = false;
  const SESSION_PROBE_TIMEOUT_MS = Number(import.meta.env.PUBLIC_AUTH_SESSION_PROBE_TIMEOUT_MS ?? 1800);

  async function getValidSession() {
    const sessionResult = await Promise.race([
      supabase.auth.getSession(),
      new Promise<null>((resolve) => window.setTimeout(() => resolve(null), SESSION_PROBE_TIMEOUT_MS)),
    ]);
    if (!sessionResult) return null;
    const session = sessionResult?.data?.session ?? null;
    if (session?.access_token) return session;

    const refreshResult = await Promise.race([
      supabase.auth.refreshSession(),
      new Promise<null>((resolve) => window.setTimeout(() => resolve(null), SESSION_PROBE_TIMEOUT_MS)),
    ]);
    if (!refreshResult) return null;
    const refreshed = refreshResult?.data?.session ?? null;
    if (refreshed?.access_token) return refreshed;
    return null;
  }

  async function redirectAfterAuth() {
    if (redirectInFlight) return;
    redirectInFlight = true;
    try {
      const session = await getValidSession();
      if (!session) {
        clearSessionCookie();
        window.location.href = '/login';
        return;
      }

      setSessionCookie(session.access_token);
      const target = await resolvePostAuthDestination(session.access_token);
      if (target === '/login') {
        clearSessionCookie();
        await supabase.auth.signOut().catch(() => undefined);
        window.location.href = '/login';
        return;
      }

      window.location.replace(target);
    } finally {
      redirectInFlight = false;
    }
  }

  async function confirmFromEmailLink() {
    const params = new URLSearchParams(window.location.search);
    const tokenHash = params.get('token_hash');
    const rawType = params.get('type') ?? 'email';
    const type = (rawType === 'signup' ? 'email' : rawType) as 'email' | 'recovery' | 'invite' | 'email_change';

    if (!tokenHash) {
      message.textContent = 'Lien incomplet. Demandez un nouvel email de confirmation.';
      loginLink.classList.remove('hidden');
      return;
    }

    const { error } = await supabase.auth.verifyOtp({
      token_hash: tokenHash,
      type,
    });

    if (error) {
      message.textContent = 'Impossible de confirmer votre compte.';
      errorBox.textContent = error.message ?? 'Le lien de confirmation est invalide ou expiré.';
      errorBox.classList.remove('hidden');
      loginLink.classList.remove('hidden');
      return;
    }

    message.textContent = 'Compte confirmé. Redirection...';
    await redirectAfterAuth();
  }

  // Le SDK Supabase échange automatiquement le fragment #access_token au premier getSession().
  // Ce cas couvre les callbacks OAuth (Apple, Google) qui redirigent ici.
  const hasOAuthHash = window.location.hash.includes('access_token=');
  const oauthSession = await getValidSession();
  if (oauthSession) {
    message.textContent = 'Connexion réussie. Redirection...';
    await redirectAfterAuth();
  } else if (hasOAuthHash) {
    message.textContent = 'Finalisation de la connexion...';
    await new Promise((resolve) => window.setTimeout(resolve, 700));
    const retriedSession = await getValidSession();
    if (retriedSession) {
      await redirectAfterAuth();
    } else {
      message.textContent = 'La connexion a expiré. Merci de réessayer.';
      loginLink.classList.remove('hidden');
    }
  } else {
    await confirmFromEmailLink();
  }
</script>
