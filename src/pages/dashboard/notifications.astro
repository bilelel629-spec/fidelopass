---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Notifications push — Fidelopass" activeNav="notifications">
  <div class="mb-6">
    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.26em] text-sky-700/70">Communication client</p>
    <h1 class="mt-2 font-display text-3xl font-bold text-slate-900">Notifications push</h1>
    <p class="mt-2 text-sm text-slate-600">Envoyez un message immédiat ou activez des automatisations pour vos clients Wallet.</p>
  </div>

  <div class="mb-5 grid gap-4 sm:grid-cols-2">
    <div class="card p-5">
      <p class="text-slate-500 text-xs uppercase tracking-wide">Clients joignables Wallet</p>
      <p id="summary-wallet" class="mt-2 text-2xl font-display font-bold text-slate-900">—</p>
      <p class="mt-1 text-xs text-slate-500">Apple Wallet + Google Wallet</p>
    </div>
    <div class="card p-5">
      <p class="text-slate-500 text-xs uppercase tracking-wide">Campagnes envoyées</p>
      <p id="summary-history" class="mt-2 text-2xl font-display font-bold text-slate-900">—</p>
      <p class="mt-1 text-xs text-slate-500">Historique du point de vente actif</p>
    </div>
  </div>

  <div class="mb-5 rounded-2xl border border-sky-100 bg-white p-2">
    <div class="grid gap-2 sm:grid-cols-3">
      <button type="button" data-tab="manual" class="notif-tab rounded-xl bg-sky-100 px-4 py-2.5 text-sm font-semibold text-sky-800">Envoi manuel</button>
      <button type="button" data-tab="automation" class="notif-tab rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-50">Automatisations</button>
      <button type="button" data-tab="history" class="notif-tab rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-50">Historique</button>
    </div>
  </div>

  <section id="tab-manual" class="notif-panel card p-6">
    <h2 class="mb-4 font-display font-bold text-slate-900">Nouveau message client</h2>
    <form id="notif-form" class="flex flex-col gap-4">
      <div>
        <label class="label" for="titre">Titre</label>
        <input id="titre" type="text" class="input" placeholder="Ex: Offre du weekend" maxlength="50" required />
      </div>
      <div>
        <label class="label" for="message">Message</label>
        <textarea id="message" class="input h-24 resize-none" placeholder="Ex: -20% ce samedi pour les membres fidélité." maxlength="150" required></textarea>
        <span class="mt-1 block text-right text-xs text-slate-500"><span id="char-count">0</span>/150</span>
      </div>
      <div id="error-msg" class="hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
      <div id="success-msg" class="hidden rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700"></div>
      <button type="submit" class="btn-primary py-3">Envoyer le message</button>
    </form>
  </section>

  <section id="tab-automation" class="notif-panel hidden space-y-5">
    <div class="card border-sky-100 bg-sky-50/40 p-6">
      <div class="mb-4 flex items-start justify-between gap-3">
        <div>
          <h2 class="font-display font-bold text-slate-900">Avis Google automatique (+1h)</h2>
          <p class="mt-1 text-sm text-slate-500">Push envoyé 60 minutes après l’installation de la carte.</p>
        </div>
        <span class="rounded-full border border-amber-200 bg-amber-100 px-2 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-amber-700">Pro uniquement</span>
      </div>
      <div class="mb-4 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600">
        Plan actuel: <span id="review-auto-plan-value" class="font-semibold text-slate-900">Chargement...</span>
      </div>
      <div id="review-auto-locked" class="mb-4 hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700">
        Cette fonctionnalité est réservée au plan Pro.
      </div>
      <div id="review-auto-error" class="mb-3 hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
      <div id="review-auto-success" class="mb-3 hidden rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700"></div>
      <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3">
        <div>
          <p class="text-sm font-medium text-slate-800">Activer l’automatisation</p>
          <p class="mt-0.5 text-xs text-slate-500">Utilise le lien Google Maps du point de vente actif.</p>
        </div>
        <button id="review-auto-toggle" type="button" class="relative h-6 w-12 flex-shrink-0 rounded-full transition-colors" style="background:#334155" aria-pressed="false">
          <span id="review-auto-knob" class="absolute top-0.5 h-5 w-5 rounded-full bg-white shadow transition-all" style="left:2px"></span>
        </button>
      </div>
      <p id="review-auto-status" class="mt-2 text-center text-xs text-slate-500">Chargement du statut...</p>
    </div>

    <div class="card border-pink-100 bg-pink-50/40 p-6">
      <div class="mb-4 flex items-start justify-between gap-3">
        <div>
          <h2 class="font-display font-bold text-slate-900">Anniversaire automatique (jour J à 10h)</h2>
          <p class="mt-1 text-sm text-slate-500">Push anniversaire + bonus automatique sur la carte client.</p>
        </div>
        <span class="rounded-full border border-amber-200 bg-amber-100 px-2 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-amber-700">Pro uniquement</span>
      </div>
      <div class="mb-4 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-600">
        Plan actuel: <span id="birthday-plan-value" class="font-semibold text-slate-900">Chargement...</span>
      </div>
      <div id="birthday-locked" class="mb-4 hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700">
        Cette fonctionnalité est réservée au plan Pro.
      </div>
      <div id="birthday-error" class="mb-3 hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
      <div id="birthday-success" class="mb-3 hidden rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700"></div>

      <div class="mb-4 space-y-3">
        <div>
          <label class="label" for="birthday-reward-value">Bonus anniversaire (tampon/point)</label>
          <input id="birthday-reward-value" type="number" min="1" max="50" value="1" class="input" />
        </div>
        <div>
          <label class="label" for="birthday-title">Titre du push</label>
          <input id="birthday-title" type="text" maxlength="80" class="input" placeholder="Joyeux anniversaire 🎉" />
        </div>
        <div>
          <label class="label" for="birthday-message">Message du push</label>
          <textarea id="birthday-message" maxlength="180" class="input h-24 resize-none" placeholder="Votre bonus anniversaire est disponible sur votre carte Fidelopass."></textarea>
        </div>
      </div>
      <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3">
        <div>
          <p class="text-sm font-medium text-slate-800">Activer l’automatisation anniversaire</p>
          <p class="mt-0.5 text-xs text-slate-500">Execution Europe/Paris à 10h.</p>
        </div>
        <button id="birthday-toggle" type="button" class="relative h-6 w-12 flex-shrink-0 rounded-full transition-colors" style="background:#334155" aria-pressed="false">
          <span id="birthday-knob" class="absolute top-0.5 h-5 w-5 rounded-full bg-white shadow transition-all" style="left:2px"></span>
        </button>
      </div>
      <p id="birthday-status" class="mt-2 text-center text-xs text-slate-500">Chargement du statut...</p>
    </div>
  </section>

  <section id="tab-history" class="notif-panel hidden card p-6">
    <h2 class="mb-4 font-display font-bold text-slate-900">Historique des messages</h2>
    <div id="notif-history" class="flex flex-col gap-3">
      <p class="text-sm text-slate-500">Chargement...</p>
    </div>
  </section>
</DashboardLayout>

<script>
  import { authFetch } from '../../lib/api';
  import { isProPlan, normalizePlan } from '../../lib/dashboard-config';

  function escapeHtml(value: unknown) {
    return String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;',
    }[char] ?? char));
  }

  function setNotifTab(tab: 'manual' | 'automation' | 'history') {
    document.querySelectorAll<HTMLElement>('.notif-panel').forEach((panel) => panel.classList.add('hidden'));
    document.getElementById(`tab-${tab}`)?.classList.remove('hidden');

    document.querySelectorAll<HTMLElement>('.notif-tab').forEach((btn) => {
      const active = btn.dataset.tab === tab;
      btn.className = active
        ? 'notif-tab rounded-xl bg-sky-100 px-4 py-2.5 text-sm font-semibold text-sky-800'
        : 'notif-tab rounded-xl px-4 py-2.5 text-sm font-semibold text-slate-600 hover:bg-slate-50';
    });
  }

  document.querySelectorAll<HTMLElement>('.notif-tab').forEach((btn) => {
    btn.addEventListener('click', () => setNotifTab((btn.dataset.tab as 'manual' | 'automation' | 'history') ?? 'manual'));
  });

  const messageInput = document.getElementById('message') as HTMLTextAreaElement;
  const charCount = document.getElementById('char-count') as HTMLSpanElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const successMsg = document.getElementById('success-msg') as HTMLDivElement;
  const form = document.getElementById('notif-form') as HTMLFormElement;

  messageInput.addEventListener('input', () => {
    charCount.textContent = String(messageInput.value.length);
  });

  let summaryWallet = 0;
  let summaryHistory = 0;
  let reviewAutoEnabled = false;
  let reviewAutoIsPro = false;
  let birthdayEnabled = false;
  let birthdayIsPro = false;

  const reviewAutoToggle = document.getElementById('review-auto-toggle') as HTMLButtonElement;
  const reviewAutoKnob = document.getElementById('review-auto-knob') as HTMLSpanElement;
  const reviewAutoStatus = document.getElementById('review-auto-status') as HTMLParagraphElement;
  const reviewAutoPlanValue = document.getElementById('review-auto-plan-value') as HTMLSpanElement;
  const reviewAutoLocked = document.getElementById('review-auto-locked') as HTMLDivElement;
  const reviewAutoError = document.getElementById('review-auto-error') as HTMLDivElement;
  const reviewAutoSuccess = document.getElementById('review-auto-success') as HTMLDivElement;

  const birthdayToggle = document.getElementById('birthday-toggle') as HTMLButtonElement;
  const birthdayKnob = document.getElementById('birthday-knob') as HTMLSpanElement;
  const birthdayStatus = document.getElementById('birthday-status') as HTMLParagraphElement;
  const birthdayPlanValue = document.getElementById('birthday-plan-value') as HTMLSpanElement;
  const birthdayLocked = document.getElementById('birthday-locked') as HTMLDivElement;
  const birthdayError = document.getElementById('birthday-error') as HTMLDivElement;
  const birthdaySuccess = document.getElementById('birthday-success') as HTMLDivElement;
  const birthdayRewardValue = document.getElementById('birthday-reward-value') as HTMLInputElement;
  const birthdayTitle = document.getElementById('birthday-title') as HTMLInputElement;
  const birthdayMessage = document.getElementById('birthday-message') as HTMLTextAreaElement;

  function setReviewPlanLabel(planRaw: unknown) {
    const normalized = normalizePlan(planRaw);
    if (normalized.includes('sur-mesure') || normalized.includes('surmesure') || normalized.includes('custom') || normalized.includes('enterprise')) {
      reviewAutoPlanValue.textContent = 'Sur mesure';
      return;
    }
    reviewAutoPlanValue.textContent = isProPlan(normalized) ? 'Pro' : 'Starter';
  }

  function setReviewToggle(enabled: boolean) {
    reviewAutoEnabled = enabled;
    reviewAutoToggle.style.background = enabled ? '#4f46e5' : '#334155';
    reviewAutoKnob.style.left = enabled ? '26px' : '2px';
    reviewAutoToggle.setAttribute('aria-pressed', String(enabled));
    reviewAutoStatus.textContent = enabled ? 'Automatisation active.' : 'Automatisation inactive.';
  }

  function setBirthdayPlanLabel(planRaw: unknown) {
    const normalized = normalizePlan(planRaw);
    if (normalized.includes('sur-mesure') || normalized.includes('surmesure') || normalized.includes('custom') || normalized.includes('enterprise')) {
      birthdayPlanValue.textContent = 'Sur mesure';
      return;
    }
    birthdayPlanValue.textContent = isProPlan(normalized) ? 'Pro' : 'Starter';
  }

  function setBirthdayToggle(enabled: boolean) {
    birthdayEnabled = enabled;
    birthdayToggle.style.background = enabled ? '#4f46e5' : '#334155';
    birthdayKnob.style.left = enabled ? '26px' : '2px';
    birthdayToggle.setAttribute('aria-pressed', String(enabled));
    birthdayStatus.textContent = enabled ? 'Automatisation active.' : 'Automatisation inactive.';
  }

  function setBirthdayFormDisabled(disabled: boolean) {
    birthdayToggle.disabled = disabled;
    birthdayRewardValue.disabled = disabled;
    birthdayTitle.disabled = disabled;
    birthdayMessage.disabled = disabled;
    birthdayToggle.classList.toggle('opacity-40', disabled);
    birthdayToggle.classList.toggle('cursor-not-allowed', disabled);
  }

  async function loadSummary() {
    try {
      const [summaryRes, historyRes] = await Promise.all([
        authFetch('/api/notifications/summary'),
        authFetch('/api/notifications?limit=50'),
      ]);
      const summaryPayload = await summaryRes.json().catch(() => null);
      const historyPayload = await historyRes.json().catch(() => null);

      summaryWallet = summaryPayload?.data?.wallet_ready ?? 0;
      summaryHistory = Array.isArray(historyPayload?.data) ? historyPayload.data.length : 0;

      document.getElementById('summary-wallet')!.textContent = String(summaryWallet);
      document.getElementById('summary-history')!.textContent = String(summaryHistory);
    } catch {
      document.getElementById('summary-wallet')!.textContent = '—';
      document.getElementById('summary-history')!.textContent = '—';
    }
  }

  async function loadHistory() {
    const container = document.getElementById('notif-history')!;
    try {
      const res = await authFetch('/api/notifications?limit=20');
      if (!res.ok) throw new Error();
      const { data } = await res.json();

      if (!data?.length) {
        container.innerHTML = '<p class="text-slate-500 text-sm">Aucune notification envoyée.</p>';
        return;
      }

      container.innerHTML = data.map((n: { titre: string; message: string; nb_destinataires: number; nb_delivrees: number | null; created_at: string }) => `
        <div class="border-b border-slate-200 pb-3 last:border-0 last:pb-0">
          <div class="flex items-start justify-between gap-2">
            <div>
              <p class="text-sm font-medium text-slate-900">${escapeHtml(n.titre)}</p>
              <p class="mt-0.5 text-xs text-slate-600">${escapeHtml(n.message)}</p>
            </div>
            <span class="badge badge-info shrink-0">${n.nb_delivrees ?? 0}/${n.nb_destinataires}</span>
          </div>
          <p class="mt-1 text-xs text-slate-500">${new Date(n.created_at).toLocaleString('fr-FR')}</p>
        </div>
      `).join('');
    } catch {
      container.innerHTML = '<p class="text-red-600 text-sm">Erreur lors du chargement.</p>';
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    successMsg.classList.add('hidden');
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';

    try {
      const titre = (document.getElementById('titre') as HTMLInputElement).value.trim();
      const message = messageInput.value.trim();
      const res = await authFetch('/api/notifications', {
        method: 'POST',
        body: JSON.stringify({ titre, message }),
      });
      const data = await res.json().catch(() => null);
      if (!res.ok) throw new Error(data?.error ?? 'Erreur lors de l’envoi.');

      successMsg.textContent = data?.nb_destinataires === 0
        ? 'Aucun client joignable pour le moment.'
        : `Message envoyé à ${data?.nb_delivrees ?? 0}/${data?.nb_destinataires ?? 0} client(s).`;
      successMsg.classList.remove('hidden');
      form.reset();
      charCount.textContent = '0';
      await Promise.all([loadSummary(), loadHistory()]);
    } catch (error: unknown) {
      errorMsg.textContent = error instanceof Error ? error.message : 'Erreur réseau.';
      errorMsg.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Envoyer le message';
    }
  });

  async function loadReviewAutoSettings() {
    try {
      const res = await authFetch('/api/notifications/review-reminder-settings');
      const payload = await res.json().catch(() => null);
      if (!res.ok) throw new Error(payload?.error ?? 'Impossible de charger le réglage.');

      reviewAutoIsPro = Boolean(payload?.data?.is_pro) || isProPlan(payload?.data?.plan ?? payload?.data?.raw_plan);
      setReviewPlanLabel(payload?.data?.plan);
      setReviewToggle(Boolean(payload?.data?.enabled));

      if (!reviewAutoIsPro) {
        reviewAutoLocked.classList.remove('hidden');
        reviewAutoToggle.disabled = true;
        reviewAutoToggle.classList.add('opacity-40', 'cursor-not-allowed');
      } else {
        reviewAutoLocked.classList.add('hidden');
        reviewAutoToggle.disabled = false;
        reviewAutoToggle.classList.remove('opacity-40', 'cursor-not-allowed');
      }
    } catch {
      setReviewPlanLabel('starter');
      setReviewToggle(false);
      reviewAutoToggle.disabled = true;
      reviewAutoLocked.classList.remove('hidden');
      reviewAutoStatus.textContent = 'Impossible de charger le statut pour le moment.';
    }
  }

  reviewAutoToggle.addEventListener('click', async () => {
    if (!reviewAutoIsPro) return;
    reviewAutoError.classList.add('hidden');
    reviewAutoSuccess.classList.add('hidden');
    reviewAutoToggle.disabled = true;

    try {
      const nextValue = !reviewAutoEnabled;
      const res = await authFetch('/api/notifications/review-reminder-settings', {
        method: 'PATCH',
        body: JSON.stringify({ enabled: nextValue }),
      });
      const payload = await res.json().catch(() => null);
      if (!res.ok) throw new Error(payload?.error ?? 'Impossible de mettre à jour le réglage.');
      setReviewToggle(nextValue);
      reviewAutoSuccess.textContent = nextValue ? 'Automatisation activée.' : 'Automatisation désactivée.';
      reviewAutoSuccess.classList.remove('hidden');
    } catch (error: unknown) {
      reviewAutoError.textContent = error instanceof Error ? error.message : 'Erreur réseau.';
      reviewAutoError.classList.remove('hidden');
    } finally {
      reviewAutoToggle.disabled = false;
    }
  });

  async function loadBirthdaySettings() {
    try {
      const res = await authFetch('/api/notifications/birthday-settings');
      const payload = await res.json().catch(() => null);
      if (!res.ok) throw new Error(payload?.error ?? 'Impossible de charger le réglage anniversaire.');

      birthdayIsPro = Boolean(payload?.data?.is_pro) || isProPlan(payload?.data?.plan ?? payload?.data?.raw_plan);
      setBirthdayPlanLabel(payload?.data?.plan);
      setBirthdayToggle(Boolean(payload?.data?.enabled));
      birthdayRewardValue.value = String(payload?.data?.reward_value ?? 1);
      birthdayTitle.value = String(payload?.data?.push_title ?? '');
      birthdayMessage.value = String(payload?.data?.push_message ?? '');

      if (!payload?.data?.has_active_card) {
        setBirthdayFormDisabled(true);
        birthdayStatus.textContent = 'Aucune carte active sur ce point de vente.';
        return;
      }

      if (!birthdayIsPro) {
        birthdayLocked.classList.remove('hidden');
        setBirthdayFormDisabled(true);
      } else {
        birthdayLocked.classList.add('hidden');
        setBirthdayFormDisabled(false);
      }
    } catch {
      setBirthdayPlanLabel('starter');
      setBirthdayToggle(false);
      birthdayLocked.classList.remove('hidden');
      setBirthdayFormDisabled(true);
      birthdayStatus.textContent = 'Impossible de charger le statut pour le moment.';
    }
  }

  async function persistBirthdaySettings(nextEnabled: boolean) {
    const rewardValue = Number.parseInt(birthdayRewardValue.value, 10);
    if (!Number.isFinite(rewardValue) || rewardValue < 1 || rewardValue > 50) {
      throw new Error('Le bonus anniversaire doit être compris entre 1 et 50.');
    }
    const res = await authFetch('/api/notifications/birthday-settings', {
      method: 'PATCH',
      body: JSON.stringify({
        enabled: nextEnabled,
        reward_value: rewardValue,
        push_title: birthdayTitle.value.trim() || null,
        push_message: birthdayMessage.value.trim() || null,
      }),
    });
    const payload = await res.json().catch(() => null);
    if (!res.ok) throw new Error(payload?.error ?? 'Impossible de mettre à jour le réglage anniversaire.');
    return payload;
  }

  birthdayToggle.addEventListener('click', async () => {
    if (!birthdayIsPro) return;
    birthdayError.classList.add('hidden');
    birthdaySuccess.classList.add('hidden');
    setBirthdayFormDisabled(true);

    try {
      const nextEnabled = !birthdayEnabled;
      const payload = await persistBirthdaySettings(nextEnabled);
      setBirthdayToggle(Boolean(payload?.data?.enabled));
      birthdaySuccess.textContent = nextEnabled ? 'Programmation anniversaire activée.' : 'Programmation anniversaire désactivée.';
      birthdaySuccess.classList.remove('hidden');
    } catch (error: unknown) {
      birthdayError.textContent = error instanceof Error ? error.message : 'Erreur réseau.';
      birthdayError.classList.remove('hidden');
    } finally {
      setBirthdayFormDisabled(!birthdayIsPro);
    }
  });

  [birthdayRewardValue, birthdayTitle, birthdayMessage].forEach((field) => {
    field.addEventListener('change', async () => {
      if (!birthdayIsPro) return;
      birthdayError.classList.add('hidden');
      birthdaySuccess.classList.add('hidden');
      try {
        await persistBirthdaySettings(birthdayEnabled);
        birthdaySuccess.textContent = 'Réglage anniversaire enregistré.';
        birthdaySuccess.classList.remove('hidden');
      } catch (error: unknown) {
        birthdayError.textContent = error instanceof Error ? error.message : 'Erreur réseau.';
        birthdayError.classList.remove('hidden');
      }
    });
  });

  setNotifTab('manual');
  loadSummary();
  loadHistory();
  loadReviewAutoSettings();
  loadBirthdaySettings();
</script>

