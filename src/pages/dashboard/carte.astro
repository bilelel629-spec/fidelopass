---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Ma carte — Fidelopass" activeNav="carte">
  <div class="mb-8">
    <h1 class="font-display text-2xl font-bold text-white">Ma carte de fidélité</h1>
    <p class="text-slate-400 text-sm mt-1">Personnalisez l'apparence et le comportement de votre carte Wallet</p>
  </div>

  <div id="setup-banner" class="hidden mb-6 rounded-2xl border border-indigo-400/20 bg-indigo-500/10 px-5 py-4">
    <p class="text-white font-medium">Dernière étape de l’onboarding</p>
    <p class="text-slate-300 text-sm mt-1">
      Vous êtes maintenant dans l’éditeur complet. Créez votre première carte avec toutes les options de personnalisation, puis partagez son lien public à vos clients.
    </p>
  </div>

  <div id="public-link-banner" class="hidden mb-6 p-4 bg-emerald-500/10 border border-emerald-500/20 rounded-xl flex items-center justify-between gap-4">
    <div>
      <p class="text-emerald-400 text-sm font-medium">Votre carte est publiée ✓</p>
      <p id="public-link-url" class="text-slate-400 text-xs mt-0.5"></p>
    </div>
    <button id="copy-link-btn" class="shrink-0 text-xs px-3 py-1.5 rounded-lg bg-emerald-500/20 text-emerald-300 hover:bg-emerald-500/30 transition-colors">Copier le lien</button>
  </div>

  <div class="grid lg:grid-cols-[1fr_370px] gap-6 items-start">

    <div class="flex flex-col gap-5">

      <!-- Modèles métier -->
      <div class="card p-6">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
          <div>
            <h2 class="font-display font-bold text-white flex items-center gap-2"><span class="text-lg">⚡</span> Modèles rapides</h2>
            <p class="text-slate-400 text-sm mt-1">Choisissez un style de départ, puis ajustez les détails. Tout ici est compatible avec le rendu Wallet.</p>
          </div>
          <span class="text-xs text-emerald-300 bg-emerald-500/10 border border-emerald-400/20 rounded-full px-3 py-1 w-fit">Recommandé pour démarrer</span>
        </div>
        <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-3">
          {[
            {name:'Café cosy', icon:'☕', fond:'#2b1608', texte:'#fff7ed', accent:'#d97706', fond2:'#5f3214', pattern:'waves', layout:'bottom', stamp:'☕', type:'tampons', total:'10', reward:'1 boisson offerte', label:'Client', desc:'10 passages = 1 boisson offerte', message:'Votre café vous attend !'},
            {name:'Restaurant', icon:'🍽️', fond:'#111827', texte:'#fff7ed', accent:'#f97316', fond2:'#7c2d12', pattern:'diagonal', layout:'top', stamp:'🍽️', type:'tampons', total:'8', reward:'1 dessert offert', label:'Table fidèle', desc:'Cumulez des tampons à chaque repas', message:'Une récompense vous attend au restaurant.'},
            {name:'Institut beauté', icon:'✨', fond:'#4a102a', texte:'#fff1f2', accent:'#f472b6', fond2:'#831843', pattern:'confetti', layout:'bottom', stamp:'✨', type:'tampons', total:'6', reward:'-20% sur un soin', label:'Cliente', desc:'Votre carte privilège beauté', message:'Votre avantage beauté est disponible.'},
            {name:'Barber shop', icon:'✂️', fond:'#0f172a', texte:'#f8fafc', accent:'#38bdf8', fond2:'#1e3a8a', pattern:'grid', layout:'top', stamp:'✂️', type:'tampons', total:'8', reward:'1 coupe offerte', label:'Client', desc:'Une coupe offerte après 8 passages', message:'Votre barber vous attend.'},
            {name:'Boutique premium', icon:'🛍️', fond:'#030712', texte:'#fefce8', accent:'#d4af37', fond2:'#422006', pattern:'dots', layout:'background', stamp:'🛍️', type:'points', total:'10', reward:'10€ de réduction', label:'Membre', desc:'Cumulez des points à chaque achat', message:'Votre avantage fidélité est disponible en boutique.'},
            {name:'Sport & coaching', icon:'🏆', fond:'#022c22', texte:'#ecfdf5', accent:'#22c55e', fond2:'#064e3b', pattern:'diagonal', layout:'background', stamp:'🏆', type:'points', total:'10', reward:'1 séance offerte', label:'Athlète', desc:'Transformez vos visites en récompenses', message:'Votre coach vous attend.'},
          ].map((preset) => (
            <button
              type="button"
              class="business-template-btn text-left rounded-2xl border border-white/10 bg-white/[0.03] p-4 hover:border-indigo-400/60 hover:bg-indigo-500/10 transition-all"
              data-name={preset.name}
              data-icon={preset.icon}
              data-fond={preset.fond}
              data-texte={preset.texte}
              data-accent={preset.accent}
              data-fond2={preset.fond2}
              data-pattern={preset.pattern}
              data-layout={preset.layout}
              data-stamp={preset.stamp}
              data-type={preset.type}
              data-total={preset.total}
              data-reward={preset.reward}
              data-label={preset.label}
              data-desc={preset.desc}
              data-message={preset.message}
            >
              <div class="flex items-center gap-3">
                <span class="text-2xl">{preset.icon}</span>
                <div>
                  <p class="text-white text-sm font-semibold">{preset.name}</p>
                  <p class="text-slate-400 text-xs mt-0.5">{preset.reward}</p>
                </div>
              </div>
              <div class="mt-3 h-10 rounded-xl border border-white/10" style={`background:linear-gradient(135deg,${preset.fond},${preset.fond2})`}>
                <div class="h-full w-1/3 rounded-l-xl" style={`background:${preset.accent}`}></div>
              </div>
            </button>
          ))}
        </div>
      </div>

      <!-- Identité visuelle -->
      <div class="card p-6">
        <h2 class="font-display font-bold text-white mb-5 flex items-center gap-2"><span class="text-lg">🖼️</span> Identité visuelle</h2>
        <div class="grid sm:grid-cols-3 gap-5">

          <div>
            <label class="label mb-2 block">Logo</label>
            <div class="flex flex-col items-center gap-2">
              <div id="logo-preview-wrap" class="w-16 h-16 rounded-xl flex items-center justify-center border border-white/10 overflow-hidden" style="background:#1e293b">
                <img id="logo-preview-img" class="hidden w-full h-full object-cover" />
                <span id="logo-preview-icon" class="text-2xl text-slate-500">🏪</span>
              </div>
              <input type="file" id="logo-file" accept="image/png,image/jpeg,image/webp" class="hidden" />
              <button type="button" id="logo-btn" class="btn-secondary text-xs py-1.5 px-3 w-full">Choisir</button>
              <button type="button" id="logo-palette-btn" class="btn-secondary text-xs py-1.5 px-3 w-full text-emerald-300">Générer une palette</button>
              <input type="hidden" id="logo-url" />
              <p id="logo-loading" class="hidden text-indigo-400 text-xs">Upload...</p>
              <p class="text-slate-600 text-xs text-center leading-tight">PNG/JPG carré<br/>Recommandé : 120×120 px</p>
            </div>
          </div>

          <div>
            <label class="label mb-2 block">Icône de tampon</label>
            <div class="flex gap-1.5 mb-3">
              <label id="tampon-mode-default-label" class="flex-1 cursor-pointer rounded-xl border-2 p-2 text-center transition-all" style="border-color:#6366f1;background:rgb(99 102 241/0.1)">
                <input type="radio" name="tampon_mode" value="default" class="hidden" checked /><div class="text-base mb-0.5">✓</div><div class="text-white text-xs font-medium">Défaut</div>
              </label>
              <label id="tampon-mode-emoji-label" class="flex-1 cursor-pointer rounded-xl border-2 p-2 text-center transition-all" style="border-color:#334155;background:transparent">
                <input type="radio" name="tampon_mode" value="emoji" class="hidden" /><div class="text-base mb-0.5">😀</div><div class="text-white text-xs font-medium">Emoji</div>
              </label>
              <label id="tampon-mode-custom-label" class="flex-1 cursor-pointer rounded-xl border-2 p-2 text-center transition-all" style="border-color:#334155;background:transparent">
                <input type="radio" name="tampon_mode" value="custom" class="hidden" /><div class="text-base mb-0.5">🖼️</div><div class="text-white text-xs font-medium">Image</div>
              </label>
            </div>
            <div id="tampon-emoji-zone" class="hidden">
              <p class="text-slate-500 text-xs mb-1.5">Sélectionnez un emoji</p>
              <div class="grid grid-cols-6 gap-1">
                {['☕','🍩','⭐','🎁','❤️','🏆','🍕','🎫','💎','🔥','🎉','✨','🍦','🥐','🛍️','🌟','🎵','🍰','🍽️','✂️','💅','🏋️'].map(e => (
                  <button type="button" class="emoji-stamp-btn w-9 h-9 rounded-lg text-xl hover:bg-white/10 transition-all flex items-center justify-center border-2 border-transparent" data-emoji={e}>{e}</button>
                ))}
              </div>
              <input type="hidden" id="tampon-emoji" />
              <p id="tampon-emoji-selected" class="hidden text-xs text-indigo-400 mt-1.5">Sélectionné : <span id="tampon-emoji-val"></span></p>
            </div>
            <div id="tampon-custom-zone" class="hidden flex flex-col items-center gap-2">
              <div class="w-14 h-14 rounded-full flex items-center justify-center border border-white/10 overflow-hidden" style="background:#1e293b">
                <img id="tampon-preview-img" class="hidden w-full h-full object-cover rounded-full" />
                <span id="tampon-preview-icon" class="text-xl text-slate-500">🔖</span>
              </div>
              <input type="file" id="tampon-file" accept="image/png,image/jpeg,image/webp" class="hidden" />
              <button type="button" id="tampon-btn" class="btn-secondary text-xs py-1.5 px-3 w-full">Choisir image</button>
              <input type="hidden" id="tampon-icon-url" />
              <p id="tampon-loading" class="hidden text-indigo-400 text-xs">Upload...</p>
              <p class="text-slate-600 text-xs text-center leading-tight">PNG transparent — 64×64 px</p>
            </div>
          </div>

          <div>
            <label class="label mb-2 block">Bannière <span class="text-slate-500 font-normal text-xs">(fond)</span></label>
            <div class="flex flex-col gap-2">
              <div class="w-full h-16 rounded-xl border border-white/10 overflow-hidden flex items-center justify-center relative" style="background:#1e293b">
                <img id="strip-preview-img" class="hidden w-full h-full object-cover" style="object-position:center" />
                <span id="strip-preview-icon" class="text-slate-500 text-xs">Aucune image</span>
              </div>
              <div class="flex gap-1.5">
                <input type="file" id="strip-file" accept="image/png,image/jpeg,image/webp" class="hidden" />
                <button type="button" id="strip-btn" class="btn-secondary text-xs py-1.5 px-3 flex-1">Choisir</button>
                <button type="button" id="strip-clear" class="hidden btn-secondary text-xs py-1.5 px-2 text-red-400">✕</button>
              </div>
              <input type="hidden" id="strip-url" />
              <p id="strip-loading" class="hidden text-indigo-400 text-xs">Upload...</p>
              <p class="text-slate-600 text-xs text-center">PNG/JPG — <strong class="text-slate-500">750×246 px</strong></p>
              <a href="data:image/svg+xml;base64,"
                download="template-banniere-fidelopass.svg" class="text-indigo-400 text-xs underline underline-offset-2 hover:text-indigo-300 text-center">⬇ Template SVG 750×246</a>
              <div>
                <label class="text-slate-500 text-xs mb-1.5 block">Style de la bannière</label>
                <div class="grid grid-cols-2 gap-1.5">
                  <label id="strip-style-rounded-label" class="cursor-pointer rounded-lg border-2 py-1.5 text-center text-xs transition-all" style="border-color:#334155;background:transparent;color:#64748b">
                    <input type="radio" name="strip_style" value="rounded" class="hidden" />⬜ Arrondi</label>
                  <label id="strip-style-full-label" class="cursor-pointer rounded-lg border-2 py-1.5 text-center text-xs transition-all" style="border-color:#6366f1;background:rgb(99 102 241/0.1);color:white">
                    <input type="radio" name="strip_style" value="full" class="hidden" checked />▬ Pleine largeur</label>
                </div>
              </div>
              <div>
                <label class="text-slate-500 text-xs mb-1.5 block">Placement bannière / tampons</label>
                <div class="grid grid-cols-3 gap-1.5">
                  {[
                    { value: 'background', label: 'Fond' },
                    { value: 'top', label: 'Haut' },
                    { value: 'bottom', label: 'Bas' },
                  ].map(({ value, label }) => (
                    <label id={`strip-layout-${value}-label`} class="cursor-pointer rounded-lg border-2 py-1.5 text-center transition-all text-xs"
                      style={value==='background'?'border-color:#6366f1;background:rgb(99 102 241/0.1);color:white':'border-color:#334155;background:transparent;color:#64748b'}>
                      <input type="radio" name="strip_layout" value={value} class="hidden" checked={value==='background'} />
                      {label}
                    </label>
                  ))}
                </div>
                <p class="text-slate-600 text-xs mt-1 leading-tight">“Bas” place la bannière sous les tampons dans l’image Wallet générée.</p>
              </div>
              <div id="strip-position-zone" class="hidden">
                <label class="text-slate-500 text-xs mb-1.5 block">Position de l'image</label>
                <div class="grid grid-cols-3 gap-1.5">
                  {['top','center','bottom'].map(pos => (
                    <label id={`strip-pos-${pos}-label`} class="cursor-pointer rounded-lg border-2 py-1.5 text-center transition-all text-xs"
                      style={pos==='center'?'border-color:#6366f1;background:rgb(99 102 241/0.1);color:white':'border-color:#334155;background:transparent;color:#64748b'}>
                      <input type="radio" name="strip_position" value={pos} class="hidden" checked={pos==='center'} />
                      {pos==='top'?'Haut':pos==='center'?'Centre':'Bas'}
                    </label>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Programme fidélité -->
      <div class="card p-6">
        <h2 class="font-display font-bold text-white mb-5 flex items-center gap-2"><span class="text-lg">🎴</span> Programme fidélité</h2>
        <div class="flex flex-col gap-4">
          <div>
            <label class="label mb-3 block">Formules prêtes à l'emploi</label>
            <div class="grid sm:grid-cols-3 gap-2">
              {[
                {label:'10 achats = 1 offert', type:'tampons', total:'10', reward:'1 produit offert', points:'100', perEuro:'1'},
                {label:'8 visites = cadeau', type:'tampons', total:'8', reward:'1 cadeau fidélité', points:'100', perEuro:'1'},
                {label:'1€ = 1 point', type:'points', total:'10', reward:'5€ de réduction', points:'100', perEuro:'1'},
                {label:'2€ = 1 point', type:'points', total:'10', reward:'10€ de réduction', points:'200', perEuro:'0.5'},
                {label:'VIP rapide', type:'tampons', total:'5', reward:'1 avantage VIP', points:'100', perEuro:'1'},
                {label:'Récompense premium', type:'points', total:'10', reward:'1 récompense premium', points:'500', perEuro:'1'},
              ].map((preset) => (
                <button
                  type="button"
                  class="program-preset-btn rounded-xl border border-white/10 bg-white/[0.03] px-3 py-2 text-left text-xs text-slate-300 hover:border-indigo-400/60 hover:text-white transition-all"
                  data-type={preset.type}
                  data-total={preset.total}
                  data-reward={preset.reward}
                  data-points={preset.points}
                  data-per-euro={preset.perEuro}
                >
                  {preset.label}
                </button>
              ))}
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div><label class="label" for="nom-carte">Nom de la carte *</label><input id="nom-carte" type="text" class="input" placeholder="Carte fidélité Ma Boutique" required /></div>
            <div><label class="label" for="label-client">Label membre</label><input id="label-client" type="text" class="input" placeholder="Client, Membre, VIP..." maxlength="30" /></div>
          </div>
          <div><label class="label" for="description">Description</label><input id="description" type="text" class="input" placeholder="Cumulez des points à chaque achat !" /></div>
          <div>
            <label class="label">Type de programme</label>
            <div class="grid grid-cols-2 gap-3">
              <label id="type-tampons-label" class="cursor-pointer rounded-xl border-2 p-4 transition-all" style="border-color:#6366f1;background:rgb(99 102 241/0.1)">
                <input type="radio" name="type" value="tampons" class="hidden" checked /><div class="text-2xl mb-1">🔖</div><div class="font-medium text-white text-sm">Tampons</div><div class="text-slate-400 text-xs mt-0.5">Ex: 10 = 1 café offert</div>
              </label>
              <label id="type-points-label" class="cursor-pointer rounded-xl border-2 p-4 transition-all" style="border-color:#334155;background:transparent">
                <input type="radio" name="type" value="points" class="hidden" /><div class="text-2xl mb-1">⭐</div><div class="font-medium text-white text-sm">Points</div><div class="text-slate-400 text-xs mt-0.5">Ex: 1€ = 1 pt, 100pts = 5€</div>
              </label>
            </div>
          </div>
          <div id="config-tampons"><label class="label" for="tampons-total">Nombre de tampons pour la récompense</label><input id="tampons-total" type="number" class="input w-32" min="1" max="20" value="10" /></div>
          <div id="config-points" class="hidden flex flex-col gap-3">
            <div class="grid grid-cols-2 gap-3">
              <div><label class="label" for="points-par-euro">Points / euro</label><input id="points-par-euro" type="number" class="input" min="0.1" step="0.1" value="1" /></div>
              <div><label class="label" for="points-recompense">Points pour la récompense</label><input id="points-recompense" type="number" class="input" min="1" value="100" /></div>
            </div>
          </div>
          <div><label class="label" for="recompense">Récompense offerte *</label><input id="recompense" type="text" class="input" placeholder="Ex: 1 café offert, 5€ de réduction..." required /></div>
          <div class="grid lg:grid-cols-2 gap-4">
            <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
              <div class="flex items-center justify-between gap-3 mb-3">
                <div>
                  <p class="text-white text-sm font-semibold">Récompenses multiples</p>
                  <p class="text-slate-500 text-xs mt-0.5">Ex : café offert au 5e tampon, -10% au 10e.</p>
                </div>
                <button id="add-reward-tier" type="button" class="btn-secondary text-xs py-1.5 px-3">Ajouter</button>
              </div>
              <div id="reward-tiers" class="flex flex-col gap-2"></div>
            </div>
            <div id="vip-tiers-card" class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
              <p class="text-white text-sm font-semibold">Paliers VIP points</p>
              <p class="text-slate-500 text-xs mt-0.5 mb-3">Visible surtout pour les programmes à points.</p>
              <div id="vip-tiers" class="flex flex-col gap-2"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Messages client -->
      <div class="card p-6">
        <h2 class="font-display font-bold text-white mb-5 flex items-center gap-2"><span class="text-lg">💬</span> Messages client</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="label" for="welcome-message">Texte d’accueil public</label>
            <input id="welcome-message" type="text" class="input" maxlength="180" placeholder="Bienvenue chez ..., créez votre carte fidélité en 10 secondes." />
          </div>
          <div>
            <label class="label" for="success-message">Message après ajout Wallet</label>
            <input id="success-message" type="text" class="input" maxlength="180" placeholder="Votre carte est prête, montrez-la à chaque passage." />
          </div>
        </div>
      </div>

      <!-- Apparence -->
      <div class="card p-6">
        <h2 class="font-display font-bold text-white mb-5 flex items-center gap-2"><span class="text-lg">🎨</span> Apparence</h2>
        <label class="label mb-3 block">Thèmes prédéfinis</label>
        <div class="grid grid-cols-3 sm:grid-cols-6 gap-2 mb-5">
          {[
            {name:'Nuit',fond:'#0f172a',texte:'#ffffff',accent:'#6366f1',fond2:''},
            {name:'Rose',fond:'#3d0d1e',texte:'#fce7f3',accent:'#ec4899',fond2:'#6d1439'},
            {name:'Forêt',fond:'#064e3b',texte:'#ffffff',accent:'#34d399',fond2:'#065f46'},
            {name:'Océan',fond:'#0c4a6e',texte:'#ffffff',accent:'#38bdf8',fond2:'#075985'},
            {name:'Café',fond:'#1c0e04',texte:'#fef3c7',accent:'#d97706',fond2:'#292200'},
            {name:'Noir',fond:'#000000',texte:'#ffffff',accent:'#8b5cf6',fond2:'#18003a'},
          ].map(({name,fond,texte,accent,fond2})=>(
            <button type="button" class="preset-btn flex flex-col items-center gap-1.5 p-2 rounded-xl border border-white/10 hover:border-white/30 transition-all" data-fond={fond} data-texte={texte} data-accent={accent} data-fond2={fond2}>
              <div class="w-full h-8 rounded-lg flex gap-1 p-1" style={fond2?`background:linear-gradient(135deg,${fond},${fond2})`:`background:${fond}`}>
                <div class="w-3 h-full rounded-sm" style={`background:${accent}`}></div>
                <div class="flex-1 h-full rounded-sm opacity-60" style={`background:${texte}`}></div>
              </div>
              <span class="text-slate-400 text-xs">{name}</span>
            </button>
          ))}
        </div>

        <div class="mb-5">
          <div class="flex items-center justify-between mb-3">
            <label class="label">Couleur de fond</label>
            <div class="flex items-center gap-2 text-xs text-slate-400">
              <span>Uni</span>
              <button id="gradient-toggle" type="button" class="w-10 h-5 rounded-full transition-all relative" style="background:#334155" aria-pressed="false">
                <span id="gradient-knob" class="absolute top-0.5 left-0.5 w-4 h-4 rounded-full bg-white transition-all"></span>
              </button>
              <span>Dégradé</span>
            </div>
          </div>
          <div class="grid grid-cols-4 gap-3">
            <div><label class="text-slate-500 text-xs mb-1.5 block" id="fond-label">Fond</label><input id="couleur-fond" type="color" value="#0f172a" class="w-full h-10 rounded-xl border border-white/10 cursor-pointer bg-transparent" /></div>
            <div id="fond2-wrap" class="hidden"><label class="text-slate-500 text-xs mb-1.5 block">Fond 2</label><input id="couleur-fond-2" type="color" value="#6366f1" class="w-full h-10 rounded-xl border border-white/10 cursor-pointer bg-transparent" /></div>
            <div><label class="text-slate-500 text-xs mb-1.5 block">Texte</label><input id="couleur-texte" type="color" value="#ffffff" class="w-full h-10 rounded-xl border border-white/10 cursor-pointer bg-transparent" /></div>
            <div><label class="text-slate-500 text-xs mb-1.5 block">Accent</label><input id="couleur-accent" type="color" value="#6366f1" class="w-full h-10 rounded-xl border border-white/10 cursor-pointer bg-transparent" /></div>
          </div>
          <div id="gradient-angle-wrap" class="hidden mt-3">
            <div class="flex items-center justify-between mb-1"><label class="text-slate-500 text-xs">Angle du dégradé</label><span id="gradient-angle-val" class="text-indigo-400 text-xs font-mono">135°</span></div>
            <input id="gradient-angle" type="range" min="0" max="360" value="135" class="w-full accent-indigo-500" />
          </div>
        </div>

        <label class="label mb-3 block">Pattern de fond <span class="text-slate-500 font-normal text-xs">(toute la carte)</span></label>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
          {[{value:'none',label:'Aucun'},{value:'dots',label:'Points'},{value:'grid',label:'Grille'},{value:'waves',label:'Vagues'},{value:'diagonal',label:'Diagonales'},{value:'confetti',label:'Confetti'}].map(({value,label})=>(
            <label id={`pat-${value}-label`} class="cursor-pointer rounded-xl border-2 p-2.5 text-center transition-all" style={value==='none'?'border-color:#6366f1;background:rgb(99 102 241/0.1)':'border-color:#334155;background:transparent'}>
              <input type="radio" name="pattern_type" value={value} class="hidden" checked={value==='none'} />
              <div class="w-full h-8 rounded-lg mb-1.5 overflow-hidden relative" style="background:#1e293b">
                {value==='dots'&&<svg class="absolute inset-0 w-full h-full"><defs><pattern id="pd" width="8" height="8" patternUnits="userSpaceOnUse"><circle cx="4" cy="4" r="1.5" fill="rgba(99,102,241,0.5)"/></pattern></defs><rect width="100%" height="100%" fill="url(#pd)"/></svg>}
                {value==='grid'&&<svg class="absolute inset-0 w-full h-full"><defs><pattern id="pg" width="8" height="8" patternUnits="userSpaceOnUse"><path d="M 8 0 L 0 0 0 8" fill="none" stroke="rgba(99,102,241,0.4)" stroke-width="0.5"/></pattern></defs><rect width="100%" height="100%" fill="url(#pg)"/></svg>}
                {value==='waves'&&<svg class="absolute inset-0 w-full h-full"><defs><pattern id="pw" width="16" height="8" patternUnits="userSpaceOnUse"><path d="M 0 4 Q 4 0 8 4 Q 12 8 16 4" fill="none" stroke="rgba(99,102,241,0.5)" stroke-width="1"/></pattern></defs><rect width="100%" height="100%" fill="url(#pw)"/></svg>}
                {value==='diagonal'&&<svg class="absolute inset-0 w-full h-full"><defs><pattern id="pdiag" width="8" height="8" patternUnits="userSpaceOnUse" patternTransform="rotate(35)"><rect width="2" height="8" fill="rgba(99,102,241,0.42)"/></pattern></defs><rect width="100%" height="100%" fill="url(#pdiag)"/></svg>}
                {value==='confetti'&&<svg class="absolute inset-0 w-full h-full"><circle cx="18%" cy="30%" r="3" fill="rgba(99,102,241,0.55)"/><rect x="58%" y="18%" width="14" height="4" rx="2" transform="rotate(20)" fill="rgba(99,102,241,0.45)"/><circle cx="72%" cy="72%" r="2.5" fill="rgba(99,102,241,0.6)"/><rect x="22%" y="70%" width="12" height="4" rx="2" transform="rotate(-25)" fill="rgba(99,102,241,0.4)"/></svg>}
              </div>
              <div class="text-white text-xs font-medium">{label}</div>
            </label>
          ))}
