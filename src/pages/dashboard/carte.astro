      if(data.tampon_emoji){
        tamponEmoji=data.tampon_emoji;
        (document.getElementById('tampon-emoji') as HTMLInputElement).value=tamponEmoji;
        document.getElementById('tampon-emoji-val')!.textContent=tamponEmoji;
        document.getElementById('tampon-emoji-selected')!.classList.remove('hidden');
        sr('tampon_mode','emoji'); document.getElementById('tampon-emoji-zone')!.classList.remove('hidden');
        ['default','emoji','custom'].forEach(v=>document.getElementById(`tampon-mode-${v}-label`)!.style.cssText=v==='emoji'?'border-color:#60a5fa;background:rgb(239 246 255);color:#0f172a':'border-color:#dbeafe;background:#ffffff');
        document.querySelectorAll('.emoji-stamp-btn').forEach(b=>{if((b as HTMLElement).dataset.emoji===tamponEmoji)(b as HTMLElement).style.borderColor='#6366f1';});
      }else if(data.tampon_icon_url){
        tamponIconUrl=data.tampon_icon_url; setTamponPreview(tamponIconUrl); sr('tampon_mode','custom');
        document.getElementById('tampon-custom-zone')!.classList.remove('hidden');
        ['default','emoji','custom'].forEach(v=>document.getElementById(`tampon-mode-${v}-label`)!.style.cssText=v==='custom'?'border-color:#60a5fa;background:rgb(239 246 255);color:#0f172a':'border-color:#dbeafe;background:#ffffff');
      }
      updatePreview();
      const pu=publicCardUrl(data.id);
      document.getElementById('public-link-banner')!.classList.remove('hidden');
      document.getElementById('public-link-url')!.textContent=pu;
      updateQrTools(data.id);
      updateScannerTools();
      updateWizardActions();
    }catch{}
  }

