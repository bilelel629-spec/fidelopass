---
import PartnerLayout from '../../layouts/PartnerLayout.astro';
---

<PartnerLayout title="Commerces clients — Fidelopass" activeNav="commerces">
  <section class="space-y-6">
    <div>
      <p class="text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-sky-700/75">Portefeuille</p>
      <h1 class="mt-2 font-display text-4xl font-bold tracking-tight text-slate-950">Commerces clients</h1>
      <p class="mt-3 max-w-2xl text-base leading-7 text-slate-600">
        Suivez les commerces rattachés à votre offre white label et leur niveau de configuration.
      </p>
    </div>

    <div class="rounded-[1.6rem] border border-sky-100 bg-white/88 p-5 shadow-[0_22px_52px_-38px_rgba(37,99,235,0.45)]">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="font-display text-xl font-bold text-slate-950">Liste des commerces</h2>
          <p id="partner-commerce-quota" class="mt-1 text-sm text-slate-500">Chargement...</p>
        </div>
      </div>
      <div id="partner-commerce-list" class="mt-5 overflow-hidden rounded-2xl border border-slate-100"></div>
    </div>

    <div class="rounded-[1.6rem] border border-sky-100 bg-white/88 p-5 shadow-[0_22px_52px_-38px_rgba(37,99,235,0.45)]">
      <div>
        <h2 class="font-display text-xl font-bold text-slate-950">Ajouter un commerce client</h2>
        <p class="mt-1 text-sm text-slate-500">
          Créez un commerce déjà rattaché à votre white label. Le propriétaire doit avoir un compte Fidelopass/Supabase existant.
        </p>
      </div>
      <p id="partner-commerce-feedback" class="mt-4 hidden rounded-xl border px-4 py-3 text-sm"></p>
      <form id="partner-commerce-form" class="mt-5 grid gap-4 lg:grid-cols-2">
        <label class="block">
          <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Nom du commerce</span>
          <input name="nom" class="input" placeholder="Restaurant Dupont" required />
        </label>
        <label class="block">
          <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Email du propriétaire</span>
          <input name="owner_email" type="email" class="input" placeholder="client@commerce.fr" required />
        </label>
        <label class="block">
          <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Email</span>
          <input name="email" type="email" class="input" placeholder="Email de contact public (optionnel)" />
        </label>
        <label class="block">
          <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Téléphone</span>
          <input name="telephone" class="input" placeholder="06..." />
        </label>
        <label class="block lg:col-span-2">
          <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Adresse</span>
          <input name="adresse" class="input" placeholder="Adresse complète" />
        </label>
        <button type="submit" class="btn-primary px-5 py-3 text-sm lg:col-span-2">Créer le commerce white label</button>
      </form>
    </div>
  </section>
</PartnerLayout>

<script>
  import { authFetch } from '../../lib/api';

  const list = document.getElementById('partner-commerce-list');
  const quota = document.getElementById('partner-commerce-quota');
  const feedbackEl = document.getElementById('partner-commerce-feedback');

  function feedback(message: string, tone: 'success' | 'error' = 'success') {
    if (!feedbackEl) return;
    feedbackEl.textContent = message;
    feedbackEl.className = tone === 'success'
      ? 'mt-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700'
      : 'mt-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700';
  }

  function renderRows(commerces: any[]) {
    if (!list) return;
    if (!commerces.length) {
      list.innerHTML = '<div class="bg-slate-50 px-5 py-8 text-center text-sm text-slate-500">Aucun commerce rattaché pour le moment.</div>';
      return;
    }

    list.innerHTML = `
      <div class="hidden grid-cols-[1.3fr_0.8fr_0.7fr_0.7fr] gap-4 bg-slate-50 px-5 py-3 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-slate-500 md:grid">
        <span>Commerce</span><span>Carte</span><span>Clients</span><span>Statut</span>
      </div>
      ${commerces.map((commerce) => `
        <div class="grid gap-3 border-t border-slate-100 bg-white px-5 py-4 md:grid-cols-[1.3fr_0.8fr_0.7fr_0.7fr] md:items-center">
          <div>
            <p class="font-semibold text-slate-950">${commerce.nom ?? 'Commerce'}</p>
            <p class="text-sm text-slate-500">${commerce.email ?? ''}</p>
          </div>
          <span class="w-fit rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-700">${commerce.cartes?.length ? 'Configurée' : 'À créer'}</span>
          <span class="text-sm font-semibold text-slate-800">${commerce.clients?.length ?? 0}</span>
          <span class="w-fit rounded-full ${commerce.actif === false ? 'bg-red-50 text-red-600' : 'bg-emerald-50 text-emerald-700'} px-3 py-1 text-xs font-semibold">${commerce.actif === false ? 'Inactif' : 'Actif'}</span>
        </div>
      `).join('')}
    `;
  }

  async function loadCommerces() {
    const res = await authFetch('/api/partners/commerces');
    const payload = await res.json().catch(() => null);
    if (!res.ok) throw new Error(payload?.error ?? 'Chargement impossible');
    const commerces = Array.isArray(payload?.data) ? payload.data : [];
    const quotaPayload = payload?.quota;
    if (quota && quotaPayload) {
      quota.textContent = `${quotaPayload.used}/${quotaPayload.included} commerces inclus utilisés`;
    }
    renderRows(commerces);
  }

  await loadCommerces().catch((error) => {
    if (quota) quota.textContent = 'Impossible de charger les commerces.';
    if (list) list.innerHTML = `<div class="bg-red-50 px-5 py-5 text-sm text-red-600">${error.message}</div>`;
  });

  document.getElementById('partner-commerce-form')?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const form = event.currentTarget as HTMLFormElement;
    const data = new FormData(form);
    const body = Object.fromEntries(data.entries());
    for (const key of ['email', 'telephone', 'adresse']) {
      if (!String(body[key] ?? '').trim()) delete body[key];
    }

    const res = await authFetch('/api/partners/commerces', {
      method: 'POST',
      body: JSON.stringify(body),
    });
    const payload = await res.json().catch(() => null);
    if (!res.ok) {
      feedback(payload?.error ?? 'Impossible de créer ce commerce.', 'error');
      return;
    }

    form.reset();
    feedback('Commerce créé et rattaché à votre white label.');
    await loadCommerces();
  });
</script>
