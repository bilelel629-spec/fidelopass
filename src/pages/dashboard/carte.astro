  let stripDragging = false;
  function updateStripFocusFromPointer(clientX: number, clientY: number, silent = false) {
    const rect = stripDragArea.getBoundingClientRect();
    if (!rect.width || !rect.height) return;
    const x = ((clientX - rect.left) / rect.width) * 100;
    const y = ((clientY - rect.top) / rect.height) * 100;
    setStripFocus(x, y, { silent });
  }

