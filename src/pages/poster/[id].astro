---
import BaseLayout from '../../layouts/BaseLayout.astro';

const { id } = Astro.params;
const apiBase = (
  import.meta.env.PUBLIC_API_URL
  ?? (import.meta.env.PROD ? 'https://api.fidelopass.com' : 'http://localhost:3001')
).replace(/\/$/, '');
---

<BaseLayout title="Affiche A4 — Fidelopass" description="Téléchargez une affiche A4 Fidelopass prête à imprimer avec le QR code de votre carte.">
  <div class="min-h-screen px-4 py-8">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-6 items-start justify-between mb-6">
        <div>
          <p class="text-slate-400 text-sm uppercase tracking-[0.28em]">Affiches Fidelopass</p>
          <h1 class="font-display text-3xl sm:text-4xl font-bold text-white mt-3">Préparez une affiche A4 prête à imprimer</h1>
          <p class="text-slate-400 text-sm sm:text-base mt-3 max-w-2xl">
            Choisissez un modèle, imprimez-le en A4 ou téléchargez uniquement le QR code pour vos supports en boutique.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <button id="download-qr" type="button" class="btn-secondary px-5 py-3 text-sm">Télécharger le QR</button>
          <button id="print-poster" type="button" class="btn-primary px-5 py-3 text-sm">Imprimer l’affiche</button>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 mb-6">
        <button type="button" class="poster-template-btn btn-secondary text-sm px-4 py-2.5" data-template="minimal">Minimal</button>
        <button type="button" class="poster-template-btn btn-secondary text-sm px-4 py-2.5" data-template="premium">Premium</button>
        <button type="button" class="poster-template-btn btn-secondary text-sm px-4 py-2.5" data-template="promo">Promo</button>
      </div>

      <div id="poster-loading" class="text-center py-16">
        <div class="w-8 h-8 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-slate-400 text-sm">Préparation de l’affiche...</p>
      </div>

      <div id="poster-error" class="hidden text-center py-12">
        <div class="card p-8 max-w-xl mx-auto">
          <p class="text-red-400 font-semibold">Impossible de charger cette affiche.</p>
          <p class="text-slate-400 text-sm mt-2">Vérifiez que votre carte est bien publiée puis réessayez.</p>
        </div>
      </div>

      <div id="poster-stage" class="hidden">
        <div id="poster-sheet" class="poster-sheet mx-auto bg-white text-slate-900 rounded-[1.5rem] overflow-hidden shadow-2xl border border-white/10">
          <div id="poster-minimal" class="poster-variant hidden">
            <div class="p-12 h-full flex flex-col justify-between">
              <div>
                <div class="flex items-center justify-between gap-6">
                  <div class="flex items-center gap-4">
                    <img id="poster-minimal-logo" src="" alt="" class="hidden w-16 h-16 rounded-2xl object-cover" />
                    <div>
                      <p class="text-xs uppercase tracking-[0.35em] text-slate-500">Fidelopass</p>
                      <h2 id="poster-minimal-commerce" class="font-display text-4xl font-bold mt-3">Votre commerce</h2>
                    </div>
                  </div>
                  <div class="px-4 py-2 rounded-full text-sm font-semibold" id="poster-minimal-badge">Carte fidélité</div>
                </div>
                <h3 id="poster-minimal-title" class="font-display text-5xl font-bold leading-tight mt-10">Scannez et ajoutez votre carte</h3>
                <p id="poster-minimal-subtitle" class="text-xl text-slate-600 mt-5 max-w-2xl">Bienvenue, créez votre carte fidélité en 10 secondes.</p>
              </div>
              <div class="grid grid-cols-[1fr_290px] gap-10 items-end">
                <div class="rounded-[1.5rem] p-8 text-white" id="poster-minimal-program">
                  <p class="text-sm uppercase tracking-[0.28em] opacity-80">Programme fidélité</p>
                  <p id="poster-minimal-reward" class="font-display text-3xl font-bold mt-4">10 achats = 1 café offert</p>
                  <p class="text-base opacity-80 mt-4">Montrez cette carte à chaque passage pour cumuler vos avantages.</p>
                </div>
                <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-6 text-center">
                  <img id="poster-minimal-qr" src="" alt="QR code Fidelopass" class="w-56 h-56 mx-auto rounded-2xl" />
                  <p class="text-sm font-semibold mt-4">Scannez ici</p>
                  <p class="text-xs text-slate-500 mt-2">Ajoutez la carte dans Apple Wallet ou Google Wallet.</p>
                </div>
              </div>
            </div>
          </div>

          <div id="poster-premium" class="poster-variant hidden">
            <div class="h-full relative overflow-hidden">
              <div id="poster-premium-banner" class="absolute inset-x-0 top-0 h-64 bg-slate-900"></div>
              <div class="absolute inset-0 bg-gradient-to-br from-black/30 via-transparent to-black/50"></div>
              <div class="relative z-10 p-12 h-full flex flex-col justify-between">
                <div class="flex items-start justify-between gap-6">
                  <div class="max-w-2xl">
                    <p class="text-white/70 text-xs uppercase tracking-[0.35em]">Carte fidélité digitale</p>
                    <h2 id="poster-premium-commerce" class="font-display text-5xl font-bold text-white mt-5">Votre commerce</h2>
                    <p id="poster-premium-copy" class="text-white/85 text-xl mt-5 leading-relaxed">Scannez, ajoutez votre carte et profitez de vos avantages à chaque passage.</p>
                  </div>
                  <img id="poster-premium-logo" src="" alt="" class="hidden w-20 h-20 rounded-[1.5rem] object-cover border border-white/20" />
                </div>
                <div class="grid grid-cols-[320px_1fr] gap-10 items-end">
                  <div class="rounded-[2rem] bg-white p-7 text-center shadow-2xl">
                    <img id="poster-premium-qr" src="" alt="QR code Fidelopass" class="w-64 h-64 mx-auto rounded-2xl" />
                    <p class="text-base font-semibold mt-5">Scannez pour créer votre carte</p>
                    <p class="text-sm text-slate-500 mt-2">Ajout direct dans le Wallet du téléphone.</p>
                  </div>
                  <div class="rounded-[2rem] bg-white/12 backdrop-blur-md border border-white/15 p-8 text-white">
                    <p class="text-sm uppercase tracking-[0.28em] text-white/70">Récompense</p>
                    <p id="poster-premium-reward" class="font-display text-4xl font-bold mt-4">Récompense fidélité</p>
                    <div class="grid grid-cols-2 gap-4 mt-8">
                      <div class="rounded-2xl bg-white/10 p-4">
                        <p class="text-white/65 text-xs uppercase tracking-[0.22em]">Ajout</p>
                        <p class="text-lg font-semibold mt-2">10 secondes</p>
                      </div>
                      <div class="rounded-2xl bg-white/10 p-4">
                        <p class="text-white/65 text-xs uppercase tracking-[0.22em]">Support</p>
                        <p class="text-lg font-semibold mt-2">iPhone & Android</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div id="poster-promo" class="poster-variant hidden">
            <div class="p-10 h-full grid grid-cols-[1.05fr_0.95fr] gap-8">
              <div class="rounded-[2rem] p-10 text-white flex flex-col justify-between" id="poster-promo-panel">
                <div>
                  <p class="text-sm uppercase tracking-[0.35em] text-white/65">Bienvenue chez</p>
                  <h2 id="poster-promo-commerce" class="font-display text-5xl font-bold mt-4">Votre commerce</h2>
                  <p id="poster-promo-message" class="text-xl text-white/85 mt-6 leading-relaxed">Créez votre carte fidélité en 10 secondes.</p>
                </div>
                <div>
                  <div class="inline-flex px-4 py-2 rounded-full bg-white/10 border border-white/20 text-sm font-semibold">Ajout gratuit et immédiat</div>
                  <p id="poster-promo-reward" class="font-display text-4xl font-bold mt-6">10 achats = 1 récompense</p>
                  <p class="text-base text-white/75 mt-3">Scannez le QR, gardez votre carte sur le téléphone et montrez-la à chaque passage.</p>
                </div>
              </div>
              <div class="rounded-[2rem] border border-slate-200 bg-white p-8 flex flex-col items-center justify-center">
                <img id="poster-promo-logo" src="" alt="" class="hidden w-16 h-16 rounded-2xl object-cover mb-5" />
                <img id="poster-promo-qr" src="" alt="QR code Fidelopass" class="w-72 h-72 rounded-3xl" />
                <p class="text-lg font-semibold text-center mt-6">Scannez pour ajouter votre carte</p>
                <p class="text-sm text-slate-500 text-center mt-2 max-w-xs">Apple Wallet ou Google Wallet, sans application lourde.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .poster-sheet {
    width: min(100%, 794px);
    min-height: 1123px;
  }

  @media print {
    body {
      background: white;
    }

    .poster-sheet {
      width: 210mm;
      min-height: 297mm;
      border-radius: 0;
      box-shadow: none;
      border: none;
    }

    nav,
    button,
    .btn-primary,
    .btn-secondary,
    #poster-loading {
      display: none !important;
    }
  }
</style>

<script define:vars={{ apiBase, carteId: id }}>
  const API = apiBase;
  const qrBase = 'https://api.qrserver.com/v1/create-qr-code/';
  const params = new URLSearchParams(window.location.search);
  let currentTemplate = params.get('template') || 'minimal';
  let posterData = null;

  function apiUrl(path) {
    return `${API}${path}`;
  }

  function qrUrl(cardId, size = 720) {
    return `${qrBase}?size=${size}x${size}&data=${encodeURIComponent(`${window.location.origin}/carte/${cardId}`)}&bgcolor=ffffff&color=111827&qzone=1`;
  }

  function rewardSummary(data) {
    const tiers = Array.isArray(data.carte.rewards_config) ? data.carte.rewards_config : [];
    if (tiers.length) {
      return tiers.map((item) => `${item.seuil} ${data.carte.type === 'points' ? 'pts' : 'tampons'} = ${item.recompense}`).join(' • ');
    }
    return data.carte.recompense_description || 'Récompense fidélité';
  }

  function setImage(id, src) {
    const img = document.getElementById(id);
    if (!img || !src) return;
    img.src = src;
    img.classList.remove('hidden');
  }

  function renderTemplate(name) {
    currentTemplate = name;
    document.querySelectorAll('.poster-variant').forEach((node) => node.classList.add('hidden'));
    document.getElementById(`poster-${name}`)?.classList.remove('hidden');
    document.querySelectorAll('.poster-template-btn').forEach((button) => {
      const active = button.dataset.template === name;
      button.className = active
        ? 'poster-template-btn btn-primary text-sm px-4 py-2.5'
        : 'poster-template-btn btn-secondary text-sm px-4 py-2.5';
    });
    const nextUrl = new URL(window.location.href);
    nextUrl.searchParams.set('template', name);
    window.history.replaceState({}, '', nextUrl);
  }

  async function downloadQr() {
    const response = await fetch(qrUrl(carteId, 1200));
    const blob = await response.blob();
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `fidelopass-qr-${carteId}.png`;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

  async function loadPoster() {
    try {
      const response = await fetch(apiUrl(`/api/cartes/${carteId}/public`));
      if (!response.ok) throw new Error();
      const { data } = await response.json();
      posterData = data;

      const commerceName = data.commerce.nom;
      const message = data.carte.welcome_message || `Bienvenue chez ${commerceName}, créez votre carte fidélité en 10 secondes.`;
      const reward = rewardSummary(data);
      const qr = qrUrl(carteId);

      document.getElementById('poster-minimal-commerce').textContent = commerceName;
      document.getElementById('poster-minimal-title').textContent = `Scannez pour rejoindre ${commerceName}`;
      document.getElementById('poster-minimal-subtitle').textContent = message;
      document.getElementById('poster-minimal-reward').textContent = reward;
      document.getElementById('poster-minimal-badge').textContent = data.carte.type === 'points' ? 'Carte à points' : 'Carte à tampons';
      document.getElementById('poster-minimal-badge').style.background = `${data.carte.couleur_accent ?? '#6366f1'}1f`;
      document.getElementById('poster-minimal-badge').style.color = data.carte.couleur_accent ?? '#6366f1';
      document.getElementById('poster-minimal-program').style.background = `linear-gradient(135deg, ${data.carte.couleur_fond ?? '#0f172a'}, ${data.carte.couleur_fond_2 ?? data.carte.couleur_accent ?? '#6366f1'})`;

      document.getElementById('poster-premium-commerce').textContent = commerceName;
      document.getElementById('poster-premium-copy').textContent = message;
      document.getElementById('poster-premium-reward').textContent = reward;
      document.getElementById('poster-premium-banner').style.background = data.carte.strip_url
        ? `linear-gradient(rgba(15,23,42,0.25), rgba(15,23,42,0.45)), url("${data.carte.strip_url}") center/cover`
        : `linear-gradient(135deg, ${data.carte.couleur_fond ?? '#0f172a'}, ${data.carte.couleur_fond_2 ?? data.carte.couleur_accent ?? '#6366f1'})`;

      document.getElementById('poster-promo-commerce').textContent = commerceName;
      document.getElementById('poster-promo-message').textContent = message;
      document.getElementById('poster-promo-reward').textContent = reward;
      document.getElementById('poster-promo-panel').style.background = `linear-gradient(160deg, ${data.carte.couleur_fond ?? '#0f172a'}, ${data.carte.couleur_fond_2 ?? data.carte.couleur_accent ?? '#6366f1'})`;

      ['poster-minimal-qr', 'poster-premium-qr', 'poster-promo-qr'].forEach((id) => {
        document.getElementById(id).src = qr;
      });

      const logo = data.carte.logo_url ?? data.commerce.logo_url ?? '';
      setImage('poster-minimal-logo', logo);
      setImage('poster-premium-logo', logo);
      setImage('poster-promo-logo', logo);

      document.getElementById('poster-loading').classList.add('hidden');
      document.getElementById('poster-stage').classList.remove('hidden');
      renderTemplate(currentTemplate);
    } catch {
      document.getElementById('poster-loading').classList.add('hidden');
      document.getElementById('poster-error').classList.remove('hidden');
    }
  }

  document.getElementById('print-poster').addEventListener('click', () => window.print());
  document.getElementById('download-qr').addEventListener('click', downloadQr);
  document.querySelectorAll('.poster-template-btn').forEach((button) => {
    button.addEventListener('click', () => renderTemplate(button.dataset.template || 'minimal'));
  });

  loadPoster();
</script>
