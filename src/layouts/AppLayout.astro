---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Fidelopass Scanner' } = Astro.props;
---

<!doctype html>
<html lang="fr" class="dashboard">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="theme-color" content="#edf6ff" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-[100dvh] bg-[#f5f9ff] text-slate-900 antialiased overflow-x-hidden">
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -top-24 right-[-6rem] h-[18rem] w-[18rem] rounded-full bg-cyan-200/40 blur-3xl"></div>
      <div class="absolute bottom-[-6rem] left-[-4rem] h-[14rem] w-[14rem] rounded-full bg-blue-100/70 blur-3xl"></div>
    </div>
    <slot />
  </body>
</html>

<script>
  import { createClient } from '@supabase/supabase-js';
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) window.location.replace('/login');

  // Enregistrement du Service Worker
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  }
</script>
