---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Vue globale — Admin Fidelopass" activeNav="overview">
  <div class="mb-8 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="dashboard-kicker">Pilotage plateforme</p>
      <h1 class="dashboard-title">Vue globale</h1>
      <p class="dashboard-subtitle">Suivez les commerces inscrits, leur activité, leurs cartes configurées et les signaux qui comptent pour l’équipe fondatrice.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <a href="/admin/commerces" class="btn-secondary px-4 py-2.5 text-sm">Voir tous les commerces</a>
      <a href="/admin/cartes" class="btn-secondary px-4 py-2.5 text-sm">Assistance cartes</a>
      <button id="export-admin-csv" type="button" class="btn-primary px-4 py-2.5 text-sm">Exporter la base</button>
    </div>
  </div>

  <p id="admin-action-feedback" class="mb-4 hidden rounded-xl border px-4 py-3 text-sm"></p>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-7">
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Commerces</span>
      <span id="stat-commerces" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <p class="mt-2 text-xs text-slate-500">Nombre total de comptes commerçants.</p>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Actifs</span>
      <span id="stat-commerces-actifs" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <p class="mt-2 text-xs text-slate-500">Commerces actuellement accessibles.</p>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Cartes configurées</span>
      <span id="stat-cartes" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <p class="mt-2 text-xs text-slate-500">Cartes prêtes à être partagées.</p>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Clients</span>
      <span id="stat-clients" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <p class="mt-2 text-xs text-slate-500">Clients actuellement en base.</p>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Nouveaux 30 jours</span>
      <span id="stat-nouveaux-30j" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <p class="mt-2 text-xs text-slate-500">Nouveaux commerces récemment créés.</p>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Plan Starter</span>
      <span id="stat-plan-starter" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <p class="mt-2 text-xs text-slate-500">Commerces actuellement en Starter.</p>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Points de vente</span>
      <span id="stat-points-vente" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <p class="mt-2 text-xs text-slate-500">Total des lieux actifs sur la plateforme.</p>
    </div>
  </div>

  <div class="mt-6 grid gap-6 xl:grid-cols-[1.4fr_0.9fr]">
    <section class="card dashboard-panel p-6">
      <div class="mb-4 flex items-center justify-between gap-3">
        <div>
          <h2 class="font-display text-xl font-bold text-slate-900">Commerces récents</h2>
          <p class="mt-1 text-sm text-slate-500">Une vue rapide pour repérer les comptes créés, leur équipement et leur statut.</p>
        </div>
      </div>
      <div id="recent-commerces">
        <p class="text-sm text-slate-500">Chargement...</p>
      </div>
    </section>

    <section class="space-y-6">
      <div class="card dashboard-panel p-6">
        <h2 class="font-display text-xl font-bold text-slate-900">Repères admin</h2>
        <div class="mt-4 space-y-3 text-sm text-slate-600">
          <div class="rounded-2xl border border-sky-100 bg-sky-50 p-4">
            <p class="font-medium text-slate-900">Abonnements</p>
            <p class="mt-1">La structure admin est prête, mais le vrai suivi des plans et de la facturation dépend encore du branchement abonnement côté produit.</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white p-4">
            <p class="font-medium text-slate-900">Export & support</p>
            <p class="mt-1">Vous pouvez déjà exporter les commerces pour audit, migration ou suivi manuel avec vos associés.</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white p-4">
            <p class="font-medium text-slate-900">Supervision utile maintenant</p>
            <p id="admin-onboarding-helper" class="mt-1">Chargement des états d’onboarding...</p>
          </div>
        </div>
      </div>

      <div class="card dashboard-panel p-6">
        <h2 class="font-display text-xl font-bold text-slate-900">Historique global</h2>
        <div class="mt-4 flex items-end gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Événements clients</p>
            <p id="stat-transactions" class="mt-1 font-mono text-4xl font-bold text-slate-900">—</p>
          </div>
          <p class="pb-1 text-sm text-slate-500">Ajouts de points, tampons et récompenses enregistrés sur l’ensemble de la plateforme.</p>
        </div>
      </div>

      <div class="card dashboard-panel p-6">
        <h2 class="font-display text-xl font-bold text-slate-900">Santé plateforme</h2>
        <p class="mt-1 text-sm text-slate-500">Vue consolidée des dépendances critiques API et wallet.</p>
        <div class="mt-4 grid gap-3">
          <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-slate-500">API</p>
            <p id="health-api-status" class="mt-1 text-sm font-semibold text-slate-900">Chargement...</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-slate-500">Base de données</p>
            <p id="health-db-status" class="mt-1 text-sm font-semibold text-slate-900">Chargement...</p>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-slate-500">Stripe</p>
              <p id="health-stripe-status" class="mt-1 text-sm font-semibold text-slate-900">—</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-slate-500">Wallet</p>
              <p id="health-wallet-status" class="mt-1 text-sm font-semibold text-slate-900">—</p>
            </div>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-slate-500">Migrations</p>
            <p id="health-migrations-status" class="mt-1 text-sm font-semibold text-slate-900">—</p>
          </div>
        </div>
      </div>

      <div class="card dashboard-panel p-6">
        <h2 class="font-display text-xl font-bold text-slate-900">Dernières actions admin</h2>
        <p class="mt-1 text-sm text-slate-500">Trace des changements sensibles sur les commerces.</p>
        <div id="admin-audit-log-list" class="mt-4 space-y-2">
          <p class="text-sm text-slate-500">Chargement...</p>
        </div>
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  import { withTimeout } from '../../lib/utils/with-timeout';

  type AdminCommerce = {
    id: string;
    nom: string;
    email: string | null;
    telephone: string | null;
    adresse: string | null;
    actif: boolean;
    plan?: string | null;
    plan_override?: string | null;
    effective_plan?: string | null;
    created_at: string;
    cartes: unknown[];
    clients: unknown[];
  };

  let allCommerces: AdminCommerce[] = [];
  const SESSION_PROBE_TIMEOUT_MS = Number(import.meta.env.PUBLIC_AUTH_SESSION_PROBE_TIMEOUT_MS ?? 900);
  const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001';

  function normalizePlan(planRaw: unknown) {
    return String(planRaw ?? 'starter').trim().toLowerCase();
  }

  function planLabel(planRaw: unknown) {
    const plan = normalizePlan(planRaw);
    if (plan.includes('sur-mesure') || plan.includes('surmesure') || plan.includes('custom')) return 'Sur mesure';
    if (plan.includes('pro')) return 'Pro';
    return 'Starter';
  }

  function planSelectValue(planRaw: unknown): 'starter' | 'pro' | 'sur-mesure' {
    const plan = normalizePlan(planRaw);
    if (plan.includes('sur-mesure') || plan.includes('surmesure') || plan.includes('custom')) return 'sur-mesure';
    if (plan.includes('pro')) return 'pro';
    return 'starter';
  }

  function getOnboardingState(commerce: AdminCommerce) {
    if (!commerce.cartes.length) return { label: 'Compte créé', badge: 'badge-warning' };
    if (!commerce.clients.length) return { label: 'Carte prête', badge: 'badge-info' };
    return { label: 'Carte partagée', badge: 'badge-success' };
  }

  function setActionFeedback(message: string, tone: 'success' | 'error') {
    const feedback = document.getElementById('admin-action-feedback') as HTMLParagraphElement;
    feedback.textContent = message;
    feedback.className = tone === 'success'
      ? 'mb-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700'
      : 'mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700';
  }

  async function getAccessTokenFast() {
    const { supabase } = await import('../../lib/supabase');
    const sessionResult = await withTimeout(supabase.auth.getSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null);
    const sessionToken = sessionResult?.data?.session?.access_token;
    if (sessionToken) return sessionToken;
    const refreshResult = await withTimeout(supabase.auth.refreshSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null);
    return refreshResult?.data?.session?.access_token ?? '';
  }

  async function authFetch(url: string, opts: RequestInit = {}) {
    const accessToken = await getAccessTokenFast();
    return fetch(url, {
      ...opts,
      headers: {
        ...(opts.headers ?? {}),
        Authorization: `Bearer ${accessToken}`,
        'Content-Type': 'application/json',
      },
    });
  }

  function exportCsv() {
    const rows = [
      ['Nom', 'Email', 'Téléphone', 'Adresse', 'Carte configurée', 'Clients', 'Statut', 'Date création'],
      ...allCommerces.map((commerce) => [
        commerce.nom,
        commerce.email ?? '',
        commerce.telephone ?? '',
        commerce.adresse ?? '',
        commerce.cartes.length > 0 ? 'Oui' : 'Non',
        String(commerce.clients.length),
        commerce.actif ? 'Actif' : 'Inactif',
        new Date(commerce.created_at).toLocaleDateString('fr-FR'),
      ]),
    ];

    const csv = rows
      .map((row) => row.map((value) => `"${String(value).replaceAll('"', '""')}"`).join(';'))
      .join('\n');

    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = 'fidelopass-commerces.csv';
    link.click();
    URL.revokeObjectURL(url);
  }

  async function loadStats() {
    try {
      const res = await authFetch(`${API_BASE}/api/admin/stats`);
      if (!res.ok) return;
      const data = await res.json();
      document.getElementById('stat-commerces')!.textContent = String(data.totalCommerces ?? 0);
      document.getElementById('stat-commerces-actifs')!.textContent = String(data.totalCommercesActifs ?? 0);
      document.getElementById('stat-cartes')!.textContent = String(data.totalCartes ?? 0);
      document.getElementById('stat-clients')!.textContent = String(data.totalClients ?? 0);
      document.getElementById('stat-transactions')!.textContent = String(data.totalTransactions ?? 0);
      document.getElementById('stat-nouveaux-30j')!.textContent = String(data.nouveaux30J ?? 0);
      document.getElementById('stat-plan-starter')!.textContent = String(data.plans?.starter ?? 0);
      document.getElementById('stat-points-vente')!.textContent = String(data.points_vente?.total ?? 0);
      const helper = document.getElementById('admin-onboarding-helper');
      const onboarding = data.onboarding ?? {};
      const billing = data.billing ?? {};
      if (helper) {
        helper.textContent = `${onboarding.sansCarte ?? 0} comptes créés, ${onboarding.cartePrete ?? 0} cartes prêtes, ${onboarding.cartePartagee ?? 0} cartes déjà partagées. Facturation: ${billing.active ?? 0} actifs, ${billing.trialing ?? 0} en essai.`;
      }
    } catch {}
  }

  async function loadRecentCommerces() {
    const container = document.getElementById('recent-commerces')!;
    try {
      const res = await authFetch(`${API_BASE}/api/admin/commerces`);
      if (!res.ok) throw new Error();
      const { data } = await res.json();
      allCommerces = data ?? [];

      if (!allCommerces.length) {
        container.innerHTML = '<p class="text-sm text-slate-500">Aucun commerce inscrit.</p>';
        return;
      }

      container.innerHTML = `
        <div class="overflow-x-auto">
          <table class="w-full min-w-[760px]">
            <thead class="border-b border-slate-200">
              <tr class="text-left">
                <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Commerce</th>
                <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Carte</th>
                <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Clients</th>
                <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Abonnement</th>
                <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Onboarding</th>
                <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Statut</th>
                <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Création</th>
                <th class="px-4 py-3 text-xs uppercase tracking-wide text-slate-500">Action</th>
              </tr>
            </thead>
            <tbody>
              ${allCommerces.slice(0, 12).map((commerce) => `
                <tr class="border-b border-slate-100 last:border-0 hover:bg-sky-50/70 transition-colors">
                  <td class="px-4 py-4">
                    <p class="text-sm font-semibold text-slate-900">${commerce.nom}</p>
                    <p class="mt-1 text-xs text-slate-500">${commerce.email ?? 'Pas d’email de contact'}</p>
                  </td>
                  <td class="px-4 py-4">
                    ${commerce.cartes.length > 0
                      ? '<span class="badge badge-success">Configurée</span>'
                      : '<span class="badge bg-slate-100 text-slate-500 border border-slate-200">À faire</span>'}
                  </td>
                  <td class="px-4 py-4 font-mono text-sm text-sky-700">${commerce.clients.length}</td>
                  <td class="px-4 py-4">
                    <div class="space-y-2">
                      <span class="badge bg-slate-100 text-slate-700 border border-slate-200">${planLabel(commerce.effective_plan ?? commerce.plan)}</span>
                      <div class="flex items-center gap-2">
                        <select
                          data-admin-plan-select="${commerce.id}"
                          class="rounded-lg border border-slate-200 bg-white px-2 py-1 text-[0.72rem] font-medium text-slate-700"
                        >
                          <option value="starter" ${planSelectValue(commerce.effective_plan ?? commerce.plan) === 'starter' ? 'selected' : ''}>Starter</option>
                          <option value="pro" ${planSelectValue(commerce.effective_plan ?? commerce.plan) === 'pro' ? 'selected' : ''}>Pro</option>
                          <option value="sur-mesure" ${planSelectValue(commerce.effective_plan ?? commerce.plan) === 'sur-mesure' ? 'selected' : ''}>Sur mesure</option>
                        </select>
                        <button data-admin-plan-apply="${commerce.id}" class="rounded-lg border border-sky-200 bg-sky-50 px-2 py-1 text-[0.68rem] font-semibold text-sky-700 transition hover:border-sky-300 hover:bg-sky-100" type="button">OK</button>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-4">
                    <span class="badge ${getOnboardingState(commerce).badge}">${getOnboardingState(commerce).label}</span>
                  </td>
                  <td class="px-4 py-4">
                    ${commerce.actif
                      ? '<span class="badge badge-success">Actif</span>'
                      : '<span class="badge badge-danger">Inactif</span>'}
                  </td>
                  <td class="px-4 py-4 text-sm text-slate-600">${new Date(commerce.created_at).toLocaleDateString('fr-FR')}</td>
                  <td class="px-4 py-4">
                    <button onclick="toggleCommerce('${commerce.id}', ${!commerce.actif})" class="rounded-xl border border-slate-200 px-3 py-2 text-xs font-medium text-slate-600 transition hover:bg-slate-50">
                      ${commerce.actif ? 'Désactiver' : 'Activer'}
                    </button>
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `;
      bindPlanActions();
    } catch {
      container.innerHTML = '<p class="text-sm text-red-500">Erreur lors du chargement admin.</p>';
    }
  }

  async function toggleCommerce(id: string, actif: boolean) {
    try {
      await authFetch(`${API_BASE}/api/admin/commerces/${id}`, {
        method: 'PATCH',
        body: JSON.stringify({ actif }),
      });
      await loadStats();
      await loadRecentCommerces();
    } catch {}
  }

  async function updatePlan(id: string, planOverride: 'starter' | 'pro' | 'sur-mesure') {
    const endpoint = `${API_BASE}/api/admin/commerces/${id}/plan`;
    const response = await authFetch(endpoint, {
      method: 'PATCH',
      body: JSON.stringify({ plan_override: planOverride }),
    });
    if (!response.ok) {
      const payload = await response.json().catch(() => null);
      throw new Error(payload?.error ?? 'Impossible de mettre à jour le plan.');
    }
  }

  function bindPlanActions() {
    document.querySelectorAll<HTMLButtonElement>('[data-admin-plan-apply]').forEach((button) => {
      button.addEventListener('click', async () => {
        const id = button.dataset.adminPlanApply;
        if (!id) return;
        const select = document.querySelector<HTMLSelectElement>(`[data-admin-plan-select="${id}"]`);
        if (!select) return;
        button.disabled = true;
        const previous = button.textContent ?? 'OK';
        button.textContent = '...';
        try {
          await updatePlan(id, select.value as 'starter' | 'pro' | 'sur-mesure');
          await loadStats();
          await loadRecentCommerces();
          setActionFeedback('Plan mis à jour avec succès.', 'success');
        } catch (error) {
          setActionFeedback(error instanceof Error ? error.message : 'Erreur de mise à jour du plan.', 'error');
          button.disabled = false;
          button.textContent = previous;
        }
      });
    });
  }

  function setHealthStatus(targetId: string, label: string, ok: boolean | null) {
    const node = document.getElementById(targetId);
    if (!node) return;
    node.textContent = label;
    if (ok === null) {
      node.className = 'mt-1 text-sm font-semibold text-slate-900';
      return;
    }
    node.className = ok
      ? 'mt-1 text-sm font-semibold text-emerald-700'
      : 'mt-1 text-sm font-semibold text-rose-700';
  }

  async function loadAdminAuditLogs() {
    const container = document.getElementById('admin-audit-log-list');
    if (!container) return;
    try {
      const res = await authFetch(`${API_BASE}/api/admin/audit-logs?limit=8`);
      if (!res.ok) throw new Error();
      const payload = await res.json().catch(() => null);
      const logs = Array.isArray(payload?.data) ? payload.data : [];
      if (!logs.length) {
        container.innerHTML = '<p class="text-sm text-slate-500">Aucune action enregistrée pour le moment.</p>';
        return;
      }

      container.innerHTML = logs.map((log: any) => {
        const when = new Date(log.created_at).toLocaleString('fr-FR');
        const actor = String(log.admin_email ?? 'admin');
        const action = String(log.action ?? 'action');
        const target = String(log.target_type ?? '');
        const targetId = String(log.target_id ?? '').slice(0, 8);
        return `
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-2.5">
            <p class="text-xs font-semibold text-slate-800">${action}</p>
            <p class="mt-1 text-[0.72rem] text-slate-500">${actor} · ${target}${targetId ? ` #${targetId}` : ''}</p>
            <p class="mt-1 text-[0.68rem] text-slate-400">${when}</p>
          </div>
        `;
      }).join('');
    } catch {
      container.innerHTML = '<p class="text-sm text-slate-500">Journal indisponible (migration à appliquer).</p>';
    }
  }

  async function loadPlatformHealth() {
    try {
      const [apiRes, depsRes] = await Promise.all([
        fetch(`${API_BASE}/api/health`).catch(() => null),
        fetch(`${API_BASE}/api/health/deps`).catch(() => null),
      ]);

      if (!apiRes) {
        setHealthStatus('health-api-status', 'API indisponible', false);
      } else {
        const apiPayload = await apiRes.json().catch(() => null);
        setHealthStatus('health-api-status', apiPayload?.ok ? 'Opérationnelle' : 'Dégradée', Boolean(apiPayload?.ok));
      }

      if (!depsRes) {
        setHealthStatus('health-db-status', 'Vérification indisponible', false);
        setHealthStatus('health-stripe-status', 'Indisponible', false);
        setHealthStatus('health-wallet-status', 'Indisponible', false);
        setHealthStatus('health-migrations-status', 'Indisponible', false);
        return;
      }

      const depsPayload = await depsRes.json().catch(() => null);
      const services = depsPayload?.services ?? {};
      const databaseOk = Boolean(services?.database?.ok);
      const dbLatency = Number(services?.database?.latency_ms ?? 0);
      const dbLabel = databaseOk
        ? `OK (${dbLatency} ms)`
        : `Dégradée${services?.database?.error ? ` · ${services.database.error}` : ''}`;
      setHealthStatus('health-db-status', dbLabel, databaseOk);
      setHealthStatus('health-stripe-status', services?.stripe?.ok ? 'Connecté' : 'Non configuré', Boolean(services?.stripe?.ok));

      const appleOk = Boolean(services?.wallet?.apple_ok);
      const googleOk = Boolean(services?.wallet?.google_ok);
      const walletLabel = appleOk && googleOk
        ? 'Apple + Google OK'
        : appleOk
          ? 'Apple OK · Google KO'
          : googleOk
            ? 'Google OK · Apple KO'
            : 'Non configuré';
      setHealthStatus('health-wallet-status', walletLabel, appleOk || googleOk);

      const migrationsOk = Boolean(services?.migrations?.ok);
      const checks = services?.migrations?.checks ?? {};
      const failedCount = Object.values(checks).filter((entry: any) => !entry?.ok).length;
      const migrationLabel = migrationsOk
        ? 'Schéma à jour'
        : failedCount > 0
          ? `${failedCount} vérification(s) KO`
          : 'Schéma incomplet';
      setHealthStatus('health-migrations-status', migrationLabel, migrationsOk);
    } catch {
      setHealthStatus('health-api-status', 'Vérification indisponible', false);
      setHealthStatus('health-db-status', 'Vérification indisponible', false);
