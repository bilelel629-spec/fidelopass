              <div><p id="g-label-client" class="text-gray-400 text-xs uppercase">Client</p><p class="text-gray-900 font-semibold text-sm">Votre prénom</p></div>
              <div id="g-barcode-wrap"><svg viewBox="0 0 21 21" class="w-10 h-10" style="image-rendering:pixelated"><rect x="0" y="0" width="7" height="7" fill="#111" rx="1"/><rect x="1" y="1" width="5" height="5" fill="white"/><rect x="2" y="2" width="3" height="3" fill="#111"/><rect x="14" y="0" width="7" height="7" fill="#111" rx="1"/><rect x="15" y="1" width="5" height="5" fill="white"/><rect x="16" y="2" width="3" height="3" fill="#111"/><rect x="0" y="14" width="7" height="7" fill="#111" rx="1"/><rect x="1" y="15" width="5" height="5" fill="white"/><rect x="2" y="16" width="3" height="3" fill="#111"/></svg></div>
