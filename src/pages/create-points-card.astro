---
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const examples = [
  '1€ dépensé = 1 point',
  '100 points = 5€ de réduction',
  'Seuils VIP et récompenses progressives',
];
---

<BaseLayout title="Carte à points Fidelopass" description="Lancez une carte à points Wallet pour suivre les achats, débloquer des paliers et fidéliser les clients réguliers.">
  <div class="relative overflow-hidden min-h-screen">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[62rem] h-[62rem] rounded-full blur-3xl opacity-20" style="background:radial-gradient(circle,#0ea5e9 0%,rgba(10,15,30,0) 62%)"></div>
    </div>

    <PublicNav currentPath="/create-points-card" />

    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pt-8 pb-16">
      <div class="grid lg:grid-cols-[1fr_0.95fr] gap-10 items-center">
        <div>
          <div class="badge badge-info mb-5">Produit Fidelopass</div>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-[0.96]">
            La carte à points Wallet
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-sky-300 via-indigo-300 to-emerald-200">
              pour les commerces qui veulent piloter plus finement
            </span>
          </h1>
          <p class="text-slate-300 text-lg leading-relaxed mt-6 max-w-2xl">
            La carte à points est idéale quand la valeur d’achat varie, quand plusieurs récompenses coexistent ou quand on veut introduire une logique de progression plus riche qu’un simple tampon.
          </p>
          <div class="space-y-3 mt-8">
            {examples.map((item) => (
              <div class="flex items-start gap-3 text-sm text-slate-300">
                <span class="mt-1 w-2.5 h-2.5 rounded-full bg-sky-400"></span>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="grid gap-5">
          <article class="card p-6">
            <p class="text-slate-500 text-xs uppercase tracking-[0.3em]">Pourquoi choisir les points</p>
            <p class="text-white font-semibold mt-4">Le programme devient plus flexible sans perdre en lisibilité.</p>
            <p class="text-slate-400 text-sm leading-relaxed mt-3">Tu peux récompenser le panier, la récurrence et même l’ancienneté client, tout en affichant une progression simple dans le Wallet.</p>
          </article>
          <article class="card p-6">
            <p class="text-slate-500 text-xs uppercase tracking-[0.3em]">Ce que le commerce y gagne</p>
            <p class="text-white font-semibold mt-4">Plus de paliers, plus de scénarios, plus de valeur perçue.</p>
            <p class="text-slate-400 text-sm leading-relaxed mt-3">Ce format est parfait pour pousser les récompenses multiples, les niveaux VIP et les messages ciblés aux meilleurs clients.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pb-20">
      <div class="rounded-[2rem] border border-white/10 p-8 sm:p-10" style="background:linear-gradient(135deg,rgba(15,23,42,0.92),rgba(14,165,233,0.14),rgba(99,102,241,0.18))">
        <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-center">
          <div>
            <p class="text-slate-300 text-xs uppercase tracking-[0.3em]">Structure conseillée</p>
            <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mt-4">Un bon format pour passer d’une simple fidélité à un vrai programme relationnel.</h2>
            <p class="text-slate-200/85 text-base sm:text-lg leading-relaxed mt-4 max-w-2xl">
              Si ton angle commercial repose sur la personnalisation, les seuils et les avantages progressifs, la carte à points est la plus persuasive à vendre.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row lg:flex-col gap-3">
            <a href="/register" class="btn-primary px-8 py-3.5 text-base">Créer une carte à points</a>
            <a href="/help" class="btn-secondary px-8 py-3.5 text-base">Lire les guides</a>
          </div>
        </div>
      </div>
    </section>

    <PublicFooter />
  </div>
</BaseLayout>
