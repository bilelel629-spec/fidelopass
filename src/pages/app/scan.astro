---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Scanner — FideloPass">
  <div class="min-h-[100dvh] flex flex-col">
    <!-- Header -->
    <div class="flex items-center gap-3 px-4 pt-6 pb-4 border-b border-white/10">
      <a href="/app" class="text-slate-400 hover:text-white transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h1 class="font-display font-bold text-white">Scanner la carte</h1>
    </div>

    <!-- Zone scanner -->
    <div class="flex-1 flex flex-col items-center justify-center px-4 gap-6">
      <div class="relative w-full max-w-sm">
        <div id="reader" class="w-full aspect-[3/4] rounded-2xl overflow-hidden border-2 border-indigo-500/50 bg-navy-800"></div>
        <div class="pointer-events-none absolute inset-4 rounded-2xl border-2 border-white/70 shadow-[0_0_0_999px_rgba(2,6,23,0.22)]"></div>
      </div>
      <div class="text-center">
        <p class="text-slate-200 text-sm font-medium">Scannez directement avec la caméra</p>
        <p id="scanner-status" class="text-slate-400 text-sm mt-1">Autorisez la caméra puis pointez le QR code du Wallet.</p>
      </div>
    </div>

    <!-- Résultat scan -->
    <div id="scan-result" class="hidden fixed inset-0 bg-navy-900/95 backdrop-blur-sm flex flex-col items-center justify-center px-6 z-50">
      <div class="card w-full max-w-sm p-6 text-center">
        <div id="result-icon" class="text-5xl mb-4">👤</div>
        <h2 id="result-nom" class="font-display font-bold text-xl text-white mb-1">—</h2>
        <p id="result-solde" class="text-slate-400 text-sm mb-6">—</p>

        <div class="flex gap-3 mb-4">
          <button id="btn-tampon" class="btn-primary flex-1 py-4 flex flex-col items-center">
            <span class="text-2xl mb-1">🔖</span>
            <span class="text-sm">+1 tampon</span>
          </button>
          <button id="btn-points" class="btn-secondary flex-1 py-4 flex flex-col items-center">
            <span class="text-2xl mb-1">⭐</span>
            <span class="text-sm">+points</span>
          </button>
        </div>

        <button id="btn-reward" class="hidden btn-secondary w-full py-3 mb-4 text-emerald-300 border-emerald-400/20 hover:bg-emerald-500/10">
          Utiliser 1 récompense
        </button>

        <button id="btn-close" class="btn-secondary w-full py-3">Annuler</button>
      </div>
    </div>

    <div id="points-modal" class="hidden fixed inset-0 bg-navy-950/90 backdrop-blur-sm z-[60] flex items-center justify-center px-6">
      <div class="card w-full max-w-xs p-5">
        <h2 class="font-display font-bold text-white text-lg">Ajouter des points</h2>
        <p class="text-slate-400 text-sm mt-1 mb-4">Entrez le nombre de points à créditer.</p>
        <input id="points-value" type="number" min="1" step="1" inputmode="numeric" class="input text-center text-xl font-mono" placeholder="10" />
        <div class="grid grid-cols-2 gap-3 mt-4">
          <button id="btn-cancel-points" type="button" class="btn-secondary py-3">Annuler</button>
          <button id="btn-confirm-points" type="button" class="btn-primary py-3">Ajouter</button>
        </div>
      </div>
    </div>
  </div>
</AppLayout>

<script>
  import { Html5Qrcode } from 'html5-qrcode';
  import confetti from 'canvas-confetti';
  import { authFetch } from '../../lib/api';

  let currentClientId: string | null = null;
  let currentClientRecompenses = 0;
  let scannerPaused = false;

  const scannerStatus = document.getElementById('scanner-status')!;
  const scanner = new Html5Qrcode('reader', false);
  const scanConfig = {
    fps: 12,
    qrbox: (viewfinderWidth: number, viewfinderHeight: number) => {
      const minEdge = Math.min(viewfinderWidth, viewfinderHeight);
      const size = Math.floor(Math.min(minEdge * 0.86, 360));
      return { width: size, height: size };
    },
    aspectRatio: 3 / 4,
    experimentalFeatures: {
      useBarCodeDetectorIfSupported: true,
    },
  };

  function setScannerStatus(message: string) {
    scannerStatus.textContent = message;
  }

  async function startScanner() {
    scannerPaused = false;
    setScannerStatus('Ouverture de la caméra...');

    try {
      await scanner.start(
        {
          facingMode: { exact: 'environment' },
          width: { ideal: 1280 },
          height: { ideal: 720 },
        },
        scanConfig,
        handleScan,
        () => {},
      );
      setScannerStatus('Pointez la caméra vers le QR code de la carte Wallet.');
    } catch {
      try {
        await scanner.start(
          {
            facingMode: 'environment',
            width: { ideal: 1280 },
            height: { ideal: 720 },
          },
          scanConfig,
          handleScan,
          () => {},
        );
        setScannerStatus('Pointez la caméra vers le QR code de la carte Wallet.');
      } catch {
        setScannerStatus('Caméra indisponible. Autorisez la caméra dans le navigateur puis rechargez la page.');
      }
    }
  }

  function resumeScanner() {
    if (!scannerPaused) return;
    scannerPaused = false;
    scanner.resume();
    setScannerStatus('Pointez la caméra vers le QR code de la carte Wallet.');
  }

  async function handleScan(decodedText: string) {
    if (scannerPaused) return;
    scannerPaused = true;
    scanner.pause();
    setScannerStatus('QR code détecté...');

    try {
      // Le QR contient l'ID client
      const clientId = decodedText.trim();
      const res = await authFetch(`/api/clients/${clientId}`);
      if (!res.ok) throw new Error('Client introuvable');

      const { data } = await res.json();
      currentClientId = clientId;
      currentClientRecompenses = data.recompenses_obtenues ?? 0;

      document.getElementById('result-nom')!.textContent = data.nom ?? 'Client anonyme';
      document.getElementById('result-solde')!.textContent =
        data.tampons_actuels !== undefined
          ? `${data.tampons_actuels} tampons — ${data.recompenses_obtenues} récompense(s)`
          : `${data.points_actuels} points`;
      const rewardBtn = document.getElementById('btn-reward')!;
      rewardBtn.classList.toggle('hidden', currentClientRecompenses <= 0);

      document.getElementById('scan-result')!.classList.remove('hidden');

      // Feedback haptique
      if (navigator.vibrate) navigator.vibrate(100);
    } catch {
      alert('QR code non reconnu. Réessayez.');
      resumeScanner();
    }
  }

  // Bouton +1 tampon
  document.getElementById('btn-tampon')!.addEventListener('click', async () => {
    if (!currentClientId) return;
    await addTransaction('ajout_tampon', 1);
  });

  // Bouton +points
  document.getElementById('btn-points')!.addEventListener('click', async () => {
    if (!currentClientId) return;
    document.getElementById('points-modal')!.classList.remove('hidden');
    (document.getElementById('points-value') as HTMLInputElement).focus();
  });

  document.getElementById('btn-reward')!.addEventListener('click', async () => {
    if (!currentClientId || currentClientRecompenses <= 0) return;
    await addTransaction('recompense', 1);
  });

  document.getElementById('btn-cancel-points')!.addEventListener('click', () => {
    document.getElementById('points-modal')!.classList.add('hidden');
  });

  document.getElementById('btn-confirm-points')!.addEventListener('click', async () => {
    const input = document.getElementById('points-value') as HTMLInputElement;
    const valeur = parseInt(input.value);
    if (!Number.isFinite(valeur) || valeur < 1) {
      input.focus();
      return;
    }
    document.getElementById('points-modal')!.classList.add('hidden');
    input.value = '';
    await addTransaction('ajout_points', valeur);
  });

  async function addTransaction(type: string, valeur: number) {
    try {
      const res = await authFetch('/api/transactions', {
        method: 'POST',
        body: JSON.stringify({ client_id: currentClientId, type, valeur }),
      });

      if (!res.ok) throw new Error();

      const data = await res.json();

      // Feedback positif
      if (navigator.vibrate) navigator.vibrate([50, 50, 100]);

      // Confetti si récompense obtenue (dernier tampon ou points atteints)
      const newRecompenses: number = data.client?.recompenses_obtenues ?? currentClientRecompenses;
      if (newRecompenses > currentClientRecompenses) {
        fireRewardConfetti();
      }

      closeResult();
    } catch {
      alert('Erreur lors de l\'ajout. Réessayez.');
    }
  }

  function fireRewardConfetti() {
    const duration = 2500;
    const end = Date.now() + duration;

    const frame = () => {
      confetti({
        particleCount: 4,
        angle: 60,
        spread: 55,
        origin: { x: 0, y: 0.7 },
        colors: ['#6366f1', '#a78bfa', '#f59e0b', '#10b981', '#ef4444'],
        zIndex: 9999,
      });
      confetti({
        particleCount: 4,
        angle: 120,
        spread: 55,
        origin: { x: 1, y: 0.7 },
        colors: ['#6366f1', '#a78bfa', '#f59e0b', '#10b981', '#ef4444'],
        zIndex: 9999,
      });
      if (Date.now() < end) requestAnimationFrame(frame);
    };
    frame();
  }

  function closeResult() {
    document.getElementById('scan-result')!.classList.add('hidden');
    currentClientId = null;
    currentClientRecompenses = 0;
    resumeScanner();
  }

  document.getElementById('btn-close')!.addEventListener('click', closeResult);
  startScanner();
</script>
