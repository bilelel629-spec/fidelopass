---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
---

<BaseLayout
  theme="light"
  title="Fidelopass — Cartes de fidélité Apple Wallet & Google Wallet pour commerces"
  description="Créez une carte de fidélité dans Apple Wallet et Google Wallet en 5 minutes. Sans application pour vos clients. Essai gratuit 15 jours."
>
  <PublicNav currentPath="/" />

  <!-- HERO -->
  <section class="relative overflow-hidden bg-[linear-gradient(180deg,#ffffff_0%,#f6f9ff_58%,#ffffff_100%)] pt-10 pb-16 sm:pt-14 sm:pb-20">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-16 right-0 h-72 w-72 rounded-full bg-sky-200/35 blur-3xl"></div>
      <div class="absolute top-24 left-0 h-64 w-64 rounded-full bg-indigo-200/25 blur-3xl"></div>
      <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-white"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 grid lg:grid-cols-[1.02fr_0.98fr] gap-10 lg:gap-12 items-center">
      <div class="relative">
        <span class="mb-5 inline-flex items-center rounded-full border border-sky-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-sky-700 shadow-sm">Fidélité Wallet-first · Sans application</span>
        <h1 class="font-display text-[2.85rem] sm:text-[4.15rem] font-bold text-slate-900 leading-[0.98] tracking-[-0.04em]">
          Transformez vos
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-500">
            clients en habitués.
          </span>
        </h1>
        <p class="text-slate-500 text-lg leading-relaxed mt-6 max-w-lg">
          Créez une carte de fidélité directement dans Apple Wallet et Google Wallet.
          Vos clients l'ajoutent en 20 secondes — sans compte, sans téléchargement.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mt-8">
          <a href="/register" class="inline-flex items-center justify-center rounded-2xl bg-slate-950 px-7 py-3.5 text-base font-semibold text-white shadow-[0_18px_40px_rgba(15,23,42,0.18)] transition-all hover:-translate-y-0.5 hover:bg-slate-900">
            Essai gratuit — 15 jours
          </a>
          <a href="/comment-ca-fonctionne" class="inline-flex items-center justify-center rounded-2xl border border-slate-200 bg-white px-7 py-3.5 text-base font-medium text-slate-700 shadow-sm transition-all hover:border-slate-300 hover:text-slate-900 hover:shadow-md">
            Comment ça marche →
          </a>
        </div>

        <p class="text-slate-400 text-sm mt-4">
          Aucune carte de crédit · Aucune application pour vos clients · Prêt en 5 minutes
        </p>

        <div class="flex flex-wrap gap-5 mt-8">
          <div class="flex items-center gap-2 text-sm text-slate-500">
            <span class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 text-xs font-bold">✓</span>
            Apple Wallet natif
          </div>
          <div class="flex items-center gap-2 text-sm text-slate-500">
            <span class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 text-xs font-bold">✓</span>
            Google Wallet natif
          </div>
          <div class="flex items-center gap-2 text-sm text-slate-500">
            <span class="w-5 h-5 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 text-xs font-bold">✓</span>
            +27% de rétention clients
          </div>
        </div>
      </div>

      <!-- Mockup carte Wallet -->
      <div class="relative flex justify-center">
        <div class="absolute inset-8 rounded-[3rem] blur-3xl opacity-20 bg-gradient-to-br from-indigo-300 to-sky-300"></div>
        <div class="relative w-full max-w-[25rem]">
          <div class="rounded-[2rem] overflow-hidden border border-white/70 shadow-[0_35px_80px_rgba(15,23,42,0.14)]">
            <div class="p-6" style="background:linear-gradient(145deg,#1e1b4b,#312e81 55%,#0f766e)">
              <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 rounded-2xl bg-white/15 border border-white/20 flex items-center justify-center text-2xl">☕</div>
                  <div>
                    <p class="text-white font-bold text-sm">Café Lumière</p>
                    <p class="text-white/60 text-xs">Carte de fidélité</p>
                  </div>
                </div>
                <span class="rounded-full bg-amber-400/20 border border-amber-400/30 text-amber-200 text-xs font-medium px-3 py-1">6 / 10</span>
              </div>
              <div class="rounded-2xl bg-black/20 border border-white/10 p-4 mb-5">
                <div class="grid grid-cols-5 gap-2.5">
                  {Array.from({ length: 10 }).map((_, i) => (
                    <div
                      class="aspect-square rounded-full border-2 flex items-center justify-center text-sm font-bold"
                      style={i < 6 ? 'background:#f59e0b;border-color:#f59e0b;color:white;' : 'border-color:rgba(255,255,255,0.2);color:rgba(255,255,255,0.3);'}
                    >
                      {i < 6 ? '✓' : '·'}
                    </div>
                  ))}
                </div>
                <p class="text-white/50 text-xs text-center mt-3">10 tampons = 1 café offert</p>
              </div>
              <div class="rounded-xl bg-white px-4 py-3 text-center">
                <div class="h-10 rounded-lg" style="background:repeating-linear-gradient(90deg,#1e1b4b 0,#1e1b4b 3px,transparent 3px,transparent 7px);"></div>
                <p class="text-slate-400 text-xs mt-1.5">Scanner en boutique</p>
              </div>
            </div>
          </div>
          <div class="absolute -right-4 top-6 rounded-2xl border border-slate-100 bg-white/95 px-4 py-3 text-xs shadow-[0_16px_40px_rgba(15,23,42,0.10)] backdrop-blur">
            <p class="font-semibold text-slate-900">🍎 Apple Wallet</p>
            <p class="text-slate-400 mt-0.5">Ajouté en 20 sec</p>
          </div>
          <div class="absolute -left-4 bottom-8 rounded-2xl border border-slate-100 bg-white/95 px-4 py-3 text-xs shadow-[0_16px_40px_rgba(15,23,42,0.10)] backdrop-blur">
            <p class="font-semibold text-slate-900">📲 Notification push</p>
            <p class="text-emerald-500 mt-0.5">+1 client revenu</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BARRE RÉASSURANCE -->
  <div class="bg-white py-4 sm:py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-5">
        {[
          { eyebrow: 'Compatibilité', value: 'Apple Wallet', detail: 'Ajout natif sur iPhone', icon: '/apple-wallet-logo.png' },
          { eyebrow: 'Compatibilité', value: 'Google Wallet', detail: 'Ajout natif sur Android', icon: '/google-wallet-logo.png' },
          { eyebrow: 'Expérience client', value: 'Aucune application', detail: 'Scan, ajout et fidélisation fluide', icon: '/client-experience-icon.svg' },
          { eyebrow: 'Mise en place', value: 'Prêt en 5 minutes', detail: 'QR, carte et scanner inclus', icon: '/setup-watch-icon.svg' },
          { eyebrow: 'Performance', value: '+27% de rétention', detail: 'Moyenne observée sur les cartes Wallet', icon: '/growth-arrow-icon.svg' },
        ].map((item) => (
          <div class="rounded-[1.35rem] border border-slate-200 bg-white px-5 py-4 shadow-sm">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl border border-slate-200 bg-slate-50">
              <img src={item.icon} alt={item.value} class="h-10 w-10 object-contain" />
            </div>
            <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-400">{item.eyebrow}</p>
            <p class="mt-2 text-base font-semibold text-slate-900">{item.value}</p>
            <p class="mt-1 text-sm text-slate-500 leading-relaxed">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- COMMENT ÇA FONCTIONNE -->
  <section class="bg-white py-18 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <span class="mb-4 inline-flex items-center rounded-full border border-sky-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-sky-700 shadow-sm">Simple comme bonjour</span>
        <h2 class="font-display text-4xl sm:text-5xl font-bold text-slate-900 mt-2">Comment ça fonctionne ?</h2>
        <p class="text-slate-500 text-lg mt-4 max-w-2xl mx-auto">
          Trois étapes pour passer d'un commerce sans programme à une fidélité active et mesurable.
        </p>
      </div>
      <div class="grid lg:grid-cols-3 gap-8">
        {[
          { num: '01', tag: 'Création', title: 'Créez votre carte en 5 min', desc: 'Choisissez le type de programme, vos couleurs et votre identité. La carte est immédiatement prête à être partagée.' },
          { num: '02', tag: 'Diffusion', title: 'Partagez le QR code', desc: 'Affichez le QR en magasin ou envoyez votre lien. Vos clients ajoutent leur carte au Wallet en quelques secondes.' },
          { num: '03', tag: 'Activation', title: 'Scannez & relancez', desc: 'À chaque passage, la carte est scannée, mise à jour et prête à déclencher vos récompenses ou messages Wallet.' },
        ].map((s) => (
          <div class="rounded-[1.75rem] border border-slate-200 bg-white p-8 shadow-[0_20px_45px_rgba(15,23,42,0.06)] transition-transform hover:-translate-y-1">
            <div class="flex items-center justify-between gap-4 mb-6">
              <span class="inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-950 text-sm font-bold text-white shadow-[0_14px_30px_rgba(15,23,42,0.16)]">{s.num}</span>
              <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">{s.tag}</span>
            </div>
            <h3 class="font-display text-xl font-bold text-slate-900">{s.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed mt-3">{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/comment-ca-fonctionne" class="btn-secondary px-6 py-2.5 text-sm">Voir le détail complet →</a>
      </div>
    </div>
  </section>

  <!-- AVANTAGES -->
  <section class="bg-slate-50/70 py-18 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <span class="mb-4 inline-flex items-center rounded-full border border-sky-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-sky-700 shadow-sm">Pourquoi Fidelopass</span>
        <h2 class="font-display text-4xl sm:text-5xl font-bold text-slate-900 mt-2">Tout pour fidéliser efficacement</h2>
        <p class="text-slate-500 text-lg mt-4 max-w-2xl mx-auto">
          Une solution complète, pensée pour les commerçants de proximité.
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { label: 'Personnalisation', title: 'Une carte à votre image, pas un modèle générique', desc: 'Logo, couleurs, bannière, programme à points ou à tampons : chaque carte renforce votre marque et donne envie de revenir.' },
          { label: 'Relance', title: 'Faites revenir vos clients avec des messages qui comptent', desc: 'Relancez au bon moment depuis Wallet avec des messages utiles, visibles et directement liés à la carte du client.' },
          { label: 'Proximité', title: 'Restez présent quand le client passe près du commerce', desc: 'La carte peut remonter à proximité du point de vente pour recréer un réflexe de visite sans friction.' },
          { label: 'Terrain', title: 'Recrutez des porteurs de carte directement au comptoir', desc: 'Vos affiches QR et liens d’inscription transforment chaque visite en opportunité de fidélisation immédiate.' },
          { label: 'Pilotage', title: 'Transformez chaque scan en signal exploitable', desc: 'Suivez les passages, récompenses, clients actifs et campagnes pour comprendre ce qui fait réellement revenir.' },
          { label: 'Adoption', title: 'Le client comprend instantanément quoi faire', desc: 'Pas d’application à télécharger, pas de création de compte complexe : le parcours est simple, rapide et rassurant.' },
        ].map((a) => (
          <div class="rounded-[1.75rem] border border-white/80 bg-white p-7 shadow-[0_18px_45px_rgba(15,23,42,0.08)] transition-all hover:-translate-y-1 hover:shadow-[0_24px_55px_rgba(15,23,42,0.12)]">
            <div class="mb-5 inline-flex rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">{a.label}</div>
            <h3 class="font-display text-lg font-bold text-slate-900 mb-2">{a.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{a.desc}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 rounded-[2rem] bg-[linear-gradient(135deg,#0f172a_0%,#312e81_58%,#0284c7_100%)] p-8 text-center shadow-[0_30px_70px_rgba(49,46,129,0.28)]">
        <p class="text-indigo-200 text-sm font-medium uppercase tracking-widest mb-2">Résultat moyen constaté</p>
        <p class="font-display text-5xl font-bold text-white">+27%</p>
        <p class="text-indigo-200 text-lg mt-2">de rétention clients avec une carte de fidélité Wallet</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="mb-4 inline-flex items-center rounded-full border border-sky-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-sky-700 shadow-sm">FAQ</span>
        <h2 class="font-display text-4xl sm:text-5xl font-bold text-slate-900 mt-2">On répond à vos questions</h2>
      </div>
      <div class="space-y-3" id="faq-list">
        {[
          { q: 'Mes clients doivent-ils télécharger une application ?', a: 'Non. Vos clients reçoivent la carte directement dans Apple Wallet (iPhone) ou Google Wallet (Android), déjà installés sur tous les smartphones. Aucun téléchargement supplémentaire.' },
          { q: 'Comment fonctionne l\'essai gratuit de 15 jours ?', a: 'Vous créez votre compte gratuitement sans carte bancaire. Pendant 15 jours, accès à toutes les fonctionnalités. À la fin, vous choisissez votre plan. Sans engagement.' },
          { q: 'La carte fonctionne-t-elle sur iPhone et Android ?', a: 'Oui. Fidelopass génère automatiquement une carte Apple Wallet (iPhone) et Google Wallet (Android). Vos clients reçoivent le bon format selon leur téléphone.' },
          { q: 'Combien de temps pour créer sa première carte ?', a: 'Moins de 5 minutes. Choisissez le type (tampons, points ou VIP), personnalisez couleurs et logo — votre carte est prête.' },
          { q: 'Puis-je changer de plan à tout moment ?', a: 'Oui. Passez à un plan supérieur ou résiliez à tout moment. Pas d\'engagement minimum sur les plans mensuels.' },
          { q: 'C\'est quoi la carte VIP / paliers ?', a: 'La carte VIP crée des niveaux de fidélité (ex: Bronze, Silver, Gold). Chaque palier débloque des avantages différents. Idéal pour salons, spas ou commerces premium.' },
        ].map((item, i) => (
          <div class="overflow-hidden rounded-[1.5rem] border border-slate-200 bg-white shadow-sm" data-faq={i}>
            <button class="w-full px-6 py-5 text-left flex items-center justify-between gap-4" aria-expanded="false">
              <span class="font-semibold text-slate-900 text-sm sm:text-base">{item.q}</span>
              <span class="faq-icon text-slate-400 text-xl flex-shrink-0 font-light">+</span>
            </button>
            <div class="faq-answer hidden px-6 pb-5">
              <p class="text-slate-500 text-sm leading-relaxed">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-[linear-gradient(135deg,#0f172a_0%,#312e81_55%,#0284c7_100%)] py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-4xl sm:text-5xl font-bold text-white leading-tight">
        Prêt à faire revenir vos clients ?
      </h2>
      <p class="text-indigo-200 text-lg mt-5 leading-relaxed">
        Essai gratuit de 15 jours. Aucune carte de crédit requise.<br/>
        Aucune application pour vos clients. Installation en 5 minutes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/register" class="inline-flex items-center justify-center bg-white text-indigo-700 font-bold px-8 py-4 rounded-xl hover:bg-indigo-50 transition-colors text-base shadow-lg">
          Démarrer l'essai gratuit
        </a>
        <a href="/pricing" class="inline-flex items-center justify-center bg-white/10 text-white font-medium px-8 py-4 rounded-xl hover:bg-white/20 border border-white/20 transition-colors text-base">
          Voir les tarifs
        </a>
      </div>
      <p class="text-indigo-300 text-sm mt-5">Sans engagement · Annulation à tout moment</p>
    </div>
  </section>

  <PublicFooter />
</BaseLayout>

<script>
  document.querySelectorAll('#faq-list [data-faq]').forEach((item) => {
    const btn = item.querySelector('button') as HTMLButtonElement;
    const answer = item.querySelector('.faq-answer') as HTMLDivElement;
    const icon = item.querySelector('.faq-icon') as HTMLSpanElement;
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      answer.classList.toggle('hidden', open);
      icon.textContent = open ? '+' : '×';
    });
  });
</script>
