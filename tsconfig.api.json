{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "astro/client"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    "api/**/*.ts",
    "src/lib/supabase.ts",
    "src/lib/brevo-sms.ts",
    "src/lib/database.types.ts"
  ],
  "exclude": ["node_modules", "dist", "src/pages", "src/components", "src/layouts", "src/middleware.ts"]
}
