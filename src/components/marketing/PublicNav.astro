---
interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const links = [
  { href: '/comment-ca-fonctionne', label: 'Comment ça marche' },
  { href: '/pricing', label: 'Tarifs' },
  { href: '/contact', label: 'Contact' },
];
---

<nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="inline-flex items-center shrink-0">
      <img src="/logo-premium.png" alt="Fidelopass" class="h-10 w-auto" />
    </a>

    <div class="hidden md:flex items-center gap-7 text-sm text-slate-500 font-medium">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'transition-colors hover:text-slate-900',
            currentPath === link.href && 'text-slate-900',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3 shrink-0">
      <a href="/login" class="btn-secondary text-sm px-4 py-2">Connexion</a>
      <a href="/register" class="btn-primary text-sm px-4 py-2">Essai gratuit — 15 jours</a>
    </div>
  </div>
</nav>
