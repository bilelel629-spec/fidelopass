---
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const useCases = [
  'Coffee shop, salon, barber, boulangerie, snack, boutique de passage',
  'Récompense simple du type 8 ou 10 passages = 1 offert',
  'Passage rapide au comptoir avec un scan immédiat',
];

const strengths = [
  'Le client comprend instantanément sa progression',
  'Le commerçant n’a pas besoin d’expliquer une mécanique complexe',
  'Le scan et l’ajout de tampon restent ultra fluides en boutique',
];
---

<BaseLayout title="Carte à tampons Fidelopass" description="Créez une carte à tampons Apple Wallet et Google Wallet simple à scanner et facile à comprendre pour vos clients.">
  <div class="relative overflow-hidden min-h-screen">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[60rem] h-[60rem] rounded-full blur-3xl opacity-20" style="background:radial-gradient(circle,#6366f1 0%,rgba(10,15,30,0) 62%)"></div>
      <div class="absolute bottom-0 left-0 w-[24rem] h-[24rem] rounded-full blur-3xl opacity-15" style="background:radial-gradient(circle,#f59e0b 0%,rgba(10,15,30,0) 68%)"></div>
    </div>

    <PublicNav currentPath="/create-stamp-card" />

    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pt-8 pb-16">
      <div class="grid lg:grid-cols-[1fr_0.95fr] gap-10 items-center">
        <div>
          <div class="badge badge-info mb-5">Produit Fidelopass</div>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-[0.96]">
            La carte à tampons Wallet,
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-indigo-300 via-sky-300 to-amber-200">
              la plus naturelle pour les commerces de passage
            </span>
          </h1>
          <p class="text-slate-300 text-lg leading-relaxed mt-6 max-w-2xl">
            Si le commerçant veut remplacer une carte papier sans changer ses habitudes, la carte à tampons est le meilleur point d’entrée. Elle est simple à comprendre, rapide à scanner et rassurante à vendre.
          </p>
          <div class="space-y-3 mt-8">
            {useCases.map((item) => (
              <div class="flex items-start gap-3 text-sm text-slate-300">
                <span class="mt-1 w-2.5 h-2.5 rounded-full bg-indigo-400"></span>
                <span>{item}</span>
              </div>
            ))}
          </div>
          <div class="flex flex-col sm:flex-row gap-3 mt-8">
            <a href="/register" class="btn-primary px-8 py-3.5 text-base">Créer une carte à tampons</a>
            <a href="/pricing" class="btn-secondary px-8 py-3.5 text-base">Voir les tarifs</a>
          </div>
        </div>

        <div class="card p-6 sm:p-7">
          <p class="text-slate-500 text-xs uppercase tracking-[0.3em]">Pourquoi ce format convertit bien</p>
          <div class="space-y-4 mt-6">
            {strengths.map((item, index) => (
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <p class="text-indigo-300 font-mono text-xs tracking-[0.3em]">0{index + 1}</p>
                <p class="text-white font-semibold mt-2">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pb-20">
      <div class="grid lg:grid-cols-3 gap-5">
        <article class="card p-6">
          <p class="text-slate-500 text-xs uppercase tracking-[0.3em]">Récompense</p>
          <h2 class="font-display text-2xl font-bold text-white mt-4">8 cafés = 1 offert</h2>
          <p class="text-slate-400 text-sm leading-relaxed mt-3">Le programme reste lisible sur l’affiche A4, sur la page client et dans le Wallet.</p>
        </article>
        <article class="card p-6">
          <p class="text-slate-500 text-xs uppercase tracking-[0.3em]">Opérations</p>
          <h2 class="font-display text-2xl font-bold text-white mt-4">Un scan, un tampon</h2>
          <p class="text-slate-400 text-sm leading-relaxed mt-3">Le commerçant garde un geste simple, sans devoir éditer manuellement le compte client.</p>
        </article>
        <article class="card p-6">
          <p class="text-slate-500 text-xs uppercase tracking-[0.3em]">Visuel</p>
          <h2 class="font-display text-2xl font-bold text-white mt-4">Plus premium qu’une carte papier</h2>
          <p class="text-slate-400 text-sm leading-relaxed mt-3">Logo, bannière, palette, icône de tampon et messages Wallet structurent un rendu plus vendeur.</p>
        </article>
      </div>
    </section>

    <PublicFooter />
  </div>
</BaseLayout>
