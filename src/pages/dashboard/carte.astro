  function getBgStyle():string{
    const f=(document.getElementById('couleur-fond') as HTMLInputElement).value;
    if(!isGradient)return f;
    const f2=(document.getElementById('couleur-fond-2') as HTMLInputElement).value;
    const a=(document.getElementById('gradient-angle') as HTMLInputElement).value;
    return `linear-gradient(${a}deg,${f},${f2})`;
