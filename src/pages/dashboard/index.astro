---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Dashboard — Fidelopass" activeNav="dashboard">
  <div class="mb-6 flex items-start justify-between gap-3">
    <div>
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.26em] text-sky-700/70">Pilotage</p>
      <h1 class="mt-2 font-display text-3xl font-bold text-slate-900">Tableau de bord</h1>
      <p class="mt-2 text-sm text-slate-600">Tout ce qui compte aujourd’hui: scanner, partager la carte, suivre l’activité.</p>
    </div>
    <button id="refresh-btn" type="button" class="rounded-2xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-medium text-slate-600 transition hover:border-slate-300 hover:bg-slate-50 flex items-center gap-1.5">
      <svg id="refresh-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
        <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
        <path d="M21 3v5h-5"></path>
        <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
        <path d="M8 16H3v5"></path>
      </svg>
      <span class="hidden sm:inline">Rafraîchir</span>
    </button>
  </div>

  <div class="card mb-6 p-5">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="text-[0.64rem] font-semibold uppercase tracking-[0.24em] text-sky-700/70">Actions du jour</p>
        <p class="mt-1 text-sm text-slate-600">
          Point actif:
          <span id="active-point-name" class="font-semibold text-slate-900">Chargement...</span>
        </p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/app/scan" class="rounded-2xl bg-sky-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-sky-700">Scanner en caisse</a>
        <a id="dashboard-client-qr-btn" href="#" class="rounded-2xl border border-sky-200 bg-white px-4 py-2.5 text-sm font-medium text-sky-700 transition hover:border-sky-300 hover:bg-sky-50">Afficher le QR client</a>
        <a href="/dashboard/notifications" class="rounded-2xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-50">Envoyer une notification</a>
      </div>
    </div>
  </div>

  <div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Clients totaux</span>
      <span id="stat-clients" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <span class="text-slate-500 text-xs">Base active</span>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Scans aujourd’hui</span>
      <span id="stat-scans" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <span class="text-slate-500 text-xs">Transactions</span>
    </div>
    <div class="stat-card">
      <span class="text-slate-500 text-xs uppercase tracking-wide">Récompenses offertes</span>
      <span id="stat-recompenses" class="font-mono text-3xl font-bold text-slate-900">—</span>
      <span class="text-slate-500 text-xs">Total</span>
    </div>
  </div>

  <div class="mb-6 grid items-start gap-6 xl:grid-cols-[1.4fr_0.6fr]">
    <div class="card p-6">
      <div class="mb-5 flex items-center justify-between">
        <div>
          <h2 class="font-display font-bold text-slate-900">Activité des 7 derniers jours</h2>
          <p class="mt-0.5 text-xs text-slate-500">Scans et récompenses</p>
        </div>
        <div class="flex items-center gap-4 text-xs text-slate-500">
          <span class="flex items-center gap-1.5"><span class="inline-block h-3 w-3 rounded-sm bg-sky-500"></span>Scans</span>
          <span class="flex items-center gap-1.5"><span class="inline-block h-3 w-3 rounded-sm bg-emerald-400"></span>Récompenses</span>
        </div>
      </div>
      <div id="chart-container" class="flex h-56 items-end gap-2 pb-1">
        <p class="m-auto text-sm text-slate-400">Chargement...</p>
      </div>
    </div>

    <div class="card p-6">
      <div class="mb-5 rounded-2xl border border-slate-200 bg-slate-50/70 p-4">
        <p class="text-[0.62rem] font-semibold uppercase tracking-[0.22em] text-slate-500">Rétention clients</p>
        <div class="mt-2 flex items-end justify-between gap-2">
          <p class="text-sm text-slate-600">Clients revenus au moins 2 fois sur 30 jours</p>
          <p id="retention-rate" class="font-mono text-2xl font-bold text-slate-900">—</p>
        </div>
        <div id="retention-chart" class="mt-3 flex h-20 items-end gap-1.5">
          <p class="m-auto text-xs text-slate-400">Chargement...</p>
        </div>
      </div>

      <p class="text-[0.64rem] font-semibold uppercase tracking-[0.24em] text-sky-700/70">Parcours rapide</p>
      <div class="mt-3 space-y-3">
        <a href="/dashboard/carte" class="block rounded-2xl border border-sky-100 bg-sky-50/70 px-4 py-3 transition hover:border-sky-200 hover:bg-sky-100/70">
          <p class="text-sm font-semibold text-slate-900">1. Personnaliser la carte</p>
          <p class="mt-1 text-xs text-slate-600">Template, visuels, programme et géolocalisation.</p>
        </a>
        <a href="/app/install" class="block rounded-2xl border border-slate-200 bg-white px-4 py-3 transition hover:border-slate-300 hover:bg-slate-50">
          <p class="text-sm font-semibold text-slate-900">2. Installer le scanner équipe</p>
          <p class="mt-1 text-xs text-slate-600">QRCode d’installation pour la caisse.</p>
        </a>
        <a href="/dashboard/points-vente" class="block rounded-2xl border border-slate-200 bg-white px-4 py-3 transition hover:border-slate-300 hover:bg-slate-50">
          <p class="text-sm font-semibold text-slate-900">3. Gérer vos points de vente</p>
          <p id="points-vente-usage" class="mt-1 text-xs text-slate-600">Chargement du quota...</p>
        </a>
      </div>
      <div id="admin-shortcut" class="hidden mt-4 rounded-2xl border border-sky-100 bg-sky-50/80 p-4">
        <p class="text-xs uppercase tracking-[0.24em] text-sky-600/75">Accès fondateur</p>
        <p class="mt-1 text-sm text-slate-700">Administration globale plateforme.</p>
        <a href="/admin" class="btn-secondary mt-3 inline-flex px-4 py-2.5 text-sm">Ouvrir l’admin</a>
      </div>
    </div>
  </div>

  <div class="card p-6">
    <h2 class="mb-4 font-display font-bold text-slate-900">Activité récente</h2>
    <div id="recent-transactions" class="flex flex-col gap-3">
      <p class="text-sm text-slate-500">Chargement...</p>
    </div>
  </div>
</DashboardLayout>

<script>
  import { authFetch } from '../../lib/api';
  import { supabase } from '../../lib/supabase';
  import { isProPlan, planLabel } from '../../lib/dashboard-config';

  function escapeHtml(value: unknown) {
    return String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;',
    }[char] ?? char));
  }

  async function loadStats() {
    try {
      const res = await authFetch('/api/dashboard/stats');
      if (!res.ok) return;
      const data = await res.json();
      document.getElementById('stat-clients')!.textContent = String(data.totalClients ?? 0);
      document.getElementById('stat-scans')!.textContent = String(data.scansAujourdhui ?? 0);
      document.getElementById('stat-recompenses')!.textContent = String(data.totalRecompenses ?? 0);
    } catch {
      // best effort
    }
  }

  async function loadChart() {
    const container = document.getElementById('chart-container')!;
    try {
      const res = await authFetch('/api/dashboard/weekly-scans');
      if (!res.ok) throw new Error();
      const { data } = await res.json();

      if (!data?.length) {
        container.innerHTML = '<p class="text-slate-400 text-sm m-auto">Aucune activité cette semaine.</p>';
        return;
      }

      const maxVal = Math.max(...data.map((d: { scans: number; recompenses: number }) => d.scans + d.recompenses), 1);
      const chartHeight = 126;

      container.innerHTML = data.map((d: { date: string; scans: number; recompenses: number }) => {
        const scansH = Math.round((d.scans / maxVal) * chartHeight);
        const recH = Math.round((d.recompenses / maxVal) * chartHeight);
        const label = new Date(d.date + 'T12:00:00').toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric' });
        return `
          <div class="flex-1 flex flex-col items-center gap-2 min-w-0">
            <div class="w-full max-w-[58px] flex flex-col-reverse items-center gap-0.5 rounded-xl bg-slate-100/70 p-1.5" style="height:${chartHeight + 14}px">
              <div class="w-full rounded-md bg-sky-500 transition-all" style="height:${scansH}px" title="${d.scans} scan(s)"></div>
              ${recH > 0 ? `<div class="w-full rounded-t-lg bg-emerald-400 transition-all" style="height:${recH}px" title="${d.recompenses} récompense(s)"></div>` : ''}
            </div>
            <p class="text-[0.62rem] text-slate-500 text-center truncate w-full">${escapeHtml(label)}</p>
          </div>
        `;
      }).join('');
    } catch {
      container.innerHTML = '<p class="text-slate-400 text-sm m-auto">Impossible de charger le graphique.</p>';
    }
  }

  async function loadRecentTransactions() {
    try {
      const res = await authFetch('/api/transactions?limit=5');
      if (!res.ok) return;
      const { data } = await res.json();
      const container = document.getElementById('recent-transactions')!;

      if (!data?.length) {
        container.innerHTML = '<p class="text-slate-500 text-sm">Aucune transaction pour le moment.</p>';
        return;
      }

      container.innerHTML = data.map((t: { type: string; valeur: number; created_at: string }) => `
        <div class="flex items-center justify-between border-b border-slate-200 py-3 last:border-0">
          <div class="flex items-center gap-3">
            <span class="w-2 h-2 rounded-full ${t.type === 'ajout_tampon' ? 'bg-indigo-400' : t.type === 'ajout_points' ? 'bg-cyan-400' : 'bg-emerald-400'}"></span>
            <span class="text-slate-700 text-sm capitalize">${escapeHtml(t.type.replace('_', ' '))}</span>
          </div>
          <div class="flex items-center gap-4">
            <span class="font-mono text-sm text-slate-900">+${t.valeur}</span>
            <span class="text-slate-500 text-xs">${new Date(t.created_at).toLocaleDateString('fr-FR')}</span>
          </div>
        </div>
      `).join('');
    } catch {
      // best effort
    }
  }

  async function loadRetention() {
    const rate = document.getElementById('retention-rate');
    const chart = document.getElementById('retention-chart');
    if (!rate || !chart) return;

    try {
      const res = await authFetch('/api/dashboard/retention');
      if (!res.ok) throw new Error();
      const payload = await res.json().catch(() => null);
      const summary = payload?.summary ?? {};
      const weekly = Array.isArray(payload?.data) ? payload.data : [];

      rate.textContent = `${summary?.rate_30d ?? 0}%`;

      if (!weekly.length) {
        chart.innerHTML = '<p class="m-auto text-xs text-slate-400">Pas assez de données.</p>';
        return;
      }

      const maxRate = Math.max(...weekly.map((item: { retention_rate?: number }) => Number(item.retention_rate ?? 0)), 1);
      chart.innerHTML = weekly.map((item: { week_start: string; retention_rate: number }) => {
        const ratio = Math.round((Number(item.retention_rate ?? 0) / maxRate) * 100);
        const label = new Date(`${item.week_start}T12:00:00`).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit' });
        return `
          <div class="min-w-0 flex-1">
            <div class="group relative h-16 rounded-lg bg-slate-200/70">
              <div class="absolute inset-x-0 bottom-0 rounded-lg bg-gradient-to-t from-sky-600 to-cyan-500 transition-all" style="height:${ratio}%"></div>
              <span class="pointer-events-none absolute -top-6 left-1/2 hidden -translate-x-1/2 rounded-md bg-slate-900 px-2 py-1 text-[10px] text-white group-hover:block">${Number(item.retention_rate ?? 0)}%</span>
            </div>
            <p class="mt-1 truncate text-center text-[0.62rem] text-slate-500">${escapeHtml(label)}</p>
          </div>
        `;
      }).join('');
    } catch {
      rate.textContent = '—';
      chart.innerHTML = '<p class="m-auto text-xs text-slate-400">Impossible de charger.</p>';
    }
  }

  async function resolveClientQrUrl(): Promise<string | null> {
    const res = await authFetch('/api/cartes');
    if (!res.ok) return null;
    const { data } = await res.json().catch(() => ({ data: null }));
    if (!data?.id) return null;
    return `/poster/${data.id}?template=signature`;
  }

  async function loadCardShortcuts() {
    try {
      const qrUrl = await resolveClientQrUrl();
      const qrBtn = document.getElementById('dashboard-client-qr-btn') as HTMLAnchorElement;
      if (qrUrl) {
        qrBtn.href = qrUrl;
        qrBtn.dataset.posterUrl = qrUrl;
      } else {
        qrBtn.href = '/dashboard/carte';
        qrBtn.removeAttribute('data-poster-url');
      }
    } catch {
      // best effort
    }
  }

  async function handleClientQrClick(event: MouseEvent) {
    event.preventDefault();
    const qrBtn = document.getElementById('dashboard-client-qr-btn') as HTMLAnchorElement | null;
    if (!qrBtn) return;

    const originalText = qrBtn.textContent;
    qrBtn.textContent = 'Chargement...';
    qrBtn.classList.add('pointer-events-none', 'opacity-70');
    try {
      const qrUrl = await resolveClientQrUrl();
      if (qrUrl) {
        qrBtn.href = qrUrl;
        window.location.href = qrUrl;
        return;
      }
      qrBtn.href = '/dashboard/carte';
      window.location.href = '/dashboard/carte';
    } catch {
      qrBtn.href = '/dashboard/carte';
      window.location.href = '/dashboard/carte';
    } finally {
      qrBtn.textContent = originalText;
      qrBtn.classList.remove('pointer-events-none', 'opacity-70');
    }
  }

  async function loadPointVenteContext() {
    const activeName = document.getElementById('active-point-name');
    const usage = document.getElementById('points-vente-usage');
    if (!activeName || !usage) return;

    try {
      const res = await authFetch('/api/commerces/points-vente');
      if (!res.ok) throw new Error();
      const payload = await res.json().catch(() => null);
      const points = Array.isArray(payload?.data) ? payload.data : [];
      const selectedId = payload?.selected_point_vente_id;
      const selected = points.find((point: { id: string; nom?: string }) => point.id === selectedId);
      const stats = payload?.usage;
      const plan = planLabel(payload?.plan);
      const pro = isProPlan(payload?.plan);

      activeName.textContent = selected?.nom ?? '—';
      usage.textContent = `Plan ${plan}: ${stats?.current ?? 0}/${stats?.max ?? 1} point(s) de vente utilisés (${pro ? 'multi-sites activé' : '1 point inclus'}).`;
    } catch {
      activeName.textContent = '—';
      usage.textContent = 'Impossible de charger votre contexte point de vente.';
    }
  }

  async function loadAdminShortcut() {
    try {
      const { data: { session } } = await supabase.auth.getSession();
      const email = session?.user?.email?.toLowerCase();
      const isAdmin = ['bilelel@live.fr', 'bilel@pulse-agency.fr'].includes(email ?? '');
      document.getElementById('admin-shortcut')!.classList.toggle('hidden', !isAdmin);
    } catch {
      // best effort
    }
  }

  async function refreshAll() {
    const icon = document.getElementById('refresh-icon')!;
    const btn = document.getElementById('refresh-btn') as HTMLButtonElement;
    btn.disabled = true;
    icon.style.animation = 'spin 0.8s linear infinite';
    await Promise.all([
      loadStats(),
      loadChart(),
      loadRecentTransactions(),
      loadRetention(),
      loadCardShortcuts(),
      loadPointVenteContext(),
    ]);
    icon.style.animation = '';
    btn.disabled = false;
  }

  document.getElementById('refresh-btn')!.addEventListener('click', refreshAll);
  document.getElementById('dashboard-client-qr-btn')?.addEventListener('click', handleClientQrClick);

  const style = document.createElement('style');
  style.textContent = '@keyframes spin { to { transform: rotate(360deg); } }';
  document.head.appendChild(style);

  loadStats();
  loadChart();
  loadRecentTransactions();
  loadRetention();
  loadCardShortcuts();
  loadPointVenteContext();
  loadAdminShortcut();
</script>
