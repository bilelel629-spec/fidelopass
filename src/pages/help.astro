---
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const guides = [
  {
    title: 'Créer sa première carte Fidelopass',
    summary: 'Choisir le bon format, configurer les récompenses et publier une première carte vendable.',
    href: '/onboarding',
  },
  {
    title: 'Installer le scanner sur l’écran d’accueil',
    summary: 'Le parcours mobile le plus simple pour que l’équipe en boutique scanne sans friction.',
    href: '/app/install',
  },
  {
    title: 'Préparer une affiche A4 avec QR code',
    summary: 'Télécharger le QR code, imprimer une affiche et capter les inscriptions en point de vente.',
    href: '/dashboard/carte',
  },
  {
    title: 'Acheter une clé d’accès',
    summary: 'Comprendre le rôle de la clé et préparer l’ouverture d’un nouvel espace commerçant.',
    href: '/acces',
  },
  {
    title: 'Envoyer un message aux clients',
    summary: 'Utiliser les messages Wallet et les relances utiles au lieu d’un simple “push” technique.',
    href: '/dashboard/notifications',
  },
  {
    title: 'Partager la carte à un client',
    summary: 'Diffuser le lien, l’affiche ou le QR code selon le contexte du commerce.',
    href: '/dashboard/carte',
  },
];
---

<BaseLayout title="Guides Fidelopass" description="Retrouvez les guides Fidelopass pour lancer votre première carte Wallet, installer le scanner et diffuser votre QR code.">
  <div class="relative overflow-hidden min-h-screen">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[64rem] h-[64rem] rounded-full blur-3xl opacity-20" style="background:radial-gradient(circle,#6366f1 0%,rgba(255,255,255,0) 62%)"></div>
    </div>

    <PublicNav currentPath="/help" />

    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pt-8 pb-16">
      <div class="max-w-4xl">
        <div class="badge badge-info mb-5">Centre d’aide Fidelopass</div>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 leading-[0.96]">
          Des guides courts,
          <span class="block text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 via-blue-500 to-cyan-500">
            pensés pour des commerçants et pas pour des développeurs
          </span>
        </h1>
        <p class="text-slate-600 text-lg leading-relaxed mt-6 max-w-3xl">
          Passtastic rassure beaucoup grâce à son help center. Fidelopass doit faire pareil, mais avec des guides plus directs, plus visuels et orientés usage terrain.
        </p>
      </div>
    </section>

    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pb-20">
      <div class="grid lg:grid-cols-2 xl:grid-cols-3 gap-5">
        {guides.map((guide) => (
          <article class="card border border-slate-200/80 bg-white/95 p-6 h-full flex flex-col shadow-[0_22px_52px_-36px_rgba(37,99,235,0.28)]">
            <p class="text-slate-500 text-xs uppercase tracking-[0.3em]">Guide</p>
            <h2 class="font-display text-2xl font-bold text-slate-900 mt-4 leading-tight">{guide.title}</h2>
            <p class="text-slate-500 text-sm leading-relaxed mt-3 flex-1">{guide.summary}</p>
            <a href={guide.href} class="btn-secondary mt-6 justify-center">Ouvrir</a>
          </article>
        ))}
      </div>
    </section>

    <PublicFooter />
  </div>
</BaseLayout>
