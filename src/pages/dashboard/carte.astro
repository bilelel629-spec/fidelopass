        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {[{value:'QR',label:'QR Code',icon:'⬛',desc:'Recommandé'},{value:'PDF417',label:'Code-barres',icon:'▬',desc:'Linéaire'},{value:'AZTEC',label:'Aztec',icon:'◈',desc:'Compact'},{value:'NONE',label:'Aucun',icon:'∅',desc:'Sans code'}].map(({value,label,icon,desc})=>(
            <label id={`barcode-${value.toLowerCase()}-label`} class="cursor-pointer rounded-xl border-2 p-3 text-center transition-all" style={value==='QR'?'border-color:#6366f1;background:rgb(99 102 241/0.1)':'border-color:#334155;background:transparent'}>
