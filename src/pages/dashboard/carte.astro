---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Ma carte — Fidelopass" activeNav="carte">
  <div id="wizard-top-anchor" class="mb-4 rounded-[1.6rem] border border-sky-100 bg-white/90 px-5 py-4 shadow-[0_24px_50px_-38px_rgba(59,130,246,0.35)] sm:mb-5 sm:py-5">
    <p class="text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-sky-600/70">Éditeur de carte</p>
    <div class="mt-2 flex flex-col gap-2 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <h1 class="font-display text-2xl font-bold text-slate-900 sm:text-3xl">Créez votre carte en 7 étapes</h1>
        <p class="mt-1 text-sm leading-6 text-slate-500">Choisissez un type de programme, personnalisez le design, puis publiez votre QR client et votre scanner équipe.</p>
      </div>
      <p class="hidden text-xs text-slate-500 lg:block">Objectif: une carte opérationnelle en caisse aujourd'hui.</p>
    </div>
  </div>
  <div id="active-point-banner" class="mb-4 rounded-2xl border border-sky-100 bg-sky-50/70 px-4 py-3 sm:mb-5">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="text-sm text-sky-800">
        <p class="font-medium">Point de vente actif: <span id="active-point-name" class="font-semibold">Chargement...</span></p>
        <p class="mt-1 hidden text-xs text-sky-700/90 sm:block">Besoin d’ajouter une autre adresse ? Cliquez sur “Gérer les points de vente”.</p>
      </div>
      <a href="/dashboard/points-vente" class="rounded-xl border border-sky-200 bg-white px-3.5 py-2 text-xs font-semibold text-sky-700 transition hover:border-sky-300 hover:bg-sky-50">
        Gérer les points de vente
      </a>
    </div>
  </div>

  <div id="setup-banner" class="hidden mb-6 rounded-[1.6rem] border border-sky-200 bg-gradient-to-r from-sky-50 to-white px-5 py-4 shadow-[0_24px_50px_-38px_rgba(14,165,233,0.35)]">
    <p class="font-medium text-sky-800">Dernière étape de l'onboarding</p>
    <p class="mt-1 text-sm text-slate-600">
      Vous êtes maintenant dans l'éditeur complet. Créez votre première carte avec toutes les options de personnalisation, puis partagez son lien public à vos clients.
    </p>
  </div>

  <div class="mb-4 rounded-[1.4rem] border border-sky-100 bg-white/95 p-4 shadow-[0_18px_48px_-36px_rgba(59,130,246,0.4)] lg:hidden">
    <div class="flex items-center justify-between gap-3">
      <div>
        <p id="wizard-mobile-counter" class="text-[0.64rem] font-semibold uppercase tracking-[0.22em] text-sky-700/70">Étape 1/7</p>
        <p id="wizard-mobile-title" class="mt-1 text-sm font-semibold text-slate-900">Type de programme</p>
      </div>
      <button id="mobile-step-picker-btn" type="button" class="btn-secondary px-3 py-2 text-xs">
        Changer d’étape
      </button>
    </div>
    <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-sky-100">
      <div id="wizard-mobile-progress" class="h-full rounded-full bg-sky-600 transition-all duration-300" style="width:14.2857%"></div>
    </div>
  </div>

  <div class="mb-6 hidden rounded-[1.6rem] border border-sky-100 bg-white/95 shadow-[0_18px_48px_-36px_rgba(59,130,246,0.4)] lg:sticky lg:top-4 lg:block z-20">
    <div class="flex items-center justify-between px-4 py-3 border-b border-sky-50">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-sky-600/70">Parcours guidé</p>
      <div class="flex items-center gap-2">
        <span id="draft-state" class="rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-emerald-700">Brouillon enregistré</span>
        <span id="wizard-current-label" class="rounded-xl bg-sky-50 border border-sky-100 px-3 py-1 text-xs font-semibold text-sky-800">Étape 1 · Type</span>
      </div>
    </div>
    <div class="flex overflow-x-auto gap-1 p-2 scrollbar-none">
      {[
        'Type',
        'Identité',
        'Programme',
        'Apparence',
        'Messages',
        'Options',
        'Partage',
      ].map((label, index) => (
        <button
          type="button"
          class="wizard-tab shrink-0 rounded-xl border border-sky-100 bg-white px-3 py-2 transition-all hover:border-sky-300 hover:bg-sky-50 flex items-center gap-2"
          data-step-target={String(index + 1)}
        >
          <span class="flex h-5 w-5 items-center justify-center rounded-full bg-sky-100 text-[0.62rem] font-bold text-sky-700">{index + 1}</span>
          <div>
            <span class="block text-xs font-medium text-slate-700 whitespace-nowrap">{label}</span>
            <span id={`wizard-status-${index + 1}`} class="wizard-step-status text-[0.62rem] text-slate-400">À faire</span>
          </div>
        </button>
      ))}
    </div>
  </div>

  <div id="mobile-step-sheet" class="fixed inset-0 z-[70] hidden lg:hidden">
    <button id="mobile-step-sheet-backdrop" type="button" class="absolute inset-0 bg-slate-900/50 backdrop-blur-[1px]"></button>
    <div class="absolute inset-x-0 bottom-0 rounded-t-[1.8rem] border border-sky-100 bg-white px-4 pb-[calc(env(safe-area-inset-bottom)+1rem)] pt-4 shadow-[0_-32px_55px_-35px_rgba(15,23,42,0.55)]">
      <div class="mx-auto mb-3 h-1 w-11 rounded-full bg-slate-200"></div>
      <div class="mb-3 flex items-center justify-between">
        <p class="text-sm font-semibold text-slate-900">Aller à une étape</p>
        <button id="mobile-step-sheet-close" type="button" class="btn-secondary px-3 py-1.5 text-xs">Fermer</button>
      </div>
      <div class="max-h-[62vh] space-y-2 overflow-y-auto pb-2">
        {[
          'Type',
          'Identité',
          'Programme',
          'Apparence',
          'Messages',
          'Options',
          'Partage',
        ].map((label, index) => (
          <button
            type="button"
            class="mobile-step-item flex w-full items-center justify-between rounded-xl border border-sky-100 bg-white px-3 py-2.5 text-left transition-all"
            data-step-target={String(index + 1)}
          >
            <div class="flex items-center gap-2">
              <span class="flex h-6 w-6 items-center justify-center rounded-full bg-sky-100 text-[0.65rem] font-bold text-sky-700">{index + 1}</span>
              <span class="text-sm font-medium text-slate-800">{label}</span>
            </div>
            <span class="wizard-step-status text-[0.65rem] text-slate-400">À faire</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <div id="mobile-step-guidance" class="mb-4 rounded-[1.2rem] border border-sky-100 bg-white/95 px-4 py-3 shadow-[0_14px_35px_-30px_rgba(59,130,246,0.45)] lg:hidden">
    <p id="mobile-step-guidance-title" class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-700/80">Objectif de l’étape</p>
    <p id="mobile-step-guidance-text" class="mt-1 text-sm font-medium text-slate-800">Choisissez le type de programme le plus simple pour votre équipe.</p>
    <p id="mobile-step-guidance-required" class="mt-1 text-[0.7rem] text-slate-500">Obligatoire: type de programme</p>
  </div>

  <div class="grid lg:grid-cols-[1fr_370px] gap-6 items-start">

    <div class="flex flex-col gap-5 pb-40 lg:pb-0">

      <!-- Étape 1 : Type de programme -->
      <div class="card wizard-section step-1 p-6">
        <div class="mb-5">
          <h2 class="font-display font-bold text-slate-900">Type de programme</h2>
          <p class="mt-1 text-sm leading-6 text-slate-500">Choisissez d'abord la mécanique de fidélité — tampons ou points. Tout le reste s'adapte à ce choix.</p>
        </div>
        <div id="step-error-1" class="step-error hidden mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
        <div class="grid grid-cols-2 gap-3 mb-6">
          <label id="type-tampons-label" class="cursor-pointer rounded-2xl border-2 p-4 transition-all" style="border-color:#60a5fa;background:rgb(239 246 255)">
            <input type="radio" name="type" value="tampons" class="hidden" checked />
            <div class="flex items-center gap-3">
              <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-sky-100 text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">TM</span>
              <div>
                <div class="font-medium text-slate-900 text-sm">Tampons</div>
                <div class="text-slate-500 text-xs mt-0.5">Simple à comprendre, rapide à utiliser en caisse.</div>
              </div>
            </div>
          </label>
          <label id="type-points-label" class="cursor-pointer rounded-2xl border-2 p-4 transition-all" style="border-color:#dbeafe;background:#ffffff">
            <input type="radio" name="type" value="points" class="hidden" />
            <div class="flex items-center gap-3">
              <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-slate-100 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700">PT</span>
              <div>
                <div class="font-medium text-slate-900 text-sm">Points</div>
                <div class="text-slate-500 text-xs mt-0.5">Plus souple pour les paliers VIP et les récompenses progressives.</div>
              </div>
            </div>
          </label>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
          <div>
            <h2 class="font-display font-bold text-slate-900">Modèles rapides</h2>
            <p class="mt-1 text-sm leading-6 text-slate-500">Choisissez une base prête à l'emploi. Le modèle remplit les couleurs, le programme et le ton général, puis vous l'affinez à votre rythme.</p>
          </div>
          <span class="w-fit rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs text-emerald-700">Recommandé pour démarrer</span>
        </div>
        <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-3">
          {[
            {name:'Café cosy', badge:'CF', fond:'#2b1608', texte:'#fff7ed', accent:'#d97706', fond2:'#5f3214', pattern:'waves', layout:'bottom', stamp:'☕', type:'tampons', total:'10', reward:'1 boisson offerte', label:'Client', desc:'10 passages = 1 boisson offerte', message:'Votre café vous attend !'},
            {name:'Restaurant', badge:'RS', fond:'#111827', texte:'#fff7ed', accent:'#f97316', fond2:'#7c2d12', pattern:'diagonal', layout:'top', stamp:'🍽️', type:'tampons', total:'8', reward:'1 dessert offert', label:'Table fidèle', desc:'Cumulez des tampons à chaque repas', message:'Une récompense vous attend au restaurant.'},
            {name:'Institut beauté', badge:'BE', fond:'#4a102a', texte:'#fff1f2', accent:'#f472b6', fond2:'#831843', pattern:'confetti', layout:'bottom', stamp:'✨', type:'tampons', total:'6', reward:'-20% sur un soin', label:'Cliente', desc:'Votre carte privilège beauté', message:'Votre avantage beauté est disponible.'},
            {name:'Barber shop', badge:'BR', fond:'#0f172a', texte:'#f8fafc', accent:'#38bdf8', fond2:'#1e3a8a', pattern:'grid', layout:'top', stamp:'✂️', type:'tampons', total:'8', reward:'1 coupe offerte', label:'Client', desc:'Une coupe offerte après 8 passages', message:'Votre barber vous attend.'},
            {name:'Boutique premium', badge:'BT', fond:'#030712', texte:'#fefce8', accent:'#d4af37', fond2:'#422006', pattern:'dots', layout:'background', stamp:'🛍️', type:'points', total:'10', reward:'10€ de réduction', label:'Membre', desc:'Cumulez des points à chaque achat', message:'Votre avantage fidélité est disponible en boutique.'},
            {name:'Sport & coaching', badge:'SP', fond:'#022c22', texte:'#ecfdf5', accent:'#22c55e', fond2:'#064e3b', pattern:'diagonal', layout:'background', stamp:'🏆', type:'points', total:'10', reward:'1 séance offerte', label:'Athlète', desc:'Transformez vos visites en récompenses', message:'Votre coach vous attend.'},
          ].map((preset, index) => (
            <button
              type="button"
              class={`business-template-btn text-left rounded-[1.4rem] border border-sky-100 bg-gradient-to-br from-white to-sky-50/60 p-4 transition-all hover:-translate-y-0.5 hover:border-sky-200 hover:shadow-[0_24px_55px_-36px_rgba(59,130,246,0.45)] ${index >= 4 ? 'template-extra hidden' : ''}`}
              data-name={preset.name}
              data-icon={preset.badge}
              data-fond={preset.fond}
              data-texte={preset.texte}
              data-accent={preset.accent}
              data-fond2={preset.fond2}
              data-pattern={preset.pattern}
              data-layout={preset.layout}
              data-stamp={preset.stamp}
              data-type={preset.type}
              data-total={preset.total}
              data-reward={preset.reward}
              data-label={preset.label}
              data-desc={preset.desc}
              data-message={preset.message}
            >
              <div class="flex items-center gap-3">
                <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-sky-100 text-sm font-bold tracking-[0.12em] text-sky-700">{preset.badge}</span>
                <div>
                  <p class="text-sm font-semibold text-slate-900">{preset.name}</p>
                  <p class="mt-0.5 text-xs text-slate-500">{preset.reward}</p>
                </div>
              </div>
              <div class="mt-3 h-10 rounded-xl border border-sky-100" style={`background:linear-gradient(135deg,${preset.fond},${preset.fond2})`}>
                <div class="h-full w-1/3 rounded-l-xl" style={`background:${preset.accent}`}></div>
              </div>
            </button>
          ))}
        </div>
        <button id="toggle-more-templates-btn" type="button" class="mt-4 btn-secondary text-sm py-2.5 px-4">Voir plus de modèles</button>
      </div>

      <!-- Étape 2 : Identité -->
      <div class="card wizard-section step-2 p-6">
        <div class="mb-5">
          <h2 class="font-display font-bold text-slate-900">Identité visuelle</h2>
          <p class="mt-1 text-sm leading-6 text-slate-500">Ajoutez les éléments qui feront reconnaître votre commerce au premier coup d'œil : nom, logo et icône de tampon.</p>
        </div>
        <div id="step-error-2" class="step-error hidden mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
        <div class="grid sm:grid-cols-2 gap-4 mb-5">
          <div><label class="label" for="nom-carte">Nom de la carte *</label><input id="nom-carte" type="text" class="input" placeholder="Carte fidélité Ma Boutique" required /></div>
          <div><label class="label" for="label-client">Label membre</label><input id="label-client" type="text" class="input" placeholder="Client, Membre, VIP..." maxlength="30" /></div>
        </div>
        <div class="mb-5"><label class="label" for="description">Description</label><input id="description" type="text" class="input" placeholder="Cumulez des points à chaque achat !" /></div>
        <div class="grid sm:grid-cols-2 gap-5">

          <div>
            <label class="label mb-2 block">Logo</label>
            <div class="flex flex-col items-center gap-2">
              <div id="logo-preview-wrap" class="w-16 h-16 rounded-xl flex items-center justify-center border border-white/10 overflow-hidden" style="background:#1e293b">
                <img id="logo-preview-img" class="hidden w-full h-full object-cover" />
                <span id="logo-preview-icon" class="text-2xl text-slate-500">🏪</span>
              </div>
              <input type="file" id="logo-file" accept="image/png,image/jpeg,image/webp" class="hidden" />
              <button type="button" id="logo-btn" class="btn-secondary text-xs py-1.5 px-3 w-full">Choisir</button>
              <button type="button" id="logo-palette-btn" class="btn-secondary text-xs py-1.5 px-3 w-full text-emerald-300">Générer une palette</button>
              <input type="hidden" id="logo-url" />
              <p id="logo-loading" class="hidden text-indigo-400 text-xs">Upload...</p>
              <p class="text-slate-600 text-xs text-center leading-tight">
                PNG/JPG carré<br/>
                Recommandé : 512×512 px<br/>
                Sujet centré, peu de texte, marges fines
              </p>
              <div class="w-full rounded-xl border border-sky-100 bg-sky-50/60 px-3 py-3">
                <div class="flex items-center justify-between text-xs text-slate-600 mb-1.5">
                  <span>Taille du logo</span>
                  <span id="logo-scale-val" class="font-semibold text-slate-800">100%</span>
                </div>
                <input id="logo-scale" type="range" min="80" max="220" step="5" value="100" class="w-full accent-indigo-500" />
                <button type="button" id="logo-apply-resize" class="btn-secondary mt-2 w-full text-xs py-2">
                  Appliquer au fichier logo (512×512)
                </button>
                <p class="text-[0.68rem] leading-tight text-slate-500 mt-2">
                  Agrandissez si votre logo paraît trop petit dans Wallet.
                </p>
              </div>
            </div>
          </div>

          <div id="tampon-icon-section">
            <label class="label mb-2 block">Icône de tampon</label>
            <div class="flex gap-1.5 mb-3">
              <label id="tampon-mode-default-label" class="flex-1 cursor-pointer rounded-xl border-2 p-2 text-center transition-all" style="border-color:#60a5fa;background:rgb(239 246 255);color:#0f172a">
                <input type="radio" name="tampon_mode" value="default" class="hidden" checked /><div class="text-base mb-0.5">✓</div><div class="text-xs font-medium text-slate-900">Défaut</div>
              </label>
              <label id="tampon-mode-emoji-label" class="flex-1 cursor-pointer rounded-xl border-2 p-2 text-center transition-all" style="border-color:#dbeafe;background:#ffffff">
                <input type="radio" name="tampon_mode" value="emoji" class="hidden" /><div class="text-base mb-0.5">😀</div><div class="text-xs font-medium text-slate-900">Emoji</div>
              </label>
              <label id="tampon-mode-custom-label" class="flex-1 cursor-pointer rounded-xl border-2 p-2 text-center transition-all" style="border-color:#dbeafe;background:#ffffff">
                <input type="radio" name="tampon_mode" value="custom" class="hidden" /><div class="text-base mb-0.5">🖼️</div><div class="text-xs font-medium text-slate-900">Image</div>
              </label>
            </div>
            <div id="tampon-emoji-zone" class="hidden">
              <p class="text-slate-500 text-xs mb-1.5">Sélectionnez un emoji</p>
              <div class="grid grid-cols-6 gap-1">
                {['☕','🍩','⭐','🎁','❤️','🏆','🍕','🎫','💎','🔥','🎉','✨','🍦','🥐','🛍️','🌟','🎵','🍰','🍽️','✂️','💅','🏋️'].map(e => (
                  <button type="button" class="emoji-stamp-btn w-9 h-9 rounded-lg text-xl hover:bg-white/10 transition-all flex items-center justify-center border-2 border-transparent" data-emoji={e}>{e}</button>
                ))}
              </div>
              <input type="hidden" id="tampon-emoji" />
              <p id="tampon-emoji-selected" class="hidden text-xs text-indigo-400 mt-1.5">Sélectionné : <span id="tampon-emoji-val"></span></p>
            </div>
            <div id="tampon-custom-zone" class="hidden flex flex-col items-center gap-2">
              <div class="w-14 h-14 rounded-full flex items-center justify-center border border-white/10 overflow-hidden" style="background:#1e293b">
                <img id="tampon-preview-img" class="hidden w-full h-full object-cover rounded-full" />
                <span id="tampon-preview-icon" class="text-xl text-slate-500">🔖</span>
              </div>
              <input type="file" id="tampon-file" accept="image/png,image/jpeg,image/webp" class="hidden" />
              <button type="button" id="tampon-btn" class="btn-secondary text-xs py-1.5 px-3 w-full">Choisir image</button>
              <input type="hidden" id="tampon-icon-url" />
              <p id="tampon-loading" class="hidden text-indigo-400 text-xs">Upload...</p>
              <p class="text-slate-600 text-xs text-center leading-tight">PNG transparent — 64×64 px</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Étape 3 : Programme -->
      <div class="card wizard-section step-3 p-6">
        <div class="mb-5">
          <h2 class="font-display font-bold text-slate-900">Ce que gagne le client</h2>
          <p class="mt-1 text-sm leading-6 text-slate-500">Définissez le rythme de fidélité et la promesse de récompense affichée dans Wallet.</p>
          <p class="mt-2 text-xs text-slate-500">Conseil conversion: une récompense claire et rapide (5 à 10 passages max) augmente l’usage en caisse.</p>
        </div>
        <div id="step-error-3" class="step-error hidden mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
        <div class="flex flex-col gap-4">
          <div id="config-tampons"><label class="label" for="tampons-total">Nombre de tampons pour la récompense</label><input id="tampons-total" type="number" class="input w-32" min="1" max="20" value="10" /></div>
          <div id="config-points" class="hidden flex flex-col gap-3">
            <div class="grid grid-cols-2 gap-3">
              <div><label class="label" for="points-par-euro">Points / euro</label><input id="points-par-euro" type="number" class="input" min="0.1" step="0.1" value="1" /></div>
              <div><label class="label" for="points-recompense">Points pour la récompense</label><input id="points-recompense" type="number" class="input" min="1" value="100" /></div>
            </div>
          </div>
          <div><label class="label" for="recompense">Récompense offerte *</label><input id="recompense" type="text" class="input" placeholder="Ex: 1 café offert, 5€ de réduction..." required /></div>
          <div class="grid lg:grid-cols-2 gap-4">
            <div class="rounded-2xl border border-sky-100 bg-sky-50/60 p-4">
              <div class="flex items-center justify-between gap-3 mb-3">
                <div>
                  <p class="text-sm font-semibold text-slate-900">Récompenses multiples</p>
                  <p class="text-slate-500 text-xs mt-0.5">Désactivé par défaut. Activez pour proposer plusieurs paliers.</p>
                </div>
                <button
                  id="multi-rewards-toggle"
                  type="button"
                  class="relative w-12 h-6 rounded-full transition-colors flex-shrink-0"
                  style="background:#334155"
                  aria-pressed="false"
                >
                  <span id="multi-rewards-knob" class="absolute top-0.5 w-5 h-5 rounded-full bg-white shadow transition-all" style="left:2px"></span>
                </button>
              </div>
              <div id="multi-rewards-content" class="hidden">
                <div class="flex items-center justify-end mb-3">
                  <button id="add-reward-tier" type="button" class="btn-secondary text-xs py-1.5 px-3">Ajouter</button>
                </div>
                <div id="reward-tiers" class="flex flex-col gap-2"></div>
              </div>
