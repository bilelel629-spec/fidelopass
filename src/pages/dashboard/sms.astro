---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const apiUrlRuntime = (process.env.API_URL || import.meta.env.PUBLIC_API_URL || 'https://api.fidelopass.com').replace(/\/$/, '');

const priceIds = {
  sms_100:  'price_1TLUSS7qMJeoJ4KrmbPWFh9V',
  sms_500:  'price_1TLUSS7qMJeoJ4KrR2wppPSv',
  sms_2000: 'price_1TLUSS7qMJeoJ4Krtl3iQKiF',
};
---

<DashboardLayout title="Campagnes SMS — Fidelopass" activeNav="sms">
  <meta id="api-config" data-url={apiUrlRuntime} />

  <div class="mb-8">
    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.26em] text-sky-700/70">Communication client</p>
    <h1 class="font-display text-3xl font-bold text-slate-900 mt-2">Campagnes SMS</h1>
    <p class="text-slate-600 text-sm mt-2">Envoyez des SMS personnalisés à vos clients directement depuis votre espace.</p>
  </div>

  <!-- ── Section 1 : Solde + achat ─────────────────────────────────── -->
  <div class="card p-6 mb-6">
    <div class="flex items-center justify-between flex-wrap gap-4 mb-6">
      <div>
        <p class="text-slate-500 text-xs uppercase tracking-wide mb-1">Solde de crédits SMS</p>
        <div class="flex items-center gap-3">
          <span id="sms-credits-badge" class="inline-flex items-center rounded-full px-4 py-1.5 text-lg font-bold">
            <span id="sms-credits-val">—</span>&nbsp;crédits
          </span>
          <button id="btn-refresh-credits" type="button" class="text-slate-400 hover:text-slate-600 text-xs">↻ Actualiser</button>
        </div>
      </div>
    </div>

    <p class="text-slate-600 text-sm mb-4 font-medium">Recharger des crédits :</p>
    <div class="grid sm:grid-cols-3 gap-4">
      {[
        { label: 'Pack 100 SMS', credits: '100 crédits', price: '12€', priceId: priceIds.sms_100 },
        { label: 'Pack 500 SMS', credits: '500 crédits', price: '49€', priceId: priceIds.sms_500 },
        { label: 'Pack 2000 SMS', credits: '2000 crédits', price: '159€', priceId: priceIds.sms_2000 },
      ].map((pack) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-5 flex flex-col gap-3 shadow-sm">
          <p class="font-semibold text-slate-900 text-sm">{pack.label}</p>
          <p class="text-slate-500 text-xs">{pack.credits}</p>
          <div class="flex items-end justify-between mt-auto">
            <span class="font-display text-2xl font-bold text-slate-900">{pack.price}</span>
            <button
              type="button"
              class="sms-pack-btn rounded-xl bg-slate-950 px-4 py-2 text-xs font-medium text-white hover:bg-slate-800 transition-colors"
              data-price-id={pack.priceId}
            >
              Acheter
            </button>
          </div>
        </div>
      ))}
    </div>
    <div id="sms-pack-error" class="hidden mt-4 rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-red-600 text-sm"></div>
  </div>

  <!-- ── Section 2 : Campagne manuelle ─────────────────────────────── -->
  <div class="card p-6 mb-6">
    <h2 class="font-display text-xl font-bold text-slate-900 mb-5">Envoyer une campagne</h2>

    <div class="space-y-4">
      <div>
        <label class="label" for="sms-filtre">Cible</label>
        <select id="sms-filtre" class="input">
          <option value="tous">Tous mes clients</option>
          <option value="sans_avis">Clients sans avis Google</option>
          <option value="inactifs">Clients inactifs depuis X jours</option>
        </select>
      </div>

      <div id="inactifs-jours-wrap" class="hidden">
        <label class="label" for="inactifs-jours">Inactifs depuis (jours)</label>
        <input id="inactifs-jours" type="number" min="1" max="365" value="30" class="input w-32" />
      </div>

      <div id="sms-preview-wrap" class="rounded-xl border border-sky-100 bg-sky-50 px-4 py-3 text-sky-700 text-sm">
        <span id="sms-preview-text">Chargement...</span>
      </div>

      <div>
        <label class="label" for="sms-message">Message <span class="text-slate-400 font-normal">(160 caractères max)</span></label>
        <textarea
          id="sms-message"
          class="input resize-none"
          rows="3"
          maxlength="160"
          placeholder="Ex : Bonjour {prenom}, profitez de -10% chez {commerce} ce week-end !"
        ></textarea>
        <div class="flex justify-between mt-1">
          <p class="text-slate-400 text-xs">Variables : <code>{'{prenom}'}</code> <code>{'{commerce}'}</code> <code>{'{lien_avis}'}</code> <code>{'{lien_carte}'}</code></p>
          <span id="sms-char-count" class="text-slate-400 text-xs">0/160</span>
        </div>
      </div>

      <div id="sms-campagne-error" class="hidden rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-red-600 text-sm"></div>
      <div id="sms-campagne-success" class="hidden rounded-xl bg-emerald-50 border border-emerald-200 px-4 py-3 text-emerald-700 text-sm"></div>

      <button id="btn-envoyer-campagne" type="button"
        class="btn-primary py-3 px-6">
        Envoyer maintenant
      </button>
    </div>
  </div>

  <!-- ── Section 3 : Campagnes automatiques ────────────────────────── -->
  <div class="card p-6 mb-6">
    <h2 class="font-display text-xl font-bold text-slate-900 mb-5">Campagnes automatiques</h2>
    <div class="space-y-5">

      <!-- SMS Bienvenue -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <p class="font-semibold text-slate-900 text-sm">SMS Bienvenue</p>
            <p class="text-slate-500 text-xs mt-1">Envoyé 1h après l'installation de la carte. 1 crédit par nouveau client.</p>
            <textarea
              id="sms-welcome-message"
              class="input mt-3 resize-none text-xs"
              rows="2"
              maxlength="160"
              placeholder="Bienvenue chez {commerce} ! Laissez un avis et gagnez un tampon : {lien_carte}?nouveau=1 STOP pour se désabonner"
            ></textarea>
          </div>
          <button id="toggle-sms-welcome" type="button"
            class="sms-toggle shrink-0 w-12 h-6 rounded-full border-2 transition-colors flex items-center"
            style="border-color:#e2e8f0;background:#f1f5f9"
            data-field="sms_welcome_enabled" data-state="false">
            <span class="w-4 h-4 rounded-full bg-white shadow-sm transition-all ml-0.5"></span>
          </button>
        </div>
      </div>

      <!-- SMS Avis Google -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <p class="font-semibold text-slate-900 text-sm">SMS Avis Google</p>
            <p class="text-slate-500 text-xs mt-1">Envoyé lors d'une campagne avis Google. Complète la notification Wallet.</p>
          </div>
          <button id="toggle-sms-review" type="button"
            class="sms-toggle shrink-0 w-12 h-6 rounded-full border-2 transition-colors flex items-center"
            style="border-color:#e2e8f0;background:#f1f5f9"
            data-field="sms_review_enabled" data-state="false">
            <span class="w-4 h-4 rounded-full bg-white shadow-sm transition-all ml-0.5"></span>
          </button>
        </div>
      </div>

      <!-- SMS Relance -->
      <div class="rounded-2xl border border-slate-200 bg-white p-5">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <p class="font-semibold text-slate-900 text-sm">SMS Relance inactivité</p>
            <p class="text-slate-500 text-xs mt-1">Envoyé aux clients inactifs. Configurer le délai ci-dessous.</p>
            <div class="flex items-center gap-2 mt-3">
              <label class="text-xs text-slate-500">Après</label>
              <input id="sms-relance-jours" type="number" min="1" max="365" value="30" class="input w-20 text-xs py-1" />
              <label class="text-xs text-slate-500">jours d'inactivité</label>
            </div>
          </div>
          <button id="toggle-sms-relance" type="button"
            class="sms-toggle shrink-0 w-12 h-6 rounded-full border-2 transition-colors flex items-center"
            style="border-color:#e2e8f0;background:#f1f5f9"
            data-field="sms_relance_enabled" data-state="false">
            <span class="w-4 h-4 rounded-full bg-white shadow-sm transition-all ml-0.5"></span>
          </button>
        </div>
      </div>

      <button id="btn-save-settings" type="button" class="btn-secondary py-2 px-5 text-sm">
        Enregistrer les paramètres
      </button>
      <div id="settings-feedback" class="hidden text-sm"></div>
    </div>
  </div>

  <!-- ── Section 4 : Historique ─────────────────────────────────────── -->
  <div class="card p-6">
    <h2 class="font-display text-xl font-bold text-slate-900 mb-5">Historique (30 derniers jours)</h2>
    <div id="sms-history-loading" class="text-slate-400 text-sm">Chargement...</div>
    <div id="sms-history-empty" class="hidden text-slate-400 text-sm">Aucun SMS envoyé ces 30 derniers jours.</div>
    <div class="overflow-x-auto">
      <table class="hidden w-full text-sm" id="sms-history-table">
        <thead>
          <tr class="text-left text-xs text-slate-500 border-b border-slate-100">
            <th class="pb-2 pr-4">Date</th>
            <th class="pb-2 pr-4">Téléphone</th>
            <th class="pb-2 pr-4">Type</th>
            <th class="pb-2 pr-4">Statut</th>
            <th class="pb-2">Crédits</th>
          </tr>
        </thead>
        <tbody id="sms-history-body" class="divide-y divide-slate-50"></tbody>
      </table>
    </div>
  </div>
</DashboardLayout>

<script define:vars={{ priceIds }}>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const API = document.getElementById('api-config')?.dataset.url ?? '';
  const apiUrl = (p) => `${API}${p}`;

  async function getToken() {
    const { data: { session } } = await supabase.auth.getSession();
    return session?.access_token ?? null;
  }

  async function apiFetch(path, opts = {}) {
    const token = await getToken();
    const res = await fetch(apiUrl(path), {
      ...opts,
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${token}`,
        ...(opts.headers ?? {}),
      },
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(data.error ?? 'Erreur API');
    return data;
  }

  // ── Crédits badge ──────────────────────────────────────────────────
  function renderCreditsBadge(credits) {
    const badge = document.getElementById('sms-credits-badge');
    document.getElementById('sms-credits-val').textContent = credits;
    if (credits > 50) {
      badge.className = 'inline-flex items-center rounded-full px-4 py-1.5 text-lg font-bold bg-emerald-100 text-emerald-700';
    } else if (credits >= 10) {
      badge.className = 'inline-flex items-center rounded-full px-4 py-1.5 text-lg font-bold bg-amber-100 text-amber-700';
    } else {
      badge.className = 'inline-flex items-center rounded-full px-4 py-1.5 text-lg font-bold bg-red-100 text-red-700';
    }
  }

  // ── Historique ─────────────────────────────────────────────────────
  function renderHistory(logs) {
    const loading = document.getElementById('sms-history-loading');
    const empty = document.getElementById('sms-history-empty');
    const table = document.getElementById('sms-history-table');
    const body = document.getElementById('sms-history-body');

    loading.classList.add('hidden');

    if (!logs || logs.length === 0) {
      empty.classList.remove('hidden');
      return;
    }

    table.classList.remove('hidden');
    body.innerHTML = logs.map((log) => `
      <tr class="text-sm">
        <td class="py-2 pr-4 text-slate-500 text-xs">${new Date(log.created_at).toLocaleDateString('fr-FR', { day: '2-digit', month: '2-digit', hour: '2-digit', minute: '2-digit' })}</td>
        <td class="py-2 pr-4 font-mono text-xs text-slate-700">${log.telephone}</td>
        <td class="py-2 pr-4 text-slate-600">${log.type}</td>
        <td class="py-2 pr-4">
          <span class="rounded-full px-2 py-0.5 text-xs font-medium ${log.statut === 'envoye' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700'}">
            ${log.statut}
          </span>
        </td>
        <td class="py-2 text-slate-600">${log.credits_debites}</td>
      </tr>
    `).join('');
  }

  // ── Toggles paramètres ─────────────────────────────────────────────
  function setToggle(btn, active) {
    btn.dataset.state = active ? 'true' : 'false';
    const dot = btn.querySelector('span');
    if (active) {
      btn.style.borderColor = '#6366f1';
      btn.style.background = '#6366f1';
      dot.style.transform = 'translateX(24px)';
    } else {
      btn.style.borderColor = '#e2e8f0';
      btn.style.background = '#f1f5f9';
      dot.style.transform = 'translateX(0)';
    }
  }

  document.querySelectorAll('.sms-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const current = btn.dataset.state === 'true';
      setToggle(btn, !current);
    });
  });

  // ── Charger les données ────────────────────────────────────────────
  async function loadStats() {
    try {
      const { data } = await apiFetch('/api/sms/stats');
      renderCreditsBadge(data.sms_credits ?? 0);
      renderHistory(data.logs ?? []);

      // Remplir les paramètres
      setToggle(document.getElementById('toggle-sms-welcome'), data.sms_welcome_enabled);
      setToggle(document.getElementById('toggle-sms-review'), data.sms_review_enabled);
      setToggle(document.getElementById('toggle-sms-relance'), data.sms_relance_enabled);

      const welcomeMsg = document.getElementById('sms-welcome-message');
      if (data.sms_welcome_message) welcomeMsg.value = data.sms_welcome_message;

      document.getElementById('sms-relance-jours').value = data.sms_relance_jours ?? 30;
    } catch (e) {
      console.error('loadStats:', e);
    }
  }

  document.getElementById('btn-refresh-credits').addEventListener('click', loadStats);

  // ── Preview destinataires ──────────────────────────────────────────
  async function updatePreview() {
    const filtre = document.getElementById('sms-filtre').value;
    const jours = document.getElementById('inactifs-jours').value;
    const previewText = document.getElementById('sms-preview-text');

    document.getElementById('inactifs-jours-wrap').classList.toggle('hidden', filtre !== 'inactifs');

    try {
      const params = new URLSearchParams({ filtre });
      if (filtre === 'inactifs') params.set('inactifs_jours', jours);
      const { count } = await apiFetch(`/api/sms/preview?${params}`);
      previewText.textContent = `Cette campagne enverra environ ${count} SMS et consommera ${count} crédit(s).`;
    } catch {
      previewText.textContent = 'Impossible de calculer le nombre de destinataires.';
    }
  }

  document.getElementById('sms-filtre').addEventListener('change', updatePreview);
  document.getElementById('inactifs-jours').addEventListener('change', updatePreview);

  // ── Compteur caractères ────────────────────────────────────────────
  const msgTextarea = document.getElementById('sms-message');
  msgTextarea.addEventListener('input', () => {
    document.getElementById('sms-char-count').textContent = `${msgTextarea.value.length}/160`;
  });

  // ── Envoyer campagne ───────────────────────────────────────────────
  document.getElementById('btn-envoyer-campagne').addEventListener('click', async () => {
    const btn = document.getElementById('btn-envoyer-campagne');
    const errEl = document.getElementById('sms-campagne-error');
    const succEl = document.getElementById('sms-campagne-success');
    const message = msgTextarea.value.trim();
    const filtre = document.getElementById('sms-filtre').value;
    const inactifs_jours = parseInt(document.getElementById('inactifs-jours').value);

    errEl.classList.add('hidden');
    succEl.classList.add('hidden');

    if (!message) { errEl.textContent = 'Entrez un message.'; errEl.classList.remove('hidden'); return; }

    btn.disabled = true;
    btn.textContent = 'Envoi en cours…';

    try {
      const body = { filtre, message };
      if (filtre === 'inactifs') body.inactifs_jours = inactifs_jours;
      const { envoyes, echecs, credits_restants } = await apiFetch('/api/sms/campagne', {
        method: 'POST', body: JSON.stringify(body),
      });
      succEl.textContent = `✓ ${envoyes} SMS envoyé(s), ${echecs} échec(s). Crédits restants : ${credits_restants}.`;
      succEl.classList.remove('hidden');
      renderCreditsBadge(credits_restants);
    } catch (e) {
      errEl.textContent = e.message;
      errEl.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Envoyer maintenant';
    }
  });

  // ── Enregistrer paramètres ─────────────────────────────────────────
  document.getElementById('btn-save-settings').addEventListener('click', async () => {
    const btn = document.getElementById('btn-save-settings');
    const feedback = document.getElementById('settings-feedback');
    btn.disabled = true;

    try {
      await apiFetch('/api/sms/settings', {
        method: 'PATCH',
        body: JSON.stringify({
          sms_welcome_enabled: document.getElementById('toggle-sms-welcome').dataset.state === 'true',
          sms_welcome_message: document.getElementById('sms-welcome-message').value.trim() || null,
          sms_review_enabled: document.getElementById('toggle-sms-review').dataset.state === 'true',
          sms_relance_enabled: document.getElementById('toggle-sms-relance').dataset.state === 'true',
          sms_relance_jours: parseInt(document.getElementById('sms-relance-jours').value),
        }),
      });
      feedback.textContent = '✓ Paramètres enregistrés.';
      feedback.className = 'text-emerald-600 text-sm';
      feedback.classList.remove('hidden');
      setTimeout(() => feedback.classList.add('hidden'), 3000);
    } catch (e) {
      feedback.textContent = e.message;
      feedback.className = 'text-red-600 text-sm';
      feedback.classList.remove('hidden');
    } finally {
      btn.disabled = false;
    }
  });

  // ── Achats packs SMS ───────────────────────────────────────────────
  document.querySelectorAll('.sms-pack-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const priceId = btn.dataset.priceId;
      const errEl = document.getElementById('sms-pack-error');
      errEl.classList.add('hidden');
      btn.disabled = true;
      btn.textContent = 'Redirection…';

      const { data: { session } } = await supabase.auth.getSession();
      if (!session) { window.location.href = '/login?redirect=/dashboard/sms'; return; }

      try {
        const res = await fetch(apiUrl('/api/checkout/create-session'), {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${session.access_token}` },
          body: JSON.stringify({ priceId, mode: 'payment' }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error ?? 'Erreur serveur');
        window.location.href = data.url;
      } catch (e) {
        errEl.textContent = e.message;
        errEl.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = 'Acheter';
      }
    });
  });

  // ── Init ───────────────────────────────────────────────────────────
  loadStats();
  updatePreview();
</script>
