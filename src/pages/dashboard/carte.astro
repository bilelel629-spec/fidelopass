  function parseStripPosition(raw: string | null | undefined): { x: number; y: number } {
    const value = String(raw ?? '').trim().toLowerCase();
    if (!value) return { x: 50, y: 50 };
    if (value === 'top') return { x: 50, y: 0 };
    if (value === 'bottom') return { x: 50, y: 100 };
    if (value === 'center') return { x: 50, y: 50 };
    const [xRaw, yRaw] = value.split(':');
    const x = Number(xRaw);
    const y = Number(yRaw);
    if (!Number.isFinite(x) || !Number.isFinite(y)) return { x: 50, y: 50 };
    return { x: clamp(x, 0, 100), y: clamp(y, 0, 100) };
  }

  function getSerializedStripPosition(): string {
    return `${Math.round(stripFocusX)}:${Math.round(stripFocusY)}`;
  }

  function setStripFocus(nextX: number, nextY: number, options: { silent?: boolean } = {}) {
    stripFocusX = clamp(nextX, 0, 100);
    stripFocusY = clamp(nextY, 0, 100);
    const position = `${stripFocusX}% ${stripFocusY}%`;
    ['preview-strip', 'strip-preview-img', 'g-strip-img'].forEach((id) => {
      const el = document.getElementById(id) as HTMLImageElement | null;
      if (el) el.style.objectPosition = position;
    });
    stripPositionInput.value = getSerializedStripPosition();
    stripPositionLabel.textContent = `Position: ${Math.round(stripFocusX)}% / ${Math.round(stripFocusY)}%`;
    if (!options.silent) markDirty();
  }

  function resetStripFocus() {
    setStripFocus(50, 50);
  }

