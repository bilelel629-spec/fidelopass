    updateStripFocusFromPointer(event.clientX, event.clientY, true);
    event.preventDefault();
  });
  stripDragArea.addEventListener('pointermove', (event) => {
    if (!stripDragging) return;
    updateStripFocusFromPointer(event.clientX, event.clientY, true);
  });
  const stopStripDrag = () => {
