  function parseJsonArray<T>(value: unknown): T[] {
    if(Array.isArray(value)) return value as T[];
    if(typeof value==='string'){
      try{const parsed=JSON.parse(value); return Array.isArray(parsed)?parsed as T[]:[];}catch{return [];}
    }
    return [];
  }

  function getProgramUnit() {
    return ((document.querySelector('input[name="type"]:checked') as HTMLInputElement)?.value??'tampons')==='points'?'pts':'tampon(s)';
  }

  function defaultRewardTiers(): RewardTier[] {
    const type=(document.querySelector('input[name="type"]:checked') as HTMLInputElement)?.value??'tampons';
    if(type==='points') return [
      {seuil:100,recompense:'5€ de réduction'},
      {seuil:250,recompense:'-10% sur votre prochain achat'},
    ];
    const total=parseInt((document.getElementById('tampons-total') as HTMLInputElement).value)||10;
    return [
      {seuil:Math.max(1,Math.floor(total/2)),recompense:'Café offert'},
      {seuil:total,recompense:(document.getElementById('recompense') as HTMLInputElement).value||'Récompense fidélité'},
    ];
  }

  function escapeAttr(value: string) {
    return value.replaceAll('&','&amp;').replaceAll('"','&quot;').replaceAll('<','&lt;').replaceAll('>','&gt;');
  }

  function renderRewardTiers(tiers: RewardTier[]=[]) {
    const wrap=document.getElementById('reward-tiers')!;
    const normalized=tiers.length?tiers:defaultRewardTiers();
    wrap.innerHTML=normalized.map((tier)=>`
      <div class="reward-tier-row grid grid-cols-[92px_1fr_34px] gap-2 items-center">
        <input class="input text-xs py-2 reward-tier-seuil" type="number" min="1" value="${Number(tier.seuil)||1}" aria-label="Seuil récompense" />
        <input class="input text-xs py-2 reward-tier-label" type="text" maxlength="80" value="${escapeAttr(tier.recompense||'')}" placeholder="Ex : café offert" aria-label="Récompense" />
        <button type="button" class="reward-tier-remove btn-secondary text-xs py-2 px-2" aria-label="Retirer récompense">×</button>
      </div>
    `).join('');
    wrap.querySelectorAll('.reward-tier-remove').forEach((button,index)=>button.addEventListener('click',()=>{
      const current=collectRewardTiers();
      current.splice(index,1);
      renderRewardTiers(current);
      updatePreview();
    }));
    wrap.querySelectorAll('input').forEach(input=>input.addEventListener('input',updatePreview));
  }

  function collectRewardTiers(): RewardTier[] {
    return Array.from(document.querySelectorAll('.reward-tier-row')).map((row)=>({
      seuil:parseInt((row.querySelector('.reward-tier-seuil') as HTMLInputElement).value)||0,
      recompense:(row.querySelector('.reward-tier-label') as HTMLInputElement).value.trim(),
    })).filter((tier)=>tier.seuil>0&&tier.recompense).slice(0,6).sort((a,b)=>a.seuil-b.seuil);
  }

