---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Notifications push — Fidelopass" activeNav="notifications">
  <div class="mb-8">
    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.26em] text-sky-700/70">Communication client</p>
    <h1 class="font-display text-3xl font-bold text-slate-900 mt-2">Notifications push</h1>
    <p class="text-slate-600 text-sm mt-2">Envoyez un message à vos porteurs de carte et suivez les clients réellement joignables depuis votre programme fidélité.</p>
  </div>

  <div id="notif-summary" class="grid gap-4 md:grid-cols-1 mb-6">
    <div class="card p-5">
      <p class="text-slate-500 text-xs uppercase tracking-wide">Canal Wallet</p>
      <p id="summary-wallet" class="text-slate-900 text-2xl font-display font-bold mt-2">—</p>
      <p class="text-slate-600 text-sm mt-2">Clients joignables sans app via Apple Wallet ou Google Wallet.</p>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-6">
    <!-- Formulaire d'envoi -->
    <div class="card p-6">
      <h2 class="font-display font-bold text-slate-900 mb-4">Nouveau message client</h2>
      <form id="notif-form" class="flex flex-col gap-4">
        <div>
          <label class="label" for="titre">Titre</label>
          <input id="titre" type="text" class="input" placeholder="Ex: Offre du weekend !" maxlength="50" required />
        </div>
        <div>
          <label class="label" for="message">Message</label>
          <textarea
            id="message"
            class="input resize-none h-24"
            placeholder="Ex: -20% sur tout le magasin ce samedi uniquement 🎉"
            maxlength="150"
            required
          ></textarea>
          <span class="text-slate-500 text-xs mt-1 block text-right">
            <span id="char-count">0</span>/150
          </span>
        </div>

        <div id="error-msg" class="hidden text-red-400 text-sm bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3"></div>
        <div id="success-msg" class="hidden text-emerald-400 text-sm bg-emerald-500/10 border border-emerald-500/20 rounded-xl px-4 py-3"></div>

        <button type="submit" class="btn-primary py-3">
          Envoyer le message
        </button>
      </form>
    </div>

    <!-- Push auto avis Google -->
    <div class="card p-6 border-sky-100 bg-sky-50/40">
      <div class="flex items-start justify-between gap-3 mb-4">
        <div>
          <h2 class="font-display font-bold text-slate-900">Avis Google automatique (+1h)</h2>
          <p class="text-slate-500 text-sm mt-1">Envoie automatiquement un push 60 minutes après l'installation de la carte pour inviter le client à laisser un avis Google.</p>
        </div>
        <span class="rounded-full border border-amber-200 bg-amber-100 px-2 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-amber-700">Pro uniquement</span>
      </div>
      <div id="review-auto-plan-info" class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-600 text-sm mb-4">
        Plan actuel: <span id="review-auto-plan-value" class="font-semibold text-slate-900">Chargement...</span>
      </div>
      <div id="review-auto-locked" class="hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-700 text-sm mb-4">
        Cette fonctionnalite est reservee au plan Pro. Ce n'est pas un bug. Passez au plan Pro pour l'activer depuis cette page.
        <a href="/pricing" class="font-semibold underline ml-1">Voir les plans</a>
      </div>
      <div id="review-auto-error" class="hidden text-red-400 text-sm bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 mb-3"></div>
      <div id="review-auto-success" class="hidden text-emerald-400 text-sm bg-emerald-500/10 border border-emerald-500/20 rounded-xl px-4 py-3 mb-3"></div>
      <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3">
        <div>
          <p class="text-slate-800 text-sm font-medium">Activer le push avis Google automatique</p>
          <p class="text-slate-500 text-xs mt-0.5">Le lien Google Maps de la carte active est utilisé dans le push.</p>
        </div>
        <button
          id="review-auto-toggle"
          type="button"
          class="relative w-12 h-6 rounded-full transition-colors flex-shrink-0"
          style="background:#334155"
          aria-pressed="false"
        >
          <span id="review-auto-knob" class="absolute top-0.5 w-5 h-5 rounded-full bg-white shadow transition-all" style="left:2px"></span>
        </button>
      </div>
      <p id="review-auto-status" class="text-slate-500 text-xs mt-2 text-center">Chargement du statut...</p>
    </div>

    <!-- Push auto anniversaire -->
    <div class="card p-6 border-pink-100 bg-pink-50/40">
      <div class="flex items-start justify-between gap-3 mb-4">
        <div>
          <h2 class="font-display font-bold text-slate-900">Anniversaire automatique (jour J à 10h)</h2>
          <p class="text-slate-500 text-sm mt-1">Envoie automatiquement un push anniversaire et ajoute un bonus sur la carte du client.</p>
        </div>
        <span class="rounded-full border border-amber-200 bg-amber-100 px-2 py-1 text-[0.62rem] font-semibold uppercase tracking-[0.18em] text-amber-700">Pro uniquement</span>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white px-4 py-3 text-slate-600 text-sm mb-4">
        Plan actuel: <span id="birthday-plan-value" class="font-semibold text-slate-900">Chargement...</span>
      </div>
      <div id="birthday-locked" class="hidden rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-700 text-sm mb-4">
        Cette fonctionnalite est reservee au plan Pro. Ce n'est pas un bug. Passez au plan Pro pour l'activer.
        <a href="/pricing" class="font-semibold underline ml-1">Voir les plans</a>
      </div>
      <div id="birthday-error" class="hidden text-red-400 text-sm bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 mb-3"></div>
      <div id="birthday-success" class="hidden text-emerald-400 text-sm bg-emerald-500/10 border border-emerald-500/20 rounded-xl px-4 py-3 mb-3"></div>
      <div class="space-y-3 mb-4">
        <div>
          <label class="label" for="birthday-reward-value">Bonus anniversaire (tampon/point)</label>
          <input id="birthday-reward-value" type="number" min="1" max="50" value="1" class="input" />
        </div>
        <div>
          <label class="label" for="birthday-title">Titre du push</label>
          <input id="birthday-title" type="text" maxlength="80" class="input" placeholder="Joyeux anniversaire 🎉" />
        </div>
        <div>
          <label class="label" for="birthday-message">Message du push</label>
          <textarea id="birthday-message" maxlength="180" class="input resize-none h-24" placeholder="Votre bonus anniversaire est disponible sur votre carte Fidelopass."></textarea>
        </div>
      </div>
      <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-3">
        <div>
          <p class="text-slate-800 text-sm font-medium">Activer la programmation anniversaire</p>
          <p class="text-slate-500 text-xs mt-0.5">Execution: Europe/Paris, chaque jour à 10h.</p>
        </div>
        <button
          id="birthday-toggle"
          type="button"
          class="relative w-12 h-6 rounded-full transition-colors flex-shrink-0"
          style="background:#334155"
          aria-pressed="false"
        >
          <span id="birthday-knob" class="absolute top-0.5 w-5 h-5 rounded-full bg-white shadow transition-all" style="left:2px"></span>
        </button>
      </div>
      <p id="birthday-status" class="text-slate-500 text-xs mt-2 text-center">Chargement du statut...</p>
    </div>

  <!-- Historique -->
    <div class="card p-6">
      <h2 class="font-display font-bold text-slate-900 mb-4">Historique</h2>
      <div id="notif-history" class="flex flex-col gap-3">
        <p class="text-slate-500 text-sm">Chargement...</p>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { authFetch } from '../../lib/api';

  function escapeHtml(value: unknown) {
    return String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;',
    }[char] ?? char));
  }

  // Compteur de caractères
  const messageInput = document.getElementById('message') as HTMLTextAreaElement;
  const charCount = document.getElementById('char-count')!;
  messageInput.addEventListener('input', () => {
    charCount.textContent = String(messageInput.value.length);
  });

  // Envoi de notification
  const form = document.getElementById('notif-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const successMsg = document.getElementById('success-msg') as HTMLDivElement;
  let notificationSummary = { web_push_ready: 0, wallet_ready: 0 };

  async function loadSummary() {
    try {
      const res = await authFetch('/api/notifications/summary');
      if (!res.ok) throw new Error();
      const { data } = await res.json();
      notificationSummary = {
        web_push_ready: data?.web_push_ready ?? 0,
        wallet_ready: data?.wallet_ready ?? 0,
      };

      document.getElementById('summary-wallet')!.textContent = String(notificationSummary.wallet_ready);
    } catch {
      document.getElementById('summary-wallet')!.textContent = '—';
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    successMsg.classList.add('hidden');

    const titre = (document.getElementById('titre') as HTMLInputElement).value;
    const message = messageInput.value;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';

    try {
      const res = await authFetch('/api/notifications', {
        method: 'POST',
        body: JSON.stringify({ titre, message }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error ?? 'Erreur');

      successMsg.textContent = data.nb_destinataires === 0
        ? `Aucun client n'est encore joignable depuis votre programme pour le moment.`
        : `Message envoyé à ${data.nb_delivrees} client(s) sur ${data.nb_destinataires}. Canal Wallet : ${data.nb_wallet ?? 0}. Canal web : ${data.nb_web_push ?? 0}.`;
      successMsg.classList.remove('hidden');
      form.reset();
      charCount.textContent = '0';
      await loadSummary();
      loadHistory();
    } catch (err: unknown) {
      errorMsg.textContent = err instanceof Error ? err.message : 'Erreur lors de l\'envoi.';
      errorMsg.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Envoyer le message';
    }
  });

  // Chargement historique
  async function loadHistory() {
    const container = document.getElementById('notif-history')!;
    try {
      const res = await authFetch('/api/notifications?limit=10');
      if (!res.ok) throw new Error();
      const { data } = await res.json();

      if (!data?.length) {
        container.innerHTML = '<p class="text-slate-500 text-sm">Aucune notification envoyée.</p>';
        return;
      }

      container.innerHTML = data.map((n: { titre: string; message: string; nb_destinataires: number; nb_delivrees: number | null; created_at: string }) => `
        <div class="border-b border-slate-200 pb-3 last:border-0 last:pb-0">
          <div class="flex items-start justify-between gap-2">
            <div>
              <p class="text-slate-900 text-sm font-medium">${escapeHtml(n.titre)}</p>
              <p class="text-slate-600 text-xs mt-0.5">${escapeHtml(n.message)}</p>
            </div>
            <span class="badge badge-info shrink-0">${n.nb_delivrees ?? 0}/${n.nb_destinataires}</span>
          </div>
          <p class="text-slate-500 text-xs mt-1">${new Date(n.created_at).toLocaleString('fr-FR')}</p>
        </div>
      `).join('');
    } catch {
      container.innerHTML = '<p class="text-red-400 text-sm">Erreur lors du chargement.</p>';
    }
  }

  // Push auto avis Google (+1h)
  const reviewAutoToggle = document.getElementById('review-auto-toggle') as HTMLButtonElement;
  const reviewAutoKnob = document.getElementById('review-auto-knob') as HTMLSpanElement;
  const reviewAutoStatus = document.getElementById('review-auto-status') as HTMLParagraphElement;
  const reviewAutoPlanValue = document.getElementById('review-auto-plan-value') as HTMLSpanElement;
  const reviewAutoLocked = document.getElementById('review-auto-locked') as HTMLDivElement;
  const reviewAutoError = document.getElementById('review-auto-error') as HTMLDivElement;
  const reviewAutoSuccess = document.getElementById('review-auto-success') as HTMLDivElement;
  let reviewAutoEnabled = false;
  let reviewAutoIsPro = false;
  const normalizePlan = (planRaw: unknown) => String(planRaw ?? 'starter').trim().toLowerCase();
  const isProPlan = (planRaw: unknown) => {
    const normalized = normalizePlan(planRaw);
    return normalized === 'pro' || normalized.startsWith('pro-') || normalized.includes('pro');
  };

  function setReviewAutoToggle(enabled: boolean) {
    reviewAutoEnabled = enabled;
    reviewAutoToggle.style.background = enabled ? '#4f46e5' : '#334155';
    reviewAutoKnob.style.left = enabled ? '26px' : '2px';
    reviewAutoToggle.setAttribute('aria-pressed', String(enabled));
    reviewAutoStatus.textContent = enabled
      ? 'Automatisation active: push envoyé 1h après installation.'
      : 'Automatisation inactive.';
  }

  function setReviewPlanLabel(planRaw: unknown) {
    const normalized = normalizePlan(planRaw);
    if (isProPlan(normalized)) {
      reviewAutoPlanValue.textContent = 'Pro';
      return;
    }
    if (normalized.includes('sur-mesure') || normalized.includes('surmesure') || normalized.includes('custom') || normalized.includes('enterprise')) {
      reviewAutoPlanValue.textContent = 'Sur mesure';
      return;
    }
    reviewAutoPlanValue.textContent = 'Starter';
  }

  async function loadReviewAutoSettings() {
    try {
      const res = await authFetch('/api/notifications/review-reminder-settings');
      const payload = await res.json().catch(() => null);
      if (!res.ok) throw new Error(payload?.error ?? 'Impossible de charger le réglage.');

      reviewAutoIsPro = Boolean(payload?.data?.is_pro) || isProPlan(payload?.data?.plan ?? payload?.data?.raw_plan);
      setReviewPlanLabel(payload?.data?.plan);
      setReviewAutoToggle(Boolean(payload?.data?.enabled));

      if (!reviewAutoIsPro) {
        reviewAutoLocked.classList.remove('hidden');
        reviewAutoToggle.disabled = true;
        reviewAutoToggle.classList.add('opacity-40', 'cursor-not-allowed');
        reviewAutoStatus.textContent = 'Plan Starter: indisponible. Activez le plan Pro pour debloquer cette automatisation.';
      } else {
        reviewAutoStatus.textContent = reviewAutoEnabled
          ? 'Plan Pro: automatisation active (envoi 1h apres installation).'
          : 'Plan Pro: vous pouvez activer cette automatisation.';
      }
    } catch (error) {
      console.error('[notifications review auto]', error);
      try {
        const planRes = await authFetch('/api/dashboard/plan');
        const planPayload = await planRes.json().catch(() => null);
        const fallbackPlan = planPayload?.data?.plan ?? planPayload?.data?.raw_plan ?? 'starter';
        setReviewPlanLabel(fallbackPlan);
        reviewAutoIsPro = isProPlan(fallbackPlan);
      } catch {
        setReviewPlanLabel('starter');
        reviewAutoIsPro = false;
      }
      reviewAutoToggle.disabled = true;
      reviewAutoToggle.classList.add('opacity-40', 'cursor-not-allowed');
      if (!reviewAutoIsPro) reviewAutoLocked.classList.remove('hidden');
      reviewAutoStatus.textContent = 'Impossible de charger le statut pour le moment.';
    }
  }

  reviewAutoToggle.addEventListener('click', async () => {
    if (!reviewAutoIsPro) return;

    reviewAutoError.classList.add('hidden');
    reviewAutoSuccess.classList.add('hidden');
    reviewAutoToggle.disabled = true;

    try {
      const nextValue = !reviewAutoEnabled;
      const res = await authFetch('/api/notifications/review-reminder-settings', {
        method: 'PATCH',
        body: JSON.stringify({ enabled: nextValue }),
      });
      const payload = await res.json();
      if (!res.ok) throw new Error(payload.error ?? 'Impossible de mettre à jour le réglage.');

      setReviewAutoToggle(nextValue);
      reviewAutoSuccess.textContent = nextValue
        ? 'Automatisation activée.'
        : 'Automatisation désactivée.';
      reviewAutoSuccess.classList.remove('hidden');
    } catch (err: unknown) {
      reviewAutoError.textContent = err instanceof Error ? err.message : 'Erreur réseau. Réessayez.';
      reviewAutoError.classList.remove('hidden');
    } finally {
      reviewAutoToggle.disabled = false;
    }
  });

  setReviewPlanLabel('starter');
  loadSummary();
  loadHistory();
  loadReviewAutoSettings();

  // Push auto anniversaire
  const birthdayToggle = document.getElementById('birthday-toggle') as HTMLButtonElement;
  const birthdayKnob = document.getElementById('birthday-knob') as HTMLSpanElement;
  const birthdayStatus = document.getElementById('birthday-status') as HTMLParagraphElement;
  const birthdayPlanValue = document.getElementById('birthday-plan-value') as HTMLSpanElement;
  const birthdayLocked = document.getElementById('birthday-locked') as HTMLDivElement;
  const birthdayError = document.getElementById('birthday-error') as HTMLDivElement;
  const birthdaySuccess = document.getElementById('birthday-success') as HTMLDivElement;
  const birthdayRewardValue = document.getElementById('birthday-reward-value') as HTMLInputElement;
  const birthdayTitle = document.getElementById('birthday-title') as HTMLInputElement;
  const birthdayMessage = document.getElementById('birthday-message') as HTMLTextAreaElement;
  let birthdayEnabled = false;
  let birthdayIsPro = false;

  function setBirthdayToggle(enabled: boolean) {
    birthdayEnabled = enabled;
    birthdayToggle.style.background = enabled ? '#4f46e5' : '#334155';
    birthdayKnob.style.left = enabled ? '26px' : '2px';
    birthdayToggle.setAttribute('aria-pressed', String(enabled));
    birthdayStatus.textContent = enabled
      ? 'Automatisation active: envoi anniversaire le jour J à 10h.'
      : 'Automatisation inactive.';
  }

  function setBirthdayPlanLabel(planRaw: unknown) {
    const normalized = normalizePlan(planRaw);
    if (isProPlan(normalized)) {
      birthdayPlanValue.textContent = 'Pro';
      return;
    }
    if (normalized.includes('sur-mesure') || normalized.includes('surmesure') || normalized.includes('custom') || normalized.includes('enterprise')) {
      birthdayPlanValue.textContent = 'Sur mesure';
      return;
    }
    birthdayPlanValue.textContent = 'Starter';
  }

  function setBirthdayFormDisabled(disabled: boolean) {
    birthdayToggle.disabled = disabled;
    birthdayRewardValue.disabled = disabled;
    birthdayTitle.disabled = disabled;
    birthdayMessage.disabled = disabled;
    birthdayToggle.classList.toggle('opacity-40', disabled);
    birthdayToggle.classList.toggle('cursor-not-allowed', disabled);
  }

  async function loadBirthdaySettings() {
    try {
      const res = await authFetch('/api/notifications/birthday-settings');
      const payload = await res.json().catch(() => null);
      if (!res.ok) throw new Error(payload?.error ?? 'Impossible de charger le réglage anniversaire.');

      birthdayIsPro = Boolean(payload?.data?.is_pro) || isProPlan(payload?.data?.plan ?? payload?.data?.raw_plan);
      setBirthdayPlanLabel(payload?.data?.plan);
      setBirthdayToggle(Boolean(payload?.data?.enabled));
      birthdayRewardValue.value = String(payload?.data?.reward_value ?? 1);
      birthdayTitle.value = String(payload?.data?.push_title ?? '');
      birthdayMessage.value = String(payload?.data?.push_message ?? '');

      if (!payload?.data?.has_active_card) {
        setBirthdayFormDisabled(true);
        birthdayStatus.textContent = 'Aucune carte active sur ce point de vente.';
        return;
      }

      if (!birthdayIsPro) {
        birthdayLocked.classList.remove('hidden');
        setBirthdayFormDisabled(true);
        birthdayStatus.textContent = 'Plan Starter: indisponible. Activez le plan Pro pour debloquer cette automatisation.';
      } else {
        birthdayLocked.classList.add('hidden');
        setBirthdayFormDisabled(false);
        birthdayStatus.textContent = birthdayEnabled
          ? 'Plan Pro: automatisation active (jour J à 10h, Europe/Paris).'
          : 'Plan Pro: vous pouvez activer cette automatisation.';
      }
    } catch (error) {
      console.error('[notifications birthday auto]', error);
      setBirthdayFormDisabled(true);
      birthdayStatus.textContent = 'Impossible de charger le statut pour le moment.';
      setBirthdayPlanLabel('starter');
      birthdayLocked.classList.remove('hidden');
    }
  }

  async function persistBirthdaySettings(nextEnabled: boolean) {
    const rewardValue = Number.parseInt(birthdayRewardValue.value, 10);
    if (!Number.isFinite(rewardValue) || rewardValue < 1 || rewardValue > 50) {
      throw new Error('Le bonus anniversaire doit être compris entre 1 et 50.');
    }
    const title = birthdayTitle.value.trim();
    const message = birthdayMessage.value.trim();

    const res = await authFetch('/api/notifications/birthday-settings', {
      method: 'PATCH',
      body: JSON.stringify({
        enabled: nextEnabled,
        reward_value: rewardValue,
        push_title: title || null,
        push_message: message || null,
      }),
    });
    const payload = await res.json().catch(() => null);
    if (!res.ok) throw new Error(payload?.error ?? 'Impossible de mettre à jour le réglage anniversaire.');
    return payload;
  }

  birthdayToggle.addEventListener('click', async () => {
    if (!birthdayIsPro) return;

    birthdayError.classList.add('hidden');
    birthdaySuccess.classList.add('hidden');
    setBirthdayFormDisabled(true);

    try {
      const nextEnabled = !birthdayEnabled;
      const payload = await persistBirthdaySettings(nextEnabled);
      setBirthdayToggle(Boolean(payload?.data?.enabled));
      birthdayRewardValue.value = String(payload?.data?.reward_value ?? birthdayRewardValue.value);
      birthdayTitle.value = String(payload?.data?.push_title ?? birthdayTitle.value);
      birthdayMessage.value = String(payload?.data?.push_message ?? birthdayMessage.value);
      birthdaySuccess.textContent = nextEnabled
        ? 'Programmation anniversaire activée.'
        : 'Programmation anniversaire désactivée.';
      birthdaySuccess.classList.remove('hidden');
    } catch (err: unknown) {
      birthdayError.textContent = err instanceof Error ? err.message : 'Erreur réseau. Réessayez.';
      birthdayError.classList.remove('hidden');
    } finally {
      setBirthdayFormDisabled(!birthdayIsPro);
    }
  });

  [birthdayRewardValue, birthdayTitle, birthdayMessage].forEach((field) => {
    field.addEventListener('change', async () => {
      if (!birthdayIsPro) return;
      birthdayError.classList.add('hidden');
      birthdaySuccess.classList.add('hidden');

      try {
        await persistBirthdaySettings(birthdayEnabled);
        birthdaySuccess.textContent = 'Réglage anniversaire enregistré.';
        birthdaySuccess.classList.remove('hidden');
      } catch (err: unknown) {
        birthdayError.textContent = err instanceof Error ? err.message : 'Erreur réseau. Réessayez.';
        birthdayError.classList.remove('hidden');
      }
    });
  });

  setBirthdayPlanLabel('starter');
  loadBirthdaySettings();
</script>
