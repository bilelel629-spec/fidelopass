---
import '../styles/global.css';

interface Props {
  title?: string;
  activeNav?: string;
}

const { title = 'Admin — Fidelopass', activeNav = '' } = Astro.props;

const navItems = [
  { href: '/admin', id: 'overview', label: 'Vue globale', icon: '📊' },
  { href: '/admin/commerces', id: 'commerces', label: 'Commerces', icon: '🏪' },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-navy-900 text-slate-50 antialiased">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside class="w-60 shrink-0 bg-navy-950 border-r border-white/5 flex flex-col">
        <div class="px-6 py-5 border-b border-white/5">
          <a href="/admin" class="flex items-center gap-2 text-white">
            <img src="/logo-mark.svg" alt="" class="h-8 w-8 rounded-xl" />
            <span class="font-display font-bold text-lg">Fidelopass</span>
            <span class="ml-2 badge badge-danger text-[10px]">ADMIN</span>
          </a>
        </div>
        <nav class="flex-1 px-3 py-4 flex flex-col gap-1">
          {navItems.map(({ href, id, label, icon }) => (
            <a
              href={href}
              class={`flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-all
                ${activeNav === id
                  ? 'bg-red-500/20 text-red-300 font-medium'
                  : 'text-slate-400 hover:text-slate-200 hover:bg-white/5'
                }`}
            >
              <span class="text-base">{icon}</span>
              {label}
            </a>
          ))}
        </nav>
        <div class="px-3 py-4 border-t border-white/5">
          <a href="/dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-slate-400 hover:text-slate-200 hover:bg-white/5 transition-all">
            <span>←</span> Dashboard commerçant
          </a>
        </div>
      </aside>

      <!-- Main -->
      <main class="flex-1 overflow-y-auto">
        <div class="p-6 md:p-8 max-w-7xl mx-auto">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>

<script>
  import { getSession } from '../lib/auth';
  const session = await getSession();
  if (!session) window.location.replace('/login');
</script>
