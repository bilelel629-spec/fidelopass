---
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const tiers = [
  {
    name: 'Bronze',
    detail: 'Niveau d’entrée qui valorise les clients actifs dès les premières interactions.',
    benefits: ['Offres de bienvenue', 'Bonus ponctuels', 'Accès à des avantages de base'],
  },
  {
    name: 'Silver',
    detail: 'Niveau intermédiaire pour les clients récurrents à forte valeur.',
    benefits: ['Réductions dédiées', 'Accès anticipé à certaines offres', 'Priorité sur campagnes ciblées'],
  },
  {
    name: 'Gold',
    detail: 'Niveau premium pour les meilleurs clients ou membres à engagement.',
    benefits: ['Avantages exclusifs', 'Expérience prioritaire', 'Sentiment de statut clairement visible'],
  },
];

const profiles = [
  {
    title: 'Studios et clubs',
    text: 'Yoga, fitness, pilates, boxe : parfait pour gérer des membres et des niveaux de fidélité.',
  },
  {
    title: 'Beauté / bien-être premium',
    text: 'Spas, instituts, barber haut de gamme : idéal pour valoriser la clientèle régulière.',
  },
  {
    title: 'Food et hospitality',
    text: 'Restaurants, coffee concepts, bars : différencier les habitués avec un statut clair.',
  },
];

const strengths = [
  {
    title: 'Positionnement haut de gamme',
    text: 'La carte devient un signe d’appartenance, pas seulement un compteur de passages.',
  },
  {
    title: 'Plus de valeur perçue',
    text: 'Un client VIP dépense plus facilement quand il sent qu’il a un traitement privilégié.',
  },
  {
    title: 'Meilleure rétention',
    text: 'Les niveaux motivent à revenir pour conserver ou atteindre un statut supérieur.',
  },
];

const useCases = [
  'Programme Bronze / Silver / Gold avec règles d’accès',
  'Carte membre mensuelle ou annuelle avec avantages permanents',
  'Accès prioritaire, offres dédiées et récompenses réservées',
];
---

<BaseLayout title="Carte VIP Fidelopass" description="Créez une carte VIP ou membership Apple Wallet et Google Wallet avec niveaux Bronze, Silver, Gold et avantages visibles.">
  <div class="min-h-screen bg-[linear-gradient(180deg,#ffffff_0%,#f5f9ff_62%,#ffffff_100%)] relative overflow-hidden">
    <div class="pointer-events-none absolute -top-24 right-[-10rem] h-[30rem] w-[30rem] rounded-full bg-amber-200/30 blur-3xl"></div>
    <div class="pointer-events-none absolute bottom-[-9rem] left-[-8rem] h-[24rem] w-[24rem] rounded-full bg-indigo-200/20 blur-3xl"></div>

    <PublicNav currentPath="/create-membership-card" />

    <main class="max-w-7xl mx-auto px-4 sm:px-6 pt-12 pb-20">
      <section class="grid lg:grid-cols-[1.05fr_0.95fr] gap-8 items-center">
        <div>
          <span class="inline-flex items-center rounded-full border border-amber-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-amber-700 shadow-sm">
            Carte VIP / Membership
          </span>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 leading-[0.96] mt-5">
            Transformez la fidélité
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-amber-500 to-indigo-600">
              en statut visible et désirable.
            </span>
          </h1>
          <p class="text-slate-500 text-lg leading-relaxed mt-6 max-w-2xl">
            La carte membership Fidelopass permet de créer un vrai sentiment d’appartenance avec des niveaux VIP, des avantages réservés et une expérience plus premium.
          </p>

          <div class="space-y-3 mt-8">
            {useCases.map((item) => (
              <div class="flex items-start gap-3 text-sm text-slate-600">
                <span class="mt-1 w-2.5 h-2.5 rounded-full bg-amber-500"></span>
                <span>{item}</span>
              </div>
            ))}
          </div>

          <div class="flex flex-col sm:flex-row gap-3 mt-8">
            <a href="/register" class="btn-primary px-8 py-3.5 text-base">Créer une carte VIP</a>
            <a href="/pricing" class="btn-secondary px-8 py-3.5 text-base">Voir les tarifs</a>
          </div>
        </div>

        <aside class="rounded-[2rem] border border-slate-200 bg-white shadow-[0_22px_50px_rgba(15,23,42,0.08)] p-6 sm:p-7">
          <p class="text-xs uppercase tracking-[0.22em] text-slate-400 font-semibold">Profils adaptés</p>
          <div class="space-y-3 mt-4">
            {profiles.map((profile) => (
              <article class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                <p class="text-sm font-semibold text-slate-900">{profile.title}</p>
                <p class="text-sm text-slate-500 mt-1">{profile.text}</p>
              </article>
            ))}
          </div>
        </aside>
      </section>

      <section class="mt-16">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">
          Niveaux VIP recommandés
        </h2>
        <div class="grid md:grid-cols-3 gap-4 mt-6">
          {tiers.map((tier) => (
            <article class="rounded-[1.25rem] border border-slate-200 bg-white shadow-sm px-5 py-5">
              <p class="text-xs uppercase tracking-[0.18em] text-slate-400 font-semibold">{tier.name}</p>
              <p class="text-sm text-slate-700 mt-3 leading-relaxed">{tier.detail}</p>
              <ul class="space-y-1.5 mt-3">
                {tier.benefits.map((benefit) => (
                  <li class="text-sm text-slate-500">• {benefit}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="mt-16 rounded-[2rem] border border-slate-200 bg-white shadow-[0_22px_50px_rgba(15,23,42,0.08)] p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.22em] text-slate-400 font-semibold">Pourquoi ce format est puissant</p>
        <div class="grid md:grid-cols-3 gap-4 mt-6">
          {strengths.map((strength) => (
            <article class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-4">
              <p class="text-sm font-semibold text-slate-900">{strength.title}</p>
              <p class="text-sm text-slate-500 mt-2 leading-relaxed">{strength.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="mt-16 rounded-[2rem] bg-[linear-gradient(135deg,#111827_0%,#1e3a8a_60%,#f59e0b_100%)] px-6 py-8 sm:px-8 sm:py-10">
        <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-6">
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-amber-100 font-semibold">Prêt à lancer votre club VIP ?</p>
            <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mt-3">
              Créez une carte membership premium en quelques minutes.
            </h2>
            <p class="text-amber-100 mt-3 text-base">Essai gratuit 14 jours, avec carte bancaire, résiliable à tout moment pendant l'essai.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
            <a href="/register" class="inline-flex items-center justify-center rounded-xl bg-white px-6 py-3 text-sm font-semibold text-indigo-700 hover:bg-indigo-50 transition-colors">
              Démarrer l’essai gratuit
            </a>
            <a href="/contact" class="inline-flex items-center justify-center rounded-xl border border-white/30 bg-white/10 px-6 py-3 text-sm font-semibold text-white hover:bg-white/20 transition-colors">
              Parler à l’équipe
            </a>
          </div>
        </div>
      </section>
    </main>

    <PublicFooter />
  </div>
</BaseLayout>
