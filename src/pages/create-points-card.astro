---
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const scenarios = [
  '1€ dépensé = 1 point',
  '100 points = -5€ immédiat',
  'Paliers VIP Bronze / Silver / Gold',
  'Bonus anniversaire',
  'Boost points sur créneaux calmes',
  'Offres ciblées selon fréquence client',
];

const advantages = [
  {
    title: 'Plus flexible que le tampon',
    text: 'Vous adaptez la récompense à la valeur du panier, pas seulement au nombre de passages.',
  },
  {
    title: 'Idéal pour plusieurs récompenses',
    text: 'Proposez des paliers différents (petite récompense, offre moyenne, avantage premium).',
  },
  {
    title: 'Pilotage plus fin',
    text: 'Le commerce peut ajuster la mécanique et tester ce qui performe le mieux.',
  },
];

const profiles = [
  {
    title: 'Restaurants et food premium',
    text: 'Récompenser proportionnellement au ticket moyen.',
  },
  {
    title: 'Beauté / bien-être',
    text: 'Valoriser la fidélité long terme et les soins récurrents.',
  },
  {
    title: 'Retail spécialisé',
    text: 'Encourager les achats réguliers avec des niveaux VIP.',
  },
];
---

<BaseLayout title="Carte à points Fidelopass" description="Lancez une carte à points Wallet pour suivre les achats, débloquer des paliers et fidéliser les clients réguliers.">
  <div class="min-h-screen bg-[linear-gradient(180deg,#ffffff_0%,#f5f9ff_62%,#ffffff_100%)] relative overflow-hidden">
    <div class="pointer-events-none absolute -top-24 right-[-10rem] h-[30rem] w-[30rem] rounded-full bg-sky-200/35 blur-3xl"></div>
    <div class="pointer-events-none absolute bottom-[-9rem] left-[-8rem] h-[24rem] w-[24rem] rounded-full bg-indigo-200/20 blur-3xl"></div>

    <PublicNav currentPath="/create-points-card" />

    <main class="max-w-7xl mx-auto px-4 sm:px-6 pt-12 pb-20">
      <section class="grid lg:grid-cols-[1.05fr_0.95fr] gap-8 items-center">
        <div>
          <span class="inline-flex items-center rounded-full border border-sky-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-sky-700 shadow-sm">
            Carte à points
          </span>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 leading-[0.96] mt-5">
            La fidélité évolutive
            <span class="block text-transparent bg-clip-text bg-gradient-to-r from-sky-600 to-indigo-600">
              pour piloter plus finement votre croissance.
            </span>
          </h1>
          <p class="text-slate-500 text-lg leading-relaxed mt-6 max-w-2xl">
            Utilisez les points quand vous voulez récompenser selon le montant d’achat, gérer plusieurs paliers et faire évoluer votre stratégie fidélité dans le temps.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 mt-8">
            <a href="/register" class="btn-primary px-8 py-3.5 text-base">Créer une carte à points</a>
            <a href="/pricing" class="btn-secondary px-8 py-3.5 text-base">Voir les tarifs</a>
          </div>
        </div>

        <aside class="rounded-[2rem] border border-slate-200 bg-white shadow-[0_22px_50px_rgba(15,23,42,0.08)] p-6 sm:p-7">
          <p class="text-xs uppercase tracking-[0.22em] text-slate-400 font-semibold">Exemples de mécanique</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-4">
            {scenarios.map((scenario) => (
              <div class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700">
                {scenario}
              </div>
            ))}
          </div>
          <div class="rounded-xl border border-sky-100 bg-sky-50 px-4 py-3 mt-5">
            <p class="text-sm font-semibold text-sky-900">Cas typique</p>
            <p class="text-sm text-sky-800 mt-1">“200 points = offre premium” + “bonus fidélité mensuel”.</p>
          </div>
        </aside>
      </section>

      <section class="mt-16">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">
          Pourquoi choisir une carte à points
        </h2>
        <div class="grid md:grid-cols-3 gap-4 mt-6">
          {advantages.map((advantage) => (
            <article class="rounded-[1.25rem] border border-slate-200 bg-white shadow-sm px-5 py-5">
              <p class="text-base font-semibold text-slate-900">{advantage.title}</p>
              <p class="text-sm text-slate-500 mt-2 leading-relaxed">{advantage.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="mt-16 rounded-[2rem] border border-slate-200 bg-white shadow-[0_22px_50px_rgba(15,23,42,0.08)] p-6 sm:p-8">
        <p class="text-xs uppercase tracking-[0.22em] text-slate-400 font-semibold">Pour quels commerces ?</p>
        <h2 class="font-display text-3xl font-bold text-slate-900 mt-3">
          Idéal quand la valeur d’achat varie
        </h2>
        <div class="grid md:grid-cols-3 gap-4 mt-6">
          {profiles.map((profile) => (
            <article class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-4">
              <p class="text-sm font-semibold text-slate-900">{profile.title}</p>
              <p class="text-sm text-slate-500 mt-2 leading-relaxed">{profile.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="mt-16 rounded-[2rem] bg-[linear-gradient(135deg,#0f172a_0%,#1e3a8a_62%,#0284c7_100%)] px-6 py-8 sm:px-8 sm:py-10">
        <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-6">
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-sky-200 font-semibold">Prêt à lancer votre programme ?</p>
            <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mt-3">
              Passez d’une fidélité basique à une fidélité pilotable.
            </h2>
            <p class="text-sky-100 mt-3 text-base">Essai gratuit 14 jours, avec carte bancaire, résiliable à tout moment pendant l'essai.</p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto">
            <a href="/register" class="inline-flex items-center justify-center rounded-xl bg-white px-6 py-3 text-sm font-semibold text-sky-700 hover:bg-sky-50 transition-colors">
              Démarrer l’essai gratuit
            </a>
            <a href="/contact" class="inline-flex items-center justify-center rounded-xl border border-white/30 bg-white/10 px-6 py-3 text-sm font-semibold text-white hover:bg-white/20 transition-colors">
              Parler à l’équipe
            </a>
          </div>
        </div>
      </section>
    </main>

    <PublicFooter />
  </div>
</BaseLayout>
