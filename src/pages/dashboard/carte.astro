      couleur_texte:getInput('couleur-texte'),
      couleur_accent:getInput('couleur-accent'),
      push_icon_bg_color:getInput('push-icon-bg-color'),
      logo_url:logoUrl||null,
      strip_url:stripUrl||null,
      strip_position:stripPositionInput.value || getSerializedStripPosition(),
      tampon_icon_url:tamponIconUrl||null,
