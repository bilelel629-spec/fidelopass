---
import BaseLayout from '../../layouts/BaseLayout.astro';
const { id } = Astro.params;
const apiBase = (
  import.meta.env.PUBLIC_API_URL
  ?? (import.meta.env.PROD ? 'https://api.fidelopass.com' : 'http://localhost:3001')
).replace(/\/$/, '');
const firebasePushConfig = {
  apiKey: import.meta.env.PUBLIC_FIREBASE_API_KEY ?? '',
  authDomain: import.meta.env.PUBLIC_FIREBASE_AUTH_DOMAIN ?? '',
  projectId: import.meta.env.PUBLIC_FIREBASE_PROJECT_ID ?? '',
  messagingSenderId: import.meta.env.PUBLIC_FIREBASE_MESSAGING_SENDER_ID ?? '',
  appId: import.meta.env.PUBLIC_FIREBASE_APP_ID ?? '',
  vapidKey: import.meta.env.PUBLIC_FIREBASE_VAPID_KEY ?? '',
};
---

<BaseLayout title="Ajouter à mon Wallet — Fidelopass">
  <div class="min-h-screen flex flex-col items-center justify-center px-4 py-12">

    <div id="loading" class="text-center">
      <div class="w-8 h-8 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
      <p class="text-slate-400 text-sm">Chargement...</p>
    </div>

    <div id="carte-content" class="hidden w-full max-w-sm">

      <!-- Aperçu carte -->
      <div id="wallet-card" class="rounded-2xl overflow-hidden shadow-2xl mb-5">
        <!-- Strip image (si présente) -->
        <div id="preview-strip-wrap" class="hidden w-full h-28 relative">
          <img id="preview-strip-img" src="" alt="" class="w-full h-full object-cover" />
          <div class="absolute inset-0" style="background:linear-gradient(to bottom,transparent 50%,rgba(0,0,0,0.4))"></div>
        </div>
        <!-- Contenu carte -->
        <div class="p-5">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-2.5">
              <div id="preview-logo-wrap" class="w-10 h-10 rounded-lg overflow-hidden shrink-0 flex items-center justify-center" style="background:rgba(255,255,255,0.15)">
                <img id="preview-logo-img" class="hidden w-full h-full object-cover" src="" alt="" />
                <span id="preview-logo-ph" class="text-base">🏪</span>
              </div>
              <div>
                <p id="commerce-nom" class="font-bold text-sm leading-tight"></p>
                <p id="carte-nom" class="text-xs opacity-60 mt-0.5"></p>
              </div>
            </div>
            <div class="text-right">
              <p id="preview-type-lbl" class="text-xs uppercase tracking-wide opacity-50">Tampons</p>
              <p id="preview-solde" class="font-mono font-bold text-base">0/10</p>
            </div>
          </div>
          <!-- Tampons -->
          <div id="preview-stamps-wrap" class="mb-4">
            <div id="preview-stamps" class="flex flex-wrap gap-1.5"></div>
          </div>
          <!-- Points -->
          <div id="preview-points-wrap" class="hidden mb-4">
            <div class="h-1.5 rounded-full" style="background:rgba(255,255,255,0.15)">
              <div id="preview-bar" class="h-full rounded-full w-0" style="background:#6366f1"></div>
            </div>
            <p id="preview-pts-txt" class="text-xs opacity-50 mt-1">0 pts</p>
          </div>
          <div>
            <p class="text-xs opacity-60 mb-0.5">Récompense</p>
            <p id="recompense-desc" class="text-sm font-medium"></p>
          </div>
        </div>
      </div>

      <!-- Formulaire -->
      <div class="card p-5 mb-4">
        <p class="text-white font-semibold mb-1">Créer votre carte de fidélité</p>
        <p id="client-welcome-message" class="text-slate-400 text-xs mb-4">Bienvenue, créez votre carte fidélité en 10 secondes.</p>

        <div class="flex flex-col gap-3">
          <div>
            <label class="label" for="client-nom">Prénom</label>
            <input id="client-nom" type="text" class="input" placeholder="Votre prénom" autocomplete="given-name" />
          </div>
          <div>
            <label class="label" for="client-tel">Téléphone</label>
            <input id="client-tel" type="tel" class="input" placeholder="06 12 34 56 78" autocomplete="tel" />
          </div>

          <!-- Consentement notifications -->
          <div
            id="consent-box"
            class="flex items-start gap-3 cursor-pointer rounded-xl border-2 p-3 transition-all mt-1"
            style="border-color:#334155;background:transparent"
          >
            <div class="shrink-0 mt-0.5">
              <div
                id="consent-check"
                class="w-5 h-5 rounded border-2 flex items-center justify-center transition-all"
                style="border-color:#475569;background:transparent"
              >
                <svg id="consent-check-icon" class="hidden w-3 h-3" viewBox="0 0 12 12" fill="none">
                  <path d="M2 6l3 3 5-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
            <div>
              <p class="text-white text-xs font-medium">Recevoir des notifications push</p>
              <p class="text-slate-400 text-xs mt-0.5 leading-relaxed">
                Activé par défaut pour recevoir vos offres, promotions et rappels de fidélité. Désactivable à tout moment.
              </p>
            </div>
          </div>
          <input type="hidden" id="consent-value" value="true" />
          <div id="push-helper" class="hidden rounded-xl border border-indigo-400/20 bg-indigo-500/10 px-4 py-3">
            <p id="push-helper-title" class="text-white text-sm font-medium"></p>
            <p id="push-helper-text" class="text-slate-300 text-xs mt-1 leading-relaxed"></p>
            <button
              id="push-helper-action"
              type="button"
              class="hidden mt-3 inline-flex items-center justify-center rounded-lg border border-indigo-300/30 bg-white/5 px-4 py-2 text-xs font-medium text-white transition hover:bg-white/10"
            >
              Activer maintenant
            </button>
          </div>
        </div>
      </div>

      <div id="success-msg" class="hidden mb-3 text-emerald-300 text-sm bg-emerald-500/10 border border-emerald-400/20 rounded-xl px-4 py-3 text-center"></div>
      <div id="error-msg" class="hidden mb-3 text-red-400 text-sm bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3 text-center"></div>

      <!-- Boutons Wallet -->
      <div class="flex flex-col gap-3">
        <button id="btn-apple" class="w-full py-4 px-6 rounded-xl font-semibold text-sm bg-black text-white hover:bg-gray-900 flex items-center justify-center gap-3 transition-all">
          <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          Ajouter à Apple Wallet
        </button>
        <button id="btn-google" class="w-full py-4 px-6 rounded-xl font-semibold text-sm bg-white text-gray-900 hover:bg-gray-100 flex items-center justify-center gap-3 border border-gray-200 transition-all">
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none">
            <path d="M21.56 10.74a9.55 9.55 0 0 0-.15-1.69H12v3.2h5.37a4.6 4.6 0 0 1-2 3.02v2.51h3.23c1.89-1.74 2.96-4.3 2.96-7.04z" fill="#4285F4"/>
            <path d="M12 22c2.7 0 4.96-.9 6.61-2.43l-3.23-2.51c-.9.6-2.04.96-3.38.96-2.6 0-4.8-1.76-5.59-4.12H3.08v2.6A10 10 0 0 0 12 22z" fill="#34A853"/>
            <path d="M6.41 13.9A6 6 0 0 1 6.09 12c0-.66.11-1.3.32-1.9V7.5H3.08A10 10 0 0 0 2 12c0 1.61.38 3.13 1.08 4.5l3.33-2.6z" fill="#FBBC05"/>
            <path d="M12 5.88c1.47 0 2.79.5 3.82 1.5l2.86-2.86A9.96 9.96 0 0 0 12 2 10 10 0 0 0 3.08 7.5l3.33 2.6C7.2 7.64 9.4 5.88 12 5.88z" fill="#EA4335"/>
          </svg>
          Ajouter à Google Wallet
        </button>
      </div>
    </div>

    <div id="error-content" class="hidden text-center">
      <p class="text-red-400">Carte introuvable ou expirée.</p>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ carteId: id, apiBase, firebasePushConfig }}>
  const API = apiBase;
  const apiUrl = (path) => `${API}${path}`;
  const pushConfig = Object.fromEntries(
    Object.entries(firebasePushConfig ?? {}).map(([key, value]) => [key, String(value ?? '').trim()])
  );
  const isPushConfigured = Boolean(
    pushConfig?.apiKey
    && pushConfig?.projectId
    && pushConfig?.messagingSenderId
    && pushConfig?.appId
    && pushConfig?.vapidKey
  );

  // ── Checkbox consentement ────────────────────────────────────────
  const isIos = /iphone|ipad|ipod/i.test(navigator.userAgent)
    || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
  const isStandalone = () => window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true;
  const supportsPushBrowser = 'Notification' in window && 'serviceWorker' in navigator;

  let pushConsent = isPushConfigured;
  let latestPushStatus = isPushConfigured ? 'pending-auto' : 'disabled';
  const consentBox = document.getElementById('consent-box');
  const consentCheck = document.getElementById('consent-check');
  const consentIcon = document.getElementById('consent-check-icon');
  const consentText = consentBox.querySelector('p.text-slate-400');
  const pushHelper = document.getElementById('push-helper');
  const pushHelperTitle = document.getElementById('push-helper-title');
  const pushHelperText = document.getElementById('push-helper-text');
  const pushHelperAction = document.getElementById('push-helper-action');

  function renderConsentState() {
    document.getElementById('consent-value').value = String(pushConsent);
    if (pushConsent) {
      consentBox.style.cssText = 'border-color:#6366f1;background:rgb(99 102 241/0.1)';
      consentCheck.style.cssText = 'border-color:#6366f1;background:#6366f1;width:20px;height:20px;border-radius:4px;border-width:2px;display:flex;align-items:center;justify-content:center;transition:all 0.15s';
      consentIcon.classList.remove('hidden');
      return;
    }

    consentBox.style.cssText = 'border-color:#334155;background:transparent';
    consentCheck.style.cssText = 'border-color:#475569;background:transparent;width:20px;height:20px;border-radius:4px;border-width:2px;display:flex;align-items:center;justify-content:center;transition:all 0.15s';
    consentIcon.classList.add('hidden');
  }

  function setPushHelper({ title, text, actionLabel = '', actionHidden = true, actionDisabled = false } = {}) {
    if (!title && !text) {
      pushHelper.classList.add('hidden');
      pushHelperAction.classList.add('hidden');
      pushHelperAction.textContent = 'Activer maintenant';
      pushHelperTitle.textContent = '';
      pushHelperText.textContent = '';
      return;
    }

    pushHelper.classList.remove('hidden');
    pushHelperTitle.textContent = title ?? '';
    pushHelperText.textContent = text ?? '';
    pushHelperAction.textContent = actionLabel || 'Activer maintenant';
    pushHelperAction.disabled = actionDisabled;
    pushHelperAction.classList.toggle('hidden', actionHidden);
  }

  function refreshPushUi() {
    renderConsentState();

    if (!isPushConfigured) {
      consentText.textContent = 'Les notifications sont en cours de configuration. Vous pourrez les activer prochainement.';
      consentBox.style.opacity = '0.6';
      consentBox.style.cursor = 'not-allowed';
      setPushHelper({
        title: 'Notifications bientôt disponibles',
        text: 'Ce commerce finalise encore la configuration technique des notifications.',
      });
      return;
    }

    consentBox.style.opacity = '1';
    consentBox.style.cursor = 'pointer';
    consentText.textContent = pushConsent
      ? 'Activé par défaut pour recevoir vos offres, promotions et rappels de fidélité. Désactivable à tout moment.'
      : 'Désactivé pour cette carte. Vous pourrez les réactiver plus tard.';

    if (!pushConsent) {
      latestPushStatus = 'disabled';
      setPushHelper({
        title: 'Notifications désactivées',
        text: 'Vous pourrez les réactiver plus tard depuis cette page si vous changez d’avis.',
      });
      return;
    }

    if (!supportsPushBrowser) {
      latestPushStatus = 'unsupported';
      setPushHelper({
        title: 'Navigateur limité',
        text: 'Votre navigateur ne permet pas encore d’activer les notifications web pour cette carte.',
      });
      return;
    }

    if (isIos && !isStandalone()) {
      latestPushStatus = 'requires-install';
      setPushHelper({
        title: 'Activation en 1 étape sur iPhone',
        text: 'Ajoutez cette page à l’écran d’accueil, rouvrez-la depuis l’icône, puis continuez : la demande de notification apparaîtra automatiquement.',
      });
      return;
    }

    if (Notification.permission === 'denied') {
      latestPushStatus = 'denied';
      setPushHelper({
        title: 'Autorisation bloquée',
        text: 'Les notifications sont refusées dans votre navigateur. Autorisez-les dans les réglages du site, puis revenez ici.',
      });
      return;
    }

    if (Notification.permission === 'granted') {
      if (latestPushStatus === 'success') {
        setPushHelper({
          title: 'Notifications activées',
          text: 'Tout est prêt. Vous recevrez les offres et rappels de fidélité de ce commerce.',
        });
        return;
      }

      setPushHelper({
        title: 'Notifications en préparation',
        text: 'Votre appareil autorise déjà les notifications. Elles seront liées à votre carte automatiquement.',
      });
      return;
    }

    const clientId = walletClient?.id ?? readRememberedClient()?.id ?? '';
    setPushHelper({
      title: clientId ? 'Dernière étape très rapide' : 'Notifications prêtes',
      text: clientId
        ? 'Touchez simplement pour autoriser les notifications et finaliser l’activation pour cette carte.'
        : 'Nous vous proposerons automatiquement les notifications dès que votre carte sera créée.',
      actionLabel: 'Activer maintenant',
      actionHidden: !clientId,
    });
  }

  if (!isPushConfigured) {
    pushConsent = false;
  }

  consentBox.addEventListener('click', () => {
    if (!isPushConfigured) {
      showError('Les notifications push ne sont pas encore configurées pour ce site.');
      return;
    }

    pushConsent = !pushConsent;
    refreshPushUi();
  });

  pushHelperAction.addEventListener('click', async () => {
    const clientId = walletClient?.id ?? readRememberedClient()?.id;
    if (!clientId) return;
    await maybeActivatePush(clientId, { showFeedback: true, source: 'helper' });
  });
  refreshPushUi();

  // ── Validation ───────────────────────────────────────────────────
  function showError(msg) {
    const el = document.getElementById('error-msg');
    document.getElementById('success-msg').classList.add('hidden');
    el.textContent = msg;
    el.classList.remove('hidden');
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function showSuccess(msg) {
    const el = document.getElementById('success-msg');
    document.getElementById('error-msg').classList.add('hidden');
    el.textContent = msg;
    el.classList.remove('hidden');
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function rememberWalletRedirect(provider) {
    try {
      localStorage.setItem('fidelopass_wallet_redirect', JSON.stringify({
        provider,
        startedAt: Date.now(),
      }));
    } catch {
      // Le message de retour est un bonus, l'ajout Wallet ne doit pas en dépendre.
    }
  }

  function showWalletReturnMessage() {
    try {
      const raw = localStorage.getItem('fidelopass_wallet_redirect');
      if (!raw) return;
      const state = JSON.parse(raw);
      const isFresh = Date.now() - Number(state.startedAt) < 10 * 60 * 1000;
      if (!isFresh) {
        localStorage.removeItem('fidelopass_wallet_redirect');
        return;
      }
      localStorage.removeItem('fidelopass_wallet_redirect');
      showSuccess(carteData?.carte?.success_message || 'Votre carte est prête, montrez-la à chaque passage.');
    } catch {
      localStorage.removeItem('fidelopass_wallet_redirect');
    }
  }

  window.addEventListener('pageshow', showWalletReturnMessage);

  function hideError() {
    document.getElementById('error-msg').classList.add('hidden');
  }

  ['client-nom', 'client-tel'].forEach(id => {
    document.getElementById(id).addEventListener('input', hideError);
  });

  function validateForm() {
    const nom = document.getElementById('client-nom').value.trim();
    const tel = document.getElementById('client-tel').value.trim().replace(/[\s\-\.]/g, '');
    if (!nom) { showError('Veuillez entrer votre prénom.'); document.getElementById('client-nom').focus(); return false; }
    if (!tel || tel.length < 8) { showError('Veuillez entrer un numéro de téléphone valide.'); document.getElementById('client-tel').focus(); return false; }
    hideError();
    return true;
  }

  const clientStorageKey = `fidelopass_client_${carteId}`;

  function rememberClient(client) {
    try {
      localStorage.setItem(clientStorageKey, JSON.stringify({
        id: client.id,
        nom: client.nom ?? '',
        telephone: client.telephone ?? '',
      }));
    } catch {
      // Le suivi local améliore seulement l'UX.
    }
  }

  function readRememberedClient() {
    try {
      const raw = localStorage.getItem(clientStorageKey);
      return raw ? JSON.parse(raw) : null;
    } catch {
      return null;
    }
  }

  function rewardSeenKey(clientId) {
    return `fidelopass_reward_seen_${carteId}_${clientId}`;
  }

  // ── Chargement carte ─────────────────────────────────────────────
  let carteData = null;

  async function loadCarte() {
    try {
      const res = await fetch(apiUrl(`/api/cartes/${carteId}/public`));
      if (!res.ok) throw new Error();
      const { data } = await res.json();
      carteData = data;

      // Couleurs
      const card = document.getElementById('wallet-card');
      card.style.background = data.carte.couleur_fond;
      card.style.color = data.carte.couleur_texte;

      // Textes
      document.getElementById('commerce-nom').textContent = data.commerce.nom;
      document.getElementById('carte-nom').textContent = data.carte.nom;
      const rewards = Array.isArray(data.carte.rewards_config) ? data.carte.rewards_config : [];
      document.getElementById('recompense-desc').textContent = rewards.length
        ? rewards.map((item) => `${item.seuil} ${data.carte.type === 'points' ? 'pts' : 'tampon(s)'} : ${item.recompense}`).join(' • ')
        : data.carte.recompense_description ?? '—';
      document.getElementById('client-welcome-message').textContent =
        data.carte.welcome_message || `Bienvenue chez ${data.commerce.nom}, créez votre carte fidélité en 10 secondes.`;

      // Logo
      if (data.commerce.logo_url || data.carte.logo_url) {
        const url = data.carte.logo_url ?? data.commerce.logo_url;
        const img = document.getElementById('preview-logo-img');
        img.src = url;
        img.classList.remove('hidden');
        document.getElementById('preview-logo-ph').classList.add('hidden');
      }

      // Strip image
      if (data.carte.strip_url) {
        const stripWrap = document.getElementById('preview-strip-wrap');
        const stripImg = document.getElementById('preview-strip-img');
        stripImg.src = data.carte.strip_url;
        stripImg.style.objectPosition = data.carte.strip_position ?? 'center';
        stripWrap.classList.remove('hidden');
      }

      // Type + solde
      const type = data.carte.type ?? 'tampons';
      const accent = data.carte.couleur_accent ?? '#6366f1';
      const texte = data.carte.couleur_texte ?? '#ffffff';

      if (type === 'tampons') {
        const total = data.carte.tampons_total ?? 10;
        document.getElementById('preview-type-lbl').textContent = 'Tampons';
        document.getElementById('preview-solde').textContent = `0/${total}`;
        renderStamps(0, total, accent, texte, data.carte.tampon_icon_url, data.carte.tampon_emoji);
      } else {
        const pts = data.carte.points_recompense ?? 100;
        document.getElementById('preview-type-lbl').textContent = 'Points';
        document.getElementById('preview-solde').textContent = '0';
        document.getElementById('preview-stamps-wrap').classList.add('hidden');
        document.getElementById('preview-points-wrap').classList.remove('hidden');
        document.getElementById('preview-bar').style.background = accent;
        document.getElementById('preview-pts-txt').textContent = `0 / ${pts} pts`;
      }

      document.getElementById('loading').classList.add('hidden');
      document.getElementById('carte-content').classList.remove('hidden');
      await hydrateRememberedClientState();
    } catch {
      document.getElementById('loading').classList.add('hidden');
      document.getElementById('error-content').classList.remove('hidden');
    }
  }

  function renderClientProgress(client) {
    if (!carteData?.carte) return;

    const type = carteData.carte.type ?? 'tampons';
    const accent = carteData.carte.couleur_accent ?? '#6366f1';
    const texte = carteData.carte.couleur_texte ?? '#ffffff';

    if (type === 'tampons') {
      const total = carteData.carte.tampons_total ?? 10;
      document.getElementById('preview-type-lbl').textContent = 'Tampons';
      document.getElementById('preview-solde').textContent = `${client.tampons_actuels ?? 0}/${total}`;
      document.getElementById('preview-stamps-wrap').classList.remove('hidden');
      document.getElementById('preview-points-wrap').classList.add('hidden');
      renderStamps(client.tampons_actuels ?? 0, total, accent, texte, carteData.carte.tampon_icon_url, carteData.carte.tampon_emoji);
      return;
    }

    const target = carteData.carte.points_recompense ?? 100;
    const current = client.points_actuels ?? 0;
    const ratio = Math.max(0, Math.min(100, Math.round((current / target) * 100)));
    document.getElementById('preview-type-lbl').textContent = 'Points';
    document.getElementById('preview-solde').textContent = String(current);
    document.getElementById('preview-stamps-wrap').classList.add('hidden');
    document.getElementById('preview-points-wrap').classList.remove('hidden');
    document.getElementById('preview-bar').style.background = accent;
    document.getElementById('preview-bar').style.width = `${ratio}%`;
    document.getElementById('preview-pts-txt').textContent = `${current} / ${target} pts`;
  }

  async function hydrateRememberedClientState() {
    const remembered = readRememberedClient();
    refreshPushUi();
    if (!remembered?.id) return;

    const inputNom = document.getElementById('client-nom');
    const inputTel = document.getElementById('client-tel');
    if (!inputNom.value) inputNom.value = remembered.nom ?? '';
    if (!inputTel.value) inputTel.value = remembered.telephone ?? '';

    try {
      const res = await fetch(apiUrl(`/api/clients/public/${remembered.id}?carte_id=${encodeURIComponent(carteId)}`));
      if (!res.ok) return;
      const { data } = await res.json();
      walletClient = {
        id: data.id,
        nom: data.nom,
        telephone: data.telephone,
      };
      refreshPushUi();
      renderClientProgress(data);

      const seenKey = rewardSeenKey(data.id);
      const previousRewards = Number(localStorage.getItem(seenKey) ?? '0');
      const currentRewards = Number(data.recompenses_obtenues ?? 0);
      localStorage.setItem(seenKey, String(currentRewards));

      if (currentRewards > previousRewards) {
        await fireWelcomeConfetti();
        showSuccess(`Bravo ! Vous avez débloqué ${currentRewards > 1 ? 'une nouvelle récompense' : 'votre récompense'}. Montrez votre carte à chaque passage.`);
      }

      if (
        pushConsent
        && isPushConfigured
        && supportsPushBrowser
        && Notification.permission === 'granted'
      ) {
        await maybeActivatePush(data.id, { showFeedback: false, source: 'restore' });
      }
    } catch {
      // L'état public du client n'est qu'un confort.
    }
  }

  function renderStamps(current, total, accent, texte, iconUrl, emoji) {
    const container = document.getElementById('preview-stamps');
    container.innerHTML = '';
    const display = Math.min(total, 12);
    for (let i = 0; i < display; i++) {
      const dot = document.createElement('div');
      dot.style.cssText = `width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;`;
      if (i < current) {
        dot.style.background = accent;
        if (emoji) {
          dot.style.fontSize = '16px';
          dot.textContent = emoji;
        } else if (iconUrl) {
          dot.innerHTML = `<img src="${iconUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />`;
        } else {
          dot.innerHTML = `<svg viewBox="0 0 12 12" style="width:14px;height:14px"><path d="M2 6l3 3 5-5" stroke="${texte}" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
        }
      } else {
        dot.style.border = `2px solid rgba(255,255,255,0.25)`;
        if (emoji) {
          dot.style.fontSize = '15px';
          dot.style.opacity = '0.35';
          dot.textContent = emoji;
        } else if (iconUrl) {
          dot.innerHTML = `<img src="${iconUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;opacity:0.3;" />`;
        }
      }
      container.appendChild(dot);
    }
  }

  // ── Créer le client ──────────────────────────────────────────────
  let walletClient = null;
  let walletClientPromise = null;

  async function ensureClient() {
    if (walletClient) return walletClient;
    if (walletClientPromise) return walletClientPromise;

    const nom = document.getElementById('client-nom').value.trim();
    const telephone = document.getElementById('client-tel').value.trim();

    walletClientPromise = (async () => {
      const res = await fetch(apiUrl('/api/clients'), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ carte_id: carteId, nom, telephone, push_consent: pushConsent && isPushConfigured }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error ?? 'Erreur lors de la création');

      walletClient = data.data;
      rememberClient(walletClient);
      refreshPushUi();
      if (pushConsent && isPushConfigured) {
        await maybeActivatePush(walletClient.id, { showFeedback: true, source: 'create' });
      }
      return walletClient;
    })();

    try {
      return await walletClientPromise;
    } finally {
      walletClientPromise = null;
    }
  }

  async function registerPushToken(clientId) {
    const required = ['apiKey', 'projectId', 'messagingSenderId', 'appId', 'vapidKey'];
    const missing = required.some((key) => !pushConfig?.[key]);
    if (missing) {
      console.warn('[push] Firebase public config missing');
      return { status: 'unavailable' };
    }

    if (!supportsPushBrowser) {
      console.warn('[push] notifications unavailable in this browser');
      return { status: 'unsupported' };
    }

    if (isIos && !isStandalone()) {
      return { status: 'requires-install' };
    }

    if (Notification.permission === 'denied') {
      return { status: 'denied' };
    }

    const permission = Notification.permission === 'granted'
      ? 'granted'
      : await Notification.requestPermission();
    if (permission !== 'granted') {
      return { status: permission === 'denied' ? 'denied' : 'dismissed' };
    }

    const [{ initializeApp, getApps }, { getMessaging, getToken }] = await Promise.all([
      import('firebase/app'),
      import('firebase/messaging'),
    ]);

    const app = getApps().find((existing) => existing.name === 'fidelopass-client')
      ?? initializeApp({
        apiKey: pushConfig.apiKey,
        authDomain: pushConfig.authDomain,
        projectId: pushConfig.projectId,
        messagingSenderId: pushConfig.messagingSenderId,
        appId: pushConfig.appId,
      }, 'fidelopass-client');

    const registration = await navigator.serviceWorker.register('/sw.js');
    const token = await getToken(getMessaging(app), {
      vapidKey: pushConfig.vapidKey,
      serviceWorkerRegistration: registration,
    });

    if (!token) return { status: 'dismissed' };

    await fetch(apiUrl(`/api/clients/${clientId}/fcm`), {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ fcm_token: token }),
    });

    return { status: 'success', token };
  }

  async function primePushPermission() {
    if (!pushConsent || !isPushConfigured) return { status: 'disabled' };
    if (!supportsPushBrowser) return { status: 'unsupported' };
    if (isIos && !isStandalone()) return { status: 'requires-install' };
    if (Notification.permission === 'granted') return { status: 'granted' };
    if (Notification.permission === 'denied') return { status: 'denied' };

    const permission = await Notification.requestPermission();
    if (permission === 'granted') return { status: 'granted' };
    return { status: permission === 'denied' ? 'denied' : 'dismissed' };
  }

  async function maybeActivatePush(clientId, { showFeedback = false, source = 'manual' } = {}) {
    if (!clientId || !pushConsent || !isPushConfigured) {
      refreshPushUi();
      return { status: 'disabled' };
    }

    latestPushStatus = source === 'helper' ? 'pending-manual' : 'pending-auto';
    refreshPushUi();

    try {
      const result = await registerPushToken(clientId);
      latestPushStatus = result.status;
      refreshPushUi();

      if (showFeedback && result.status === 'success') {
        showSuccess('Notifications activées pour cette carte. Vous recevrez maintenant les offres et rappels de fidélité.');
      } else if (showFeedback && result.status === 'requires-install') {
        showSuccess('Votre carte est prête. Sur iPhone, ajoutez maintenant cette page à l’écran d’accueil pour activer les notifications.');
      }

      return result;
    } catch (error) {
      latestPushStatus = 'error';
      refreshPushUi();
      console.warn('[push registration]', error);
      return { status: 'error', error };
    }
  }

  // ── Confetti récompense ──────────────────────────────────────────
  async function fireWelcomeConfetti() {
    const { default: confetti } = await import('canvas-confetti');
    const accent = carteData?.carte?.couleur_accent ?? '#6366f1';

    confetti({
      particleCount: 120,
      spread: 90,
      origin: { y: 0.5 },
      colors: [accent, '#ffffff', '#f59e0b', '#10b981'],
      zIndex: 9999,
    });
    setTimeout(() => {
      confetti({
        particleCount: 60,
        angle: 60,
        spread: 55,
        origin: { x: 0, y: 0.6 },
        colors: [accent, '#ffffff', '#a78bfa'],
        zIndex: 9999,
      });
      confetti({
        particleCount: 60,
        angle: 120,
        spread: 55,
        origin: { x: 1, y: 0.6 },
        colors: [accent, '#ffffff', '#a78bfa'],
        zIndex: 9999,
      });
    }, 300);
  }

  // ── Apple Wallet ─────────────────────────────────────────────────
  document.getElementById('btn-apple').addEventListener('click', async () => {
    if (!validateForm()) return;
    const btn = document.getElementById('btn-apple');
    btn.disabled = true; btn.textContent = 'Génération en cours...';
    let redirecting = false;

    try {
      if (pushConsent && isPushConfigured) {
        const primed = await primePushPermission();
        latestPushStatus = primed.status === 'granted' ? 'pending-auto' : primed.status;
        refreshPushUi();
      }

      const client = await ensureClient();
      showSuccess('Carte prête. Apple Wallet va s’ouvrir pour finaliser l’ajout.');
      rememberWalletRedirect('apple');
      redirecting = true;
      window.location.assign(apiUrl(`/api/wallet/apple/${carteId}?client_id=${encodeURIComponent(client.id)}`));
    } catch (err) {
      showError(err.message ?? 'Erreur. Réessayez.');
    } finally {
      if (!redirecting) {
        btn.disabled = false;
        btn.innerHTML = `<svg viewBox="0 0 24 24" class="w-5 h-5 fill-current"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg> Ajouter à Apple Wallet`;
      }
    }
  });

  // ── Google Wallet ────────────────────────────────────────────────
  document.getElementById('btn-google').addEventListener('click', async () => {
    if (!validateForm()) return;
    const btn = document.getElementById('btn-google');
    btn.disabled = true; btn.textContent = 'Génération en cours...';
    let redirecting = false;

    try {
      if (pushConsent && isPushConfigured) {
        const primed = await primePushPermission();
        latestPushStatus = primed.status === 'granted' ? 'pending-auto' : primed.status;
        refreshPushUi();
      }

      const client = await ensureClient();

      const res = await fetch(apiUrl(`/api/wallet/google/${carteId}`), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ client_id: client.id }),
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error ?? 'Erreur lors de la génération.');
      }

      const { saveUrl } = await res.json();
      showSuccess('Carte prête. Google Wallet va s’ouvrir pour finaliser l’ajout.');
      rememberWalletRedirect('google');
      redirecting = true;
      window.location.assign(saveUrl);
    } catch (err) {
      showError(err.message ?? 'Erreur. Réessayez.');
    } finally {
      if (!redirecting) {
        btn.disabled = false;
        btn.innerHTML = `<svg viewBox="0 0 24 24" class="w-5 h-5" fill="none"><path d="M21.56 10.74a9.55 9.55 0 0 0-.15-1.69H12v3.2h5.37a4.6 4.6 0 0 1-2 3.02v2.51h3.23c1.89-1.74 2.96-4.3 2.96-7.04z" fill="#4285F4"/><path d="M12 22c2.7 0 4.96-.9 6.61-2.43l-3.23-2.51c-.9.6-2.04.96-3.38.96-2.6 0-4.8-1.76-5.59-4.12H3.08v2.6A10 10 0 0 0 12 22z" fill="#34A853"/><path d="M6.41 13.9A6 6 0 0 1 6.09 12c0-.66.11-1.3.32-1.9V7.5H3.08A10 10 0 0 0 2 12c0 1.61.38 3.13 1.08 4.5l3.33-2.6z" fill="#FBBC05"/><path d="M12 5.88c1.47 0 2.79.5 3.82 1.5l2.86-2.86A9.96 9.96 0 0 0 12 2 10 10 0 0 0 3.08 7.5l3.33 2.6C7.2 7.64 9.4 5.88 12 5.88z" fill="#EA4335"/></svg> Ajouter à Google Wallet`;
      }
    }
  });

  loadCarte();
</script>
