---
import BaseLayout from '../../layouts/BaseLayout.astro';

const { id } = Astro.params;
const apiBase = (
  import.meta.env.PUBLIC_API_URL
  ?? (import.meta.env.PROD ? 'https://api.fidelopass.com' : 'http://localhost:3001')
).replace(/\/$/, '');
---

<BaseLayout title="Affiche A4 — Fidelopass" description="Téléchargez une affiche A4 Fidelopass prête à imprimer avec le QR code de votre carte.">
  <div class="relative min-h-screen overflow-hidden bg-[linear-gradient(180deg,#ffffff_0%,#f5f9ff_62%,#ffffff_100%)] px-4 py-8">
    <div class="pointer-events-none absolute -top-24 right-[-7rem] h-[22rem] w-[22rem] rounded-full bg-cyan-200/35 blur-3xl"></div>
    <div class="pointer-events-none absolute bottom-[-8rem] left-[-6rem] h-[20rem] w-[20rem] rounded-full bg-blue-100/80 blur-3xl"></div>
    <div class="max-w-6xl mx-auto">
      <div class="poster-ui flex flex-col lg:flex-row gap-6 items-start justify-between mb-6">
        <div>
          <p class="text-slate-500 text-sm uppercase tracking-[0.28em]">Affiches Fidelopass</p>
          <h1 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 mt-3">Préparez une affiche A4 prête à imprimer</h1>
          <p class="text-slate-600 text-sm sm:text-base mt-3 max-w-2xl">
            Choisissez un modèle, imprimez-le en A4 ou téléchargez uniquement le QR code pour vos supports en boutique.
          </p>
        </div>
        <div class="flex flex-wrap gap-3">
          <button id="download-qr" type="button" class="btn-secondary px-5 py-3 text-sm">Télécharger le QR</button>
          <button id="print-poster" type="button" class="btn-primary px-5 py-3 text-sm">Imprimer l’affiche</button>
        </div>
      </div>

      <div class="poster-ui flex flex-wrap gap-3 mb-6">
        <button type="button" class="poster-template-btn btn-secondary text-sm px-4 py-2.5" data-template="essential">Premium clair</button>
        <button type="button" class="poster-template-btn btn-secondary text-sm px-4 py-2.5" data-template="signature">Premium sombre</button>
      </div>

      <div class="poster-ui card mb-6 border border-slate-200/80 bg-white/95 p-5 shadow-[0_24px_56px_-34px_rgba(37,99,235,0.24)]">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <p class="text-[0.66rem] font-semibold uppercase tracking-[0.24em] text-sky-700/80">Personnalisation complète</p>
            <p class="mt-1 text-sm leading-6 text-slate-500">Réglez uniquement ce qui compte pour une affiche claire, imprimable et prête pour la caisse.</p>
          </div>
          <div class="grid gap-2 text-xs text-slate-600 sm:min-w-[18rem]">
            <p id="poster-safe-check" class="rounded-2xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-emerald-700">Marges sécurisées A4 vérifiées</p>
            <p id="poster-contrast-check" class="rounded-2xl border border-slate-200 bg-slate-50 px-3 py-2">Contraste en cours de vérification...</p>
          </div>
        </div>

        <details class="mt-4 rounded-2xl border border-slate-200 bg-slate-50/80 p-4" open>
          <summary class="cursor-pointer text-sm font-bold text-slate-900">Contenu principal</summary>
          <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
          <div class="xl:col-span-2">
            <label for="poster-custom-title" class="text-xs font-medium text-slate-600">Titre principal</label>
            <input id="poster-custom-title" type="text" class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-sky-400 focus:outline-none" />
          </div>
          <div class="xl:col-span-2">
            <label for="poster-custom-subtitle" class="text-xs font-medium text-slate-600">Sous-titre</label>
            <input id="poster-custom-subtitle" type="text" class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-sky-400 focus:outline-none" />
          </div>
          <div class="xl:col-span-2">
            <label for="poster-custom-reward" class="text-xs font-medium text-slate-600">Texte récompense</label>
            <input id="poster-custom-reward" type="text" class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-sky-400 focus:outline-none" />
          </div>
          <div class="xl:col-span-2">
            <label for="poster-custom-footer" class="text-xs font-medium text-slate-600">Footer</label>
            <input id="poster-custom-footer" type="text" class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-sky-400 focus:outline-none" />
          </div>
          <label class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-medium text-slate-700">
            <input id="poster-show-logo" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-sky-600" checked />
            Afficher le logo
          </label>
          <div>
            <label for="poster-banner-file" class="text-xs font-medium text-slate-600">Bannière locale</label>
            <input id="poster-banner-file" type="file" accept="image/*" class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-xs text-slate-600 file:mr-3 file:rounded-lg file:border-0 file:bg-sky-50 file:px-3 file:py-1.5 file:text-xs file:font-semibold file:text-sky-700" />
          </div>
          </div>
        </details>

        <details class="mt-3 rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
          <summary class="cursor-pointer text-sm font-bold text-slate-900">Couleurs, fond et icônes</summary>
          <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
          <div>
            <label for="poster-custom-accent" class="text-xs font-medium text-slate-600">Couleur accent</label>
            <input id="poster-custom-accent" type="color" value="#6366f1" class="mt-1 h-11 w-full cursor-pointer rounded-xl border border-slate-200 bg-white p-1" />
          </div>
          <div>
            <label for="poster-custom-bg" class="text-xs font-medium text-slate-600">Couleur fond</label>
            <input id="poster-custom-bg" type="color" value="#0f172a" class="mt-1 h-11 w-full cursor-pointer rounded-xl border border-slate-200 bg-white p-1" />
          </div>
          <div>
            <label for="poster-custom-text" class="text-xs font-medium text-slate-600">Couleur texte</label>
            <input id="poster-custom-text" type="color" value="#0f172a" class="mt-1 h-11 w-full cursor-pointer rounded-xl border border-slate-200 bg-white p-1" />
          </div>
          <div>
            <label for="poster-icon-style" class="text-xs font-medium text-slate-600">Icônes étapes</label>
            <select id="poster-icon-style" class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 focus:border-sky-400 focus:outline-none">
              <option value="numbers">Numéros</option>
              <option value="icons">Pictos simples</option>
            </select>
          </div>
          </div>
        </details>

        <details class="mt-3 rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
          <summary class="cursor-pointer text-sm font-bold text-slate-900">Étapes et informations commerce</summary>
          <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
            <input id="poster-step-1-title" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" placeholder="Étape 1" />
            <input id="poster-step-2-title" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" placeholder="Étape 2" />
            <input id="poster-step-3-title" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" placeholder="Étape 3" />
            <input id="poster-step-1-desc" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" placeholder="Détail étape 1" />
            <input id="poster-step-2-desc" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" placeholder="Détail étape 2" />
            <input id="poster-step-3-desc" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" placeholder="Détail étape 3" />
            <input id="poster-commerce-address" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" placeholder="Adresse" />
            <input id="poster-commerce-phone" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" placeholder="Téléphone" />
            <input id="poster-commerce-site" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" placeholder="Site web" />
            <input id="poster-commerce-socials" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" placeholder="Réseaux sociaux" />
            <input id="poster-commerce-hours" type="text" class="rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900 md:col-span-2" placeholder="Horaires" />
          </div>
        </details>

        <details class="mt-3 rounded-2xl border border-slate-200 bg-slate-50/80 p-4">
          <summary class="cursor-pointer text-sm font-bold text-slate-900">QR code et impression</summary>
          <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
            <div>
              <label for="poster-qr-label" class="text-xs font-medium text-slate-600">Label QR</label>
              <input id="poster-qr-label" type="text" value="Scannez-moi" class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900" />
            </div>
            <div>
              <label for="poster-qr-size" class="text-xs font-medium text-slate-600">Taille QR</label>
              <input id="poster-qr-size" type="range" min="58" max="84" value="72" class="mt-3 w-full accent-sky-600" />
            </div>
            <div>
              <label for="poster-qr-position" class="text-xs font-medium text-slate-600">Position QR</label>
              <select id="poster-qr-position" class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900">
                <option value="center">Centre</option>
                <option value="left">Gauche</option>
                <option value="right">Droite</option>
              </select>
            </div>
            <div>
              <label for="poster-qr-frame" class="text-xs font-medium text-slate-600">Cadre QR</label>
              <select id="poster-qr-frame" class="mt-1 w-full rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm text-slate-900">
                <option value="rounded">Arrondi</option>
                <option value="square">Carré</option>
                <option value="premium">Premium</option>
              </select>
            </div>
            <label class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2.5 text-sm font-medium text-slate-700">
              <input id="poster-show-safe-zone" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-sky-600" />
              Afficher la zone sûre
            </label>
          </div>
        </details>
      </div>

      <div id="poster-loading" class="text-center py-16">
        <div class="w-8 h-8 border-2 border-indigo-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-slate-500 text-sm">Préparation de l’affiche...</p>
      </div>

      <div id="poster-error" class="hidden text-center py-12">
        <div class="card p-8 max-w-xl mx-auto">
          <p class="text-red-400 font-semibold">Impossible de charger cette affiche.</p>
          <p class="text-slate-400 text-sm mt-2">Vérifiez que votre carte est bien publiée puis réessayez.</p>
        </div>
      </div>

      <div id="poster-stage" class="hidden">
        <div id="poster-sheet" class="poster-sheet mx-auto bg-white text-slate-900 overflow-hidden shadow-2xl border border-white/10">
          <div id="poster-essential" class="poster-variant hidden h-full">
            <div class="poster-safe-zone h-full flex flex-col">
              <div id="poster-essential-hero" class="rounded-[1.2rem] border border-slate-200 bg-gradient-to-br from-slate-900 to-slate-700 text-white p-6">
                <div class="flex items-center justify-between gap-6">
                  <div class="flex items-center gap-4">
                    <img id="poster-essential-logo" src="" alt="" class="hidden w-16 h-16 rounded-2xl object-cover border border-white/30" />
                    <div>
                      <p class="text-[10px] uppercase tracking-[0.34em] text-white/70">Programme fidélité</p>
                      <h2 id="poster-essential-commerce" class="font-display text-[2rem] leading-tight font-bold mt-2">Votre commerce</h2>
                    </div>
                  </div>
                  <div id="poster-essential-badge" class="px-4 py-2 rounded-full text-sm font-semibold border border-white/25 bg-white/10">Wallet instantané</div>
                </div>

                <div class="mt-5">
                  <h3 id="poster-essential-title" class="font-display text-[2.3rem] leading-[1.03] font-bold max-w-[13cm]">
                    VOS ACHATS D’ICI RÉCOMPENSÉS !
                  </h3>
                  <p id="poster-essential-subtitle" class="text-[1rem] text-white/90 mt-3.5 max-w-[13.2cm]">
                    Installez votre carte de fidélité dans le wallet en 10 secondes, puis cumulez vos avantages à chaque passage.
                  </p>
                </div>
              </div>

              <div id="poster-essential-banner-wrap" class="mt-4 hidden h-[55mm] overflow-hidden rounded-[1rem] border border-white/40 bg-white/10">
                <img id="poster-essential-banner" src="" alt="" class="h-full w-full object-cover" />
              </div>

              <div id="poster-essential-qr-grid" class="mt-5 grid grid-cols-[1fr_86mm_1fr] gap-4 items-center">
                <div id="poster-essential-side-left" class="poster-side-card rounded-[1rem] border border-slate-200 bg-slate-50 p-4 h-[112px] flex flex-col justify-center">
                  <p class="poster-step-title text-[11px] uppercase tracking-[0.24em] text-slate-500" data-step-title="1">1. Installez</p>
                  <p class="poster-step-desc text-sm font-semibold mt-2 leading-snug" data-step-desc="1">Ajoutez votre carte en un scan, sans application.</p>
                </div>

                <div id="poster-essential-qr-card" class="poster-qr-card rounded-[1.1rem] border border-slate-300 bg-white p-4 text-center shadow-sm">
                  <p class="inline-flex rounded-full px-3 py-1 text-xs font-semibold text-white mb-2" id="poster-essential-scan-pill" style="background:#0f172a">Scannez-moi</p>
                  <img id="poster-essential-qr" src="" alt="QR code Fidelopass" class="w-[72mm] h-[72mm] mx-auto rounded-xl border border-slate-200" />
                </div>

                <div id="poster-essential-side-right" class="poster-side-card rounded-[1rem] border border-slate-200 bg-slate-50 p-4 h-[112px] flex flex-col justify-center">
                  <p class="poster-step-title text-[11px] uppercase tracking-[0.24em] text-slate-500" data-step-title="2">2. Présentez</p>
                  <p class="poster-step-desc text-sm font-semibold mt-2 leading-snug" data-step-desc="2">Montrez la carte en caisse pour valider points/tampons.</p>
                </div>
              </div>

              <div class="mt-4 rounded-[1rem] border border-slate-200 bg-white p-4">
                <p class="text-center text-sm font-semibold tracking-[0.16em] text-slate-700 uppercase">C’est simple</p>
                <div class="mt-3 grid grid-cols-3 gap-3 text-center">
                  <div class="rounded-xl border border-slate-200 p-3">
                    <p class="mx-auto mb-2 w-6 h-6 rounded-full text-xs font-bold text-white leading-6" id="poster-essential-step-dot-1" style="background:#0f172a">1</p>
                    <p class="poster-step-title text-[11px] uppercase tracking-[0.14em] text-slate-500" data-step-title="1">Téléchargez</p>
                    <p class="poster-step-desc text-xs text-slate-700 mt-1" data-step-desc="1">Votre carte wallet en 10 sec</p>
                  </div>
                  <div class="rounded-xl border border-slate-200 p-3">
                    <p class="mx-auto mb-2 w-6 h-6 rounded-full text-xs font-bold text-white leading-6" id="poster-essential-step-dot-2" style="background:#0f172a">2</p>
                    <p class="poster-step-title text-[11px] uppercase tracking-[0.14em] text-slate-500" data-step-title="2">Scannez</p>
                    <p class="poster-step-desc text-xs text-slate-700 mt-1" data-step-desc="2">En caisse à chaque achat</p>
                  </div>
                  <div class="rounded-xl border border-slate-200 p-3">
                    <p class="mx-auto mb-2 w-6 h-6 rounded-full text-xs font-bold text-white leading-6" id="poster-essential-step-dot-3" style="background:#0f172a">3</p>
                    <p class="poster-step-title text-[11px] uppercase tracking-[0.14em] text-slate-500" data-step-title="3">Cumulez</p>
                    <p id="poster-essential-reward" class="text-xs text-slate-700 mt-1 font-semibold">Vos récompenses fidélité</p>
                  </div>
                </div>
              </div>

              <div class="mt-auto rounded-[1rem] border border-dashed border-slate-300 bg-slate-50 p-4 flex items-center justify-between gap-4">
                <div>
                  <p class="text-[10px] uppercase tracking-[0.28em] text-slate-500">Votre commerce personnalisable</p>
                  <p class="text-sm font-semibold text-slate-900 mt-1">Ajoutez logo, message et récompense</p>
                  <p id="poster-essential-subtitle-mini" class="text-xs text-slate-600 mt-1">Le client scanne et rejoint votre programme en quelques secondes.</p>
                  <p id="poster-essential-contact" class="mt-2 text-[11px] font-semibold text-slate-500"></p>
                </div>
                <div class="rounded-xl border border-slate-300 bg-white px-5 py-3 text-xs font-semibold text-slate-500 text-center min-w-[145px]">
                  VOTRE LOGO ICI
                </div>
              </div>

              <p id="poster-essential-footer" class="mt-3 text-center text-sm text-slate-600 font-medium">
                Merci de soutenir le commerce local
              </p>
            </div>
          </div>

          <div id="poster-signature" class="poster-variant hidden h-full">
            <div class="h-full relative overflow-hidden bg-[#f3efe7]">
              <div id="poster-signature-banner" class="absolute inset-x-0 top-0 h-[34%] bg-slate-900"></div>
              <div class="absolute inset-x-0 top-0 h-[34%] bg-gradient-to-br from-black/45 via-black/20 to-black/40"></div>

              <div class="poster-safe-zone relative z-10 h-full flex flex-col">
                <div class="flex items-start justify-between gap-5">
                  <div class="max-w-[12.8cm] text-white">
                    <p class="text-[10px] uppercase tracking-[0.34em] text-white/70">Programme fidélité Wallet</p>
                    <h2 id="poster-signature-commerce" class="font-display text-[2.2rem] leading-tight font-bold mt-2.5">Votre commerce</h2>
                    <h3 id="poster-signature-title" class="font-display text-[1.9rem] leading-tight font-bold mt-3">
                      VOS ACHATS D’ICI RÉCOMPENSÉS !
                    </h3>
                    <p id="poster-signature-copy" class="text-[1rem] text-white/90 mt-3.5 leading-relaxed">
                      Cumulez vos avantages à chaque passage. Ajout en 10 secondes dans Apple Wallet ou Google Wallet.
                    </p>
                  </div>
                  <img id="poster-signature-logo" src="" alt="" class="hidden w-16 h-16 rounded-2xl object-cover border border-white/25" />
                </div>

                <div id="poster-signature-qr-grid" class="mt-5 grid grid-cols-[1fr_90mm_1fr] gap-4 items-center">
                  <div id="poster-signature-side-left" class="poster-side-card rounded-[1rem] bg-white/90 border border-slate-300 p-4 text-slate-900 h-[112px] flex flex-col justify-center">
                    <p class="poster-step-title text-[11px] uppercase tracking-[0.24em] text-slate-500" data-step-title="1">Plus vous venez</p>
                    <p class="poster-step-desc text-sm font-semibold mt-2" data-step-desc="1">Plus vous gagnez d’avantages et de récompenses.</p>
                  </div>

                  <div id="poster-signature-qr-card" class="poster-qr-card rounded-[1.1rem] bg-white p-4 text-center border border-slate-300 shadow-xl">
                    <p id="poster-signature-scan-pill" class="inline-flex rounded-full px-3 py-1 text-xs font-semibold text-white mb-2" style="background:#0f172a">Scannez-moi</p>
                    <img id="poster-signature-qr" src="" alt="QR code Fidelopass" class="w-[74mm] h-[74mm] mx-auto rounded-xl border border-slate-200" />
                  </div>

                  <div id="poster-signature-side-right" class="poster-side-card rounded-[1rem] bg-white/90 border border-slate-300 p-4 text-slate-900 h-[112px] flex flex-col justify-center">
                    <p class="poster-step-title text-[11px] uppercase tracking-[0.24em] text-slate-500" data-step-title="3">Récompense</p>
                    <p id="poster-signature-reward" class="text-sm font-semibold mt-2">Votre récompense fidélité</p>
                  </div>
                </div>

                <div class="mt-4 rounded-[1rem] border border-slate-300 bg-white p-4">
                  <p class="text-center text-sm font-semibold tracking-[0.16em] text-slate-700 uppercase">C’est simple</p>
                  <div class="mt-3 grid grid-cols-3 gap-3 text-center">
                    <div class="rounded-xl border border-slate-200 p-3">
                      <p class="mx-auto mb-2 w-6 h-6 rounded-full text-xs font-bold text-white leading-6" id="poster-signature-step-dot-1" style="background:#0f172a">1</p>
                      <p class="poster-step-title text-[11px] uppercase tracking-[0.14em] text-slate-500" data-step-title="1">Téléchargez</p>
                      <p class="poster-step-desc text-xs text-slate-700 mt-1" data-step-desc="1">La carte sur votre téléphone</p>
                    </div>
                    <div class="rounded-xl border border-slate-200 p-3">
                      <p class="mx-auto mb-2 w-6 h-6 rounded-full text-xs font-bold text-white leading-6" id="poster-signature-step-dot-2" style="background:#0f172a">2</p>
                      <p class="poster-step-title text-[11px] uppercase tracking-[0.14em] text-slate-500" data-step-title="2">Scannez</p>
                      <p class="poster-step-desc text-xs text-slate-700 mt-1" data-step-desc="2">En caisse à chaque achat</p>
                    </div>
                    <div class="rounded-xl border border-slate-200 p-3">
                      <p class="mx-auto mb-2 w-6 h-6 rounded-full text-xs font-bold text-white leading-6" id="poster-signature-step-dot-3" style="background:#0f172a">3</p>
                      <p class="poster-step-title text-[11px] uppercase tracking-[0.14em] text-slate-500" data-step-title="3">Cumulez</p>
                      <p class="text-xs text-slate-700 mt-1">Des avantages fidélité</p>
                    </div>
                  </div>
                </div>

                <div class="mt-auto rounded-[1rem] border border-dashed border-slate-400 bg-white/95 p-4">
                  <p class="text-[10px] uppercase tracking-[0.28em] text-slate-500">Votre commerce personnalisable</p>
                  <p class="text-sm font-semibold text-slate-900 mt-1">Adresse · Téléphone · Réseaux sociaux</p>
                  <p id="poster-signature-contact" class="text-xs text-slate-600 mt-1">Personnalisez cette affiche pour votre point de vente.</p>
                </div>
                <p id="poster-signature-footer" class="mt-3 text-center text-sm font-medium text-slate-700">Merci de soutenir le commerce local</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .poster-sheet {
    width: min(100%, 860px);
    aspect-ratio: 210 / 297;
    border-radius: 1.5rem;
  }

  .poster-safe-zone {
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    padding: 1.2cm;
  }

  .poster-safe-zone.safe-preview {
    outline: 2px dashed rgba(14, 165, 233, 0.55);
    outline-offset: -8mm;
  }

  @page {
    size: A4 portrait;
    margin: 0;
  }

  @media print {
    html, body {
      width: 210mm;
      height: 297mm;
      margin: 0 !important;
      padding: 0 !important;
      background: #fff !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    nav,
    header,
    footer,
    .poster-ui,
    #poster-loading,
    #poster-error {
      display: none !important;
    }

    main,
    .min-h-screen,
    #poster-stage {
      margin: 0 !important;
      padding: 0 !important;
      min-height: auto !important;
      width: 210mm !important;
      height: 297mm !important;
      background: #fff !important;
    }

    #poster-sheet {
      width: 210mm !important;
      height: 297mm !important;
      aspect-ratio: auto !important;
      border: none !important;
      border-radius: 0 !important;
      box-shadow: none !important;
      margin: 0 !important;
      overflow: hidden !important;
      page-break-inside: avoid;
    }

    .poster-safe-zone {
      padding: 12mm !important;
      outline: none !important;
    }
  }
</style>

<script is:inline define:vars={{ apiBase, carteId: id }}>
  const API = apiBase;
  const qrBase = 'https://api.qrserver.com/v1/create-qr-code/';
  const params = new URLSearchParams(window.location.search);
  const TEMPLATE_ALIASES = {
    minimal: 'essential',
    premium: 'signature',
    promo: 'signature',
    essential: 'essential',
    signature: 'signature',
  };
  let currentTemplate = normalizeTemplate(params.get('template'));
  const customTitleInput = document.getElementById('poster-custom-title');
  const customSubtitleInput = document.getElementById('poster-custom-subtitle');
  const customRewardInput = document.getElementById('poster-custom-reward');
  const customFooterInput = document.getElementById('poster-custom-footer');
  const customAccentInput = document.getElementById('poster-custom-accent');
  const customBgInput = document.getElementById('poster-custom-bg');
  const customTextInput = document.getElementById('poster-custom-text');
  const showLogoInput = document.getElementById('poster-show-logo');
  const bannerFileInput = document.getElementById('poster-banner-file');
  const iconStyleInput = document.getElementById('poster-icon-style');
  const step1TitleInput = document.getElementById('poster-step-1-title');
  const step2TitleInput = document.getElementById('poster-step-2-title');
  const step3TitleInput = document.getElementById('poster-step-3-title');
  const step1DescInput = document.getElementById('poster-step-1-desc');
  const step2DescInput = document.getElementById('poster-step-2-desc');
  const step3DescInput = document.getElementById('poster-step-3-desc');
  const addressInput = document.getElementById('poster-commerce-address');
  const phoneInput = document.getElementById('poster-commerce-phone');
  const siteInput = document.getElementById('poster-commerce-site');
  const socialsInput = document.getElementById('poster-commerce-socials');
  const hoursInput = document.getElementById('poster-commerce-hours');
  const qrLabelInput = document.getElementById('poster-qr-label');
  const qrSizeInput = document.getElementById('poster-qr-size');
  const qrPositionInput = document.getElementById('poster-qr-position');
  const qrFrameInput = document.getElementById('poster-qr-frame');
  const showSafeZoneInput = document.getElementById('poster-show-safe-zone');
  const contrastCheck = document.getElementById('poster-contrast-check');
  let posterBase = null;
  let localBannerUrl = null;

  function normalizeTemplate(value) {
    const key = String(value || '').trim().toLowerCase();
    return TEMPLATE_ALIASES[key] || 'essential';
  }

  function apiUrl(path) {
    return `${API}${path}`;
  }

  function qrUrl(cardId, size = 720) {
    return `${qrBase}?size=${size}x${size}&data=${encodeURIComponent(`${window.location.origin}/carte/${cardId}`)}&bgcolor=ffffff&color=111827&qzone=1`;
  }

  function rewardSummary(data) {
    const tiers = Array.isArray(data.carte.rewards_config) ? data.carte.rewards_config : [];
    if (tiers.length) {
      return tiers.map((item) => `${item.seuil} ${data.carte.type === 'points' ? 'pts' : 'tampons'} = ${item.recompense}`).join(' • ');
    }
    return data.carte.recompense_description || 'Récompense fidélité';
  }

  function setImage(id, src) {
    const img = document.getElementById(id);
    if (!img || !src) return;
    img.src = src;
    img.classList.remove('hidden');
  }

  function setImageVisibility(id, visible) {
    const img = document.getElementById(id);
    if (!img) return;
    img.classList.toggle('hidden', !visible || !img.getAttribute('src'));
  }

  function setText(id, value) {
    const node = document.getElementById(id);
    if (node) node.textContent = value;
  }

  function hexToRgb(hex) {
    const normalized = String(hex || '').replace('#', '').trim();
    if (!/^[0-9a-fA-F]{6}$/.test(normalized)) return null;
    return {
      r: parseInt(normalized.slice(0, 2), 16),
      g: parseInt(normalized.slice(2, 4), 16),
      b: parseInt(normalized.slice(4, 6), 16),
    };
  }

  function luminance(hex) {
    const rgb = hexToRgb(hex);
    if (!rgb) return 0;
    const transform = (value) => {
      const channel = value / 255;
      return channel <= 0.03928 ? channel / 12.92 : Math.pow((channel + 0.055) / 1.055, 2.4);
    };
    return 0.2126 * transform(rgb.r) + 0.7152 * transform(rgb.g) + 0.0722 * transform(rgb.b);
  }

  function contrastRatio(a, b) {
    const lighter = Math.max(luminance(a), luminance(b));
    const darker = Math.min(luminance(a), luminance(b));
    return (lighter + 0.05) / (darker + 0.05);
  }

  function setStepText(step, title, desc) {
    document.querySelectorAll(`[data-step-title="${step}"]`).forEach((node) => {
      node.textContent = node.textContent?.includes('.') ? `${step}. ${title}` : title;
    });
    document.querySelectorAll(`[data-step-desc="${step}"]`).forEach((node) => {
      node.textContent = desc;
    });
  }

  function setQrPosition(position) {
    [
      ['poster-essential-qr-grid', 'poster-essential-qr-card', 'poster-essential-side-left', 'poster-essential-side-right'],
      ['poster-signature-qr-grid', 'poster-signature-qr-card', 'poster-signature-side-left', 'poster-signature-side-right'],
    ].forEach(([gridId, qrId, leftId, rightId]) => {
      const grid = document.getElementById(gridId);
      const qr = document.getElementById(qrId);
      const left = document.getElementById(leftId);
      const right = document.getElementById(rightId);
      if (!grid || !qr || !left || !right) return;
      grid.style.gridTemplateColumns = position === 'center' ? '1fr 86mm 1fr' : '86mm 1fr 1fr';
      qr.style.order = position === 'right' ? '3' : '1';
      left.style.order = position === 'left' ? '2' : '1';
      right.style.order = position === 'left' ? '3' : '2';
      if (position === 'center') {
        left.style.order = '1';
        qr.style.order = '2';
        right.style.order = '3';
      }
    });
  }

  function setQrFrame(frame, accent) {
    document.querySelectorAll('.poster-qr-card').forEach((card) => {
      card.style.borderRadius = frame === 'square' ? '0.35rem' : '1.1rem';
      card.style.borderColor = frame === 'premium' ? accent : '#cbd5e1';
      card.style.boxShadow = frame === 'premium' ? `0 18px 45px ${accent}33` : '';
    });
    ['poster-essential-qr', 'poster-signature-qr'].forEach((id) => {
      const img = document.getElementById(id);
      if (!img) return;
      img.style.borderRadius = frame === 'square' ? '0.15rem' : '0.75rem';
      img.style.borderColor = frame === 'premium' ? accent : '#e2e8f0';
    });
  }

  function contactLine() {
    return [addressInput?.value, phoneInput?.value, siteInput?.value, socialsInput?.value, hoursInput?.value]
      .map((value) => String(value || '').trim())
      .filter(Boolean)
      .join(' · ');
  }

  function applyCustomizations() {
    if (!posterBase) return;

    const title = (customTitleInput?.value || '').trim() || posterBase.defaultTitle;
    const subtitle = (customSubtitleInput?.value || '').trim() || posterBase.defaultSubtitle;
    const reward = (customRewardInput?.value || '').trim() || posterBase.defaultReward;
    const footer = (customFooterInput?.value || '').trim() || posterBase.defaultFooter;
    const accent = (customAccentInput?.value || posterBase.defaultAccent || '#6366f1').trim();
    const background = (customBgInput?.value || posterBase.defaultBackground || '#0f172a').trim();
    const textColor = (customTextInput?.value || posterBase.defaultText || '#0f172a').trim();
    const qrSize = Number(qrSizeInput?.value || 72);
    const qrLabel = (qrLabelInput?.value || 'Scannez-moi').trim();
    const qrPosition = (qrPositionInput?.value || 'center').trim();
    const qrFrame = (qrFrameInput?.value || 'rounded').trim();
    const showLogo = Boolean(showLogoInput?.checked);
    const bannerUrl = localBannerUrl || posterBase.stripUrl;
    const iconStyle = (iconStyleInput?.value || 'numbers').trim();

    setText('poster-essential-title', title);
    setText('poster-essential-subtitle', subtitle);
    setText('poster-essential-subtitle-mini', subtitle);
    setText('poster-essential-reward', reward);
    setText('poster-essential-footer', footer);
    setText('poster-signature-title', title);
    setText('poster-signature-copy', subtitle);
    setText('poster-signature-reward', reward);
    setText('poster-signature-footer', footer);
    setText('poster-essential-scan-pill', qrLabel);
    setText('poster-signature-scan-pill', qrLabel);
    setText('poster-essential-contact', contactLine());
    setText('poster-signature-contact', contactLine() || 'Adresse · Téléphone · Réseaux sociaux');

    setStepText(1, (step1TitleInput?.value || 'Téléchargez').trim(), (step1DescInput?.value || 'Votre carte wallet en 10 sec').trim());
    setStepText(2, (step2TitleInput?.value || 'Scannez').trim(), (step2DescInput?.value || 'En caisse à chaque achat').trim());
    setStepText(3, (step3TitleInput?.value || 'Cumulez').trim(), (step3DescInput?.value || reward).trim());

    const essentialHero = document.getElementById('poster-essential-hero');
    if (essentialHero) essentialHero.style.background = `linear-gradient(135deg, ${background}, ${accent})`;
    if (essentialHero) essentialHero.style.color = '#ffffff';

    const essentialBadge = document.getElementById('poster-essential-badge');
    if (essentialBadge) {
      essentialBadge.style.background = `${accent}26`;
      essentialBadge.style.borderColor = `${accent}55`;
      essentialBadge.style.color = '#ffffff';
    }

    const essentialScanPill = document.getElementById('poster-essential-scan-pill');
    if (essentialScanPill) essentialScanPill.style.background = accent;
    const signatureScanPill = document.getElementById('poster-signature-scan-pill');
    if (signatureScanPill) signatureScanPill.style.background = accent;

    ['poster-essential-step-dot-1', 'poster-essential-step-dot-2', 'poster-essential-step-dot-3',
      'poster-signature-step-dot-1', 'poster-signature-step-dot-2', 'poster-signature-step-dot-3'].forEach((id) => {
      const dot = document.getElementById(id);
      if (dot) dot.style.background = accent;
    });
    const iconValues = iconStyle === 'icons' ? ['▣', '⌁', '★'] : ['1', '2', '3'];
    ['poster-essential-step-dot-', 'poster-signature-step-dot-'].forEach((prefix) => {
      iconValues.forEach((value, index) => setText(`${prefix}${index + 1}`, value));
    });

    const signatureBanner = document.getElementById('poster-signature-banner');
    if (signatureBanner) signatureBanner.style.background = bannerUrl
      ? `linear-gradient(rgba(15,23,42,0.34), rgba(15,23,42,0.55)), url("${bannerUrl}") center/cover`
      : `linear-gradient(135deg, ${background}, ${accent})`;

    const essentialBannerWrap = document.getElementById('poster-essential-banner-wrap');
    const essentialBanner = document.getElementById('poster-essential-banner');
    if (essentialBannerWrap && essentialBanner) {
      essentialBannerWrap.classList.toggle('hidden', !bannerUrl);
      if (bannerUrl) essentialBanner.src = bannerUrl;
    }

    ['poster-essential-qr', 'poster-signature-qr'].forEach((id) => {
      const img = document.getElementById(id);
      if (!img) return;
      img.style.width = `${qrSize}mm`;
      img.style.height = `${qrSize}mm`;
    });

    setImageVisibility('poster-essential-logo', showLogo);
    setImageVisibility('poster-signature-logo', showLogo);
    setQrPosition(qrPosition);
    setQrFrame(qrFrame, accent);

    document.querySelectorAll('.poster-safe-zone').forEach((node) => {
      node.classList.toggle('safe-preview', Boolean(showSafeZoneInput?.checked));
    });

    document.querySelectorAll('.poster-side-card').forEach((node) => {
      node.style.color = textColor;
    });

    const ratio = contrastRatio(background, textColor);
    if (contrastCheck) {
      const ok = ratio >= 4.5;
      contrastCheck.textContent = ok ? 'Contraste vérifié pour impression' : 'Contraste faible: augmentez l’écart fond / texte';
      contrastCheck.className = ok
        ? 'rounded-2xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-emerald-700'
        : 'rounded-2xl border border-amber-200 bg-amber-50 px-3 py-2 text-amber-800';
    }
  }

  function renderTemplate(name) {
    currentTemplate = normalizeTemplate(name);
    document.querySelectorAll('.poster-variant').forEach((node) => node.classList.add('hidden'));
    document.getElementById(`poster-${currentTemplate}`)?.classList.remove('hidden');
    document.querySelectorAll('.poster-template-btn').forEach((button) => {
      const active = button.dataset.template === currentTemplate;
      button.className = active
        ? 'poster-template-btn btn-primary text-sm px-4 py-2.5'
        : 'poster-template-btn btn-secondary text-sm px-4 py-2.5';
    });
    const nextUrl = new URL(window.location.href);
    nextUrl.searchParams.set('template', currentTemplate);
    window.history.replaceState({}, '', nextUrl);
  }

  async function downloadQr() {
    const response = await fetch(qrUrl(carteId, 1200));
    const blob = await response.blob();
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `fidelopass-qr-${carteId}.png`;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(url);
  }

  async function loadPoster() {
    try {
      const response = await fetch(apiUrl(`/api/cartes/${carteId}/public`));
      if (!response.ok) throw new Error();
      const { data } = await response.json();

      const commerceName = data.commerce.nom;
      const message = data.carte.welcome_message || `Bienvenue chez ${commerceName}, créez votre carte fidélité en 10 secondes.`;
      const reward = rewardSummary(data);
      const qr = qrUrl(carteId);
      const logo = data.carte.logo_url ?? data.commerce.logo_url ?? '';
      const typeLabel = data.carte.type === 'points' ? 'Carte à points' : 'Carte à tampons';
      const accent = data.carte.couleur_accent ?? '#6366f1';
      const fond = data.carte.couleur_fond ?? '#0f172a';
      const fond2 = data.carte.couleur_fond_2 ?? accent;
      const textColor = data.carte.couleur_texte ?? '#0f172a';
      const defaultTitle = 'VOS ACHATS D’ICI RÉCOMPENSÉS !';
      const defaultFooter = 'Merci de soutenir le commerce local';

      setText('poster-essential-commerce', commerceName);
      setText('poster-essential-title', defaultTitle);
      setText('poster-essential-subtitle', message);
      setText('poster-essential-subtitle-mini', message);
      setText('poster-essential-reward', reward);
      setText('poster-signature-commerce', commerceName);
      setText('poster-signature-title', defaultTitle);
      setText('poster-signature-copy', message);
      setText('poster-signature-reward', reward);

      const essentialBadge = document.getElementById('poster-essential-badge');
      if (essentialBadge) {
        essentialBadge.textContent = typeLabel;
        essentialBadge.style.background = `${accent}26`;
        essentialBadge.style.borderColor = `${accent}55`;
        essentialBadge.style.color = '#ffffff';
      }

      const essentialHero = document.getElementById('poster-essential-hero');
      if (essentialHero) essentialHero.style.background = `linear-gradient(135deg, ${fond}, ${fond2})`;

      const signatureBanner = document.getElementById('poster-signature-banner');
      if (signatureBanner) signatureBanner.style.background = data.carte.strip_url
        ? `linear-gradient(rgba(15,23,42,0.3), rgba(15,23,42,0.45)), url("${data.carte.strip_url}") center/cover`
        : `linear-gradient(135deg, ${fond}, ${fond2})`;

      const essentialScanPill = document.getElementById('poster-essential-scan-pill');
      if (essentialScanPill) essentialScanPill.style.background = accent;
      const signatureScanPill = document.getElementById('poster-signature-scan-pill');
      if (signatureScanPill) signatureScanPill.style.background = accent;
      ['poster-essential-step-dot-1', 'poster-essential-step-dot-2', 'poster-essential-step-dot-3',
        'poster-signature-step-dot-1', 'poster-signature-step-dot-2', 'poster-signature-step-dot-3'].forEach((id) => {
        const dot = document.getElementById(id);
        if (dot) dot.style.background = accent;
      });

      ['poster-essential-qr', 'poster-signature-qr'].forEach((elementId) => {
        document.getElementById(elementId).src = qr;
      });

      setImage('poster-essential-logo', logo);
      setImage('poster-signature-logo', logo);

      posterBase = {
        defaultTitle,
        defaultSubtitle: message,
        defaultReward: reward,
        defaultFooter,
        defaultAccent: accent,
        defaultBackground: fond,
        defaultText: textColor,
        stripUrl: data.carte.strip_url ?? null,
      };

      if (customTitleInput) customTitleInput.value = defaultTitle;
      if (customSubtitleInput) customSubtitleInput.value = message;
      if (customRewardInput) customRewardInput.value = reward;
      if (customFooterInput) customFooterInput.value = defaultFooter;
      if (customAccentInput) customAccentInput.value = accent;
      if (customBgInput) customBgInput.value = fond;
      if (customTextInput) customTextInput.value = textColor;
      if (step1TitleInput) step1TitleInput.value = 'Téléchargez';
      if (step2TitleInput) step2TitleInput.value = 'Scannez';
      if (step3TitleInput) step3TitleInput.value = 'Cumulez';
      if (step1DescInput) step1DescInput.value = 'Votre carte wallet en 10 sec';
      if (step2DescInput) step2DescInput.value = 'En caisse à chaque achat';
      if (step3DescInput) step3DescInput.value = reward;
      if (addressInput) addressInput.value = data.point_vente?.adresse || data.commerce?.adresse || '';
      if (phoneInput) phoneInput.value = data.commerce?.telephone || '';
      if (siteInput) siteInput.value = data.commerce?.site_web || '';

      document.getElementById('poster-loading').classList.add('hidden');
      document.getElementById('poster-stage').classList.remove('hidden');
      renderTemplate(currentTemplate);
      applyCustomizations();
    } catch {
      document.getElementById('poster-loading').classList.add('hidden');
      document.getElementById('poster-error').classList.remove('hidden');
    }
  }

  document.getElementById('print-poster').addEventListener('click', () => window.print());
  document.getElementById('download-qr').addEventListener('click', downloadQr);
  bannerFileInput?.addEventListener('change', () => {
    const file = bannerFileInput.files?.[0];
    if (!file) return;
    if (localBannerUrl) URL.revokeObjectURL(localBannerUrl);
    localBannerUrl = URL.createObjectURL(file);
    applyCustomizations();
  });
  document.querySelectorAll('.poster-template-btn').forEach((button) => {
    button.addEventListener('click', () => renderTemplate(button.dataset.template || 'essential'));
  });
  [
    customTitleInput, customSubtitleInput, customRewardInput, customFooterInput,
    customAccentInput, customBgInput, customTextInput, showLogoInput,
    iconStyleInput, step1TitleInput, step2TitleInput, step3TitleInput,
    step1DescInput, step2DescInput, step3DescInput, addressInput,
    phoneInput, siteInput, socialsInput, hoursInput, qrLabelInput,
    qrSizeInput, qrPositionInput, qrFrameInput, showSafeZoneInput,
  ]
    .filter(Boolean)
    .forEach((field) => field.addEventListener('input', applyCustomizations));

  loadPoster();
</script>
