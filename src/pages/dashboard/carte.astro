  function renderStamps(container:HTMLElement, current:number, display:number, accent:string, texte:string){
    container.innerHTML='';
    const cols=stampCols(display);
    const containerW=(container.closest('#apple-preview,#google-preview') as HTMLElement)?.offsetWidth??340;
    const avail=containerW-48;
    const gap=6;
    const dotSize=Math.max(28,Math.min(52,Math.floor((avail-gap*(cols-1))/cols)));
    const rows:number[][]=[];
    for(let i=0;i<display;i++){const ri=Math.floor(i/cols);if(!rows[ri])rows[ri]=[];rows[ri].push(i);}
    container.style.cssText='display:flex;flex-direction:column;align-items:center;gap:6px;width:100%;';
    rows.forEach(row=>{
      const rowEl=document.createElement('div');
      rowEl.style.cssText='display:flex;justify-content:center;gap:6px;';
      row.forEach(i=>{
        const dot=document.createElement('div');
        const filled=i<current;
        dot.style.cssText=`width:${dotSize}px;height:${dotSize}px;border-radius:50%;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0;`;
        if(filled){
          dot.style.background=accent;
          if(tamponEmoji){dot.style.fontSize=`${Math.round(dotSize*0.55)}px`;dot.style.lineHeight='1';dot.textContent=tamponEmoji;}
          else if(tamponIconUrl){dot.innerHTML=`<img src="${tamponIconUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;"/>`;}
          else{const sw=Math.max(1.5,dotSize*0.07);dot.innerHTML=`<svg viewBox="0 0 12 12" style="width:${Math.round(dotSize*0.55)}px;height:${Math.round(dotSize*0.55)}px"><path d="M2 6l3 3 5-5" stroke="${texte}" stroke-width="${sw}" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`;}
        }else{
          dot.style.border='2px solid rgba(255,255,255,0.25)';dot.style.background='rgba(255,255,255,0.05)';
          if(tamponEmoji){dot.style.fontSize=`${Math.round(dotSize*0.5)}px`;dot.style.opacity='0.3';dot.textContent=tamponEmoji;}
          else if(tamponIconUrl){dot.innerHTML=`<img src="${tamponIconUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;opacity:0.3;"/>`;}
        }
        rowEl.appendChild(dot);
      });
      container.appendChild(rowEl);
    });
  }

  function updatePreview(){
    const fond=(document.getElementById('couleur-fond') as HTMLInputElement).value;
    const texte=(document.getElementById('couleur-texte') as HTMLInputElement).value;
    const accent=(document.getElementById('couleur-accent') as HTMLInputElement).value;
    const nom=(document.getElementById('nom-carte') as HTMLInputElement).value||'Ma carte';
    const recompense=(document.getElementById('recompense') as HTMLInputElement).value||'—';
    const labelClient=(document.getElementById('label-client') as HTMLInputElement).value||'Client';
    const type=(document.querySelector('input[name="type"]:checked') as HTMLInputElement)?.value??'tampons';
    const total=parseInt((document.getElementById('tampons-total') as HTMLInputElement).value)||10;
    const ptsCible=parseInt((document.getElementById('points-recompense') as HTMLInputElement).value)||100;
    const pt=(document.querySelector('input[name="pattern_type"]:checked') as HTMLInputElement)?.value??'none';
    const rewardTiers=collectRewardTiers();
    const rewardSummary=rewardTiers.length?rewardTiers.map(t=>`${t.seuil} ${getProgramUnit()} : ${t.recompense}`).join(' • '):recompense;

    const bg=getBgStyle();
    const pat=getPatBg(pt,accent);
    const display=Math.min(total,12);

    // Apple
    const apple=document.getElementById('apple-preview')!;
    apple.style.background=bg; apple.style.color=texte;
    const ag=document.getElementById('a-pattern-global')!;
    ag.style.backgroundImage=pat.image; ag.style.backgroundSize=pat.size;
    const sc=document.getElementById('preview-strip-color')!; sc.style.background=bg;
    const so=document.getElementById('preview-pattern-overlay')!; so.style.backgroundImage=pat.image; so.style.backgroundSize=pat.size;

    document.getElementById('preview-card-name')!.textContent=nom;
    document.getElementById('preview-recompense')!.textContent=rewardSummary;
    document.getElementById('preview-label-client')!.textContent=labelClient.toUpperCase();
    document.getElementById('preview-type-label')!.textContent=type==='tampons'?'Tampons':'Points';

    if(type==='tampons'){
      document.getElementById('preview-solde')!.textContent=`1/${total}`;
      document.getElementById('preview-stamps-wrap')!.classList.remove('hidden');
      document.getElementById('preview-points-wrap')!.classList.add('hidden');
      renderStamps(document.getElementById('preview-stamps')!,1,display,accent,texte);
    }else{
      document.getElementById('preview-solde')!.textContent='0';
      document.getElementById('preview-stamps-wrap')!.classList.add('hidden');
      document.getElementById('preview-points-wrap')!.classList.remove('hidden');
      (document.getElementById('preview-points-bar') as HTMLElement).style.background=accent;
      (document.getElementById('preview-points-bar') as HTMLElement).style.width='0%';
      document.getElementById('preview-points-text')!.textContent=`0 / ${ptsCible} pts`;
    }

    // Google
    const gb=document.getElementById('g-strip-bg')!; gb.style.background=bg;
    const gp=document.getElementById('g-pattern-overlay')!; gp.style.backgroundImage=pat.image; gp.style.backgroundSize=pat.size;

    document.getElementById('g-card-name')!.textContent=nom;
    document.getElementById('g-recompense')!.textContent=rewardSummary;
    document.getElementById('g-label-client')!.textContent=labelClient.toUpperCase();
    document.getElementById('g-type-lbl')!.textContent=type==='tampons'?'Tampons':'Points';

    if(type==='tampons'){
      document.getElementById('g-solde')!.textContent=`1/${total}`;
      document.getElementById('g-stamps-wrap')!.classList.remove('hidden');
      document.getElementById('g-points-wrap')!.classList.add('hidden');
      renderStamps(document.getElementById('g-stamps')!,1,display,accent,'#111');
    }else{
      document.getElementById('g-solde')!.textContent='0';
      document.getElementById('g-stamps-wrap')!.classList.add('hidden');
      document.getElementById('g-points-wrap')!.classList.remove('hidden');
      (document.getElementById('g-points-bar') as HTMLElement).style.background=accent;
      document.getElementById('g-points-text')!.textContent=`0/${ptsCible} pts`;
    }
  }

  document.querySelectorAll('#nom-carte,#recompense,#label-client,#tampons-total,#points-recompense,#couleur-fond,#couleur-texte,#couleur-accent,#couleur-fond-2').forEach(el=>el.addEventListener('input',updatePreview));
  window.addEventListener('resize',()=>requestAnimationFrame(updatePreview));

  async function loadExistingCarte(){
    try{
      const res=await authFetch('/api/cartes'); if(!res.ok)return;
      const {data}=await res.json(); if(!data)return;
      carteId=data.id;
      const set=(id:string,val:string)=>{const el=document.getElementById(id) as HTMLInputElement;if(el)el.value=val;};
      set('nom-carte',data.nom??''); set('description',data.description??''); set('tampons-total',String(data.tampons_total??10));
      set('points-par-euro',String(data.points_par_euro??1)); set('points-recompense',String(data.points_recompense??100));
      set('recompense',data.recompense_description??''); set('message-geo',data.message_geo??'');
      set('couleur-fond',data.couleur_fond??'#0f172a'); set('couleur-texte',data.couleur_texte??'#ffffff'); set('couleur-accent',data.couleur_accent??'#6366f1');
      set('label-client',data.label_client??'Client');
      if(data.couleur_fond_2){set('couleur-fond-2',data.couleur_fond_2);if(!isGradient)gradientToggle.click();}
      if(data.gradient_angle!=null){set('gradient-angle',String(data.gradient_angle));document.getElementById('gradient-angle-val')!.textContent=`${data.gradient_angle}°`;}

      function sr(name:string,val:string){const el=document.querySelector(`input[name="${name}"][value="${val}"]`) as HTMLInputElement;if(el)el.checked=true;}
      function sl(prefix:string,opts:string[],sel:string){opts.forEach(v=>document.getElementById(`${prefix}${v}-label`)!.style.cssText=v===sel?'border-color:#6366f1;background:rgb(99 102 241/0.1)':'border-color:#334155;background:transparent');}

      const pt=data.pattern_type??'none'; sr('pattern_type',pt); sl('pat-',['none','dots','grid','waves','diagonal','confetti'],pt);
      const isFull=data.strip_plein_largeur !== false; applyStripStyle(isFull); sr('strip_style',isFull?'full':'rounded');
      const layout=data.strip_layout??'background'; sr('strip_layout',layout);
      ['background','top','bottom'].forEach(v=>document.getElementById(`strip-layout-${v}-label`)!.style.cssText=v===layout?'border-color:#6366f1;background:rgb(99 102 241/0.1);color:white':'border-color:#334155;background:transparent;color:#64748b');
      const tp=data.type??'tampons'; sr('type',tp); applyTypeUI(tp);
      document.getElementById('type-tampons-label')!.style.cssText=tp==='tampons'?'border-color:#6366f1;background:rgb(99 102 241/0.1)':'border-color:#334155;background:transparent';
      document.getElementById('type-points-label')!.style.cssText=tp==='points'?'border-color:#6366f1;background:rgb(99 102 241/0.1)':'border-color:#334155;background:transparent';
      const bt=data.barcode_type??'QR'; sr('barcode_type',bt);
      ['QR','PDF417','AZTEC','NONE'].forEach(v=>document.getElementById(`barcode-${v.toLowerCase()}-label`)!.style.cssText=v===bt?'border-color:#6366f1;background:rgb(99 102 241/0.1)':'border-color:#334155;background:transparent');
      if(data.logo_url){logoUrl=data.logo_url;setLogoPreview(logoUrl);}
      set('welcome-message', data.welcome_message ?? `Bienvenue chez ${data.nom ?? 'nous'}, créez votre carte fidélité en 10 secondes.`);
      set('success-message', data.success_message ?? 'Votre carte est prête, montrez-la à chaque passage.');
      renderRewardTiers(parseJsonArray<RewardTier>(data.rewards_config));
      renderVipTiers(parseJsonArray<VipTier>(data.vip_tiers));
      if(data.strip_url){
        stripUrl=data.strip_url; const sp=data.strip_position??'center'; sr('strip_position',sp);
        ['top','center','bottom'].forEach(v=>document.getElementById(`strip-pos-${v}-label`)!.style.cssText=v===sp?'border-color:#6366f1;background:rgb(99 102 241/0.1);color:white':'border-color:#334155;background:transparent;color:#64748b');
        setStripPreview(stripUrl);
      }
      if(data.tampon_emoji){
        tamponEmoji=data.tampon_emoji;
        (document.getElementById('tampon-emoji') as HTMLInputElement).value=tamponEmoji;
        document.getElementById('tampon-emoji-val')!.textContent=tamponEmoji;
        document.getElementById('tampon-emoji-selected')!.classList.remove('hidden');
        sr('tampon_mode','emoji'); document.getElementById('tampon-emoji-zone')!.classList.remove('hidden');
        ['default','emoji','custom'].forEach(v=>document.getElementById(`tampon-mode-${v}-label`)!.style.cssText=v==='emoji'?'border-color:#6366f1;background:rgb(99 102 241/0.1)':'border-color:#334155;background:transparent');
        document.querySelectorAll('.emoji-stamp-btn').forEach(b=>{if((b as HTMLElement).dataset.emoji===tamponEmoji)(b as HTMLElement).style.borderColor='#6366f1';});
      }else if(data.tampon_icon_url){
        tamponIconUrl=data.tampon_icon_url; setTamponPreview(tamponIconUrl); sr('tampon_mode','custom');
        document.getElementById('tampon-custom-zone')!.classList.remove('hidden');
        ['default','emoji','custom'].forEach(v=>document.getElementById(`tampon-mode-${v}-label`)!.style.cssText=v==='custom'?'border-color:#6366f1;background:rgb(99 102 241/0.1)':'border-color:#334155;background:transparent');
      }
      updatePreview();
      const pu=publicCardUrl(data.id);
      document.getElementById('public-link-banner')!.classList.remove('hidden');
      document.getElementById('public-link-url')!.textContent=pu;
      document.getElementById('qr-section')!.classList.remove('hidden');
      updateQrTools(data.id);
      const qc=document.getElementById('qr-container')!;
      if(!qc.firstChild){const qi=document.createElement('img');qi.src=`https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${encodeURIComponent(pu)}&bgcolor=1e293b&color=ffffff&qzone=1`;qi.className='rounded-xl';qi.width=150;qi.height=150;qc.appendChild(qi);}
      document.getElementById('submit-btn')!.textContent='Mettre à jour la carte';
    }catch{}
  }

  document.getElementById('copy-link-btn')!.addEventListener('click',()=>{
    navigator.clipboard.writeText(document.getElementById('public-link-url')!.textContent??'').then(()=>{
      const b=document.getElementById('copy-link-btn')!;b.textContent='Copié !';setTimeout(()=>b.textContent='Copier le lien',2000);
    });
  });

  document.getElementById('download-qr-btn')!.addEventListener('click', async () => {
    if (!carteId) return;
    const button = document.getElementById('download-qr-btn') as HTMLButtonElement;
    const original = button.textContent;
    button.disabled = true;
    button.textContent = 'Téléchargement...';
    try {
      const response = await fetch(qrImageUrl(carteId, 1200));
      const blob = await response.blob();
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `fidelopass-qr-${carteId}.png`;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
      button.textContent = 'QR téléchargé';
    } catch {
      button.textContent = 'Erreur';
    } finally {
      setTimeout(() => {
        button.disabled = false;
        button.textContent = original;
      }, 1800);
    }
  });

  document.getElementById('submit-btn')!.addEventListener('click',async()=>{
    const err=document.getElementById('error-msg') as HTMLDivElement;
    const suc=document.getElementById('success-msg') as HTMLDivElement;
    err.classList.add('hidden');suc.classList.add('hidden');
    const btn=document.getElementById('submit-btn') as HTMLButtonElement;
    btn.disabled=true;btn.textContent='Enregistrement...';
    const hadExistingCard = !!carteId;
    const v=(name:string)=>(document.querySelector(`input[name="${name}"]:checked`) as HTMLInputElement)?.value??'';
    const gi=(id:string)=>(document.getElementById(id) as HTMLInputElement).value;
    const payload={
      nom:gi('nom-carte'),description:gi('description')||null,type:v('type')||'tampons',
      tampons_total:parseInt(gi('tampons-total')),points_par_euro:parseFloat(gi('points-par-euro')),
      points_recompense:parseInt(gi('points-recompense')),recompense_description:gi('recompense')||null,
      message_geo:gi('message-geo')||undefined,
      couleur_fond:gi('couleur-fond'),couleur_texte:gi('couleur-texte'),couleur_accent:gi('couleur-accent'),
      logo_url:logoUrl||null,strip_url:stripUrl||null,strip_position:v('strip_position')||'center',
      tampon_icon_url:tamponIconUrl||null,barcode_type:v('barcode_type')||'QR',
      label_client:gi('label-client')||'Client',
      couleur_fond_2:isGradient?gi('couleur-fond-2'):null,
      gradient_angle:isGradient?parseInt(gi('gradient-angle')):135,
      pattern_type:v('pattern_type')||'none',tampon_emoji:tamponEmoji||null,
      police:'system',police_taille:100,
      police_gras:false,texte_alignement:'left',
      strip_plein_largeur:v('strip_style')==='full',
      strip_layout:v('strip_layout')||'background',
      welcome_message:gi('welcome-message')||null,
      success_message:gi('success-message')||null,
      rewards_config:collectRewardTiers(),
      vip_tiers:collectVipTiers(),
    };
    try{
      const res=carteId?await authFetch(`/api/cartes/${carteId}`,{method:'PATCH',body:JSON.stringify(payload)}):await authFetch('/api/cartes',{method:'POST',body:JSON.stringify(payload)});
      if(!res.ok)throw new Error((await res.json()).error??'Erreur');
      const{data}=await res.json();
      if(!carteId){carteId=data.id;const pu=publicCardUrl(data.id);document.getElementById('public-link-banner')!.classList.remove('hidden');document.getElementById('public-link-url')!.textContent=pu;}
      if (carteId) updateQrTools(carteId);
      suc.textContent=!hadExistingCard&&setupMode?'Carte créée avec succès. Votre programme est opérationnel : vous pouvez maintenant scanner les cartes depuis votre espace Scan.':'Carte enregistrée avec succès !';suc.classList.remove('hidden');
      if (setupMode && !hadExistingCard) {
        document.getElementById('setup-banner')!.classList.add('hidden');
        window.history.replaceState({}, '', '/dashboard/carte');
      }
      btn.textContent='Mettre à jour la carte';
    }catch(e:unknown){
      err.textContent=e instanceof Error?e.message:'Erreur inattendue.';err.classList.remove('hidden');
      btn.textContent=carteId?'Mettre à jour la carte':'Enregistrer la carte';
    }finally{btn.disabled=false;}
  });

  updatePreview();
  applyTypeUI('tampons');
  applyStripStyle(true);
  renderRewardTiers();
  renderVipTiers();
  loadExistingCarte();
</script>
