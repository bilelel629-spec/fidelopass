---
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const plans = [
  {
    name: 'Starter',
    price: 'À partir de 29€',
    subtitle: 'Pour lancer une première carte et commencer à scanner en boutique.',
    highlights: [
      '1 commerce, 1 carte active',
      'Apple Wallet + Google Wallet',
      'Scanner mobile et QR boutique',
      'Affiche A4 et lien d’inscription',
    ],
  },
  {
    name: 'Pro',
    price: 'À partir de 69€',
    subtitle: 'Pour un commerce qui veut personnaliser plus fort et communiquer avec ses clients.',
    highlights: [
      'Récompenses multiples et paliers VIP',
      'Messages Wallet et campagnes client',
      'Templates métier, palette auto, bannières',
      'Stats de scans et parcours plus structurés',
    ],
    featured: true,
  },
  {
    name: 'Réseau',
    price: 'Sur devis',
    subtitle: 'Pensé pour plusieurs points de vente ou plusieurs cartes par enseigne.',
    highlights: [
      'Multi-sites et plusieurs scanners',
      'Structuration plus avancée des accès',
      'Accompagnement au déploiement',
      'Personnalisation plus poussée de marque',
    ],
  },
];

const comparisons = [
  ['Ajout Apple / Google Wallet', 'Inclus', 'Inclus', 'Inclus'],
  ['Affiches QR et lien public', 'Inclus', 'Inclus', 'Inclus'],
  ['Récompenses multiples', '—', 'Inclus', 'Inclus'],
  ['VIP Bronze / Silver / Gold', '—', 'Inclus', 'Inclus'],
  ['Accompagnement au lancement', 'Guides', 'Prioritaire', 'Sur mesure'],
];
---

<BaseLayout
  title="Tarifs Fidelopass — Lancez une carte Wallet vendable"
  description="Découvrez les plans Fidelopass pour lancer une carte de fidélité Apple Wallet et Google Wallet sans app client."
>
  <div class="relative overflow-hidden min-h-screen">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[70rem] h-[70rem] rounded-full blur-3xl opacity-20" style="background:radial-gradient(circle,#6366f1 0%,rgba(10,15,30,0) 62%)"></div>
      <div class="absolute top-20 right-0 w-[34rem] h-[34rem] rounded-full blur-3xl opacity-15" style="background:radial-gradient(circle,#0ea5e9 0%,rgba(10,15,30,0) 68%)"></div>
    </div>

    <PublicNav currentPath="/pricing" />

    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pt-8 pb-16">
      <div class="max-w-4xl">
        <div class="badge badge-info mb-5">Tarifs Fidelopass</div>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-[0.96]">
          Des offres lisibles pour lancer plus vite,
          <span class="block text-transparent bg-clip-text bg-gradient-to-r from-indigo-300 via-sky-300 to-amber-200">
            sans refaire le produit à chaque commerce
          </span>
        </h1>
        <p class="text-slate-300 text-lg sm:text-xl leading-relaxed mt-6 max-w-3xl">
          Fidelopass doit se vendre comme un outil opérationnel : une carte Wallet, un parcours client, un scanner boutique et des messages utiles. Les offres ci-dessous posent déjà cette logique.
        </p>
      </div>
    </section>

    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pb-16">
      <div class="grid lg:grid-cols-3 gap-5">
        {plans.map((plan) => (
          <article class:list={['card p-7 h-full flex flex-col', plan.featured && 'border-indigo-400/30 bg-indigo-500/10']}>
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-slate-500 text-xs uppercase tracking-[0.3em]">{plan.name}</p>
                <h2 class="font-display text-3xl font-bold text-white mt-3">{plan.price}</h2>
              </div>
              {plan.featured && <span class="badge badge-info">Le plus équilibré</span>}
            </div>
            <p class="text-slate-300 text-sm leading-relaxed mt-4">{plan.subtitle}</p>
            <div class="space-y-3 mt-6 flex-1">
              {plan.highlights.map((item) => (
                <div class="flex items-start gap-3 text-sm text-slate-300">
                  <span class="mt-1 w-2.5 h-2.5 rounded-full bg-emerald-400"></span>
                  <span>{item}</span>
                </div>
              ))}
            </div>
            <a href="/acces" class:list={['mt-8 justify-center', plan.featured ? 'btn-primary' : 'btn-secondary']}>
              Acheter une clé d’accès
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pb-16">
      <div class="card p-7 sm:p-8 overflow-x-auto">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-6">
          <div>
            <p class="text-slate-500 text-xs uppercase tracking-[0.3em]">Comparatif rapide</p>
            <h2 class="font-display text-3xl font-bold text-white mt-4">Ce que chaque plan débloque vraiment.</h2>
          </div>
          <p class="text-slate-400 text-sm max-w-2xl">
            Le but n’est pas d’empiler des options abstraites, mais de rendre l’offre compréhensible pour un commerce qui veut savoir ce qu’il peut mettre en place concrètement.
          </p>
        </div>

        <table class="w-full min-w-[760px] text-left">
          <thead>
            <tr class="text-slate-400 text-sm border-b border-white/10">
              <th class="pb-4 font-medium">Fonction</th>
              <th class="pb-4 font-medium">Starter</th>
              <th class="pb-4 font-medium">Pro</th>
              <th class="pb-4 font-medium">Réseau</th>
            </tr>
          </thead>
          <tbody>
            {comparisons.map((row) => (
              <tr class="border-b border-white/5 text-sm">
                <td class="py-4 text-white">{row[0]}</td>
                <td class="py-4 text-slate-300">{row[1]}</td>
                <td class="py-4 text-slate-300">{row[2]}</td>
                <td class="py-4 text-slate-300">{row[3]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 pb-20">
      <div class="rounded-[2rem] border border-white/10 p-8 sm:p-10" style="background:linear-gradient(135deg,rgba(30,41,59,0.9),rgba(49,46,129,0.82),rgba(15,118,110,0.55))">
        <div class="grid lg:grid-cols-[1fr_auto] gap-8 items-center">
          <div>
            <p class="text-slate-300 text-xs uppercase tracking-[0.3em]">Étape suivante</p>
            <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mt-4">Choisissons l’offre qui colle à ton lancement.</h2>
            <p class="text-slate-200/85 text-base sm:text-lg leading-relaxed mt-4 max-w-2xl">
              Tu peux déjà vendre Fidelopass avec une structure claire : une clé d’accès, un niveau d’usage, puis une montée en gamme logique quand le commerce veut aller plus loin.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row lg:flex-col gap-3">
            <a href="/acces" class="btn-primary px-8 py-3.5 text-base">Acheter une clé</a>
            <a href="/contact" class="btn-secondary px-8 py-3.5 text-base">Parler du lancement</a>
          </div>
        </div>
      </div>
    </section>

    <PublicFooter />
  </div>
</BaseLayout>
