---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mot de passe oublié — FideloPass">
  <div class="min-h-screen flex items-center justify-center px-4 py-10">
    <div class="w-full max-w-md">
      <div class="text-center mb-8">
        <a href="/" class="font-display font-bold text-2xl text-white">
          Fidéli<span style="color:#818cf8">Pass</span>
        </a>
        <p class="text-slate-400 mt-2 text-sm">Réinitialisation sécurisée du mot de passe</p>
      </div>

      <div class="card p-6">
        <div id="request-panel">
          <h1 class="font-display text-2xl font-bold text-white">Recevoir un lien</h1>
          <p class="text-slate-400 text-sm mt-2 mb-5">
            Entrez votre email. Vous recevrez un lien pour choisir un nouveau mot de passe.
          </p>

          <form id="request-form" class="flex flex-col gap-4">
            <div>
              <label class="label" for="reset-email">Email</label>
              <input id="reset-email" type="email" class="input" placeholder="vous@commerce.fr" required autocomplete="email" />
            </div>
            <div id="request-error" class="hidden text-red-400 text-sm bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3"></div>
            <div id="request-success" class="hidden text-emerald-400 text-sm bg-emerald-500/10 border border-emerald-500/20 rounded-xl px-4 py-3"></div>
            <button type="submit" id="request-btn" class="btn-primary w-full py-3">Envoyer le lien</button>
          </form>
        </div>

        <div id="update-panel" class="hidden">
          <h1 class="font-display text-2xl font-bold text-white">Nouveau mot de passe</h1>
          <p class="text-slate-400 text-sm mt-2 mb-5">
            Choisissez un mot de passe d’au moins 8 caractères.
          </p>

          <form id="update-form" class="flex flex-col gap-4">
            <div>
              <label class="label" for="new-password">Nouveau mot de passe</label>
              <input id="new-password" type="password" class="input" minlength="8" required autocomplete="new-password" />
            </div>
            <div>
              <label class="label" for="new-password-confirm">Confirmer</label>
              <input id="new-password-confirm" type="password" class="input" minlength="8" required autocomplete="new-password" />
            </div>
            <div id="update-error" class="hidden text-red-400 text-sm bg-red-500/10 border border-red-500/20 rounded-xl px-4 py-3"></div>
            <div id="update-success" class="hidden text-emerald-400 text-sm bg-emerald-500/10 border border-emerald-500/20 rounded-xl px-4 py-3"></div>
            <button type="submit" id="update-btn" class="btn-primary w-full py-3">Mettre à jour</button>
          </form>
        </div>
      </div>

      <p class="text-center text-slate-500 text-sm mt-6">
        <a href="/login" class="text-indigo-400 hover:text-indigo-300 transition-colors">Retour à la connexion</a>
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const requestPanel = document.getElementById('request-panel') as HTMLDivElement;
  const updatePanel = document.getElementById('update-panel') as HTMLDivElement;
  const requestForm = document.getElementById('request-form') as HTMLFormElement;
  const updateForm = document.getElementById('update-form') as HTMLFormElement;
  const requestError = document.getElementById('request-error') as HTMLDivElement;
  const requestSuccess = document.getElementById('request-success') as HTMLDivElement;
  const updateError = document.getElementById('update-error') as HTMLDivElement;
  const updateSuccess = document.getElementById('update-success') as HTMLDivElement;
  const requestBtn = document.getElementById('request-btn') as HTMLButtonElement;
  const updateBtn = document.getElementById('update-btn') as HTMLButtonElement;

  const initialEmail = new URLSearchParams(window.location.search).get('email') ?? '';
  (document.getElementById('reset-email') as HTMLInputElement).value = initialEmail;

  function show(el: HTMLDivElement, message: string) {
    el.textContent = message;
    el.classList.remove('hidden');
  }

  function hideMessages() {
    [requestError, requestSuccess, updateError, updateSuccess].forEach((el) => el.classList.add('hidden'));
  }

  const { data: { session } } = await supabase.auth.getSession();
  if (session) {
    requestPanel.classList.add('hidden');
    updatePanel.classList.remove('hidden');
  }

  requestForm.addEventListener('submit', async (event) => {
    event.preventDefault();
    hideMessages();
    requestBtn.disabled = true;
    requestBtn.textContent = 'Envoi...';

    const email = (document.getElementById('reset-email') as HTMLInputElement).value.trim().toLowerCase();
    const { error } = await supabase.auth.resetPasswordForEmail(email, {
      redirectTo: `${window.location.origin}/reset-password`,
    });

    if (error) {
      show(requestError, error.message ?? 'Impossible d’envoyer le lien.');
    } else {
      show(requestSuccess, 'Lien envoyé. Vérifiez votre boîte mail et vos spams.');
    }

    requestBtn.disabled = false;
    requestBtn.textContent = 'Envoyer le lien';
  });

  updateForm.addEventListener('submit', async (event) => {
    event.preventDefault();
    hideMessages();

    const password = (document.getElementById('new-password') as HTMLInputElement).value;
    const confirm = (document.getElementById('new-password-confirm') as HTMLInputElement).value;
    if (password !== confirm) {
      show(updateError, 'Les mots de passe ne correspondent pas.');
      return;
    }

    updateBtn.disabled = true;
    updateBtn.textContent = 'Mise à jour...';

    const { error } = await supabase.auth.updateUser({ password });
    if (error) {
      show(updateError, error.message ?? 'Impossible de mettre à jour le mot de passe.');
      updateBtn.disabled = false;
      updateBtn.textContent = 'Mettre à jour';
      return;
    }

    show(updateSuccess, 'Mot de passe mis à jour. Redirection vers le dashboard...');
    setTimeout(() => {
      window.location.href = '/dashboard';
    }, 900);
  });
</script>
