---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
import PublicFooter from '../components/marketing/PublicFooter.astro';

const RESELLER_SETUP_PRICE = 290;
const RESELLER_MONTHLY_PRICE = 49.99;

const profitabilityExamples = [
  { commerces: 5 },
  { commerces: 10 },
  { commerces: 15 },
];

const formatEuro = (amount: number) => amount.toLocaleString('fr-FR', {
  style: 'currency',
  currency: 'EUR',
  minimumFractionDigits: amount % 1 === 0 ? 0 : 2,
});
---

<BaseLayout
  title="Devenir revendeur Fidelopass"
  description="Revendez Fidelopass à vos clients en gardant votre marge. Idéal pour agences, commerciaux et consultants commerce."
>
  <PublicNav />

  <section class="bg-[linear-gradient(180deg,#ffffff_0%,#f5f9ff_45%,#eef6ff_100%)] px-4 pb-20 pt-10 sm:px-6">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-10 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
        <div>
          <p class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-700/70">Programme partenaire</p>
          <h1 class="mt-5 font-display text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
            Revendez Fidelopass à vos clients. Vous fixez vos prix. Vous gardez la marge.
          </h1>
          <p class="mt-5 max-w-2xl text-base leading-relaxed text-slate-600 sm:text-lg">
            Idéal pour agences digitales, commerciaux indépendants, consultants commerce et accompagnateurs terrain qui veulent proposer une solution fidélité Wallet sans porter toute la technique.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="#white-label-plans" class="btn-primary px-7 py-3.5 text-center text-sm font-semibold">Choisir mon offre white label</a>
            <a href="#rentabilite" class="btn-secondary px-7 py-3.5 text-center text-sm font-semibold">Voir le potentiel de marge</a>
          </div>
        </div>

        <div class="rounded-[2rem] border border-sky-100 bg-white p-6 shadow-[0_32px_80px_-42px_rgba(59,130,246,0.32)]">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-700/70">Ce que vous obtenez</p>
          <div class="mt-5 grid gap-3">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-sm font-semibold text-slate-900">Dashboard revendeur</p>
              <p class="mt-1 text-sm text-slate-600">Gérez plusieurs commerces depuis un seul espace et suivez leur activation.</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-4">
              <p class="text-sm font-semibold text-slate-900">Interface white-label</p>
              <p class="mt-1 text-sm text-slate-600">Vos clients ne voient pas Fidelopass : vous gardez la relation commerciale.</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
              <p class="text-sm font-semibold text-slate-900">Modèle simple</p>
              <p class="mt-1 text-sm text-slate-600">Abonnement fixe: 10 commerces inclus en Starter, 25 commerces inclus en Pro, puis add-ons selon le volume.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="white-label-plans" class="bg-white px-4 py-16 sm:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-700/70">Offres white label</p>
        <h2 class="mt-4 font-display text-3xl font-bold text-slate-900 sm:text-4xl">Deux niveaux pour structurer votre activité partenaire</h2>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <article class="rounded-[2rem] border border-slate-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-6 shadow-[0_22px_58px_-42px_rgba(59,130,246,0.35)]">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-700/70">White Label Starter</p>
          <p class="mt-4 font-display text-4xl font-bold text-slate-950">199€<span class="text-base font-semibold text-slate-500">/mois</span></p>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">10 commerces inclus pour lancer votre offre revendeur avec votre marque.</p>
          <button
            type="button"
            class="js-white-label-checkout mt-6 w-full rounded-2xl bg-slate-950 px-5 py-3.5 text-sm font-semibold text-white shadow-[0_18px_36px_-24px_rgba(15,23,42,0.8)] transition hover:-translate-y-0.5 hover:bg-slate-800"
            data-plan="white_label_starter"
          >
            Démarrer White Label Starter
          </button>
        </article>
        <article class="rounded-[2rem] border border-blue-200 bg-[linear-gradient(135deg,#172554_0%,#2563eb_100%)] p-6 text-white shadow-[0_28px_70px_-38px_rgba(37,99,235,0.65)]">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-100/80">White Label Pro</p>
          <p class="mt-4 font-display text-4xl font-bold">449€<span class="text-base font-semibold text-sky-100/75">/mois</span></p>
          <p class="mt-3 text-sm leading-relaxed text-sky-50/85">25 commerces inclus pour les agences et partenaires qui veulent scaler plus vite.</p>
          <button
            type="button"
            class="js-white-label-checkout mt-6 w-full rounded-2xl bg-white px-5 py-3.5 text-sm font-semibold text-blue-700 shadow-[0_18px_36px_-24px_rgba(255,255,255,0.85)] transition hover:-translate-y-0.5 hover:bg-sky-50"
            data-plan="white_label_pro"
          >
            Démarrer White Label Pro
          </button>
        </article>
      </div>
      <p id="white-label-checkout-status" class="mt-4 min-h-6 text-sm font-medium text-slate-600" aria-live="polite"></p>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-700/70">Comment ça marche</p>
        <h2 class="mt-4 font-display text-3xl font-bold text-slate-900 sm:text-4xl">Un modèle simple en 3 étapes</h2>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {[
          ['1', 'Vous signez un accord revendeur et payez l’abonnement mensuel fixe', 'Une base claire pour lancer votre activité partenaire sans coût variable au premier commerce.'],
          ['2', 'Vous créez les espaces de vos commerçants depuis votre tableau de bord', 'Vous pilotez l’installation, la carte, le scanner et la mise en ligne pour vos clients.'],
          ['3', 'Vous facturez vos clients au prix que vous voulez', '100% de la marge commerciale est pour vous. Fidelopass reste votre moteur, pas votre concurrent.'],
        ].map(([step, title, text]) => (
          <div class="rounded-[1.75rem] border border-slate-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-6 shadow-[0_20px_50px_-40px_rgba(59,130,246,0.35)]">
            <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-sky-600 text-sm font-bold text-white">{step}</div>
            <h3 class="mt-5 text-lg font-semibold text-slate-900">{title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50/70 px-4 py-20 sm:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-10 lg:grid-cols-[1fr_1fr]">
        <div>
          <p class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-700/70">Ce que vous obtenez</p>
          <h2 class="mt-4 font-display text-3xl font-bold text-slate-900">Un cadre clair pour développer votre offre</h2>
          <div class="mt-8 grid gap-4">
            {[
              'Dashboard revendeur pour gérer tous vos commerces',
              'Interface white-label : vos clients ne voient pas Fidelopass',
              'Suivi de vos revenus et commerces actifs en temps réel',
              '10 commerces inclus en Starter, 25 en Pro + add-ons disponibles',
              'Support dédié Fidelopass',
            ].map((item) => (
              <div class="rounded-2xl border border-slate-200 bg-white px-5 py-4 text-sm font-medium text-slate-700 shadow-sm">{item}</div>
            ))}
          </div>
        </div>

        <div id="rentabilite" class="rounded-[2rem] border border-sky-100 bg-white p-6 shadow-[0_28px_70px_-42px_rgba(59,130,246,0.28)]">
          <p class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-700/70">Exemple de rentabilité</p>
          <h2 class="mt-4 font-display text-3xl font-bold text-slate-900">Un modèle lisible pour vendre sans vous sous-estimer</h2>
          <div class="mt-8 grid gap-3">
            {profitabilityExamples.map((example) => (
              <div class="flex items-center justify-between rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4">
                <div>
                  <p class="text-sm font-semibold text-slate-900">{example.commerces} commerces</p>
                  <p class="mt-1 text-xs text-slate-500">
                    Moyenne observée: 290€ de mise en place + 49,99€/mois par commerce
                  </p>
                </div>
                <div class="text-right">
                  <p class="font-mono text-2xl font-bold text-sky-700">{formatEuro(example.commerces * RESELLER_MONTHLY_PRICE)}/mois</p>
                  <p class="mt-1 text-xs font-semibold text-slate-500">{formatEuro(example.commerces * RESELLER_SETUP_PRICE)} au setup</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4">
            <p class="text-sm font-semibold text-slate-900">Votre abonnement : 199€/mois ou 449€/mois selon le volume</p>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">
              Le modèle est simple : Starter inclut 10 commerces, Pro inclut 25 commerces. L’objectif est de vous garder une marge claire sur chaque commerce actif.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-20 sm:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-2xl">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-700/70">Pour qui ?</p>
        <h2 class="mt-4 font-display text-3xl font-bold text-slate-900">Des profils qui ont déjà la confiance des commerçants</h2>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {[
          'Agences web et digitales',
          'Commerciaux / apporteurs d’affaires',
          'Consultants en commerce de proximité',
          'Indépendants qui accompagnent des commerçants',
        ].map((item) => (
          <div class="rounded-[1.75rem] border border-slate-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] p-6 text-center shadow-[0_18px_44px_-36px_rgba(59,130,246,0.32)]">
            <p class="text-sm font-semibold text-slate-900">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50/70 px-4 py-20 sm:px-6">
    <div class="mx-auto max-w-4xl">
      <div class="text-center">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-sky-700/70">FAQ</p>
        <h2 class="mt-4 font-display text-3xl font-bold text-slate-900">Questions fréquentes</h2>
      </div>

      <div class="mt-10 space-y-4">
        {[
          ['Mes clients sauront-ils que c’est Fidelopass ?', 'Non. Le principe revendeur repose sur un fonctionnement white-label : vos clients voient votre marque et votre relation commerciale.'],
          ['Puis-je utiliser mon propre logo ?', 'Oui. L’objectif est que votre univers visuel soit visible côté revendeur et côté client final.'],
          ['Y a-t-il un engagement ?', 'Le niveau exact d’engagement sera défini avec vous selon le modèle partenaire retenu.'],
          ['Comment je facture mes clients ?', 'Librement, en direct. Vous choisissez votre prix de revente et vous gardez votre marge.'],
        ].map(([q, a]) => (
          <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm">
            <p class="text-base font-semibold text-slate-900">{q}</p>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[linear-gradient(135deg,#0f172a_0%,#1d4ed8_100%)] px-4 py-20 sm:px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-display text-4xl font-bold text-white">Vous voulez revendre Fidelopass à vos clients ?</h2>
      <p class="mt-4 text-lg text-sky-100">
        On prépare le cadre partenaire avec vous. Pas de self-service ici : on valide ensemble le modèle, le volume et le fonctionnement.
      </p>
      <a href="/contact" class="mt-8 inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-sm font-semibold text-sky-700 shadow-[0_20px_45px_rgba(255,255,255,0.15)] transition hover:-translate-y-0.5 hover:bg-sky-50">
        Devenir revendeur → Nous contacter
      </a>
    </div>
  </section>

  <PublicFooter />

  <script>
    import { getSession } from '../lib/auth';
    import { authFetch } from '../lib/api';

    const status = document.getElementById('white-label-checkout-status');
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.js-white-label-checkout'));

    function setStatus(message: string, tone: 'neutral' | 'error' = 'neutral') {
      if (!status) return;
      status.textContent = message;
      status.className = `mt-4 min-h-6 text-sm font-medium ${tone === 'error' ? 'text-red-600' : 'text-slate-600'}`;
    }

    function setLoading(isLoading: boolean, activeButton?: HTMLButtonElement) {
      buttons.forEach((button) => {
        button.disabled = isLoading;
        button.classList.toggle('opacity-60', isLoading);
        button.classList.toggle('cursor-wait', isLoading);
      });
      if (activeButton) {
        activeButton.textContent = isLoading ? 'Redirection vers Stripe…' : activeButton.dataset.plan === 'white_label_pro'
          ? 'Démarrer White Label Pro'
          : 'Démarrer White Label Starter';
      }
    }

    buttons.forEach((button) => {
      button.addEventListener('click', async () => {
        const plan = button.dataset.plan;
        if (plan !== 'white_label_starter' && plan !== 'white_label_pro') return;

        setLoading(true, button);
        setStatus('Préparation de votre checkout sécurisé…');

        try {
          const session = await getSession();
          if (!session?.access_token) {
            const next = encodeURIComponent('/devenir-revendeur');
            window.location.href = `/register?next=${next}`;
            return;
          }

          const response = await authFetch('/api/checkout/white-label-session', {
            method: 'POST',
            body: JSON.stringify({ plan }),
          });
          const payload = await response.json().catch(() => ({}));
          if (!response.ok || !payload?.url) {
            throw new Error(payload?.error ?? 'Impossible de créer le paiement White Label.');
          }
          window.location.href = payload.url;
        } catch (error) {
          setStatus(error instanceof Error ? error.message : 'Erreur de redirection vers Stripe.', 'error');
          setLoading(false, button);
        }
      });
    });
  </script>
</BaseLayout>
