---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Mon compte commerçant — Fidelopass" activeNav="parametres">
  <div class="mb-8">
    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.26em] text-sky-700/70">Espace commerçant</p>
    <h1 class="font-display text-3xl font-bold text-slate-900 mt-2">Mon compte commerçant</h1>
    <p class="text-slate-600 text-sm mt-2">Retrouvez ici vos informations de profil, votre organisation et les éléments liés à votre abonnement.</p>
  </div>

  <div class="grid xl:grid-cols-[240px_1fr] gap-6 items-start">
    <aside class="card p-3">
      <div class="grid gap-1">
        {[
          ['profil', 'Profil'],
          ['abonnement', 'Abonnement et facturation'],
          ['plans', 'Plans'],
          ['organisation', 'Organisation'],
          ['paiements', 'Paiements'],
        ].map(([value, label], index) => (
          <button
            type="button"
            class={`account-tab rounded-2xl px-4 py-3 text-left text-sm font-medium transition-all ${index === 0 ? 'bg-sky-100 text-sky-800' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'}`}
            data-tab={value}
          >
            {label}
          </button>
        ))}
      </div>
    </aside>

    <div class="space-y-6">
      <section id="tab-profil" class="account-panel card p-6">
        <h2 class="font-display font-bold text-slate-900 text-xl mb-5">Profil</h2>
        <form id="settings-form" class="flex flex-col gap-5">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="label" for="nom">Nom du commerce</label>
              <input id="nom" type="text" class="input" placeholder="Ma Boutique" required />
            </div>
            <div>
              <label class="label" for="telephone">Téléphone</label>
              <input id="telephone" type="tel" class="input" placeholder="06 12 34 56 78" />
            </div>
          </div>

          <div>
            <label class="label" for="email-commerce">Email contact</label>
            <input id="email-commerce" type="email" class="input" placeholder="contact@moncommerce.fr" />
          </div>

          <div class="rounded-2xl border border-sky-100 bg-sky-50 px-4 py-3 text-sm text-slate-700">
            L’adresse du commerce et le rayon de géolocalisation se règlent maintenant dans
            <a href="/dashboard/carte" class="font-semibold text-sky-700 underline underline-offset-2">Ma carte → Géolocalisation</a>.
          </div>

          <div id="error-msg" class="hidden text-red-600 text-sm bg-red-50 border border-red-200 rounded-xl px-4 py-3"></div>
          <div id="success-msg" class="hidden text-emerald-700 text-sm bg-emerald-50 border border-emerald-200 rounded-xl px-4 py-3"></div>

          <div class="flex gap-3">
            <button type="submit" class="btn-primary px-6 py-2.5">Enregistrer</button>
          </div>
        </form>
      </section>

      <section id="tab-abonnement" class="account-panel hidden card p-6">
        <h2 class="font-display font-bold text-slate-900 text-xl mb-2">Abonnement et facturation</h2>
        <p class="text-slate-600 text-sm mb-5">Cette section prépare l’arrivée du vrai suivi abonnement. Pour l’instant, on y met les repères utiles et les prochaines étapes de facturation.</p>
        <div class="grid gap-4 lg:grid-cols-2">
          <div class="rounded-2xl border border-sky-100 bg-sky-50/90 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-600/80">Plan actuel</p>
            <p class="mt-2 text-xl font-semibold text-slate-900">Plan en cours de configuration</p>
            <p class="mt-2 text-sm text-slate-600">Votre produit est prêt à recevoir une vraie logique de plan. On branchera ici le plan choisi, le renouvellement et le statut d’essai.</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Facturation</p>
            <p class="mt-2 text-xl font-semibold text-slate-900">Mise en place par l’équipe</p>
            <p class="mt-2 text-sm text-slate-600">Comme prévu sur la vitrine, la mise en place accompagnée pourra apparaître ici comme option à 20€ une seule fois.</p>
          </div>
        </div>
      </section>

      <section id="tab-plans" class="account-panel hidden card p-6">
        <h2 class="font-display font-bold text-slate-900 text-xl mb-2">Plans</h2>
        <p class="text-slate-600 text-sm mb-5">Comparez les offres Fidelopass et préparez vos évolutions de capacité sans sortir de l’espace commerçant.</p>
        <div class="grid gap-4 xl:grid-cols-3">
          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="text-sm font-semibold text-slate-900">Lancement</p>
            <p class="mt-2 text-3xl font-bold text-slate-900">25€<span class="text-sm font-medium text-slate-500">/mois</span></p>
            <p class="mt-3 text-sm text-slate-600">Jusqu’à 500 cartes clients actives, 3 scanners inclus, notifications push, points & VIP, géolocalisation.</p>
          </div>
          <div class="rounded-2xl border border-sky-200 bg-sky-50 p-5 shadow-[0_20px_50px_-38px_rgba(59,130,246,0.7)]">
            <p class="text-sm font-semibold text-slate-900">Croissance</p>
            <p class="mt-2 text-3xl font-bold text-slate-900">65€<span class="text-sm font-medium text-slate-500">/mois</span></p>
            <p class="mt-3 text-sm text-slate-600">Jusqu’à 5 000 cartes clients actives, 3 lieux / commerces, 6 scanners par lieu.</p>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="text-sm font-semibold text-slate-900">Sur mesure</p>
            <p class="mt-2 text-3xl font-bold text-slate-900">Sur devis</p>
            <p class="mt-3 text-sm text-slate-600">Volume, multi-sites et équipement adaptés à votre réseau. Scanner supplémentaire à partir de 5€.</p>
          </div>
        </div>
        <a href="/pricing" class="btn-secondary mt-5 inline-flex px-4 py-2.5 text-sm">Voir la page tarifs complète</a>
      </section>

      <section id="tab-organisation" class="account-panel hidden card p-6">
        <h2 class="font-display font-bold text-slate-900 text-xl mb-2">Organisation</h2>
        <p class="text-slate-600 text-sm mb-5">Cette zone prépare la gestion multi-lieux, les associés et l’équipement scanner du personnel.</p>
        <div class="grid gap-4 lg:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="text-sm font-semibold text-slate-900">Lieu principal</p>
            <p id="organisation-adresse" class="mt-2 text-sm text-slate-600">Adresse en cours de chargement…</p>
            <p id="organisation-rayon" class="mt-2 text-xs text-slate-500">Rayon de géolocalisation : —</p>
            <a href="/dashboard/carte" class="btn-secondary mt-4 inline-flex px-4 py-2.5 text-sm">Modifier l’adresse et la proximité</a>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="text-sm font-semibold text-slate-900">Équipe & scanner</p>
            <p class="mt-2 text-sm text-slate-600">Le scanner du personnel se configure désormais après la création de la carte. Cette section accueillera ensuite les accès par collaborateur.</p>
            <a href="/dashboard/carte" class="btn-secondary mt-4 inline-flex px-4 py-2.5 text-sm">Configurer la carte et le scanner</a>
          </div>
        </div>
      </section>

      <section id="tab-paiements" class="account-panel hidden card p-6">
        <h2 class="font-display font-bold text-slate-900 text-xl mb-2">Paiements</h2>
        <p class="text-slate-600 text-sm mb-5">Retrouvez ici les encaissements liés à votre abonnement et les informations bancaires nécessaires, dès le branchement de la facturation réelle.</p>
        <div class="grid gap-4 lg:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
            <p class="text-slate-900 font-medium">Paiements à connecter</p>
            <p class="text-slate-600 text-sm mt-1">Cette section recevra la méthode de paiement, les prochaines échéances et l’historique des factures.</p>
          </div>
          <div class="rounded-2xl border border-sky-100 bg-sky-50/90 p-5">
            <p class="text-slate-900 font-medium">Besoin d’un coup de main ?</p>
            <p class="text-slate-600 text-sm mt-1">En attendant, on peut garder ici un support manuel pour la mise en place et les ajustements de facturation.</p>
            <a href="/contact" class="btn-secondary mt-4 inline-flex px-4 py-2.5 text-sm">Contacter l’équipe</a>
          </div>
        </div>
      </section>

      <section class="card p-6 border border-red-100">
        <h2 class="font-display font-bold text-slate-900 mb-1">Déconnexion</h2>
        <p class="text-slate-600 text-sm mb-4">Vous serez redirigé vers la page de connexion.</p>
        <button id="logout-btn" class="btn-secondary text-red-600 hover:text-red-600 hover:bg-red-50 border-red-200 px-5 py-2">
          Se déconnecter
        </button>
      </section>
    </div>
  </div>
</DashboardLayout>

<script>
  import { authFetch } from '../../lib/api';
  import { signOut } from '../../lib/auth';

  document.querySelectorAll('.account-tab').forEach((button) => {
    button.addEventListener('click', () => {
      const tab = (button as HTMLButtonElement).dataset.tab;
      document.querySelectorAll('.account-tab').forEach((el) => {
        el.className = 'account-tab rounded-2xl px-4 py-3 text-left text-sm font-medium transition-all text-slate-600 hover:bg-slate-50 hover:text-slate-900';
      });
      button.className = 'account-tab rounded-2xl px-4 py-3 text-left text-sm font-medium transition-all bg-sky-100 text-sky-800';
      document.querySelectorAll('.account-panel').forEach((panel) => panel.classList.add('hidden'));
      document.getElementById(`tab-${tab}`)?.classList.remove('hidden');
    });
  });

  async function loadSettings() {
    try {
      const res = await authFetch('/api/commerces/me');
      if (!res.ok) return;
      const { data } = await res.json();
      if (!data) return;

      (document.getElementById('nom') as HTMLInputElement).value = data.nom ?? '';
      (document.getElementById('telephone') as HTMLInputElement).value = data.telephone ?? '';
      (document.getElementById('email-commerce') as HTMLInputElement).value = data.email ?? '';

      document.getElementById('organisation-adresse')!.textContent = data.adresse ?? 'Adresse non renseignée';
      document.getElementById('organisation-rayon')!.textContent = `Rayon de géolocalisation : ${(data.rayon_geo ?? 1000).toLocaleString('fr-FR')} m`;
    } catch { /* silencieux */ }
  }

  const form = document.getElementById('settings-form') as HTMLFormElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
  const successMsg = document.getElementById('success-msg') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg.classList.add('hidden');
    successMsg.classList.add('hidden');

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Enregistrement...';

    try {
      const res = await authFetch('/api/commerces/me', {
        method: 'PATCH',
        body: JSON.stringify({
          nom: (document.getElementById('nom') as HTMLInputElement).value,
          telephone: (document.getElementById('telephone') as HTMLInputElement).value || null,
          email: (document.getElementById('email-commerce') as HTMLInputElement).value || null,
        }),
      });

      if (!res.ok) throw new Error((await res.json()).error ?? 'Erreur');
      const { data } = await res.json();

      successMsg.textContent = 'Profil commerçant enregistré.';
      successMsg.classList.remove('hidden');

      document.getElementById('organisation-adresse')!.textContent = data?.adresse ?? 'Adresse non renseignée';
      document.getElementById('organisation-rayon')!.textContent = `Rayon de géolocalisation : ${(data?.rayon_geo ?? 1000).toLocaleString('fr-FR')} m`;
    } catch (err: unknown) {
      errorMsg.textContent = err instanceof Error ? err.message : 'Erreur lors de l’enregistrement.';
      errorMsg.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enregistrer';
    }
  });

  document.getElementById('logout-btn')!.addEventListener('click', async () => {
    await signOut();
    window.location.href = '/login';
  });

  loadSettings();
</script>
