# =============================================
# FidéliPass — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Apple Wallet
APPLE_PASS_TYPE_ID=pass.com.votre-societe.fidelopass
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_P12_PASSWORD=ton_mot_de_passe
APPLE_WWDR_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
APPLE_SIGNER_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
APPLE_SIGNER_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Google Wallet
GOOGLE_SERVICE_ACCOUNT_PATH=./certs/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_ISSUER_ID=3388000000012345678

# Firebase (notifications push)
FIREBASE_PROJECT_ID=fidelipass
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@fidelipass.iam.gserviceaccount.com
PUBLIC_FIREBASE_API_KEY=...
PUBLIC_FIREBASE_AUTH_DOMAIN=fidelipass.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=fidelipass
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=...
PUBLIC_FIREBASE_APP_ID=...
PUBLIC_FIREBASE_VAPID_KEY=...

# App
APP_URL=http://localhost:4321
API_URL=http://localhost:3001
APPLE_WEB_SERVICE_URL=http://localhost:3001/api/wallet/apple
NODE_ENV=development
REGISTER_ACCESS_KEY=change_me_register_access_key
CORS_ALLOWED_ORIGINS=https://fidelopass.com,https://www.fidelopass.com,http://localhost:4321
RATE_LIMIT_GLOBAL=240
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_AUTH=20
RATE_LIMIT_AUTH_WINDOW_MS=300000

# Géolocalisation / autocomplétion d'adresse
# Optionnel mais recommandé. Sans clé, fallback OpenStreetMap/Nominatim.
GEOAPIFY_API_KEY=

# Super admin (emails séparés par virgule)
ADMIN_EMAILS=contact@duo-agency.com,admin@votre-domaine.com
