# =============================================
# FidéliPass — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# =============================================

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Apple Wallet
APPLE_PASS_TYPE_ID=pass.com.pulse-agency.fidelite
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_P12_PASSWORD=ton_mot_de_passe
APPLE_WWDR_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
APPLE_SIGNER_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
APPLE_SIGNER_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Google Wallet
GOOGLE_SERVICE_ACCOUNT_PATH=./certs/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_ISSUER_ID=3388000000012345678

# Firebase (notifications push)
FIREBASE_PROJECT_ID=fidelipass
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@fidelipass.iam.gserviceaccount.com

# App
APP_URL=http://localhost:4321
API_URL=http://localhost:3001
NODE_ENV=development
REGISTER_ACCESS_KEY=Fidelopass3.0

# Super admin (emails séparés par virgule)
ADMIN_EMAILS=bilel@pulse-agency.fr
