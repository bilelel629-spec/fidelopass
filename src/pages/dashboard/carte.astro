      label_client:getInput('label-client')||'Client',
      couleur_fond_2:isGradient?getInput('couleur-fond-2'):null,
      gradient_angle:isGradient?parseInt(getInput('gradient-angle')):135,
      pattern_type:getChecked('pattern_type')||'none',
