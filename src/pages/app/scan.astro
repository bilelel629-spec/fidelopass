---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Scanner — Fidelopass">
  <div class="min-h-[100dvh] flex flex-col">
    <!-- Header -->
    <div class="scanner-header flex items-center gap-3 px-4 pb-4 border-b border-sky-100">
      <a href="/app" class="inline-flex h-11 w-11 items-center justify-center rounded-xl border border-sky-100 bg-white text-slate-500 shadow-sm hover:text-slate-900 transition-colors">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <div class="flex items-center gap-3">
        <img src="/favicon.png" alt="Fidelopass" class="h-10 w-10 rounded-xl border border-sky-100 shadow-sm" />
        <div>
          <h1 class="font-display font-bold text-slate-900">Scanner la carte</h1>
          <p class="text-xs text-slate-500">Ouverture directe caméra arrière</p>
        </div>
      </div>
    </div>

    <!-- Zone scanner -->
    <div class="flex-1 flex flex-col items-center justify-center px-4 gap-6">
      <div class="relative w-full max-w-sm">
        <div class="scanner-reader-shell rounded-[2rem] border border-sky-100 bg-white p-3 shadow-[0_32px_70px_-42px_rgba(59,130,246,0.45)]">
          <div id="reader" class="scanner-reader w-full aspect-[4/5] rounded-[1.4rem] overflow-hidden border border-sky-100 bg-slate-950"></div>
          <div class="pointer-events-none absolute inset-[1.35rem] rounded-[1.4rem] border border-white/70 shadow-[0_0_30px_rgba(59,130,246,0.28)]"></div>
        </div>
      </div>
      <div class="text-center">
        <p class="text-slate-900 text-sm font-semibold">Scannez directement avec la caméra</p>
        <p id="scanner-status" class="text-slate-600 text-sm mt-1">Autorisez la caméra puis placez le QR code dans l’image.</p>
        <div id="camera-help" class="hidden mt-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-4 text-left">
          <p class="text-amber-900 text-sm font-semibold">Autorisation caméra nécessaire</p>
          <p id="camera-help-text" class="text-amber-800/80 text-xs mt-1 leading-relaxed">
            Autorisez la caméra pour scanner directement la carte du client.
          </p>
          <button id="btn-camera-permission" type="button" class="btn-primary w-full py-3 mt-3">
            Autoriser la caméra
          </button>
        </div>
      </div>
    </div>

    <!-- Résultat scan -->
    <div id="scan-result" class="hidden fixed inset-0 bg-navy-900/95 backdrop-blur-sm flex flex-col items-center justify-center px-6 z-50">
      <div class="card w-full max-w-sm p-6 text-center">
        <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl border border-sky-100 bg-sky-50">
          <img src="/favicon.png" alt="" class="h-12 w-12 rounded-xl" />
        </div>
        <h2 id="result-nom" class="font-display font-bold text-xl text-white mb-1">—</h2>
        <p id="result-solde" class="text-slate-400 text-sm mb-6">—</p>
        <p id="result-rewards" class="text-emerald-300 text-xs font-medium mb-4">Récompenses disponibles: 0</p>

        <div class="flex gap-3 mb-4">
          <button id="btn-tampon" class="btn-primary flex-1 py-4 flex flex-col items-center">
            <span class="text-2xl mb-1">🔖</span>
            <span class="text-sm">+1 tampon</span>
          </button>
          <button id="btn-points" class="btn-secondary flex-1 py-4 flex flex-col items-center">
            <span class="text-2xl mb-1">⭐</span>
            <span class="text-sm">+points</span>
          </button>
        </div>

        <button id="btn-reward" class="hidden btn-secondary w-full py-3 mb-4 text-emerald-300 border-emerald-400/20 hover:bg-emerald-500/10">
          Utiliser 1 récompense
        </button>

        <button id="btn-close" class="btn-secondary w-full py-3">Annuler</button>
      </div>
    </div>

    <div id="points-modal" class="hidden fixed inset-0 bg-navy-950/90 backdrop-blur-sm z-[60] flex items-center justify-center px-6">
      <div class="card w-full max-w-xs p-5">
        <h2 class="font-display font-bold text-white text-lg">Ajouter des points</h2>
        <p class="text-slate-400 text-sm mt-1 mb-4">Entrez le nombre de points à créditer.</p>
        <input id="points-value" type="number" min="1" step="1" inputmode="numeric" class="input text-center text-xl font-mono" placeholder="10" />
        <div class="grid grid-cols-2 gap-3 mt-4">
          <button id="btn-cancel-points" type="button" class="btn-secondary py-3">Annuler</button>
          <button id="btn-confirm-points" type="button" class="btn-primary py-3">Ajouter</button>
        </div>
      </div>
    </div>

    <div id="scan-toast" class="hidden fixed left-4 right-4 bottom-6 z-[70] rounded-2xl border border-emerald-400/30 bg-emerald-500/15 px-4 py-3 text-center text-sm font-semibold text-emerald-100 shadow-2xl backdrop-blur-md"></div>
  </div>
</AppLayout>

<style is:global>
  .scanner-header {
    padding-top: max(1rem, calc(env(safe-area-inset-top) + 0.6rem));
  }

  .scanner-reader-shell {
    position: relative;
  }

  .scanner-reader {
    position: relative !important;
    display: block !important;
    contain: layout paint !important;
    line-height: 0 !important;
  }

  .scanner-reader * {
    box-sizing: border-box !important;
  }

  .scanner-reader > div,
  .scanner-reader #reader__scan_region {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    min-height: 0 !important;
    overflow: hidden !important;
    border: 0 !important;
    background: transparent !important;
  }

  .scanner-reader video {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    max-width: none !important;
    object-fit: cover !important;
    border-radius: 1rem !important;
  }

  .scanner-reader canvas {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
  }

  .scanner-reader #reader__dashboard,
  .scanner-reader #reader__header_message,
  .scanner-reader #reader__camera_permission_button,
  .scanner-reader #reader__camera_selection,
  .scanner-reader #reader__dashboard_section_csr,
  .scanner-reader #reader__dashboard_section_fsr,
  .scanner-reader #reader__dashboard_section_swaplink,
  .scanner-reader #reader__dashboard_section {
    display: none !important;
  }
</style>

<script>
  import { authFetch } from '../../lib/api';

  type ScannerInstance = {
    start: (
      cameraConfigOrDeviceId: string | MediaTrackConstraints,
      configuration: Record<string, unknown>,
      qrCodeSuccessCallback: (decodedText: string) => void,
      qrCodeErrorCallback?: (errorMessage: string) => void,
    ) => Promise<void>;
    pause: () => void;
    resume: () => void;
  };

  type Html5QrcodeModule = {
    Html5Qrcode: new (elementId: string, verbose?: boolean) => ScannerInstance;
    Html5QrcodeSupportedFormats: {
      QR_CODE: number;
    };
  };

  let currentClientId: string | null = null;
  let currentClientRecompenses = 0;
  let scannerPaused = false;
  let audioContext: AudioContext | null = null;
  let confettiPromise: Promise<any> | null = null;
  let toastTimeout: ReturnType<typeof setTimeout> | null = null;

  const scannerStatus = document.getElementById('scanner-status')!;
  const cameraHelp = document.getElementById('camera-help')!;
  const cameraHelpText = document.getElementById('camera-help-text')!;
  const cameraPermissionBtn = document.getElementById('btn-camera-permission') as HTMLButtonElement;
  const scanToast = document.getElementById('scan-toast')!;
  let scanner: ScannerInstance | null = null;
  let html5QrcodeModule: Html5QrcodeModule | null = null;
  let scannerModulePromise: Promise<Html5QrcodeModule> | null = null;
  let scannerStarting = false;
  const CAMERA_CACHE_KEY = 'fidelopass_scanner_camera_id';
  const SCANNER_TOKEN_KEY = 'fidelopass_scanner_token';
  const API_TIMEOUT_MS = Number(import.meta.env.PUBLIC_API_FETCH_TIMEOUT_MS ?? 3500);
  const scanConfigBase = {
    fps: 24,
    aspectRatio: 4 / 5,
    disableFlip: true,
    experimentalFeatures: {
      useBarCodeDetectorIfSupported: true,
    },
  };

  function getScanConfig() {
    if (!html5QrcodeModule) return scanConfigBase;
    return {
      ...scanConfigBase,
      formatsToSupport: [html5QrcodeModule.Html5QrcodeSupportedFormats.QR_CODE],
    };
  }

  function withTimeout<T>(promise: Promise<T>, timeoutMs: number): Promise<T> {
    return Promise.race([
      promise,
      new Promise<T>((_, reject) => window.setTimeout(() => reject(new Error('timeout')), timeoutMs)),
    ]);
  }

  async function authFetchWithTimeout(path: string, init?: RequestInit): Promise<Response> {
    return withTimeout(authFetch(path, init), API_TIMEOUT_MS);
  }

  async function loadScannerModule() {
    if (html5QrcodeModule) return html5QrcodeModule;
    if (!scannerModulePromise) {
      scannerModulePromise = import('html5-qrcode').then((module) => module as unknown as Html5QrcodeModule);
    }
    html5QrcodeModule = await scannerModulePromise;
    return html5QrcodeModule;
  }

  async function ensureScannerInstance() {
    if (scanner) return scanner;
    const module = await loadScannerModule();
    scanner = new module.Html5Qrcode('reader', false);
    return scanner;
  }

  function setScannerStatus(message: string) {
    scannerStatus.textContent = message;
  }

  function getAudioContext() {
    const AudioContextClass =
      window.AudioContext ?? (window as Window & { webkitAudioContext?: typeof AudioContext }).webkitAudioContext;
    if (!AudioContextClass) return null;
    audioContext ??= new AudioContextClass();
    return audioContext;
  }

  function unlockAudio() {
    const context = getAudioContext();
    if (context?.state === 'suspended') {
      context.resume().catch(() => {});
    }
  }

  function playBeep(type: 'scan' | 'success' = 'scan') {
    const context = getAudioContext();
    if (!context) return;

    const now = context.currentTime;
    const oscillator = context.createOscillator();
    const gain = context.createGain();
    oscillator.type = type === 'success' ? 'triangle' : 'sine';
    oscillator.frequency.setValueAtTime(type === 'success' ? 880 : 660, now);
    if (type === 'success') {
      oscillator.frequency.exponentialRampToValueAtTime(1320, now + 0.08);
    }

    gain.gain.setValueAtTime(0.001, now);
    gain.gain.exponentialRampToValueAtTime(type === 'success' ? 0.18 : 0.13, now + 0.01);
    gain.gain.exponentialRampToValueAtTime(0.001, now + (type === 'success' ? 0.16 : 0.09));

    oscillator.connect(gain);
    gain.connect(context.destination);
    oscillator.start(now);
    oscillator.stop(now + (type === 'success' ? 0.18 : 0.11));
  }

  function showToast(message: string, tone: 'success' | 'error' = 'success') {
    if (toastTimeout) clearTimeout(toastTimeout);
    scanToast.textContent = message;
    scanToast.classList.remove('border-emerald-400/30', 'bg-emerald-500/15', 'text-emerald-100');
    scanToast.classList.remove('border-red-300/40', 'bg-red-500/15', 'text-red-100');
    if (tone === 'error') {
      scanToast.classList.add('border-red-300/40', 'bg-red-500/15', 'text-red-100');
    } else {
      scanToast.classList.add('border-emerald-400/30', 'bg-emerald-500/15', 'text-emerald-100');
    }
    scanToast.classList.remove('hidden');
    toastTimeout = setTimeout(() => scanToast.classList.add('hidden'), 2200);
  }

  function showCameraHelp(message: string) {
    cameraHelpText.textContent = message;
    cameraHelp.classList.remove('hidden');
  }

  function hideCameraHelp() {
    cameraHelp.classList.add('hidden');
  }

  function stopTracks(stream: MediaStream | null) {
    stream?.getTracks().forEach((track) => track.stop());
  }

  function getScannerToken() {
    let token = localStorage.getItem(SCANNER_TOKEN_KEY);
    if (!token) {
      token = `${crypto.randomUUID()}-${Date.now()}`;
      localStorage.setItem(SCANNER_TOKEN_KEY, token);
    }
    return token;
  }

  function getDeviceName() {
    const userAgentPlatform = (navigator as Navigator & { userAgentData?: { platform?: string } }).userAgentData?.platform;
    return (userAgentPlatform ?? navigator.userAgent ?? 'Téléphone').slice(0, 120);
  }

  async function ensureScannerAccess() {
    const token = getScannerToken();
    const statusRes = await authFetchWithTimeout(`/api/scanners/status?scanner_token=${encodeURIComponent(token)}`);
    const statusPayload = await statusRes.json().catch(() => null);
    if (!statusRes.ok) {
      throw new Error(statusPayload?.error ?? 'Impossible de vérifier le quota scanner.');
    }

    const statusData = statusPayload?.data;
    if (!statusData) throw new Error('Réponse scanner invalide.');

    if (statusData.registered_for_token) {
      return;
    }

    if (statusData.remaining_scanners <= 0) {
      throw new Error(`Limite de scanners atteinte (${statusData.max_scanners}). Passez au plan supérieur pour ajouter un nouvel appareil.`);
    }

    const registerRes = await authFetchWithTimeout('/api/scanners/register', {
      method: 'POST',
      body: JSON.stringify({
        scanner_token: token,
        device_name: getDeviceName(),
      }),
    });
    const registerPayload = await registerRes.json().catch(() => null);
    if (!registerRes.ok) {
      throw new Error(registerPayload?.error ?? 'Impossible d’enregistrer ce scanner.');
    }
  }

  async function requestCameraPermission() {
    if (!navigator.mediaDevices?.getUserMedia) {
      throw new Error('Ce navigateur ne permet pas l’accès caméra. Ouvrez le scanner dans Safari ou Chrome.');
    }

    let stream: MediaStream | null = null;
    try {
      stream = await navigator.mediaDevices.getUserMedia({
        video: {
          facingMode: { ideal: 'environment' },
          width: { ideal: 1920 },
          height: { ideal: 1080 },
          advanced: [{ focusMode: 'continuous' } as MediaTrackConstraintSet],
        },
        audio: false,
      });
    } finally {
      stopTracks(stream);
    }
  }

  function rememberCameraId(deviceId: string | null) {
    if (!deviceId) return;
    try {
      localStorage.setItem(CAMERA_CACHE_KEY, deviceId);
    } catch {
      // Stockage best-effort.
    }
  }

  function readRememberedCameraId(): string | null {
    try {
      return localStorage.getItem(CAMERA_CACHE_KEY);
    } catch {
      return null;
    }
  }

  async function getRearCameraId() {
    if (!navigator.mediaDevices?.enumerateDevices) return null;
    const devices = await navigator.mediaDevices.enumerateDevices();
    const cameras = devices.filter((device) => device.kind === 'videoinput');
    if (!cameras.length) return null;

    const rearCamera = cameras.find((camera) => {
      const label = camera.label.toLowerCase();
      return label.includes('back')
        || label.includes('rear')
        || label.includes('environment')
        || label.includes('arrière')
        || label.includes('arriere');
    });

    return rearCamera?.deviceId ?? cameras[cameras.length - 1]?.deviceId ?? null;
  }

  async function startScanner({ fromUserAction = false } = {}) {
    if (scannerStarting) return;
    scannerStarting = true;
    scannerPaused = false;
    hideCameraHelp();
    setScannerStatus('Ouverture de la caméra...');

    try {
      const qrScanner = await ensureScannerInstance();
      try {
        const rememberedCameraId = readRememberedCameraId();
        await qrScanner.start(
          rememberedCameraId
            ? { deviceId: { exact: rememberedCameraId } }
            : {
                facingMode: { ideal: 'environment' },
                width: { ideal: 1920 },
                height: { ideal: 1080 },
                advanced: [{ focusMode: 'continuous' } as MediaTrackConstraintSet],
              },
          getScanConfig(),
          handleScan,
          () => {},
        );
        if (!rememberedCameraId) {
          getRearCameraId().then((rearCameraId) => rememberCameraId(rearCameraId)).catch(() => {});
        }
        setScannerStatus('Placez le QR code dans l’image, même s’il n’est pas parfaitement centré.');
      } catch {
        await requestCameraPermission();
        const rearCameraId = await getRearCameraId();
        rememberCameraId(rearCameraId);
        await qrScanner.start(
          rearCameraId
            ? { deviceId: { exact: rearCameraId } }
            : { facingMode: 'environment', width: { ideal: 1920 }, height: { ideal: 1080 } },
          getScanConfig(),
          handleScan,
          () => {},
        );
        if (!rearCameraId) {
          getRearCameraId().then((nextCameraId) => rememberCameraId(nextCameraId)).catch(() => {});
        }
        setScannerStatus('Placez le QR code dans l’image, même s’il n’est pas parfaitement centré.');
      }
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Caméra indisponible.';
      setScannerStatus('Caméra non autorisée.');
      showCameraHelp(
        fromUserAction
          ? `${message} Si vous avez refusé, activez la caméra dans les réglages du navigateur puis rechargez la page.`
          : 'Touchez “Autoriser la caméra”, puis acceptez la demande du navigateur.'
      );
    } finally {
      scannerStarting = false;
    }
  }

  function resumeScanner() {
    if (!scannerPaused || !scanner) return;
    scannerPaused = false;
    scanner.resume();
    setScannerStatus('Placez le QR code dans l’image, même s’il n’est pas parfaitement centré.');
  }

  async function handleScan(decodedText: string) {
    if (scannerPaused || !scanner) return;
    scannerPaused = true;
    scanner.pause();
    setScannerStatus('QR code détecté...');
    playBeep('scan');

    try {
      // Le QR contient l'ID client
      const normalized = decodedText.trim();
      const fromUrl = normalized.match(/[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}/i);
      const clientId = fromUrl?.[0] ?? normalized;
      const res = await authFetchWithTimeout(`/api/clients/${clientId}`);
      if (!res.ok) throw new Error('Client introuvable');

      const { data } = await res.json();
      currentClientId = clientId;
      currentClientRecompenses = data.recompenses_obtenues ?? 0;

      document.getElementById('result-nom')!.textContent = data.nom ?? 'Client anonyme';
      document.getElementById('result-solde')!.textContent =
        data.tampons_actuels !== undefined
          ? `${data.tampons_actuels} tampons — ${data.recompenses_obtenues} récompense(s)`
          : `${data.points_actuels} points`;
      document.getElementById('result-rewards')!.textContent = `Récompenses disponibles: ${data.recompenses_obtenues ?? 0}`;
      const rewardBtn = document.getElementById('btn-reward')!;
      rewardBtn.classList.toggle('hidden', currentClientRecompenses <= 0);

      document.getElementById('scan-result')!.classList.remove('hidden');

      // Feedback haptique
      if (navigator.vibrate) navigator.vibrate(100);
    } catch {
      showToast('QR code non reconnu. Réessayez.', 'error');
      resumeScanner();
    }
  }

  // Bouton +1 tampon
  document.getElementById('btn-tampon')!.addEventListener('click', async () => {
    if (!currentClientId) return;
    await addTransaction('ajout_tampon', 1);
  });

  // Bouton +points
  document.getElementById('btn-points')!.addEventListener('click', async () => {
    if (!currentClientId) return;
    document.getElementById('points-modal')!.classList.remove('hidden');
    (document.getElementById('points-value') as HTMLInputElement).focus();
  });

  document.getElementById('btn-reward')!.addEventListener('click', async () => {
    if (!currentClientId || currentClientRecompenses <= 0) return;
    await addTransaction('recompense', 1);
  });

  document.getElementById('btn-cancel-points')!.addEventListener('click', () => {
    document.getElementById('points-modal')!.classList.add('hidden');
  });

  document.getElementById('btn-confirm-points')!.addEventListener('click', async () => {
    const input = document.getElementById('points-value') as HTMLInputElement;
    const valeur = parseInt(input.value);
    if (!Number.isFinite(valeur) || valeur < 1) {
      input.focus();
      return;
    }
    document.getElementById('points-modal')!.classList.add('hidden');
    input.value = '';
    await addTransaction('ajout_points', valeur);
  });

  async function addTransaction(type: string, valeur: number) {
    try {
      const res = await authFetchWithTimeout('/api/transactions', {
        method: 'POST',
        body: JSON.stringify({ client_id: currentClientId, type, valeur }),
      });

      if (!res.ok) throw new Error();

      const data = await res.json();

      // Feedback positif
      if (navigator.vibrate) navigator.vibrate([50, 50, 100]);
      playBeep('success');
      const confirmation = type === 'ajout_tampon'
        ? 'Tampon ajouté avec succès.'
        : type === 'ajout_points'
          ? `${valeur} point${valeur > 1 ? 's' : ''} ajouté${valeur > 1 ? 's' : ''} avec succès.`
          : type === 'recompense'
            ? 'Récompense utilisée avec succès.'
            : 'Action enregistrée avec succès.';
      showToast(confirmation);

      // Confetti si récompense obtenue (dernier tampon ou points atteints)
      const newRecompenses: number = data.client?.recompenses_obtenues ?? currentClientRecompenses;
      if (newRecompenses > currentClientRecompenses) {
        fireRewardConfetti();
      }

      closeResult();
    } catch {
      showToast("Erreur lors de l'ajout. Réessayez.", 'error');
    }
  }

  function fireRewardConfetti() {
    if (!confettiPromise) confettiPromise = import('canvas-confetti');
    const duration = 2500;
    const end = Date.now() + duration;

    const frame = () => {
      confettiPromise?.then((module) => {
        const confetti = module?.default ?? module;
        confetti({
          particleCount: 4,
          angle: 60,
          spread: 55,
          origin: { x: 0, y: 0.7 },
          colors: ['#6366f1', '#a78bfa', '#f59e0b', '#10b981', '#ef4444'],
          zIndex: 9999,
        });
        confetti({
          particleCount: 4,
          angle: 120,
          spread: 55,
          origin: { x: 1, y: 0.7 },
          colors: ['#6366f1', '#a78bfa', '#f59e0b', '#10b981', '#ef4444'],
          zIndex: 9999,
        });
      }).catch(() => {});
      if (Date.now() < end) requestAnimationFrame(frame);
    };
    frame();
  }

  function closeResult() {
    document.getElementById('scan-result')!.classList.add('hidden');
    currentClientId = null;
    currentClientRecompenses = 0;
    resumeScanner();
  }

  document.getElementById('btn-close')!.addEventListener('click', closeResult);
  document.addEventListener('pointerdown', unlockAudio, { once: true });
  document.addEventListener('touchstart', unlockAudio, { once: true });
  cameraPermissionBtn.addEventListener('click', async () => {
    try {
      await ensureScannerAccess();
      await startScanner({ fromUserAction: true });
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Impossible d’activer le scanner.';
      setScannerStatus('Scanner indisponible pour ce téléphone.');
      showCameraHelp(message);
    }
  });

  (async () => {
    try {
      await ensureScannerAccess();
      await startScanner();
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Impossible d’activer le scanner.';
      setScannerStatus('Scanner indisponible pour ce téléphone.');
      showCameraHelp(message);
    }
  })();
</script>
