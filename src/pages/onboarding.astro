---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Bienvenue — Fidelopass">
  <section class="min-h-screen bg-[linear-gradient(180deg,#ffffff_0%,#f5f9ff_62%,#ffffff_100%)] px-4 py-10 sm:py-14 relative overflow-hidden">
    <div class="pointer-events-none absolute -top-20 right-[-10rem] h-[28rem] w-[28rem] rounded-full bg-cyan-200/35 blur-3xl"></div>
    <div class="pointer-events-none absolute bottom-[-8rem] left-[-8rem] h-[24rem] w-[24rem] rounded-full bg-blue-100/80 blur-3xl"></div>

    <div class="max-w-3xl mx-auto">
      <a href="/" class="inline-flex items-center mb-6">
        <img src="/logo-premium-cropped.png" alt="Fidelopass" class="h-14 w-auto object-contain" />
      </a>

      <section class="rounded-[2rem] border border-slate-200 bg-white shadow-[0_20px_50px_rgba(15,23,42,0.08)] p-6 sm:p-8">
        <div class="flex items-center justify-between gap-3 mb-5">
          <div>
            <p class="text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-sky-700/75">Configuration rapide</p>
            <h1 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 mt-2">
              Configurez votre commerce
            </h1>
          </div>
          <div class="hidden sm:flex items-center gap-2">
            <span class="w-9 h-9 rounded-full bg-indigo-600 text-white text-sm font-bold flex items-center justify-center">1</span>
          </div>
        </div>

        <p class="text-slate-500 leading-relaxed mb-6">
          Enregistrez les informations de base. La création de carte se fait ensuite uniquement dans l’onglet Ma carte.
        </p>

        <form id="commerce-form" class="flex flex-col gap-4">
          <div>
            <label class="label" for="nom">Nom du commerce *</label>
            <input id="nom" type="text" class="input" placeholder="Ex: BLF Coffee, Maison Sara, Studio Nova..." required />
          </div>

          <div>
            <label class="label" for="adresse">Adresse complète</label>
            <input id="adresse" type="text" class="input" placeholder="Ex: 12 rue de la Paix, 75001 Paris" />
            <p class="text-slate-500 text-xs mt-1">Utilisée pour la géolocalisation Wallet et les rappels à proximité.</p>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="label" for="telephone">Téléphone</label>
              <input id="telephone" type="tel" class="input" placeholder="06 12 34 56 78" />
            </div>
            <div>
              <label class="label" for="email-commerce">Email de contact</label>
              <input id="email-commerce" type="email" class="input" placeholder="contact@moncommerce.fr" />
            </div>
          </div>

          <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">
            Après validation, vous serez redirigé vers l’onglet Ma carte pour personnaliser le logo, les couleurs, la bannière, le programme points/tampons et les messages client.
          </div>

          <div id="error-commerce" class="hidden text-red-600 text-sm bg-red-50 border border-red-200 rounded-xl px-4 py-3"></div>

          <button type="submit" id="btn-commerce" class="btn-primary w-full py-3 mt-1">
            Enregistrer et ouvrir Ma carte
          </button>
        </form>
      </section>
    </div>
  </section>
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { getAddressPayload, initAddressAutocomplete } from '../lib/address-autocomplete';
  import { withTimeout } from '../lib/utils/with-timeout';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  const API = (import.meta.env.PUBLIC_API_URL || 'https://api.fidelopass.com').replace(/\/$/, '');
  const SESSION_PROBE_TIMEOUT_MS = Number(import.meta.env.PUBLIC_AUTH_SESSION_PROBE_TIMEOUT_MS ?? 900);
  const BILLING_CHECK_TIMEOUT_MS = Number(import.meta.env.PUBLIC_BILLING_CHECK_TIMEOUT_MS ?? 2200);
  const API_FETCH_TIMEOUT_MS = Number(import.meta.env.PUBLIC_API_FETCH_TIMEOUT_MS ?? 3500);

  async function getToken(): Promise<string> {
    const sessionResult = await withTimeout(supabase.auth.getSession(), SESSION_PROBE_TIMEOUT_MS).catch(() => null);
    const session = sessionResult?.data?.session ?? null;
    if (!session) {
      window.location.replace('/login');
      return '';
    }
    return session.access_token;
  }

  async function api(path: string, opts: RequestInit = {}, timeoutMs = API_FETCH_TIMEOUT_MS) {
    const token = await getToken();
    const response = await withTimeout(fetch(`${API}${path}`, {
      ...opts,
      headers: {
        'Content-Type': 'application/json',
        Authorization: `Bearer ${token}`,
        ...(opts.headers ?? {}),
      },
    }), timeoutMs);
    const data = await response.json().catch(() => ({}));
    if (!response.ok) {
      throw new Error(data.error ?? 'Erreur API. Réessayez dans quelques instants.');
    }
    return data;
  }

  const commerceForm = document.getElementById('commerce-form') as HTMLFormElement;
  const errorCommerce = document.getElementById('error-commerce') as HTMLDivElement;
  const button = document.getElementById('btn-commerce') as HTMLButtonElement;
  const adresseInput = document.getElementById('adresse') as HTMLInputElement;
  let commerceExists = false;

  initAddressAutocomplete({ input: adresseInput });

  function showError(message: string) {
    errorCommerce.textContent = message;
    errorCommerce.classList.remove('hidden');
  }

  try {
    const billing = await api('/api/billing/status', {}, BILLING_CHECK_TIMEOUT_MS);
    if (!billing?.data?.has_access) {
      window.location.replace('/abonnement/choix');
    } else if (billing?.data?.onboarding_completed) {
      window.location.replace('/dashboard');
    }

    const existingCommerce = await api('/api/commerces/me');
    if (existingCommerce.data) {
      commerceExists = true;
      (document.getElementById('nom') as HTMLInputElement).value = existingCommerce.data.nom ?? '';
      adresseInput.value = existingCommerce.data.adresse ?? '';
      (document.getElementById('telephone') as HTMLInputElement).value = existingCommerce.data.telephone ?? '';
      (document.getElementById('email-commerce') as HTMLInputElement).value = existingCommerce.data.email ?? '';
    }
  } catch (error) {
    showError(error instanceof Error ? error.message : 'Impossible de vérifier votre compte.');
  }

  commerceForm.addEventListener('submit', async (event) => {
    event.preventDefault();
    errorCommerce.classList.add('hidden');

    button.disabled = true;
    button.textContent = 'Enregistrement...';

    const payload = {
      nom: (document.getElementById('nom') as HTMLInputElement).value,
      adresse: adresseInput.value || null,
      ...getAddressPayload(adresseInput),
      telephone: (document.getElementById('telephone') as HTMLInputElement).value || null,
      email: (document.getElementById('email-commerce') as HTMLInputElement).value || null,
      onboarding_completed: true,
    };

    try {
      if (commerceExists) {
        await api('/api/commerces/me', {
          method: 'PATCH',
          body: JSON.stringify(payload),
        });
      } else {
        await api('/api/commerces', {
          method: 'POST',
          body: JSON.stringify(payload),
        });
      }

      window.location.href = '/dashboard/carte?setup=1';
    } catch (error) {
      showError(error instanceof Error ? error.message : 'Erreur lors de la création du commerce.');
      button.disabled = false;
      button.textContent = 'Continuer';
    }
  });
</script>
