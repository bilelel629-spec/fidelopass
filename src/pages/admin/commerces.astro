---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Commerces — Admin Fidelopass" activeNav="commerces">
  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.26em] text-sky-700/70">Administration</p>
      <h1 class="font-display text-3xl font-bold text-slate-900 mt-2">Tous les commerces</h1>
      <p class="text-slate-600 text-sm mt-2">Consultez les commerces inscrits, leur activité et leur statut d’accès.</p>
    </div>
  </div>

  <!-- Filtres -->
  <div class="flex gap-3 mb-6">
    <input id="search" type="search" class="input max-w-xs" placeholder="Rechercher un commerce..." />
    <select id="filter-statut" class="input max-w-40">
      <option value="">Tous les statuts</option>
      <option value="actif">Actifs</option>
      <option value="inactif">Inactifs</option>
    </select>
  </div>

  <div class="card overflow-hidden">
    <div id="commerces-table">
      <p class="text-slate-500 text-sm p-6">Chargement...</p>
    </div>
  </div>
</AdminLayout>

<script>
  let allCommerces: Array<{
    id: string; nom: string; adresse: string | null; email: string | null;
    telephone: string | null; actif: boolean; created_at: string;
    cartes: unknown[]; clients: unknown[];
  }> = [];

  async function authFetch(url: string, opts: RequestInit = {}) {
    const { supabase } = await import('../../lib/supabase');
    const { data: { session } } = await supabase.auth.getSession();
    return fetch(url, {
      ...opts,
      headers: {
        ...(opts.headers ?? {}),
        Authorization: `Bearer ${session?.access_token ?? ''}`,
        'Content-Type': 'application/json',
      },
    });
  }

  async function loadCommerces() {
    const container = document.getElementById('commerces-table')!;
    try {
      const res = await authFetch(`${import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001'}/api/admin/commerces`);
      if (!res.ok) throw new Error();
      const { data } = await res.json();
      allCommerces = data ?? [];
      renderTable(allCommerces);
    } catch {
      container.innerHTML = '<p class="text-red-400 text-sm p-6">Erreur lors du chargement.</p>';
    }
  }

  function renderTable(data: typeof allCommerces) {
    const container = document.getElementById('commerces-table')!;
    if (!data.length) {
      container.innerHTML = '<p class="text-slate-500 text-sm p-6">Aucun commerce trouvé.</p>';
      return;
    }

    container.innerHTML = `
      <table class="w-full">
        <thead class="border-b border-slate-200">
          <tr class="text-left">
            <th class="px-6 py-3 text-slate-500 text-xs uppercase tracking-wide">Commerce</th>
            <th class="px-6 py-3 text-slate-500 text-xs uppercase tracking-wide">Contact</th>
            <th class="px-6 py-3 text-slate-500 text-xs uppercase tracking-wide">Carte</th>
            <th class="px-6 py-3 text-slate-500 text-xs uppercase tracking-wide">Clients</th>
            <th class="px-6 py-3 text-slate-500 text-xs uppercase tracking-wide">Abonnement</th>
            <th class="px-6 py-3 text-slate-500 text-xs uppercase tracking-wide">Statut</th>
            <th class="px-6 py-3 text-slate-500 text-xs uppercase tracking-wide">Inscrit</th>
            <th class="px-6 py-3 text-slate-500 text-xs uppercase tracking-wide">Action</th>
          </tr>
        </thead>
        <tbody>
          ${data.map((c) => `
            <tr class="border-b border-slate-200 last:border-0 hover:bg-sky-50 transition-colors">
              <td class="px-6 py-4">
                <p class="text-slate-900 text-sm font-medium">${c.nom}</p>
                <p class="text-slate-500 text-xs">${c.adresse ?? '—'}</p>
              </td>
              <td class="px-6 py-4 text-slate-600 text-sm">
                <p>${c.email ?? '—'}</p>
                <p>${c.telephone ?? '—'}</p>
              </td>
              <td class="px-6 py-4">
                ${(c.cartes as unknown[]).length > 0
                  ? '<span class="badge badge-success">Configurée</span>'
                  : '<span class="badge bg-slate-100 text-slate-500 border border-slate-200">Non</span>'
                }
              </td>
              <td class="px-6 py-4 font-mono text-sky-700 text-sm">${(c.clients as unknown[]).length}</td>
              <td class="px-6 py-4">
                <span class="badge bg-slate-100 text-slate-600 border border-slate-200">À configurer</span>
              </td>
              <td class="px-6 py-4">
                ${c.actif
                  ? '<span class="badge badge-success">Actif</span>'
                  : '<span class="badge badge-danger">Inactif</span>'
                }
              </td>
              <td class="px-6 py-4 text-slate-600 text-sm">
                ${new Date(c.created_at).toLocaleDateString('fr-FR')}
              </td>
              <td class="px-6 py-4">
                <button
                  onclick="toggleCommerce('${c.id}', ${!c.actif})"
                  class="text-xs px-3 py-1.5 rounded-lg border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors"
                >${c.actif ? 'Désactiver' : 'Activer'}</button>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  }

  async function toggleCommerce(id: string, actif: boolean) {
    await authFetch(
      `${import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001'}/api/admin/commerces/${id}`,
      { method: 'PATCH', body: JSON.stringify({ actif }) },
    );
    await loadCommerces();
  }

  (window as unknown as Record<string, unknown>).toggleCommerce = toggleCommerce;

  // Filtres en temps réel
  function applyFilters() {
    const search = (document.getElementById('search') as HTMLInputElement).value.toLowerCase();
    const statut = (document.getElementById('filter-statut') as HTMLSelectElement).value;

    const filtered = allCommerces.filter((c) => {
      const matchSearch = !search
        || c.nom.toLowerCase().includes(search)
        || (c.email ?? '').toLowerCase().includes(search);
      const matchStatut = !statut
        || (statut === 'actif' && c.actif)
        || (statut === 'inactif' && !c.actif);
      return matchSearch && matchStatut;
    });
    renderTable(filtered);
  }

  document.getElementById('search')!.addEventListener('input', applyFilters);
  document.getElementById('filter-statut')!.addEventListener('change', applyFilters);

  loadCommerces();
</script>
