---
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// Lire l'URL de l'API au runtime (SSR) — pas baked au build comme PUBLIC_*
const apiUrl = (process.env.API_URL ?? import.meta.env.PUBLIC_API_URL ?? 'https://api.fidelopass.com').replace(/\/$/, '');

// Bannière "nouvel utilisateur" après inscription
const isNew = Astro.url.searchParams.get('new') === '1';

const priceIds = {
  starter_mensuel: 'price_1TLUSO7qMJeoJ4KrrIxG6TI3',
  starter_annuel:  'price_1TLUSO7qMJeoJ4KrqScU0Tfw',
  pro_mensuel:     'price_1TLUSP7qMJeoJ4Kr6jqRgTDw',
  pro_annuel:      'price_1TLUSP7qMJeoJ4KrszNXoiBO',
  accompagnement:  'price_1TLUSQ7qMJeoJ4KrYRnAjiPT',
};

const faq = [
  { q: 'Y a-t-il un engagement minimum ?', a: 'Non. Les plans mensuels sont sans engagement. Vous pouvez annuler à tout moment depuis votre espace client, sans frais ni pénalité.' },
  { q: "Comment fonctionne l'essai gratuit ?", a: "Vous créez votre compte sans carte bancaire. Pendant 14 jours, vous configurez votre carte et votre scanner librement. À la fin, votre espace passe en lecture seule tant que vous n'avez pas choisi de plan." },
  { q: "Quelle est la différence entre mensuel et annuel ?", a: "L'abonnement annuel vous fait économiser environ 17% par rapport au mensuel. Il est facturé en une seule fois pour 12 mois." },
  { q: 'Puis-je changer de plan ?', a: 'Oui, vous pouvez évoluer ou rétrograder à tout moment. Les changements sont effectifs immédiatement.' },
  { q: "Mes clients doivent-ils télécharger une app ?", a: "Non. Vos clients utilisent Apple Wallet ou Google Wallet, déjà installés sur leur téléphone. Aucun téléchargement supplémentaire." },
];
---

<BaseLayout
  theme="light"
  title="Tarifs Fidelopass — Essai gratuit 14 jours sans carte bancaire"
  description="Plans Starter et Pro pour commerces. Essai gratuit 14 jours sans carte bancaire."
>
  <meta id="api-config" data-url={apiUrl} />
  <PublicNav currentPath="/pricing" />

  <!-- Bannière nouvel utilisateur -->
  {isNew && (
    <div class="bg-indigo-600 text-white text-center py-3 px-4">
      <p class="text-sm font-medium">
        🎉 Compte créé avec succès ! Choisissez votre plan pour commencer votre essai gratuit.
      </p>
    </div>
  )}

  <!-- Header -->
  <section class="relative overflow-hidden bg-[linear-gradient(180deg,#ffffff_0%,#f5f9ff_65%,#ffffff_100%)] pt-14 pb-12">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-20 right-0 h-72 w-72 rounded-full bg-sky-200/35 blur-3xl"></div>
      <div class="absolute top-12 left-0 h-64 w-64 rounded-full bg-indigo-200/25 blur-3xl"></div>
    </div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <span class="mb-5 inline-flex items-center rounded-full border border-sky-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-sky-700 shadow-sm">Tarifs Fidelopass</span>
      <h1 class="font-display text-5xl sm:text-6xl font-bold text-slate-900 leading-tight">
        Des tarifs simples,<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-violet-500">sans mauvaise surprise.</span>
      </h1>
      <p class="text-slate-500 text-lg mt-5 max-w-xl mx-auto">
        Essai gratuit 14 jours sur tous les plans. Aucune carte bancaire requise.
      </p>

      <!-- Toggle mensuel / annuel -->
      <div class="inline-flex items-center gap-1 mt-8 rounded-2xl border border-slate-200 bg-white/90 p-1.5 shadow-sm">
        <button id="toggle-monthly" type="button" class="px-5 py-2 rounded-xl text-sm font-semibold transition-all bg-white text-slate-900 shadow-sm">
          Mensuel
        </button>
        <button id="toggle-annual" type="button" class="px-5 py-2 rounded-xl text-sm font-medium transition-all text-slate-500">
          Annuel
          <span class="ml-1.5 rounded-full bg-emerald-100 text-emerald-700 text-xs px-2 py-0.5 font-semibold">-17%</span>
        </button>
      </div>
    </div>
  </section>

  <!-- Plans -->
  <section class="bg-slate-50/70 py-10 pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-3 gap-6 items-start">

        <!-- Starter -->
        <article class="rounded-[2rem] border border-slate-200 bg-white shadow-[0_20px_50px_rgba(15,23,42,0.08)] flex flex-col p-8">
          <div class="inline-flex items-center gap-2 mb-3">
            <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Starter Indépendant</span>
          </div>
          <div class="flex items-end gap-1 mb-3">
            <span class="font-display font-bold leading-none text-slate-900">
              <span class="text-4xl monthly-price" data-monthly="29" data-annual="24" id="starter-display">29€</span>
            </span>
            <span class="text-sm mb-1 text-slate-400">/mois</span>
          </div>
          <div class="mb-4 inline-flex items-center gap-1.5 rounded-full bg-sky-50 border border-sky-100 px-3 py-1.5 text-xs font-semibold text-sky-700 w-fit">
            <span>🎁</span> 14 jours gratuits
          </div>
          <p class="text-sm leading-relaxed mb-6 text-slate-500">Pour lancer votre première carte et commencer à fidéliser.</p>

          <button
            type="button"
            class="checkout-btn w-full inline-flex items-center justify-center py-3 rounded-xl font-semibold text-sm transition-all mb-8 btn-primary"
            data-price-monthly={priceIds.starter_mensuel}
            data-price-annual={priceIds.starter_annuel}
            data-mode="subscription"
          >
            Démarrer l'essai gratuit
          </button>

          <ul class="space-y-3 flex-1">
            {[
              "Jusqu'à 500 cartes actives",
              '1 point de vente',
              '3 scanners inclus',
              'Apple Wallet + Google Wallet',
              'Scanner mobile + affiche QR',
              'Notifications push illimitées',
              'Carte tampons, points, VIP',
              "Campagnes SMS (crédits à l'achat)",
              'Analytics de base',
              'Support email',
              '5€ / scanner supplémentaire',
            ].map((f) => (
              <li class="flex items-center gap-3 text-sm">
                <span class="w-5 h-5 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center text-xs font-bold flex-shrink-0">✓</span>
                <span class="text-slate-700">{f}</span>
              </li>
            ))}
          </ul>
        </article>

        <!-- Pro -->
        <article class="rounded-[2rem] border border-indigo-400 bg-[linear-gradient(155deg,#1e1b4b_0%,#312e81_62%,#0284c7_100%)] shadow-[0_30px_80px_rgba(49,46,129,0.24)] flex flex-col p-8 relative">
          <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
            <span class="rounded-full bg-amber-400 text-amber-900 text-xs font-bold px-4 py-1.5 shadow whitespace-nowrap">
              ⭐ Le plus populaire
            </span>
          </div>
          <div class="inline-flex items-center gap-2 mb-3">
            <span class="text-xs font-bold uppercase tracking-widest text-indigo-200">Commerce Pro</span>
          </div>
          <div class="flex items-end gap-1 mb-3">
            <span class="font-display font-bold leading-none text-white">
              <span class="text-4xl monthly-price" data-monthly="59" data-annual="49" id="pro-display">59€</span>
            </span>
            <span class="text-sm mb-1 text-indigo-200">/mois</span>
          </div>
          <div class="mb-4 inline-flex items-center gap-1.5 rounded-full bg-white/15 border border-white/20 px-3 py-1.5 text-xs font-semibold text-white w-fit">
            <span>🎁</span> 14 jours gratuits
          </div>
          <p class="text-sm leading-relaxed mb-6 text-indigo-200">Pour fidéliser plus fort et communiquer avec vos clients.</p>

          <button
            type="button"
            class="checkout-btn w-full inline-flex items-center justify-center py-3 rounded-xl font-semibold text-sm transition-all mb-8 bg-white text-indigo-700 hover:bg-indigo-50 shadow"
            data-price-monthly={priceIds.pro_mensuel}
            data-price-annual={priceIds.pro_annuel}
            data-mode="subscription"
          >
            Démarrer l'essai gratuit
          </button>

          <ul class="space-y-3 flex-1">
            {[
              "Jusqu'à 2000 cartes actives",
              '3 points de vente',
              '6 scanners inclus',
              'Apple Wallet + Google Wallet',
              'Scanner mobile + affiche QR',
              'Push ciblées & campagnes',
              'Campagne avis Google',
              "Campagnes SMS (crédits à l'achat)",
              'Analytics avancés',
              'Anniversaire automatique',
              'Support prioritaire',
              '5€ / scanner supplémentaire',
            ].map((f) => (
              <li class="flex items-center gap-3 text-sm">
                <span class="w-5 h-5 rounded-full bg-white/20 text-white flex items-center justify-center text-xs font-bold flex-shrink-0">✓</span>
                <span class="text-indigo-100">{f}</span>
              </li>
            ))}
          </ul>
        </article>

        <!-- Sur mesure -->
        <article class="rounded-[2rem] border border-slate-200 bg-white shadow-[0_20px_50px_rgba(15,23,42,0.08)] flex flex-col p-8">
          <div class="inline-flex items-center gap-2 mb-3">
            <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Réseau & Franchise</span>
          </div>
          <div class="flex items-end gap-1 mb-3">
            <span class="font-display font-bold leading-none text-slate-900 text-4xl">Sur devis</span>
          </div>
          <div class="mb-4 inline-flex items-center gap-1.5 rounded-full bg-violet-50 border border-violet-100 px-3 py-1.5 text-xs font-semibold text-violet-700 w-fit">
            <span>✦</span> Solution sur mesure
          </div>
          <p class="text-sm leading-relaxed mb-6 text-slate-500">Pour les réseaux, franchises et groupes avec plusieurs enseignes.</p>

          <a
            href="/contact"
            class="w-full inline-flex items-center justify-center py-3 rounded-xl font-semibold text-sm transition-all mb-8 border-2 border-slate-900 text-slate-900 hover:bg-slate-900 hover:text-white"
          >
            Nous contacter
          </a>

          <ul class="space-y-3 flex-1">
            {[
              'Points de vente illimités',
              'Cartes actives illimitées',
              'Scanners illimités',
              'Apple Wallet + Google Wallet',
              'Push ciblées & campagnes',
              'Campagnes SMS incluses',
              'API + intégrations caisse',
              'Accompagnement personnalisé',
              'Support prioritaire dédié',
            ].map((f) => (
              <li class="flex items-center gap-3 text-sm">
                <span class="w-5 h-5 rounded-full bg-violet-100 text-violet-600 flex items-center justify-center text-xs font-bold flex-shrink-0">✓</span>
                <span class="text-slate-700">{f}</span>
              </li>
            ))}
          </ul>
        </article>
      </div>

      <p class="text-center text-slate-400 text-xs mt-8">Prix HT. TVA applicable selon votre situation.</p>

      <!-- Option Accompagnement -->
      <div class="mt-14 max-w-md mx-auto">
        <h2 class="font-display text-2xl font-bold text-slate-900 mb-6 text-center">Option à la carte</h2>
        <div class="rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-sm flex flex-col gap-3">
          <div>
            <p class="font-semibold text-slate-900">Accompagnement Setup</p>
            <p class="text-slate-500 text-sm mt-1 leading-relaxed">Aide à la configuration, paramétrage initial et mise en ligne de votre première carte par notre équipe.</p>
          </div>
          <div class="flex items-end justify-between gap-3 mt-auto pt-2">
            <div>
              <span class="font-display text-2xl font-bold text-slate-900">20€</span>
              <span class="text-slate-400 text-sm ml-1">une fois</span>
            </div>
            <button
              type="button"
              class="checkout-btn rounded-xl border border-slate-200 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors"
              data-price-monthly={priceIds.accompagnement}
              data-price-annual={priceIds.accompagnement}
              data-mode="payment"
            >
              Ajouter
            </button>
          </div>
        </div>
      </div>

      <!-- Message d'erreur checkout -->
      <div id="checkout-error" class="hidden mt-6 rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-red-600 text-sm text-center"></div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">Questions fréquentes</h2>
      </div>
      <div class="space-y-3" id="pricing-faq">
        {faq.map((item, i) => (
          <div class="bg-white rounded-[1.5rem] border border-slate-200 overflow-hidden shadow-sm" data-faq={i}>
            <button class="w-full px-6 py-5 text-left flex items-center justify-between gap-4" aria-expanded="false">
              <span class="font-semibold text-slate-900 text-sm sm:text-base">{item.q}</span>
              <span class="faq-icon text-slate-400 text-xl flex-shrink-0 font-light">+</span>
            </button>
            <div class="faq-answer hidden px-6 pb-5">
              <p class="text-slate-500 text-sm leading-relaxed">{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[linear-gradient(135deg,#0f172a_0%,#312e81_55%,#0284c7_100%)] py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-4xl font-bold text-white">Commencez votre essai gratuit</h2>
      <p class="text-indigo-200 text-lg mt-4">14 jours offerts. Aucune carte bancaire.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/register" class="inline-flex items-center justify-center bg-white text-indigo-700 font-bold px-8 py-4 rounded-xl hover:bg-indigo-50 transition-colors text-base shadow-lg">
          Démarrer l'essai gratuit
        </a>
        <a href="/contact" class="inline-flex items-center justify-center bg-white/10 text-white font-medium px-8 py-4 rounded-xl hover:bg-white/20 border border-white/20 transition-colors text-base">
          Contacter l'équipe
        </a>
      </div>
    </div>
  </section>

  <PublicFooter />
</BaseLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );

  // ── Toggle mensuel / annuel ───────────────────────────────────────────
  const monthlyBtn = document.getElementById('toggle-monthly') as HTMLButtonElement;
  const annualBtn  = document.getElementById('toggle-annual')  as HTMLButtonElement;
  let currentMode: 'monthly' | 'annual' = 'monthly';

  function setMode(mode: 'monthly' | 'annual') {
    currentMode = mode;
    const isAnnual = mode === 'annual';

    monthlyBtn.className = isAnnual
      ? 'px-5 py-2 rounded-xl text-sm font-medium transition-all text-slate-500'
      : 'px-5 py-2 rounded-xl text-sm font-semibold transition-all bg-white text-slate-900 shadow-sm';
    annualBtn.className = isAnnual
      ? 'px-5 py-2 rounded-xl text-sm font-semibold transition-all bg-white text-slate-900 shadow-sm'
      : 'px-5 py-2 rounded-xl text-sm font-medium transition-all text-slate-500';

    document.querySelectorAll('.monthly-price').forEach((el) => {
      const monthly = el.getAttribute('data-monthly');
      const annual  = el.getAttribute('data-annual');
      (el as HTMLElement).textContent = (isAnnual ? annual : monthly) + '€';
    });
  }

  monthlyBtn.addEventListener('click', () => setMode('monthly'));
  annualBtn.addEventListener('click',  () => setMode('annual'));
  setMode('monthly');

  // ── Checkout ──────────────────────────────────────────────────────────
  // Lire l'URL depuis la meta tag injectée par le serveur SSR (runtime, pas build-time)
  const API = (document.getElementById('api-config') as HTMLMetaElement)?.dataset.url ?? '';
  const errorEl = document.getElementById('checkout-error') as HTMLDivElement;

  async function startCheckout(btn: HTMLElement) {
    const priceMonthly = btn.dataset.priceMonthly ?? '';
    const priceAnnual  = btn.dataset.priceAnnual  ?? '';
    const mode = (btn.dataset.mode ?? 'subscription') as 'subscription' | 'payment';
    const priceId = (mode === 'payment' || priceMonthly === priceAnnual)
      ? priceMonthly
      : currentMode === 'annual' ? priceAnnual : priceMonthly;

    errorEl.classList.add('hidden');
    const origText = (btn as HTMLButtonElement).textContent ?? '';
    (btn as HTMLButtonElement).disabled = true;
    (btn as HTMLButtonElement).textContent = 'Redirection…';

    // Vérifie si connecté
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      window.location.href = `/login?redirect=${encodeURIComponent(window.location.pathname)}`;
      return;
    }

    try {
      const res = await fetch(`${API}/api/checkout/create-session`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${session.access_token}`,
        },
        body: JSON.stringify({ priceId, mode }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error ?? 'Erreur serveur');
      window.location.href = data.url;
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : 'Erreur lors de la création du paiement.';
      errorEl.classList.remove('hidden');
      (btn as HTMLButtonElement).disabled = false;
      (btn as HTMLButtonElement).textContent = origText;
    }
  }

  document.querySelectorAll('.checkout-btn').forEach((btn) => {
    btn.addEventListener('click', () => startCheckout(btn as HTMLElement));
  });

  // ── FAQ ───────────────────────────────────────────────────────────────
  document.querySelectorAll('#pricing-faq [data-faq]').forEach((item) => {
    const btn    = item.querySelector('button') as HTMLButtonElement;
    const answer = item.querySelector('.faq-answer') as HTMLDivElement;
    const icon   = item.querySelector('.faq-icon') as HTMLSpanElement;
    btn.addEventListener('click', () => {
      const open = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      answer.classList.toggle('hidden', open);
      icon.textContent = open ? '+' : '×';
    });
  });
</script>
