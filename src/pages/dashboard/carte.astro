  }

  async function applyPendingMediaResizes() {
    if (logoUrl && Math.abs(logoScale - 1) > 0.001) {
      logoUrl = await uploadScaledImageFromUrl(logoUrl, 512, 512, logoScale, 'logo');
      setLogoPreview(logoUrl);
      setLogoScale(1);
    }
    if (stripUrl && Math.abs(stripScale - 1) > 0.001) {
      stripUrl = await uploadScaledImageFromUrl(stripUrl, 750, 246, stripScale, 'banniere', stripFocusX, stripFocusY);
      setStripPreview(stripUrl);
      setStripScale(1);
    }
  }

  async function persistCard(advance: boolean) {
    const err=document.getElementById('error-msg') as HTMLDivElement;
    const suc=document.getElementById('success-msg') as HTMLDivElement;
    err.classList.add('hidden');
    suc.classList.add('hidden');
    isSaving = true;
    updateWizardActions();
    const saveDraftButtons = [
      document.getElementById('save-draft-btn'),
      document.getElementById('mobile-save-draft-btn'),
    ].filter(Boolean) as HTMLButtonElement[];
    const saveContinueButtons = [
      document.getElementById('save-continue-btn'),
      document.getElementById('mobile-save-continue-btn'),
    ].filter(Boolean) as HTMLButtonElement[];
    const originalDraft = saveDraftButtons.map((button) => button.textContent ?? '');
    const originalContinue = saveContinueButtons.map((button) => button.textContent ?? '');
    saveDraftButtons.forEach((button) => {
      button.textContent = 'Enregistrement...';
    });
    saveContinueButtons.forEach((button) => {
      button.textContent = 'Enregistrement...';
    });

    const hadExistingCard = !!carteId;
    try{
      await applyPendingMediaResizes();
      const payload = buildPayload();
      const res=carteId
        ? await authFetch(`/api/cartes/${carteId}`,{method:'PATCH',body:JSON.stringify(payload)})
        : await authFetch('/api/cartes',{method:'POST',body:JSON.stringify(payload)});
      if(!res.ok) throw new Error((await res.json()).error??'Erreur');

      await authFetch('/api/commerces/me', {
        method: 'PATCH',
        body: JSON.stringify({
          rayon_geo: parseInt((document.getElementById('rayon-geo') as HTMLInputElement).value, 10),
          adresse: (document.getElementById('adresse-commerce') as HTMLInputElement).value || null,
        }),
      });

      const { data } = await res.json();
      if(!carteId){
        carteId=data.id;
        const pu=publicCardUrl(data.id);
        document.getElementById('public-link-banner')!.classList.remove('hidden');
        document.getElementById('public-link-url')!.textContent=pu;
      }
      if (carteId) {
        updateQrTools(carteId);
        updateScannerTools();
      }

      if (setupMode && !hadExistingCard) {
        document.getElementById('setup-banner')!.classList.add('hidden');
        window.history.replaceState({}, '', '/dashboard/carte');
      }

      savedProgramType = payload.type === 'points' ? 'points' : 'tampons';
      if (typeChangePendingRevalidation && currentStep >= 3) {
        typeChangePendingRevalidation = false;
      }
      markStepCompleted(currentStep);
      setMaxUnlockedStep(Math.max(maxUnlockedStep, currentStep + 1));
      if (carteId) {
        if (typeChangePendingRevalidation) {
          setMaxUnlockedStep(3);
        } else {
          setMaxUnlockedStep(TOTAL_STEPS);
        }
      }

      setDraftState(false, true);
      suc.textContent = !hadExistingCard && setupMode
        ? 'Carte créée avec succès. Votre carte est opérationnelle en caisse.'
        : 'Carte enregistrée avec succès.';
      suc.classList.remove('hidden');

      if (advance) {
        clearStepError(currentStep);
        const nextStep = currentStep < TOTAL_STEPS ? (currentStep + 1) : TOTAL_STEPS;
        setMaxUnlockedStep(Math.max(maxUnlockedStep, nextStep));
        showStep(nextStep);
      }
    }catch(e:unknown){
      err.textContent=e instanceof Error?e.message:'Erreur inattendue.';
      err.classList.remove('hidden');
    } finally {
      isSaving = false;
      saveDraftButtons.forEach((button, index) => {
        button.textContent = originalDraft[index] ?? 'Enregistrer le brouillon';
      });
      saveContinueButtons.forEach((button, index) => {
        button.textContent = originalContinue[index] ?? 'Enregistrer et continuer';
      });
      updateWizardActions();
    }
  }

  async function handleSaveDraft() {
    await persistCard(false);
  }

  async function handleSaveContinue() {
    const validation = stepValidators[currentStep]();
    if (validation) {
      showStepError(currentStep, validation);
      return;
    }
    clearStepError(currentStep);
    await persistCard(true);
  }

  document.getElementById('save-draft-btn')!.addEventListener('click', handleSaveDraft);
  document.getElementById('mobile-save-draft-btn')!.addEventListener('click', handleSaveDraft);
  document.getElementById('save-continue-btn')!.addEventListener('click', handleSaveContinue);
  document.getElementById('mobile-save-continue-btn')!.addEventListener('click', handleSaveContinue);

  document.getElementById('download-qr-btn')!.addEventListener('click', async () => {
    if (!carteId) return;
    const button = document.getElementById('download-qr-btn') as HTMLButtonElement;
    const original = button.textContent;
    button.disabled = true;
    button.textContent = 'Téléchargement...';
    try {
      const response = await fetch(qrImageUrl(carteId, 1200));
      const blob = await response.blob();
      const url = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;
      link.download = `fidelopass-qr-${carteId}.png`;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(url);
      button.textContent = 'QR téléchargé';
    } catch {
      button.textContent = 'Erreur';
    } finally {
      setTimeout(() => {
        button.disabled = false;
        button.textContent = original;
      }, 1800);
    }
  });

  const rayonSlider = document.getElementById('rayon-geo') as HTMLInputElement;
  const rayonLabel = document.getElementById('rayon-label')!;
  rayonSlider.addEventListener('input', () => {
    rayonLabel.textContent = `${parseInt(rayonSlider.value).toLocaleString('fr-FR')} m`;
  });

  async function loadCommerceGeo() {
    try {
      const res = await authFetch('/api/commerces/me');
      if (!res.ok) return;
      const { data } = await res.json();
      const activePointName = (document.getElementById('active-point-name') as HTMLSpanElement | null);
      if (activePointName) {
        activePointName.textContent = data?.point_vente_nom ?? data?.nom ?? 'Principal';
      }
      const rayon = data?.rayon_geo ?? 1000;
      (document.getElementById('adresse-commerce') as HTMLInputElement).value = data?.adresse ?? '';
      rayonSlider.value = String(rayon);
      rayonLabel.textContent = `${rayon.toLocaleString('fr-FR')} m`;
      if (data?.adresse) setGeoToggle(true, true);
    } catch {}
  }

  // ── Restrictions par plan ──────────────────────────────────────────
  async function loadPlanRestrictions() {
    try {
      const res = await authFetch('/api/dashboard/plan');
      if (!res.ok) return;
      const { data } = await res.json();
      const planRaw = String(data?.plan ?? data?.raw_plan ?? 'starter').trim().toLowerCase();
      const isStarter = planRaw === 'starter' || planRaw.startsWith('starter-') || planRaw.includes('starter');
      isProPlan = planRaw === 'pro' || planRaw.startsWith('pro-') || planRaw.includes('pro');

      if (isStarter) {
        brandingToggle.disabled = true;
        brandingToggle.classList.add('opacity-40', 'cursor-not-allowed');
        brandingUpgradeMsg.classList.remove('hidden');
        setBrandingEnabled(true, { silent: true });
      } else {
        brandingToggle.disabled = false;
        brandingToggle.classList.remove('opacity-40', 'cursor-not-allowed');
        brandingUpgradeMsg.classList.add('hidden');
        brandingProBadge.classList.add('hidden');
      }

      // Afficher compteur de cartes si proche de la limite
      const { clientsCount, limits } = data;
      if (clientsCount >= Math.floor(limits.maxClients * 0.8)) {
        const bar = document.getElementById('error-msg') as HTMLDivElement | null;
        const infoMsg = document.createElement('div');
        infoMsg.className = 'text-amber-600 text-sm bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 mb-4';
        infoMsg.textContent = `${clientsCount} / ${limits.maxClients} cartes actives utilisées sur votre plan ${isProPlan ? 'pro' : 'starter'}.`;
        bar?.parentNode?.insertBefore(infoMsg, bar);
      }
    } catch { /* silencieux */ }
  }

  registerDirtyTracking();
  setAppearancePanel('theme');
  setLogoScale(1);
  setStripScale(1);
  setStripFocus(50, 50, { silent: true });
  setMultiRewardsEnabled(false, { silent: true });
  setBrandingEnabled(true, { silent: true });
  updatePushIconPreview();
  updatePreview();
  applyTypeUI('tampons');
  applyStripStyle();
  renderRewardTiers();
  renderVipTiers();
  updateScannerTools();
  showStep(1);

  (async () => {
    await Promise.all([
      loadCommerceGeo(),
      loadExistingCarte(),
      loadPlanRestrictions(),
    ]);
    suppressDirtyTracking = false;
    setDraftState(false);
    updateWizardActions();
  })();
</script>
