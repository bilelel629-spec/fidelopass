---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
---

<BaseLayout
  theme="light"
  title="Comment ça fonctionne — Fidelopass"
  description="Découvrez comment Fidelopass permet de créer, diffuser et activer une carte de fidélité Apple Wallet et Google Wallet dans un parcours simple et concret."
>
  <PublicNav currentPath="/comment-ca-fonctionne" />

  <section class="relative overflow-hidden bg-[linear-gradient(180deg,#ffffff_0%,#f5f9ff_62%,#ffffff_100%)] pt-12 pb-14 sm:pt-14 sm:pb-16">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-16 right-0 h-72 w-72 rounded-full bg-sky-200/30 blur-3xl"></div>
      <div class="absolute top-20 left-0 h-64 w-64 rounded-full bg-indigo-200/20 blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <span class="mb-5 inline-flex items-center rounded-full border border-sky-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-sky-700 shadow-sm">Guide complet</span>
      <h1 class="font-display text-5xl sm:text-6xl font-bold text-slate-900 leading-tight">
        Comment ça fonctionne ?
      </h1>
      <p class="text-slate-500 text-lg leading-relaxed mt-6 max-w-2xl mx-auto">
        De la création de votre carte à la fidélisation de vos clients, Fidelopass vous aide à mettre en place un parcours simple, rapide et crédible pour votre commerce.
      </p>
    </div>
  </section>

  <section class="bg-slate-50/70 py-14 sm:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 space-y-14">

      <div class="grid lg:grid-cols-[0.96fr_1.04fr] gap-8 lg:gap-10 items-center">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-950 text-sm font-bold text-white shadow-[0_14px_30px_rgba(15,23,42,0.16)]">01</div>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Création</span>
          </div>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 leading-tight">
            Créez une carte fidèle à votre commerce
          </h2>
          <p class="text-slate-500 leading-relaxed mt-4">
            Depuis votre tableau de bord, vous choisissez le bon format de programme puis vous adaptez la carte à votre image. L’objectif est d’avoir un outil clair pour le client et immédiatement exploitable pour le commerce.
          </p>
          <div class="space-y-3 mt-6">
            {[
              { title: 'Carte à tampons', text: 'Le format le plus intuitif pour les commerces de passage : cafés, snacks, boulangeries, restauration rapide.' },
              { title: 'Carte à points', text: 'Idéal pour les paniers variables ou les commerces qui veulent récompenser la fréquence de visite.' },
              { title: 'Carte VIP', text: 'Créez des niveaux Bronze, Silver ou Gold pour valoriser les meilleurs clients et renforcer la récurrence.' },
            ].map((item) => (
              <div class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-white p-4 text-sm shadow-sm">
                <span class="mt-1 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-indigo-500"></span>
                <div>
                  <p class="font-semibold text-slate-900">{item.title}</p>
                  <p class="mt-1 text-slate-500">{item.text}</p>
                </div>
              </div>
            ))}
          </div>
          <p class="text-slate-400 text-sm mt-5">
            Vous personnalisez ensuite la carte : couleurs, logo, récompense, message d’accueil et règles de fidélité.
          </p>
        </div>

        <div class="rounded-[2rem] border border-white/80 bg-white p-6 shadow-[0_25px_60px_rgba(15,23,42,0.08)]">
          <div class="mb-4 flex items-center justify-between gap-3">
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">Écran réel Fidelopass</p>
            <span class="rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-sky-700">Personnalisation</span>
          </div>
          <figure class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100/80 shadow-sm p-2">
            <img src="/images/how-it-works/etape-dashboard-premium.png" alt="Configuration de carte dans Fidelopass" class="h-full w-full object-contain rounded-xl" loading="lazy" />
          </figure>
          <p class="mt-3 text-xs text-slate-500">L’éditeur guidé permet de configurer type de programme, identité et récompense en quelques étapes.</p>
        </div>
      </div>

      <div class="grid lg:grid-cols-[0.96fr_1.04fr] gap-8 lg:gap-10 items-center lg:[&>*:first-child]:order-2">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-950 text-sm font-bold text-white shadow-[0_14px_30px_rgba(15,23,42,0.16)]">02</div>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Diffusion</span>
          </div>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 leading-tight">
            Diffusez la carte là où vos clients décident
          </h2>
          <p class="text-slate-500 leading-relaxed mt-4">
            Une fois la carte prête, vous obtenez immédiatement les bons supports pour la faire circuler : en boutique, sur un comptoir, sur une vitrine ou via un lien partagé sur vos canaux habituels.
          </p>
          <div class="space-y-3 mt-6">
            {[
              { title: 'Affiche A4 à imprimer', desc: 'Un support clair avec QR code prêt à poser en caisse ou à afficher en vitrine.' },
              { title: 'Lien d’inscription partageable', desc: 'SMS, Instagram, email, WhatsApp ou site web : la carte peut être diffusée partout facilement.' },
              { title: 'Ajout immédiat dans le Wallet', desc: 'Le client scanne, remplit ses informations et ajoute sa carte sans téléchargement supplémentaire.' },
            ].map((item) => (
              <div class="flex items-start gap-4 rounded-2xl border border-slate-200 bg-white p-4 text-sm shadow-sm">
                <span class="mt-1 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-sky-500"></span>
                <div>
                  <p class="font-semibold text-slate-900">{item.title}</p>
                  <p class="text-slate-500 mt-1">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-[2rem] border border-white/80 bg-white p-6 shadow-[0_25px_60px_rgba(15,23,42,0.08)]">
          <div class="mb-4 flex items-center justify-between gap-3">
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">Écran réel client</p>
            <span class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-emerald-700">Ajout Wallet</span>
          </div>
          <figure class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100/80 shadow-sm p-2">
            <img src="/images/how-it-works/etape-diffusion-premium.png" alt="Affiche QR Fidelopass installée en commerce" class="h-full w-full object-contain rounded-xl" loading="lazy" />
          </figure>
          <p class="mt-3 text-xs text-slate-500">Le client scanne, complète son prénom et son téléphone, puis ajoute la carte directement dans son Wallet.</p>
        </div>
      </div>

      <div class="grid lg:grid-cols-[0.96fr_1.04fr] gap-8 lg:gap-10 items-center">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-950 text-sm font-bold text-white shadow-[0_14px_30px_rgba(15,23,42,0.16)]">03</div>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-slate-500">Activation</span>
          </div>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 leading-tight">
            Scannez, récompensez et relancez
          </h2>
          <p class="text-slate-500 leading-relaxed mt-4">
            À chaque visite, vous scannez la carte depuis votre téléphone. Le solde du client se met à jour, la récompense devient visible et vous gardez un vrai suivi des passages.
          </p>
          <div class="space-y-3 mt-6">
            {[
              { title: 'Scanner intégré', desc: 'Le commerçant valide un passage ou une récompense en quelques secondes depuis son téléphone.' },
              { title: 'Récompense automatique', desc: 'Dès que l’objectif est atteint, la carte affiche la récompense côté client sans manipulation compliquée.' },
              { title: 'Messages clients', desc: 'Vous pouvez relancer, informer ou remercier vos clients avec des messages visibles et directement utiles.' },
              { title: 'Suivi d’activité', desc: 'Le tableau de bord regroupe cartes actives, passages, récompenses et performances par programme.' },
            ].map((item) => (
              <div class="flex items-start gap-4 rounded-2xl border border-slate-200 bg-white p-4 text-sm shadow-sm">
                <span class="mt-1 h-2.5 w-2.5 flex-shrink-0 rounded-full bg-emerald-500"></span>
                <div>
                  <p class="font-semibold text-slate-900">{item.title}</p>
                  <p class="text-slate-500 mt-1">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="space-y-4 rounded-[2rem] border border-white/80 bg-white p-6 shadow-[0_25px_60px_rgba(15,23,42,0.08)]">
          <div class="flex items-center justify-between gap-3">
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">Écran réel en caisse</p>
            <span class="rounded-full border border-violet-200 bg-violet-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-violet-700">Carte active</span>
          </div>
          <figure class="mx-auto max-w-[340px] overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 shadow-sm">
            <img src="/images/how-it-works/etape-wallet.jpeg" alt="Carte fidélité affichée dans le Wallet client" class="h-full w-full object-cover" loading="lazy" />
          </figure>
          <p class="text-xs text-slate-500">Après chaque scan, le solde et les récompenses se mettent à jour côté client, sans application à installer.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-14 sm:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">Pourquoi ça marche</h2>
        <p class="mt-3 text-slate-500 text-base sm:text-lg max-w-2xl mx-auto">
          Fidelopass réduit la friction côté client et transforme chaque visite en opportunité de retour mesurable.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { value: '+27%', title: 'de rétention en moyenne', label: 'Une carte toujours présente dans le téléphone du client crée un réflexe de retour beaucoup plus fort.' },
          { value: '20 sec', title: 'pour ajouter la carte', label: 'Le parcours client est suffisamment simple pour convertir immédiatement en boutique.' },
          { value: '0 app', title: 'à télécharger côté client', label: 'Moins de friction, plus d’adoption et beaucoup moins d’abandon au moment du scan.' },
          { value: '5 min', title: 'pour lancer votre première carte', label: 'Le commerce peut être opérationnel très vite, sans setup technique complexe.' },
        ].map((stat) => (
          <div class="rounded-[1.75rem] border border-slate-200 bg-white p-7 shadow-[0_18px_45px_rgba(15,23,42,0.06)]">
            <p class="font-display text-4xl font-bold text-indigo-600">{stat.value}</p>
            <p class="text-slate-900 font-semibold text-base mt-2 leading-snug">{stat.title}</p>
            <p class="text-slate-500 text-sm mt-3 leading-relaxed">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[linear-gradient(135deg,#0f172a_0%,#312e81_55%,#0284c7_100%)] py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-4xl font-bold text-white">
        Prêt à commencer ?
      </h2>
      <p class="text-indigo-200 text-lg mt-4">
        Essai gratuit 14 jours. Aucune carte bancaire. Prêt en 5 minutes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/register" class="inline-flex items-center justify-center bg-white text-indigo-700 font-bold px-8 py-4 rounded-xl hover:bg-indigo-50 transition-colors text-base shadow-lg">
          Démarrer l'essai gratuit
        </a>
        <a href="/pricing" class="inline-flex items-center justify-center bg-white/10 text-white font-medium px-8 py-4 rounded-xl hover:bg-white/20 border border-white/20 transition-colors text-base">
          Voir les tarifs
        </a>
      </div>
    </div>
  </section>

  <PublicFooter />
</BaseLayout>
