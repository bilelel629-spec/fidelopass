<script>
  import { authFetch } from '../../lib/api';
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
  const API = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001';
  const PUBLIC_SITE_URL = (import.meta.env.PUBLIC_SITE_URL ?? 'https://www.fidelopass.com').replace(/\/$/, '');
  const setupMode = new URLSearchParams(window.location.search).get('setup') === '1';
  const TOTAL_STEPS = 7;
  const STEP_LABELS = ['Type', 'Identité', 'Programme', 'Apparence', 'Messages', 'Options', 'Partage'] as const;
  const STEP_TITLES = [
    'Type de programme',
    'Identité visuelle',
    'Programme fidélité',
    'Apparence',
    'Messages client',
    'Options',
    'Scanner & Partage',
  ] as const;
  const STEP_GUIDANCE = [
    {
      title: 'Choisissez le socle du programme',
      text: 'Tampons: le plus simple en caisse. Points: plus flexible pour offres évolutives.',
      required: 'Obligatoire: type de programme',
    },
    {
      title: 'Posez votre identité',
      text: 'Nom clair + logo bien centré = carte reconnue instantanément par le client.',
      required: 'Obligatoire: nom de carte',
    },
    {
      title: 'Définissez la promesse client',
      text: 'Fixez un objectif atteignable et une récompense qui donne envie de revenir vite.',
      required: 'Obligatoire: configuration programme + récompense',
    },
    {
      title: 'Habillez la carte en mode simple',
      text: 'Commencez par thème + bannière + QR. Les options avancées restent optionnelles.',
      required: 'Obligatoire: aucun (design libre)',
    },
    {
      title: 'Rassurez le client avec des messages courts',
      text: 'Un accueil clair et un message post-ajout augmentent l’activation de la carte.',
      required: 'Obligatoire: aucun',
    },
    {
      title: 'Activez la proximité si utile',
      text: 'Géolocalisation: renseignez une adresse précise et un message utile en passage boutique.',
      required: 'Obligatoire si activé: adresse du commerce',
    },
    {
      title: 'Passez en mode opérationnel',
      text: 'Installez le scanner équipe puis affichez le QR client en caisse.',
      required: 'Obligatoire: carte déjà enregistrée',
    },
  ] as const;

  let carteId: string | null = null;
  let logoUrl = '', stripUrl = '', tamponIconUrl = '', tamponEmoji = '';
  let logoScale = 1;
  let stripScale = 1;
  let stripFocusX = 50;
  let stripFocusY = 50;
  let isGradient = false;
  type WizardStep = 1 | 2 | 3 | 4 | 5 | 6 | 7;
  let currentStep: WizardStep = 1;
  let maxUnlockedStep: WizardStep = 1;
  let savedProgramType: 'tampons' | 'points' | null = null;
  let typeChangePendingRevalidation = false;
  let isDirty = false;
  let isSaving = false;
  let suppressDirtyTracking = true;
  let multiRewardsEnabled = false;
  let brandingEnabled = true;
  let isProPlan = false;
  let previewMobileOpen = false;
  let stepSheetOpen = false;
  const completedSteps = new Set<WizardStep>();
  type RewardTier = { seuil: number; recompense: string };
  type VipTier = { nom: string; seuil: number; avantage?: string };

  function setDraftState(dirty: boolean, force = false) {
    if (!force && (suppressDirtyTracking || isSaving)) return;
    isDirty = dirty;
    const state = document.getElementById('draft-state');
    const mobileDraft = document.getElementById('mobile-save-draft-btn') as HTMLButtonElement | null;
    if (mobileDraft) {
      mobileDraft.textContent = dirty ? 'Brouillon à sauvegarder' : 'Brouillon OK';
    }
    if (!state) return;
    if (dirty) {
      state.textContent = 'Brouillon non enregistré';
      state.className = 'rounded-xl border border-amber-200 bg-amber-50 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-amber-700';
    } else {
      state.textContent = 'Brouillon enregistré';
      state.className = 'rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-emerald-700';
    }
  }

  function markDirty() {
    if (suppressDirtyTracking || isSaving) return;
    if (!isDirty) setDraftState(true);
  }

  function publicCardUrl(id: string) {
    return `${PUBLIC_SITE_URL}/carte/${id}`;
  }

  function posterUrl(id: string, template: string) {
    return `${PUBLIC_SITE_URL}/poster/${id}?template=${encodeURIComponent(template)}`;
  }

  function qrImageUrl(id: string, size = 768) {
    return `https://api.qrserver.com/v1/create-qr-code/?size=${size}x${size}&data=${encodeURIComponent(publicCardUrl(id))}&bgcolor=ffffff&color=111827&qzone=1`;
  }

  function scannerInstallUrl() {
    return `${PUBLIC_SITE_URL}/app/install`;
  }

  function ensureQr(containerId: string, url: string, size = 150) {
    const container = document.getElementById(containerId);
    if (!container) return;
    container.innerHTML = '';
    const image = document.createElement('img');
    image.src = `https://api.qrserver.com/v1/create-qr-code/?size=${size}x${size}&data=${encodeURIComponent(url)}&bgcolor=ffffff&color=111827&qzone=1`;
    image.className = 'rounded-xl';
    image.width = size;
    image.height = size;
    container.appendChild(image);
  }

  function updateQrTools(id: string) {
    (document.getElementById('poster-link-essential') as HTMLAnchorElement).href = posterUrl(id, 'essential');
    (document.getElementById('poster-link-signature') as HTMLAnchorElement).href = posterUrl(id, 'signature');
    ensureQr('qr-container', publicCardUrl(id));
  }

  function updateScannerTools() {
    const installLink = document.getElementById('scanner-install-link') as HTMLAnchorElement | null;
    if (installLink) installLink.href = scannerInstallUrl();
    ensureQr('scanner-qr-container', scannerInstallUrl());
  }

