---
import '../styles/global.css';
import DashboardNav from '../components/dashboard/DashboardNav.astro';

interface Props {
  title?: string;
  activeNav?: string;
}

const { title = 'Dashboard — Fidelopass', activeNav = '' } = Astro.props;
---

<!doctype html>
<html lang="fr" class="dashboard">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f5f9ff" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-[#f5f9ff] text-slate-900 antialiased">
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -top-28 right-[-8rem] h-[28rem] w-[28rem] rounded-full bg-cyan-200/45 blur-3xl"></div>
      <div class="absolute top-1/3 left-[-9rem] h-[24rem] w-[24rem] rounded-full bg-blue-100/80 blur-3xl"></div>
      <div class="absolute inset-x-0 top-0 h-44 bg-gradient-to-b from-white/80 to-transparent"></div>
    </div>
    <div class="flex min-h-screen lg:h-screen overflow-hidden">
      <DashboardNav activeNav={activeNav} />
      <main class="relative z-10 flex-1 min-w-0 overflow-y-auto pb-24 lg:pb-0">
        <div class="p-4 sm:p-6 md:p-8 pt-24 lg:pt-8 max-w-7xl mx-auto">
          <div
            id="dashboard-global-card-actions"
            class="hidden mb-6 rounded-[1.2rem] border border-sky-100 bg-white/95 p-4 shadow-[0_18px_48px_-36px_rgba(59,130,246,0.35)]"
          >
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="text-[0.64rem] font-semibold uppercase tracking-[0.24em] text-sky-700/70">Actions rapides</p>
                <p class="mt-1 text-sm text-slate-600">Votre carte est active. Accédez instantanément au QR client et à l’installation scanner.</p>
              </div>
              <div class="flex flex-wrap gap-2">
                <a
                  id="global-client-qr-btn"
                  href="#"
                  target="_blank"
                  rel="noreferrer"
                  class="rounded-2xl border border-sky-200 bg-white px-4 py-2.5 text-sm font-medium text-sky-700 transition hover:border-sky-300 hover:bg-sky-50"
                >
                  Afficher le QR client
                </a>
                <a
                  href="/app/install"
                  class="rounded-2xl bg-sky-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-sky-700"
                >
                  Ajouter un scanner
                </a>
              </div>
            </div>
          </div>
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>

<script>
  import { createClient } from '@supabase/supabase-js';
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
  );
  const API = (import.meta.env.PUBLIC_API_URL ?? '').trim();
  const ACTIVE_POINT_VENTE_STORAGE_KEY = 'fidelopass_active_point_vente_id';

  async function loadGlobalCardActions(accessToken) {
    if (window.location.pathname === '/dashboard') return;
    const container = document.getElementById('dashboard-global-card-actions');
    const qrBtn = document.getElementById('global-client-qr-btn');
    if (!container || !qrBtn || !API) return;

    try {
      const res = await fetch(`${API}/api/cartes`, {
        headers: {
          Authorization: `Bearer ${accessToken}`,
          'Content-Type': 'application/json',
          ...(typeof window !== 'undefined' && window.localStorage.getItem(ACTIVE_POINT_VENTE_STORAGE_KEY)
            ? { 'X-Point-Vente-Id': String(window.localStorage.getItem(ACTIVE_POINT_VENTE_STORAGE_KEY)) }
            : {}),
        },
      });
      if (!res.ok) return;
      const payload = await res.json().catch(() => null);
      const cardId = payload?.data?.id;
      if (!cardId) return;
      qrBtn.href = `/poster/${cardId}?template=premium`;
      container.classList.remove('hidden');
    } catch {
      // Affichage best-effort.
    }
  }

  const { data: { session } } = await supabase.auth.getSession();
  if (!session) {
    window.location.replace('/login');
  } else {
    const billing = await fetch(`${API}/api/billing/status`, {
      headers: {
        Authorization: `Bearer ${session.access_token}`,
        'Content-Type': 'application/json',
      },
    }).then((r) => r.json()).catch(() => ({}));

    if (!billing?.data?.has_access) {
      window.location.replace('/abonnement/choix');
    } else if (!billing?.data?.onboarding_completed) {
      window.location.replace('/onboarding');
    } else {
      await loadGlobalCardActions(session.access_token);
    }
  }
</script>
