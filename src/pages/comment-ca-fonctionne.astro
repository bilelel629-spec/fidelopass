---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicFooter from '../components/marketing/PublicFooter.astro';
import PublicNav from '../components/marketing/PublicNav.astro';
---

<BaseLayout
  theme="light"
  title="Comment ça fonctionne — Fidelopass"
  description="Découvrez en détail comment Fidelopass vous permet de créer et gérer une carte de fidélité Apple Wallet et Google Wallet en 3 étapes simples."
>
  <PublicNav currentPath="/comment-ca-fonctionne" />

  <!-- Header -->
  <section class="bg-white pt-16 pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <span class="badge badge-info mb-5">Guide complet</span>
      <h1 class="font-display text-5xl sm:text-6xl font-bold text-slate-900 leading-tight">
        Comment ça fonctionne ?
      </h1>
      <p class="text-slate-500 text-lg leading-relaxed mt-6 max-w-2xl mx-auto">
        De la création de votre carte à la fidélisation de vos clients — voici le parcours complet,
        étape par étape.
      </p>
    </div>
  </section>

  <!-- ÉTAPES DÉTAILLÉES -->
  <section class="bg-slate-50 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 space-y-20">

      <!-- Étape 1 -->
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-indigo-50 flex items-center justify-center text-3xl">🎨</div>
            <span class="font-mono text-sm font-bold text-indigo-400 tracking-widest">ÉTAPE 01</span>
          </div>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 leading-tight">
            Créez votre carte de fidélité en 5 minutes
          </h2>
          <p class="text-slate-500 leading-relaxed mt-4">
            Depuis votre tableau de bord, choisissez le type de programme qui correspond à votre activité,
            puis personnalisez l'apparence de votre carte.
          </p>
          <div class="space-y-3 mt-6">
            {[
              { icon: '🃏', text: 'Carte à tampons — le format le plus intuitif (café, boulangerie, snack)' },
              { icon: '⭐', text: 'Carte à points — idéal pour les paniers variables (restaurant, boutique)' },
              { icon: '👑', text: 'Carte VIP / paliers — Bronze, Silver, Gold pour les commerces premium' },
            ].map((item) => (
              <div class="flex items-start gap-3 text-sm text-slate-600 bg-white rounded-xl border border-slate-100 p-4">
                <span class="text-lg">{item.icon}</span>
                <span>{item.text}</span>
              </div>
            ))}
          </div>
          <p class="text-slate-400 text-sm mt-5">
            Personnalisez : couleurs, logo, emoji tampons, message de bienvenue, message de récompense.
          </p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Éditeur de carte</p>
          <div class="space-y-3">
            <div class="rounded-xl bg-slate-50 border border-slate-100 p-4">
              <p class="text-xs text-slate-400 mb-1">Nom de la carte</p>
              <p class="font-semibold text-slate-900">Carte Fidélité Café Lumière</p>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div class="rounded-xl bg-slate-50 border border-slate-100 p-4">
                <p class="text-xs text-slate-400 mb-1">Type</p>
                <p class="font-semibold text-slate-900">☕ Tampons</p>
              </div>
              <div class="rounded-xl bg-slate-50 border border-slate-100 p-4">
                <p class="text-xs text-slate-400 mb-1">Objectif</p>
                <p class="font-semibold text-slate-900">10 tampons</p>
              </div>
            </div>
            <div class="grid grid-cols-3 gap-2">
              {['#312e81', '#0f766e', '#f59e0b'].map((c) => (
                <div class="rounded-xl h-10 border-2 border-white shadow-sm" style={`background:${c}`}></div>
              ))}
            </div>
            <div class="rounded-xl bg-indigo-600 text-white text-sm font-semibold text-center py-3">
              ✓ Carte prête — Générer le QR
            </div>
          </div>
        </div>
      </div>

      <!-- Étape 2 -->
      <div class="grid lg:grid-cols-2 gap-12 items-center lg:[&>*:first-child]:order-2">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-amber-50 flex items-center justify-center text-3xl">📲</div>
            <span class="font-mono text-sm font-bold text-amber-500 tracking-widest">ÉTAPE 02</span>
          </div>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 leading-tight">
            Partagez en boutique ou en ligne
          </h2>
          <p class="text-slate-500 leading-relaxed mt-4">
            Une fois votre carte créée, vous obtenez deux outils de distribution : une affiche QR à imprimer
            et un lien à partager.
          </p>
          <div class="space-y-3 mt-6">
            {[
              { icon: '🖨️', title: 'Affiche A4 à imprimer', desc: 'QR code + texte d\'invitation à poser sur votre comptoir ou coller en vitrine.' },
              { icon: '🔗', title: 'Lien d\'inscription', desc: 'Partagez par SMS, email, Instagram, WhatsApp — vos clients ajoutent leur carte en 20 secondes.' },
              { icon: '📲', title: 'Ajout au Wallet immédiat', desc: 'Votre client scanne → remplit son prénom → ajoute la carte à Apple Wallet ou Google Wallet.' },
            ].map((item) => (
              <div class="flex items-start gap-4 text-sm bg-white rounded-xl border border-slate-100 p-4">
                <span class="text-2xl">{item.icon}</span>
                <div>
                  <p class="font-semibold text-slate-900">{item.title}</p>
                  <p class="text-slate-400 mt-0.5">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Aperçu affiche QR</p>
          <div class="bg-slate-50 rounded-2xl border border-dashed border-slate-300 p-8 text-center">
            <div class="w-28 h-28 bg-slate-900 rounded-xl mx-auto flex items-center justify-center text-white text-xs font-mono p-2">
              <div class="grid grid-cols-7 gap-px w-full h-full opacity-80">
                {Array.from({ length: 49 }).map((_, i) => (
                  <div class={`rounded-[1px] ${Math.random() > 0.5 ? 'bg-white' : 'bg-transparent'}`}></div>
                ))}
              </div>
            </div>
            <p class="font-display text-lg font-bold text-slate-900 mt-4">Café Lumière</p>
            <p class="text-slate-500 text-sm mt-1">Scannez pour obtenir votre carte de fidélité</p>
            <p class="text-xs text-slate-400 mt-3">⬇ Ajout immédiat dans Apple Wallet & Google Wallet</p>
          </div>
        </div>
      </div>

      <!-- Étape 3 -->
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-2xl bg-emerald-50 flex items-center justify-center text-3xl">✅</div>
            <span class="font-mono text-sm font-bold text-emerald-500 tracking-widest">ÉTAPE 03</span>
          </div>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 leading-tight">
            Scannez, récompensez et relancez
          </h2>
          <p class="text-slate-500 leading-relaxed mt-4">
            À chaque visite, vous scannez la carte de votre client depuis votre téléphone.
            La carte se met à jour automatiquement dans son Wallet.
          </p>
          <div class="space-y-3 mt-6">
            {[
              { icon: '📸', title: 'Scanner intégré', desc: 'Ouvrez le scanner depuis votre téléphone, scannez la carte du client — c\'est tout.' },
              { icon: '🎉', title: 'Récompense automatique', desc: 'Quand le client atteint son objectif, la récompense s\'affiche et se distribue automatiquement.' },
              { icon: '🔔', title: 'Notifications push', desc: 'Envoyez un message à tous vos clients ou aux inactifs depuis 30 jours pour les faire revenir.' },
              { icon: '📊', title: 'Tableau de bord', desc: 'Suivez les passages, cartes actives et récompenses depuis un dashboard clair.' },
            ].map((item) => (
              <div class="flex items-start gap-4 text-sm bg-white rounded-xl border border-slate-100 p-4">
                <span class="text-2xl">{item.icon}</span>
                <div>
                  <p class="font-semibold text-slate-900">{item.title}</p>
                  <p class="text-slate-400 mt-0.5">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm space-y-4">
          <p class="text-xs font-semibold uppercase tracking-widest text-slate-400">Tableau de bord</p>
          <div class="grid grid-cols-2 gap-3">
            {[
              { label: 'Cartes actives', value: '248', trend: '+12 ce mois' },
              { label: 'Scans cette semaine', value: '67', trend: '+8%' },
              { label: 'Récompenses données', value: '31', trend: 'ce mois' },
              { label: 'Clients push actifs', value: '183', trend: '74%' },
            ].map((stat) => (
              <div class="bg-slate-50 rounded-xl border border-slate-100 p-4">
                <p class="text-xs text-slate-400">{stat.label}</p>
                <p class="font-display text-2xl font-bold text-slate-900 mt-1">{stat.value}</p>
                <p class="text-emerald-500 text-xs mt-0.5">{stat.trend}</p>
              </div>
            ))}
          </div>
          <div class="bg-indigo-50 border border-indigo-100 rounded-xl p-4">
            <p class="text-indigo-700 font-semibold text-sm">🔔 Campagne push envoyée</p>
            <p class="text-indigo-500 text-xs mt-1">183 clients notifiés · 12 visites générées</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RÉSUMÉ CHIFFRES CLÉS -->
  <section class="bg-white py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-slate-900">Pourquoi ça marche</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { value: '+27%', label: 'de rétention clients en moyenne' },
          { value: '20 sec', label: 'pour ajouter la carte au Wallet' },
          { value: '0', label: 'application à télécharger' },
          { value: '5 min', label: 'pour créer votre première carte' },
        ].map((stat) => (
          <div class="bg-slate-50 rounded-2xl border border-slate-100 p-7 text-center">
            <p class="font-display text-4xl font-bold text-indigo-600">{stat.value}</p>
            <p class="text-slate-500 text-sm mt-2 leading-snug">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-indigo-600 py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-display text-4xl font-bold text-white">
        Prêt à commencer ?
      </h2>
      <p class="text-indigo-200 text-lg mt-4">
        Essai gratuit 15 jours. Aucune carte bancaire. Prêt en 5 minutes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
        <a href="/register" class="inline-flex items-center justify-center bg-white text-indigo-700 font-bold px-8 py-4 rounded-xl hover:bg-indigo-50 transition-colors text-base shadow-lg">
          Démarrer l'essai gratuit
        </a>
        <a href="/pricing" class="inline-flex items-center justify-center bg-white/10 text-white font-medium px-8 py-4 rounded-xl hover:bg-white/20 border border-white/20 transition-colors text-base">
          Voir les tarifs
        </a>
      </div>
    </div>
  </section>

  <PublicFooter />
</BaseLayout>
