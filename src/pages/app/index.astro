---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Scanner — Fidelopass">
  <div class="min-h-[100dvh] flex flex-col items-center justify-center px-6 py-10">
    <div class="text-center mb-10">
      <img src="/logo.svg" alt="Fidelopass" class="h-14 w-auto" />
      <p class="text-slate-400 text-sm mt-2">Espace commerçant</p>
    </div>

    <a href="/app/scan" class="btn-primary w-full max-w-xs py-5 text-center text-lg flex items-center justify-center gap-3">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" />
      </svg>
      Scanner un client
    </a>

    <div class="card w-full max-w-xs p-4 mt-5 text-left">
      <p class="text-white font-semibold text-sm">Ajouter comme application</p>
      <p class="text-slate-400 text-xs leading-relaxed mt-2">
        Sur iPhone : ouvrez cette page dans Safari, touchez le bouton de partage, puis “Sur l’écran d’accueil”.
      </p>
      <p class="text-slate-400 text-xs leading-relaxed mt-2">
        Sur Android : ouvrez le menu du navigateur, puis “Installer l’application” ou “Ajouter à l’écran d’accueil”.
      </p>
    </div>
  </div>
</AppLayout>
