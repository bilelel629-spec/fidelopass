---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Installer le scanner — Fidelopass">
  <div class="min-h-[100dvh] px-6 py-8 max-w-4xl mx-auto">
    <a href="/app" class="inline-flex items-center gap-2 text-slate-500 text-sm hover:text-slate-900 transition-colors">
      <span>←</span>
      <span>Retour à l’espace scan</span>
    </a>

    <div class="mt-6 card p-6 sm:p-8">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="text-slate-500 text-xs uppercase tracking-[0.3em]">Installation rapide</p>
          <h1 class="font-display text-3xl sm:text-4xl font-bold text-slate-900 mt-4">Ajoutez le scanner à l’écran d’accueil</h1>
          <p class="text-slate-600 text-sm sm:text-base mt-4 leading-relaxed max-w-2xl">
            L’objectif est simple : ouvrir le scanner comme une application, sans devoir retaper l’adresse du site à chaque passage en caisse.
          </p>
        </div>
        <div class="rounded-[28px] border border-sky-100 bg-white p-3 shadow-[0_28px_60px_-36px_rgba(59,130,246,0.45)]">
          <img src="/favicon.png" alt="Icône Fidelopass pour l’écran d’accueil" class="h-24 w-24 rounded-[22px]" />
        </div>
      </div>

      <div class="mt-8 grid gap-5 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="rounded-2xl border border-sky-100 bg-sky-50 p-5">
          <p class="text-sm font-semibold text-slate-900">C’est cette icône qui sera ajoutée sur le téléphone</p>
          <p class="text-slate-600 text-sm mt-2 leading-relaxed">
            Une fois l’installation terminée, le personnel ouvre directement le scanner depuis cette icône Fidelopass.
          </p>
        </div>
        <div class="rounded-2xl border border-indigo-100 bg-white p-5 shadow-[0_18px_48px_-34px_rgba(79,70,229,0.35)]">
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
            <div class="shrink-0 rounded-2xl border border-slate-200 bg-white p-2">
              <img id="scanner-install-qr" src="" alt="QR code pour installer le scanner Fidelopass" class="h-36 w-36 rounded-xl" />
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-900">QR code à scanner sur le téléphone de caisse</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">
                Scannez ce QR avec le téléphone du personnel, connectez-vous si nécessaire, puis ajoutez le scanner à l’écran d’accueil.
              </p>
              <a id="scanner-install-link" href="/app/install" class="mt-3 inline-flex text-sm font-semibold text-sky-700 hover:text-sky-900">
                Ouvrir le lien d’installation
              </a>
            </div>
          </div>
        </div>
      </div>

      <div id="scanner-quota-card" class="rounded-2xl border border-sky-100 bg-white p-5 mt-6">
        <div class="flex flex-col gap-1.5 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-sm font-semibold text-slate-900">Quota scanners</p>
          <span id="scanner-plan-badge" class="rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-sky-700">Chargement…</span>
        </div>
        <p id="scanner-usage" class="mt-3 text-sm text-slate-700">Chargement du quota…</p>
        <p id="scanner-remaining" class="mt-1 text-xs text-slate-500"></p>
        <p id="scanner-limit-msg" class="hidden mt-3 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-700"></p>
        <div class="mt-4 flex flex-col gap-2 sm:flex-row">
          <button id="scanner-register-btn" type="button" class="btn-primary px-4 py-2.5 text-sm">
            Enregistrer ce téléphone comme scanner
          </button>
          <a href="/dashboard/parametres" class="btn-secondary px-4 py-2.5 text-sm text-center">
            Voir / upgrader mon plan
          </a>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-5 mt-8">
        <div class="rounded-2xl border border-sky-100 bg-sky-50 p-5">
          <p class="text-slate-900 font-semibold">Sur iPhone</p>
          <ol class="mt-4 space-y-3 text-sm text-slate-700 list-decimal list-inside">
            <li>Ouvrez <span class="font-medium text-slate-900">Safari</span> sur <span class="font-medium text-slate-900">www.fidelopass.com/app</span>.</li>
            <li>Touchez le bouton <span class="font-medium text-slate-900">Partager</span>.</li>
            <li>Choisissez <span class="font-medium text-slate-900">Sur l’écran d’accueil</span>.</li>
            <li>Validez : l’icône Fidelopass apparaîtra sur le téléphone.</li>
          </ol>
          <p class="text-slate-500 text-xs mt-4">Safari est recommandé sur iPhone pour un accès caméra plus fiable.</p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-5">
          <p class="text-slate-900 font-semibold">Sur Android</p>
          <ol class="mt-4 space-y-3 text-sm text-slate-700 list-decimal list-inside">
            <li>Ouvrez <span class="font-medium text-slate-900">Chrome</span> sur <span class="font-medium text-slate-900">www.fidelopass.com/app</span>.</li>
            <li>Ouvrez le menu du navigateur.</li>
            <li>Choisissez <span class="font-medium text-slate-900">Installer l’application</span> ou <span class="font-medium text-slate-900">Ajouter à l’écran d’accueil</span>.</li>
            <li>Validez pour garder le scanner à portée de main.</li>
          </ol>
          <p class="text-slate-500 text-xs mt-4">Une fois installé, le scanner s’ouvre plus vite et se comporte comme une app légère.</p>
        </div>
      </div>

      <div class="rounded-2xl border border-indigo-200 bg-indigo-50 p-5 mt-6">
        <p class="text-slate-900 font-semibold">Conseil comptoir</p>
        <p class="text-slate-600 text-sm mt-2 leading-relaxed">
          Installez l’icône sur le téléphone utilisé en caisse, autorisez la caméra une seule fois, puis gardez simplement l’écran scan prêt à l’usage.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-3 mt-6">
        <a id="open-scanner-link" href="/app/scan" class="btn-primary px-6 py-3 text-center">Ouvrir le scanner</a>
        <a href="/app" class="btn-secondary px-6 py-3 text-center">Retour à l’espace commerçant</a>
      </div>
    </div>
  </div>
</AppLayout>

<script>
  import { authFetch } from '../../lib/api';

  const SCANNER_TOKEN_KEY = 'fidelopass_scanner_token';
  const registerBtn = document.getElementById('scanner-register-btn') as HTMLButtonElement;
  const planBadge = document.getElementById('scanner-plan-badge') as HTMLSpanElement;
  const usageText = document.getElementById('scanner-usage') as HTMLParagraphElement;
  const remainingText = document.getElementById('scanner-remaining') as HTMLParagraphElement;
  const limitMsg = document.getElementById('scanner-limit-msg') as HTMLParagraphElement;
  const openScannerLink = document.getElementById('open-scanner-link') as HTMLAnchorElement;
  const scannerInstallQr = document.getElementById('scanner-install-qr') as HTMLImageElement | null;
  const scannerInstallLink = document.getElementById('scanner-install-link') as HTMLAnchorElement | null;

  function setupInstallQr() {
    const installUrl = `${window.location.origin}/app/install`;
    if (scannerInstallLink) scannerInstallLink.href = installUrl;
    if (scannerInstallQr) {
      scannerInstallQr.src = `https://api.qrserver.com/v1/create-qr-code/?size=420x420&data=${encodeURIComponent(installUrl)}&bgcolor=ffffff&color=111827&qzone=1`;
    }
  }

  function getScannerToken() {
    let token = localStorage.getItem(SCANNER_TOKEN_KEY);
    if (!token) {
      token = `${crypto.randomUUID()}-${Date.now()}`;
      localStorage.setItem(SCANNER_TOKEN_KEY, token);
    }
    return token;
  }

  function setScannerBlocked(blocked: boolean, message = '') {
    openScannerLink.classList.toggle('pointer-events-none', blocked);
    openScannerLink.classList.toggle('opacity-50', blocked);
    registerBtn.disabled = blocked;
    if (message) {
      limitMsg.textContent = message;
      limitMsg.classList.remove('hidden');
    } else {
      limitMsg.classList.add('hidden');
    }
  }

  async function loadScannerStatus() {
    const token = getScannerToken();
    const res = await authFetch(`/api/scanners/status?scanner_token=${encodeURIComponent(token)}`);
    if (!res.ok) throw new Error('Impossible de charger le quota scanner.');
    const payload = await res.json();
    const data = payload?.data;
    if (!data) throw new Error('Réponse scanner invalide.');

    const plan = String(data.plan ?? 'starter').trim().toLowerCase();
    const isPro = plan === 'pro' || plan.startsWith('pro-') || plan.includes('pro');
    planBadge.textContent = isPro ? 'Pro' : 'Starter';
    planBadge.className = isPro
      ? 'rounded-full border border-violet-200 bg-violet-50 px-2.5 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-violet-700'
      : 'rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.16em] text-sky-700';

    usageText.textContent = `${data.current_scanners} scanner(s) actif(s) sur ${data.max_scanners} disponibles.`;
    remainingText.textContent = data.registered_for_token
      ? 'Ce téléphone est déjà enregistré comme scanner.'
      : `${data.remaining_scanners} emplacement(s) scanner restant(s).`;

    if (data.registered_for_token) {
      registerBtn.textContent = 'Téléphone déjà enregistré';
      registerBtn.disabled = true;
      setScannerBlocked(false);
      return;
    }

    if (data.remaining_scanners <= 0) {
      registerBtn.textContent = 'Limite atteinte';
      setScannerBlocked(true, `Vous avez atteint la limite de ${data.max_scanners} scanners sur ce plan.`);
      return;
    }

    registerBtn.textContent = 'Enregistrer ce téléphone comme scanner';
    registerBtn.disabled = false;
    setScannerBlocked(false);
  }

  registerBtn.addEventListener('click', async () => {
    const token = getScannerToken();
    const userAgentPlatform = (navigator as Navigator & { userAgentData?: { platform?: string } }).userAgentData?.platform;
    const deviceName = (userAgentPlatform ?? navigator.userAgent ?? 'Téléphone').slice(0, 120);
    registerBtn.disabled = true;
    const previous = registerBtn.textContent;
    registerBtn.textContent = 'Enregistrement...';
    try {
      const res = await authFetch('/api/scanners/register', {
        method: 'POST',
        body: JSON.stringify({
          scanner_token: token,
          device_name: deviceName,
        }),
      });
      const payload = await res.json().catch(() => null);
      if (!res.ok) throw new Error(payload?.error ?? 'Impossible d’enregistrer ce scanner.');
      await loadScannerStatus();
    } catch (error) {
      registerBtn.disabled = false;
      registerBtn.textContent = previous ?? 'Enregistrer ce téléphone comme scanner';
      setScannerBlocked(false, error instanceof Error ? error.message : 'Impossible d’enregistrer ce scanner.');
    }
  });

  loadScannerStatus().catch((error) => {
    usageText.textContent = 'Impossible de charger le quota scanner.';
    remainingText.textContent = '';
    setScannerBlocked(true, error instanceof Error ? error.message : 'Vérifiez votre connexion et réessayez.');
  });
  setupInstallQr();
</script>
