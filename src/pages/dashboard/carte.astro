</DashboardLayout>

<script>
  import { authFetch } from '../../lib/api';
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
  const API = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3001';
  const PUBLIC_SITE_URL = (import.meta.env.PUBLIC_SITE_URL ?? 'https://www.fidelopass.com').replace(/\/$/, '');
  const setupMode = new URLSearchParams(window.location.search).get('setup') === '1';

  let carteId: string | null = null;
  let logoUrl = '', stripUrl = '', tamponIconUrl = '', tamponEmoji = '';
  let isGradient = false;
  type RewardTier = { seuil: number; recompense: string };
  type VipTier = { nom: string; seuil: number; avantage?: string };

  function publicCardUrl(id: string) {
    return `${PUBLIC_SITE_URL}/carte/${id}`;
  }

  function posterUrl(id: string, template: string) {
    return `${PUBLIC_SITE_URL}/poster/${id}?template=${encodeURIComponent(template)}`;
  }

  function qrImageUrl(id: string, size = 768) {
    return `https://api.qrserver.com/v1/create-qr-code/?size=${size}x${size}&data=${encodeURIComponent(publicCardUrl(id))}&bgcolor=ffffff&color=111827&qzone=1`;
  }

  function updateQrTools(id: string) {
    (document.getElementById('poster-link-minimal') as HTMLAnchorElement).href = posterUrl(id, 'minimal');
    (document.getElementById('poster-link-premium') as HTMLAnchorElement).href = posterUrl(id, 'premium');
    (document.getElementById('poster-link-promo') as HTMLAnchorElement).href = posterUrl(id, 'promo');
  }

  if (setupMode) {
    document.getElementById('setup-banner')!.classList.remove('hidden');
    document.getElementById('submit-btn')!.textContent = 'Créer ma première carte';
  }

  async function uploadFile(file: File): Promise<string> {
    const {data:{session}} = await supabase.auth.getSession();
    const fd = new FormData(); fd.append('file',file);
    const r = await fetch(`${API}/api/upload`,{method:'POST',headers:{Authorization:`Bearer ${session?.access_token??''}`},body:fd});
    const j = await r.json(); if(!r.ok) throw new Error(j.error??'Erreur upload'); return j.url as string;
  }

  function stampCols(total: number): number {
    if(total<=6) return total; if(total<=12) return Math.ceil(total/2); if(total<=15) return 5; return 6;
  }

  // Switch
  document.getElementById('switch-apple')!.addEventListener('click',()=>{
    document.getElementById('apple-preview')!.classList.remove('hidden');
    document.getElementById('google-preview')!.classList.add('hidden');
    (document.getElementById('switch-apple') as HTMLElement).style.cssText='background:#1e293b;color:white';
    (document.getElementById('switch-google') as HTMLElement).style.cssText='background:transparent;color:#64748b';
  });
  document.getElementById('switch-google')!.addEventListener('click',()=>{
    document.getElementById('google-preview')!.classList.remove('hidden');
    document.getElementById('apple-preview')!.classList.add('hidden');
    (document.getElementById('switch-google') as HTMLElement).style.cssText='background:#1e293b;color:white';
    (document.getElementById('switch-apple') as HTMLElement).style.cssText='background:transparent;color:#64748b';
  });

  // Gradient
  const gradientToggle = document.getElementById('gradient-toggle')!;
  const gradientKnob = document.getElementById('gradient-knob')!;
  gradientToggle.addEventListener('click',()=>{
    isGradient=!isGradient;
    gradientToggle.style.background=isGradient?'#6366f1':'#334155';
    gradientKnob.style.left=isGradient?'22px':'2px';
    document.getElementById('fond2-wrap')!.classList.toggle('hidden',!isGradient);
    document.getElementById('gradient-angle-wrap')!.classList.toggle('hidden',!isGradient);
    document.getElementById('fond-label')!.textContent=isGradient?'Fond 1':'Fond';
    updatePreview();
  });
  (document.getElementById('gradient-angle') as HTMLInputElement).addEventListener('input',(e)=>{
    document.getElementById('gradient-angle-val')!.textContent=`${(e.target as HTMLInputElement).value}°`;
    updatePreview();
  });

  // Strip style
  function applyStripStyle(isFull: boolean) {
    const sz=document.getElementById('a-strip-zone')!;
    document.getElementById('strip-style-rounded-label')!.style.cssText=!isFull?'border-color:#6366f1;background:rgb(99 102 241/0.1);color:white':'border-color:#334155;background:transparent;color:#64748b';
    document.getElementById('strip-style-full-label')!.style.cssText=isFull?'border-color:#6366f1;background:rgb(99 102 241/0.1);color:white':'border-color:#334155;background:transparent;color:#64748b';
    if(isFull){sz.classList.remove('mx-3','mb-3','rounded-xl');sz.style.cssText='position:relative;overflow:hidden;min-height:120px;z-index:10;';}
    else{sz.style.cssText='';sz.classList.add('mx-3','mb-3','rounded-xl');sz.style.minHeight='120px';}
  }
  document.querySelectorAll('input[name="strip_style"]').forEach(r=>r.addEventListener('change',()=>applyStripStyle((document.querySelector('input[name="strip_style"]:checked') as HTMLInputElement).value==='full')));
  document.querySelectorAll('input[name="strip_layout"]').forEach(r=>r.addEventListener('change',()=>{
    const layout=(document.querySelector('input[name="strip_layout"]:checked') as HTMLInputElement).value;
    ['background','top','bottom'].forEach(v=>{
      const label=document.getElementById(`strip-layout-${v}-label`);
      if(label) label.style.cssText=v===layout?'border-color:#6366f1;background:rgb(99 102 241/0.1);color:white':'border-color:#334155;background:transparent;color:#64748b';
    });
    updatePreview();
  }));

  // Logo
  document.getElementById('logo-btn')!.addEventListener('click',()=>(document.getElementById('logo-file') as HTMLInputElement).click());
  (document.getElementById('logo-file') as HTMLInputElement).addEventListener('change',async(e)=>{
    const f=(e.target as HTMLInputElement).files?.[0]; if(!f)return;
    const ld=document.getElementById('logo-loading')!; ld.classList.remove('hidden');
    try{logoUrl=await uploadFile(f);setLogoPreview(logoUrl);}catch(err:unknown){alert(err instanceof Error?err.message:'Erreur');}finally{ld.classList.add('hidden');}
  });
  function setLogoPreview(url: string){
    ['logo-preview-img','preview-logo','g-logo'].forEach(id=>{const el=document.getElementById(id) as HTMLImageElement;if(url){el.src=url;el.classList.remove('hidden');}else el.classList.add('hidden');});
    ['logo-preview-icon','preview-logo-ph','g-logo-ph'].forEach(id=>document.getElementById(id)!.classList.toggle('hidden',!!url));
    (document.getElementById('logo-url') as HTMLInputElement).value=url;
  }

  document.getElementById('logo-palette-btn')!.addEventListener('click',async()=>{
    const err=document.getElementById('error-msg') as HTMLDivElement;
    err.classList.add('hidden');
    if(!logoUrl){
      err.textContent='Ajoutez d’abord un logo, puis générez une palette depuis ses couleurs.';
      err.classList.remove('hidden');
      return;
    }
    try{
      const colors=await extractPaletteFromLogo(logoUrl);
      setInput('couleur-fond', colors.background);
      setInput('couleur-fond-2', colors.background2);
      setInput('couleur-accent', colors.accent);
      setInput('couleur-texte', colors.text);
      ensureGradient(true);
      updatePreview();
    }catch{
      err.textContent='Impossible de lire les couleurs du logo. Essayez avec une image PNG ou JPG différente.';
      err.classList.remove('hidden');
    }
  });

  async function extractPaletteFromLogo(url: string): Promise<{background:string;background2:string;accent:string;text:string}> {
    const image=await new Promise<HTMLImageElement>((resolve,reject)=>{
      const img=new Image();
      img.crossOrigin='anonymous';
      img.onload=()=>resolve(img);
      img.onerror=reject;
      img.src=url;
    });
    const canvas=document.createElement('canvas');
    canvas.width=64; canvas.height=64;
    const ctx=canvas.getContext('2d');
    if(!ctx) throw new Error('Canvas indisponible');
    ctx.drawImage(image,0,0,64,64);
    const data=ctx.getImageData(0,0,64,64).data;
    let r=0,g=0,b=0,count=0;
    const vibrant:{r:number;g:number;b:number;score:number}[]=[];
    for(let i=0;i<data.length;i+=4){
      const alpha=data[i+3];
      if(alpha<80) continue;
      const cr=data[i], cg=data[i+1], cb=data[i+2];
      const max=Math.max(cr,cg,cb), min=Math.min(cr,cg,cb);
      const saturation=max-min;
      const light=(max+min)/2;
      if(light>12&&light<245){r+=cr;g+=cg;b+=cb;count++;}
      if(saturation>35&&light>35&&light<230) vibrant.push({r:cr,g:cg,b:cb,score:saturation+Math.abs(128-light)/3});
    }
    if(!count) throw new Error('Logo illisible');
    const avg={r:Math.round(r/count),g:Math.round(g/count),b:Math.round(b/count)};
    vibrant.sort((a,b)=>b.score-a.score);
    const accent=vibrant[0]??avg;
    const background=shade(avg,-0.58);
    const background2=shade(accent,-0.28);
    const text=luminance(background)>0.45?'#111827':'#ffffff';
    return {background:rgbToHex(background),background2:rgbToHex(background2),accent:rgbToHex(accent),text};
  }

  function shade(color:{r:number;g:number;b:number}, factor:number){
    const mix=factor<0?0:255;
    const amount=Math.abs(factor);
    return {
      r:Math.round(color.r+(mix-color.r)*amount),
      g:Math.round(color.g+(mix-color.g)*amount),
      b:Math.round(color.b+(mix-color.b)*amount),
    };
  }

  function rgbToHex({r,g,b}:{r:number;g:number;b:number}) {
    return `#${[r,g,b].map(v=>Math.max(0,Math.min(255,v)).toString(16).padStart(2,'0')).join('')}`;
  }

  function luminance({r,g,b}:{r:number;g:number;b:number}) {
    return (0.2126*r+0.7152*g+0.0722*b)/255;
  }

